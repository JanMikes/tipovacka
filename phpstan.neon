includes:
    - vendor/phpstan/phpstan-phpunit/extension.neon
    - vendor/phpstan/phpstan-phpunit/rules.neon
    - vendor/phpstan/phpstan-symfony/extension.neon
    - vendor/phpstan/phpstan-symfony/rules.neon
    - vendor/phpstan/phpstan-doctrine/extension.neon
    - vendor/phpstan/phpstan-doctrine/rules.neon
    - phar://phpstan.phar/conf/bleedingEdge.neon

parameters:
    level: 8
    paths:
        - src
        - tests
    excludePaths:
        - tests/Support/IntegrationTestCase.php  # Uses test-env-only public aliases
        - tests/Integration/Auth/AdminBlockFlowTest.php  # Uses test-env-only public aliases
    symfony:
        containerXmlPath: var/cache/dev/App_KernelDevDebugContainer.xml
    doctrine:
        repositoryClass: Doctrine\ORM\EntityRepository
    tmpDir: var/cache/phpstan
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        # Test assertions - these are intentional and safe
        - '#Call to method PHPUnit\\Framework\\Assert::assertInstanceOf\(\) with .* will always evaluate to true#'
        # Form data is validated by Symfony Form component before this point
        - '#Offset .* might not exist on array<string, mixed>\|null#'
        # These are strict comparisons that are safe
        - '#Strict comparison using !== between .* and null will always evaluate to true#'
        # Symfony Session getFlashBag() exists at runtime
        - '#Call to an undefined method Symfony\\Component\\HttpFoundation\\Session\\SessionInterface::getFlashBag\(\)#'
        # Third-party bundle type issues
        - '#Parameter \#1 \$user of class App\\Entity\\ResetPasswordRequest constructor expects App\\Entity\\User, object given#'
        # Doctrine event args have unresolvable types when mocked
        - '#Return type of call to method PHPUnit\\Framework\\TestCase::createMock\(\) contains unresolvable type#'
        - '#PHPDoc tag @var for variable \$args contains unresolvable type#'
        # Intersection mock types on final classes are unresolvable by phpstan's PHPUnit extension,
        # but work correctly at runtime. Safe to ignore for test mocks.
        - '#PHPDoc tag @var for property .* contains unresolvable type\.#'
        - '#Property .* has unresolvable native type\.#'
