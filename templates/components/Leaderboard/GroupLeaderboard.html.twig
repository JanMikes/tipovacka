<div{{ attributes.defaults({class: 'bg-white rounded-2xl shadow-lg p-6'}) }}>
    <h2 class="text-lg font-semibold text-[#081e44] mb-4">Žebříček</h2>

    {% if this.leaderboard.rows|length == 0 %}
        <p class="text-sm text-gray-500">Žebříček zatím nemá žádné členy.</p>
    {% else %}
        <table class="w-full text-sm">
            <thead>
                <tr class="text-left text-gray-500 border-b border-gray-200">
                    <th class="py-2 w-12">Pořadí</th>
                    <th class="py-2">Hráč</th>
                    <th class="py-2 text-right">Body</th>
                </tr>
            </thead>
            <tbody>
                {% for row in this.leaderboard.rows %}
                    <tr class="border-b border-gray-100">
                        <td class="py-2 font-semibold text-[#081e44]">
                            {{ row.rank }}.{% if row.isTieResolvedOverride %} <span class="text-[10px] text-gray-500" title="Rozřazeno vlastníkem">(R)</span>{% endif %}
                        </td>
                        <td class="py-2">
                            <a
                                href="{{ path('portal_group_leaderboard_member', {groupId: this.group.id.toRfc4122, userId: row.userId.toRfc4122}) }}"
                                class="text-[#149AD5] hover:underline"
                            >
                                {{ row.nickname }}
                            </a>
                        </td>
                        <td class="py-2 text-right font-semibold">{{ row.totalPoints }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
</div>
