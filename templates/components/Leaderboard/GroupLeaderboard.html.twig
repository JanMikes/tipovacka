{#
    Wtips dark leaderboard (Live Component). rows: rank, userId, nickname, fullName,
    totalPoints, isTieResolvedOverride. Highlights the current user's row.
#}
<div{{ attributes.defaults({class: 'card-glass p-6'}) }}>
    <h2 class="mb-4 text-lg font-bold tracking-tight text-white">Žebříček</h2>

    {% if this.leaderboard.rows|length == 0 %}
        <div class="rounded-xl border border-white/10 bg-white/[0.03] p-8 text-center">
            <p class="text-sm text-white/60">Tabulka je zatím prázdná. Jakmile první hráč zadá tip, objeví se tady žebříček.</p>
            {% if is_granted('group_manage_members', this.group) %}
                <a href="{{ path('portal_group_detail', {id: this.group.id.toRfc4122}) }}" class="btn btn-primary btn-sm mt-4">
                    <twig:ux:icon name="lucide:users" class="h-4 w-4" />Pozvat hráče
                </a>
            {% endif %}
        </div>
    {% else %}
        {% set me_id = app.user ? app.user.id.toRfc4122 : null %}
        <div class="overflow-x-auto">
            <table class="lb-table">
                <thead class="lb-thead">
                    <tr>
                        <th class="w-12">Pozice</th>
                        <th>Hráč</th>
                        <th class="text-right">Body</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in this.leaderboard.rows %}
                        {% set is_me = me_id and row.userId.toRfc4122 == me_id %}
                        <tr class="lb-tr{{ is_me ? ' me' }}">
                            <td>
                                <span class="lb-pos{{ row.rank <= 3 ? ' rank-' ~ row.rank }}">{{ row.rank }}.</span>
                                {% if row.isTieResolvedOverride %}<span class="ml-1 text-[10px] text-white/40" title="Rozřazeno organizátorem">(R)</span>{% endif %}
                            </td>
                            <td>
                                <a href="{{ path('portal_group_leaderboard_member', {groupId: this.group.id.toRfc4122, userId: row.userId.toRfc4122}) }}"
                                   class="flex items-center gap-3 hover:opacity-90">
                                    <twig:Avatar name="{{ row.fullName ?: row.nickname }}" size="32" rank="{{ row.rank <= 3 ? row.rank : null }}" />
                                    <span class="min-w-0">
                                        <span class="block truncate text-sm font-bold text-white">{{ row.nickname }}{% if is_me %} <span class="text-accent-300">· Ty</span>{% endif %}</span>
                                        {% if row.fullName %}<small class="block truncate text-[11px] font-light text-white/50">{{ row.fullName }}</small>{% endif %}
                                    </span>
                                </a>
                            </td>
                            <td class="text-right"><span class="lb-pts">{{ row.totalPoints }}</span> <span class="text-[11px] font-light text-white/50">b</span></td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>
