<div{{ attributes.defaults({class: 'rounded-xl bg-white p-4 shadow-card ring-1 ring-navy-900/5'}) }}>
    <h3 class="flex items-center gap-1.5 text-sm font-semibold text-navy-900">
        <twig:ux:icon name="lucide:users" class="h-4 w-4 text-cyan-500" />
        Tipy skupiny
    </h3>

    {% if this.guesses.items|length == 0 %}
        <p class="mt-3 text-sm text-navy-900/60">Ještě žádné tipy.</p>
    {% else %}
        <table class="mt-3 w-full text-sm">
            <thead>
                <tr class="border-b border-navy-100/70 text-left text-xs font-semibold uppercase tracking-wider text-navy-900/50">
                    <th class="py-2">Tipující</th>
                    <th class="py-2 text-center">Tip</th>
                    <th class="py-2 text-right">Odesláno</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-navy-100/50">
                {% for item in this.guesses.items %}
                    <tr class="{{ item.isMine ? 'bg-cyan-50/50' : '' }}">
                        <td class="py-2">
                            <span class="font-medium text-navy-900">{{ item.nickname }}</span>
                            {% if item.isMine %}<span class="ml-1 text-xs text-navy-900/60">(ty)</span>{% endif %}
                        </td>
                        <td class="py-2 text-center">
                            <span class="rounded-md bg-navy-50 px-2 py-0.5 font-bold tabular-nums text-navy-900">
                                {{ item.homeScore }} : {{ item.awayScore }}
                            </span>
                        </td>
                        <td class="py-2 text-right text-xs text-navy-900/60">
                            {{ item.submittedAt|date('d. m. Y H:i') }}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
</div>
