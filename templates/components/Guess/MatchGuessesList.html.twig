<div{{ attributes.defaults({class: 'card-glass p-5 sm:p-6'}) }}>
    <h3 class="eyebrow flex items-center gap-1.5">
        <twig:ux:icon name="lucide:users" class="h-3.5 w-3.5" />
        Tipy soutěže
    </h3>

    {% if this.guesses.items|length == 0 %}
        <p class="mt-3 text-sm text-white/50">Zatím žádné tipy.</p>
    {% else %}
        <ul class="mt-4 divide-y divide-white/[0.06]">
            {% for item in this.guesses.items %}
                <li class="flex items-center justify-between gap-3 py-3 {{ item.isMine ? '-mx-3 rounded-lg bg-accent-500/[0.07] px-3' : '' }}">
                    <div class="flex min-w-0 items-center gap-2.5">
                        <twig:Avatar :name="item.nickname" size="32" />
                        <span class="truncate text-sm font-medium text-white">{{ item.nickname }}</span>
                        {% if item.isMine %}
                            <span class="shrink-0 text-xs text-white/40">(vy)</span>
                        {% endif %}
                    </div>

                    <div class="flex shrink-0 items-center gap-3">
                        {% if item.hidden %}
                            <span class="pill pill-locked">
                                <twig:ux:icon name="lucide:lock" class="h-3 w-3" />
                                Skryto
                            </span>
                        {% else %}
                            <span class="rounded-md border border-white/10 bg-white/5 px-2.5 py-1 text-sm font-bold tabular-nums text-white">
                                {{ item.homeScore }} : {{ item.awayScore }}
                            </span>
                        {% endif %}
                        <span class="hidden text-xs text-white/40 sm:inline">
                            {{ item.submittedAt|date('j. n. Y H:i') }}
                        </span>
                    </div>
                </li>
            {% endfor %}
        </ul>
    {% endif %}
</div>
