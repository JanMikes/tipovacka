<div{{ attributes.defaults({class: 'bg-white rounded-lg shadow p-4'}) }}>
    <h3 class="text-sm font-semibold text-navy-900 mb-3">Tipy skupiny</h3>

    {% if this.guesses.items|length == 0 %}
        <p class="text-sm text-gray-500">Ještě žádné tipy.</p>
    {% else %}
        <table class="w-full text-sm">
            <thead>
                <tr class="text-left text-gray-500 border-b border-gray-200">
                    <th class="py-1">Tipující</th>
                    <th class="py-1 text-center">Tip</th>
                    <th class="py-1 text-right">Odesláno</th>
                </tr>
            </thead>
            <tbody>
                {% for item in this.guesses.items %}
                    <tr class="border-b border-gray-100 {{ item.isMine ? 'bg-blue-50' : '' }}">
                        <td class="py-1">
                            {{ item.nickname }}{% if item.isMine %} <span class="text-xs text-gray-500">(ty)</span>{% endif %}
                        </td>
                        <td class="py-1 text-center font-semibold">
                            {{ item.homeScore }} : {{ item.awayScore }}
                        </td>
                        <td class="py-1 text-right text-xs text-gray-500">
                            {{ item.submittedAt|date('d. m. Y H:i') }}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
</div>
