{#
    Circular team "coin". Team names are free-text, so we render a robust initials
    badge on an accent gradient (no missing-flag failures). Pass code to override.
    props: name, code (optional short label), size (px)
#}
{% props name = '', code = null, size = 44 %}
{% set parts = name|trim|split(' ')|filter(p => p|trim is not empty) %}
{% set label = code ?: (parts|length > 1 ? parts|map(w => w|slice(0, 1))|join|slice(0, 3) : name|trim|slice(0, 3)) %}
<span class="flag club" style="width:{{ size }}px;height:{{ size }}px;font-size:{{ (size / 3.4)|round }}px">{{ label|upper }}</span>
