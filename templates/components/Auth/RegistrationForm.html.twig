<div{{ attributes }}>
    {{ form_start(form, {attr: {class: 'flex flex-col gap-4', novalidate: 'novalidate', 'data-model': 'on(change)|*', 'data-action': 'live#action:prevent', 'data-live-action-param': 'register'}}) }}

        <div class="grid gap-4 sm:grid-cols-2">
            <div class="field">
                {{ form_label(form.email, null, {label_attr: {class: 'field-label'}}) }}
                <div class="relative">
                    <span class="pointer-events-none absolute inset-y-0 left-3.5 flex items-center text-white/50">
                        <twig:ux:icon name="lucide:mail" class="h-[18px] w-[18px]" />
                    </span>
                    {{ form_widget(form.email, {attr: {class: 'input !pl-[42px]', placeholder: 'vas@email.cz'}}) }}
                </div>
                {{ form_errors(form.email) }}
            </div>

            <div class="field">
                {{ form_label(form.nickname, null, {label_attr: {class: 'field-label'}}) }}
                <div class="relative">
                    <span class="pointer-events-none absolute inset-y-0 left-3.5 flex items-center text-white/50">
                        <twig:ux:icon name="lucide:user" class="h-[18px] w-[18px]" />
                    </span>
                    {{ form_widget(form.nickname, {attr: {class: 'input !pl-[42px]', placeholder: 'vase_prezdivka'}}) }}
                </div>
                <p class="text-[11px] leading-relaxed text-white/40">3–30 znaků, písmena, čísla, podtržítko, tečka nebo pomlčka.</p>
                {{ form_errors(form.nickname) }}
            </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
            <div class="field">
                {{ form_label(form.firstName, null, {label_attr: {class: 'field-label'}}) }}
                <div class="relative">
                    <span class="pointer-events-none absolute inset-y-0 left-3.5 flex items-center text-white/50">
                        <twig:ux:icon name="lucide:user" class="h-[18px] w-[18px]" />
                    </span>
                    {{ form_widget(form.firstName, {attr: {class: 'input !pl-[42px]', placeholder: 'Jan'}}) }}
                </div>
                {{ form_errors(form.firstName) }}
            </div>

            <div class="field">
                {{ form_label(form.lastName, null, {label_attr: {class: 'field-label'}}) }}
                <div class="relative">
                    <span class="pointer-events-none absolute inset-y-0 left-3.5 flex items-center text-white/50">
                        <twig:ux:icon name="lucide:user" class="h-[18px] w-[18px]" />
                    </span>
                    {{ form_widget(form.lastName, {attr: {class: 'input !pl-[42px]', placeholder: 'Novák'}}) }}
                </div>
                {{ form_errors(form.lastName) }}
            </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
            <div class="field" data-controller="password-visibility">
                {{ form_label(form.password.first, null, {label_attr: {class: 'field-label'}}) }}
                <div class="relative">
                    <span class="pointer-events-none absolute inset-y-0 left-3.5 flex items-center text-white/50">
                        <twig:ux:icon name="lucide:lock" class="h-[18px] w-[18px]" />
                    </span>
                    {{ form_widget(form.password.first, {attr: {
                        class: 'input !pl-[42px] !pr-12',
                        placeholder: 'Zadejte heslo',
                        'data-password-visibility-target': 'input',
                    }}) }}
                    <button type="button" data-action="password-visibility#toggle" class="absolute inset-y-0 right-2 my-auto flex h-[30px] w-[30px] items-center justify-center rounded-lg text-white/50 transition-colors hover:bg-white/5 hover:text-white" aria-label="Zobrazit/skrýt heslo">
                        <span data-password-visibility-target="iconShow"><twig:ux:icon name="lucide:eye" class="h-[18px] w-[18px]" /></span>
                        <span class="hidden" data-password-visibility-target="iconHide"><twig:ux:icon name="lucide:eye-off" class="h-[18px] w-[18px]" /></span>
                    </button>
                </div>
                {{ form_errors(form.password.first) }}
            </div>

            <div class="field">
                {{ form_label(form.password.second, null, {label_attr: {class: 'field-label'}}) }}
                <div class="relative">
                    <span class="pointer-events-none absolute inset-y-0 left-3.5 flex items-center text-white/50">
                        <twig:ux:icon name="lucide:lock" class="h-[18px] w-[18px]" />
                    </span>
                    {{ form_widget(form.password.second, {attr: {class: 'input !pl-[42px]', placeholder: 'Zopakujte heslo'}}) }}
                </div>
                {{ form_errors(form.password.second) }}
                {{ form_errors(form.password) }}
            </div>
        </div>

        <div>
            <label class="flex cursor-pointer items-start gap-2.5 text-[13px] leading-relaxed text-white/70">
                {{ form_widget(form.gdprConsent, {attr: {class: 'mt-0.5 h-[17px] w-[17px] shrink-0 rounded-md border-white/20 bg-inset text-accent-500 focus:ring-accent-500 focus:ring-offset-0'}}) }}
                <span>
                    Souhlasím se
                    <a href="{{ path('app_privacy') }}" target="_blank" rel="noopener" class="font-semibold text-accent-300 underline decoration-accent-500/30 underline-offset-2 hover:text-white">zpracováním osobních údajů</a>.
                </span>
            </label>
            {{ form_errors(form.gdprConsent) }}
        </div>

        <button type="submit" class="btn btn-primary mt-2 w-full">
            Vytvořit účet
            <twig:ux:icon name="lucide:arrow-right" class="h-4 w-4" />
        </button>

    {{ form_end(form) }}
</div>
