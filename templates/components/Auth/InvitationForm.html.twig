<div{{ attributes }}>
    {% set kind = this.userKind %}
    {% set kind_new = constant('App\\Form\\InvitationFormData::KIND_NEW') %}
    {% set kind_has_password = constant('App\\Form\\InvitationFormData::KIND_HAS_PASSWORD') %}
    {% set kind_stub = constant('App\\Form\\InvitationFormData::KIND_STUB') %}

    {% set input_class = 'input pl-11' %}
    {% set label_class = 'text-[11px] font-semibold uppercase tracking-[0.14em] text-white/50 mb-1.5' %}

    <div class="mb-6">
        <span class="eyebrow">
            {% if kind == kind_has_password %}Přihlášení{% elseif kind == kind_stub %}Dokončení registrace{% else %}Registrace{% endif %}
        </span>
        <h2 class="mt-2 text-2xl font-bold tracking-tight text-white">
            {% if kind == kind_has_password %}
                Přihlaste se a připojte
            {% elseif kind == kind_stub %}
                Dokončete registraci
            {% else %}
                Vytvořte si účet
            {% endif %}
        </h2>
        <p class="mt-2 text-sm text-white/60">
            {% if this.emailLocked %}
                Pozvánka byla odeslána na <strong class="font-semibold text-white/80">{{ this.context.presetEmail }}</strong>.
            {% else %}
                Zadejte svůj e-mail — zjistíme, jestli už máte účet.
            {% endif %}
        </p>
    </div>

    {{ form_start(form, {attr: {class: 'space-y-5', novalidate: 'novalidate', 'data-model': 'on(change)|*', 'data-action': 'live#action:prevent', 'data-live-action-param': 'submit'}}) }}

        <div class="field">
            {{ form_label(form.email, null, {label_attr: {class: label_class}}) }}
            <div class="relative">
                <span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-white/40">
                    <twig:ux:icon name="lucide:mail" class="h-5 w-5" />
                </span>
                {{ form_widget(form.email, {attr: {class: input_class, disabled: this.emailLocked}}) }}
            </div>
            {{ form_errors(form.email) }}
        </div>

        {% if kind == kind_new %}
            <div class="grid gap-4 sm:grid-cols-2">
                <div class="field">
                    {{ form_label(form.firstName, null, {label_attr: {class: label_class}}) }}
                    <div class="relative">
                        <span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-white/40">
                            <twig:ux:icon name="lucide:user" class="h-5 w-5" />
                        </span>
                        {{ form_widget(form.firstName, {attr: {class: input_class}}) }}
                    </div>
                    {{ form_errors(form.firstName) }}
                </div>

                <div class="field">
                    {{ form_label(form.lastName, null, {label_attr: {class: label_class}}) }}
                    <div class="relative">
                        <span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-white/40">
                            <twig:ux:icon name="lucide:user" class="h-5 w-5" />
                        </span>
                        {{ form_widget(form.lastName, {attr: {class: input_class}}) }}
                    </div>
                    {{ form_errors(form.lastName) }}
                </div>
            </div>

            <div class="field">
                {{ form_label(form.nickname, null, {label_attr: {class: label_class}}) }}
                <div class="relative">
                    <span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-white/40">
                        <twig:ux:icon name="lucide:user" class="h-5 w-5" />
                    </span>
                    {{ form_widget(form.nickname, {attr: {class: input_class}}) }}
                </div>
                <p class="mt-1 text-xs text-white/40">3–30 znaků, pouze písmena, čísla, podtržítko, tečka nebo pomlčka.</p>
                {{ form_errors(form.nickname) }}
            </div>
        {% endif %}

        <div class="field" data-controller="password-visibility">
            <div class="mb-1.5 flex items-center justify-between">
                {{ form_label(form.password, null, {label_attr: {class: 'text-[11px] font-semibold uppercase tracking-[0.14em] text-white/50'}}) }}
                {% if kind == kind_has_password %}
                    <a href="{{ path('app_forgot_password_request') }}" class="text-sm font-medium text-accent-300 transition-colors hover:text-accent-200">Zapomenuté heslo?</a>
                {% endif %}
            </div>
            <div class="relative">
                <span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-white/40">
                    <twig:ux:icon name="lucide:lock" class="h-5 w-5" />
                </span>
                {{ form_widget(form.password, {attr: {
                    class: 'input pl-11 pr-12',
                    'data-password-visibility-target': 'input',
                }}) }}
                <button type="button" data-action="password-visibility#toggle" class="absolute inset-y-0 right-2 flex items-center rounded-md px-2 text-white/40 transition-colors hover:text-white" aria-label="Zobrazit/skrýt heslo">
                    <span data-password-visibility-target="iconShow"><twig:ux:icon name="lucide:eye" class="h-5 w-5" /></span>
                    <span class="hidden" data-password-visibility-target="iconHide"><twig:ux:icon name="lucide:eye-off" class="h-5 w-5" /></span>
                </button>
            </div>
            {{ form_errors(form.password) }}
        </div>

        {% if kind != kind_has_password %}
            <div class="field">
                {{ form_label(form.passwordConfirm, null, {label_attr: {class: label_class}}) }}
                <div class="relative">
                    <span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-white/40">
                        <twig:ux:icon name="lucide:lock" class="h-5 w-5" />
                    </span>
                    {{ form_widget(form.passwordConfirm, {attr: {class: input_class}}) }}
                </div>
                {{ form_errors(form.passwordConfirm) }}
            </div>

            <div>
                <label class="flex items-start gap-2.5 text-sm text-white/70">
                    {{ form_widget(form.gdprConsent, {attr: {class: 'mt-0.5 h-4 w-4 rounded border-white/20 bg-white/5 text-accent-500 focus:ring-accent-500 focus:ring-offset-0'}}) }}
                    <span>
                        Souhlasím se
                        <a href="{{ path('app_privacy') }}" target="_blank" rel="noopener" class="text-accent-300 transition-colors hover:text-accent-200">zpracováním osobních údajů</a>.
                    </span>
                </label>
                {{ form_errors(form.gdprConsent) }}
            </div>
        {% endif %}

        <button type="submit" class="btn btn-primary w-full">
            {% if kind == kind_has_password %}
                Přihlásit se a připojit
            {% elseif kind == kind_stub %}
                Dokončit registraci a připojit
            {% else %}
                Vytvořit účet a připojit se
            {% endif %}
            <twig:ux:icon name="lucide:arrow-right" class="h-4 w-4" />
        </button>

    {{ form_end(form) }}
</div>
