<div{{ attributes }}>
    {{ form_start(form, {attr: {class: 'space-y-5', novalidate: 'novalidate', 'data-model': 'on(change)|*', 'data-action': 'live#action:prevent', 'data-live-action-param': 'submit'}}) }}

        <div class="field" data-controller="password-visibility">
            {{ form_label(form.newPassword.first) }}
            <div class="relative">
                <span class="pointer-events-none absolute inset-y-0 left-3.5 flex items-center text-white/40">
                    <twig:ux:icon name="lucide:lock" class="h-5 w-5" />
                </span>
                {{ form_widget(form.newPassword.first, {attr: {class: 'input pl-11 pr-12', 'data-password-visibility-target': 'input'}}) }}
                <button type="button" data-action="password-visibility#toggle" class="absolute inset-y-0 right-2 flex items-center rounded-md px-2 text-white/40 transition-colors hover:text-white" aria-label="Zobrazit nebo skrýt heslo">
                    <span data-password-visibility-target="iconShow"><twig:ux:icon name="lucide:eye" class="h-5 w-5" /></span>
                    <span class="hidden" data-password-visibility-target="iconHide"><twig:ux:icon name="lucide:eye-off" class="h-5 w-5" /></span>
                </button>
            </div>
            {{ form_errors(form.newPassword.first) }}
        </div>

        <div class="field">
            {{ form_label(form.newPassword.second) }}
            <div class="relative">
                <span class="pointer-events-none absolute inset-y-0 left-3.5 flex items-center text-white/40">
                    <twig:ux:icon name="lucide:lock" class="h-5 w-5" />
                </span>
                {{ form_widget(form.newPassword.second, {attr: {class: 'input pl-11'}}) }}
            </div>
            {{ form_errors(form.newPassword.second) }}
            {{ form_errors(form.newPassword) }}
        </div>

        <button type="submit" class="btn btn-primary w-full">
            <twig:ux:icon name="lucide:shield-check" class="h-4 w-4" />
            Uložit nové heslo
        </button>

    {{ form_end(form) }}
</div>
