<div{{ attributes }}>
    {{ form_start(form, {attr: {class: 'space-y-5', novalidate: 'novalidate', 'data-model': 'on(change)|*', 'data-action': 'live#action:prevent', 'data-live-action-param': 'submit'}}) }}

        <div class="field">
            {{ form_label(form.email) }}
            <div class="relative">
                <span class="pointer-events-none absolute inset-y-0 left-3.5 flex items-center text-white/40">
                    <twig:ux:icon name="lucide:mail" class="h-5 w-5" />
                </span>
                {{ form_widget(form.email, {attr: {class: 'input pl-11'}}) }}
            </div>
            {{ form_errors(form.email) }}
        </div>

        <button type="submit" class="btn btn-primary w-full">
            Odeslat odkaz pro obnovení
            <twig:ux:icon name="lucide:arrow-right" class="h-4 w-4" />
        </button>

    {{ form_end(form) }}
</div>
