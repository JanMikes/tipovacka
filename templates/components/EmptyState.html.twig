{# @var illustration string 'leaderboard'|'tournaments'|'matches'|'search' #}
{# @var title string #}
{# @var body string #}
{# @var ctaLabel string|null #}
{# @var ctaPath string|null #}
{# @var secondaryLabel string|null #}
{# @var secondaryPath string|null #}

{% props illustration, title, body, ctaLabel = null, ctaPath = null, secondaryLabel = null, secondaryPath = null %}

<div{{ attributes.defaults({class: 'mx-auto flex max-w-md flex-col items-center py-16 text-center'}) }}>
    <h3 class="text-xl font-semibold text-navy-900">{{ title }}</h3>
    <p class="mt-2 text-base text-navy-900/70">{{ body }}</p>
    {% if ctaLabel and ctaPath %}
        <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
            <a href="{{ ctaPath }}" class="rounded-md bg-cyan-500 px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-cyan-600">
                {{ ctaLabel }}
            </a>
            {% if secondaryLabel and secondaryPath %}
                <a href="{{ secondaryPath }}" class="text-sm font-semibold text-navy-900 transition-colors hover:text-cyan-500">
                    {{ secondaryLabel }}
                </a>
            {% endif %}
        </div>
    {% endif %}
</div>
