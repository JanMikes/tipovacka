<div{{ attributes }}>
    {{ form_start(form, {attr: {class: 'flex flex-col gap-5', novalidate: 'novalidate', 'data-model': 'on(change)|*', 'data-action': 'live#action:prevent', 'data-live-action-param': 'save'}}) }}

        <div class="grid gap-5 sm:grid-cols-2">
            <div class="field">
                {{ form_label(form.firstName, null, {label_attr: {class: 'field-label'}}) }}
                <div class="relative">
                    <span class="pointer-events-none absolute inset-y-0 left-3.5 flex items-center text-white/50">
                        <twig:ux:icon name="lucide:user" class="h-[18px] w-[18px]" />
                    </span>
                    {{ form_widget(form.firstName, {attr: {class: 'input !pl-[42px]'}}) }}
                </div>
                {{ form_errors(form.firstName) }}
            </div>

            <div class="field">
                {{ form_label(form.lastName, null, {label_attr: {class: 'field-label'}}) }}
                <div class="relative">
                    <span class="pointer-events-none absolute inset-y-0 left-3.5 flex items-center text-white/50">
                        <twig:ux:icon name="lucide:user" class="h-[18px] w-[18px]" />
                    </span>
                    {{ form_widget(form.lastName, {attr: {class: 'input !pl-[42px]'}}) }}
                </div>
                {{ form_errors(form.lastName) }}
            </div>
        </div>

        <div class="field">
            {{ form_label(form.phone, null, {label_attr: {class: 'field-label'}}) }}
            <div class="relative">
                <span class="pointer-events-none absolute inset-y-0 left-3.5 flex items-center text-white/50">
                    <twig:ux:icon name="lucide:smartphone" class="h-[18px] w-[18px]" />
                </span>
                {{ form_widget(form.phone, {attr: {class: 'input !pl-[42px]'}}) }}
            </div>
            {{ form_errors(form.phone) }}
        </div>

        <button type="submit" class="btn btn-primary mt-1 self-start">
            <twig:ux:icon name="lucide:save" class="h-4 w-4" />
            Uložit změny
        </button>

    {{ form_end(form) }}
</div>
