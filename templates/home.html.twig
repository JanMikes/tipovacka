{% extends 'base.html.twig' %}

{% block title %}{{ brand_name }} — tipovací soutěže pro partičky{% endblock %}
{% block meta_description %}Vytvořte soukromou tipovací soutěž, pozvěte kámoše a bojujte o první místo v žebříčku. Bez sázek, jen pro radost a vychloubání.{% endblock %}

{% block og_title %}{{ brand_name }} — tipujte, vyhrajte a vychloubejte se{% endblock %}
{% block og_description %}Vytvořte soutěž, pozvěte hráče a sledujte žebříček naživo. Bez sázek, jen pro radost.{% endblock %}

{% block body_class %}bg-navy-850 text-white{% endblock %}

{% block body %}
{# ───────────────────────────────────────────────────────────────────
   1. HERO — Bold sport (2-col)
   ─────────────────────────────────────────────────────────────────── #}
<section class="hero-bg">
    <div class="relative z-10 mx-auto grid max-w-[80rem] grid-cols-1 items-center gap-14 px-4 py-16 sm:px-6 lg:grid-cols-[1.15fr_0.95fr] lg:gap-16 lg:px-8 lg:py-24">

        {# Left — pitch #}
        <div>
            <span class="eyebrow">Tipovací soutěže pro partičky</span>

            <h1 class="mt-4 text-[clamp(2.75rem,7vw,5.25rem)] font-black leading-[0.95] tracking-[-0.04em] text-white">
                Tipujte,
                <span class="grad-headline">vyhrajte</span>
                a&nbsp;pak&nbsp;to omlátíte kámošům&nbsp;o&nbsp;hlavu.
            </h1>

            <p class="mt-6 max-w-[50ch] text-lg leading-relaxed text-white/70">
                {{ brand_name }} je tipovačka pro firmy, party a kámoše ze sportbaru. Žádné sázky,
                žádné kurzové fígle — jen vy, váš turnaj a kdo to nakonec vystihl nejlíp.
            </p>

            <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
                <a href="{{ path('app_register') }}" class="btn btn-primary btn-lg justify-center">
                    Vytvořit soutěž zdarma
                    <twig:ux:icon name="lucide:arrow-right" class="h-[18px] w-[18px]" />
                </a>
                <a href="{{ path('app_features') }}" class="btn btn-ghost btn-lg justify-center">
                    Jak to funguje
                </a>
            </div>

            {# Reassurance row #}
            <ul class="mt-7 flex flex-wrap gap-x-6 gap-y-3 text-sm text-white/50">
                {% set reassurances = [
                    'Bez sázek a peněz',
                    'Hotovo za 2 minuty',
                    '5 hráčů zdarma navždy',
                ] %}
                {% for item in reassurances %}
                    <li class="inline-flex items-center gap-2">
                        <twig:ux:icon name="lucide:check" class="h-4 w-4 shrink-0 text-win" />
                        {{ item }}
                    </li>
                {% endfor %}
            </ul>
        </div>

        {# Right — live-ish match card (marketing decoration) #}
        <div class="relative" aria-hidden="true">
            <div class="pointer-events-none absolute -inset-10 -z-10 bg-[radial-gradient(50%_50%_at_50%_50%,rgba(70,153,208,0.32)_0%,transparent_70%)]"></div>

            <div class="glass relative rounded-[20px] p-6 sm:p-7">
                {# Card head #}
                <div class="mb-5 flex items-center justify-between">
                    <twig:Pill label="Živě · 67'" variant="live" dot />
                    <span class="text-[11px] uppercase tracking-[0.08em] text-white/40">Skupina A · MD3</span>
                </div>

                {# Match row #}
                <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-4 py-2">
                    <div class="flex flex-row-reverse items-center gap-3 text-right">
                        <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-[10px] border border-white/20 text-[11px] font-black tracking-tight text-white" style="background:linear-gradient(135deg,#75AADB 0%,#75AADB 50%,#F6B40E 50%,#F6B40E 100%)">ARG</span>
                        <div>
                            <div class="text-base font-bold text-white">Argentina</div>
                            <div class="mt-0.5 text-[11px] text-white/40">V2 R0 P0 · 6 b</div>
                        </div>
                    </div>
                    <div class="text-center text-[3.25rem] font-black leading-[0.95] tracking-[-0.04em] text-white tabular-nums">
                        2<span class="mx-1.5 align-[6px] text-2xl text-white/40">–</span>1
                    </div>
                    <div class="flex items-center gap-3">
                        <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-[10px] border border-white/20 text-[11px] font-black tracking-tight text-white" style="background:linear-gradient(135deg,#002654 0%,#002654 50%,#ED2939 50%,#ED2939 100%)">FRA</span>
                        <div>
                            <div class="text-base font-bold text-white">Francie</div>
                            <div class="mt-0.5 text-[11px] text-white/40">V1 R1 P0 · 4 b</div>
                        </div>
                    </div>
                </div>

                {# Pick distribution #}
                <div class="mt-5 border-t border-white/10 pt-5">
                    <div class="mb-3 flex items-center justify-between text-xs text-white/70">
                        <span>Tipy 248 hráčů</span>
                        <span class="text-[11px] uppercase tracking-[0.08em] text-white/40">Před začátkem</span>
                    </div>
                    <div class="dist-bar">
                        <span class="b1" style="width:58%"></span>
                        <span class="bx" style="width:22%"></span>
                        <span class="b2" style="width:20%"></span>
                    </div>
                    <div class="mt-3 flex flex-wrap gap-x-5 gap-y-1.5 text-[11px] tabular-nums text-white/50">
                        <span><span class="font-extrabold text-accent-300">1</span> Výhra Argentiny 58 %</span>
                        <span><span class="font-extrabold text-draw">X</span> Remíza 22 %</span>
                        <span><span class="font-extrabold text-loss">2</span> Výhra Francie 20 %</span>
                    </div>
                </div>
            </div>

            {# Floating mini cards (decoration, hidden on small screens) #}
            <div class="glass absolute -left-10 -top-5 hidden items-center gap-2.5 rounded-[14px] px-3.5 py-3 text-xs lg:flex">
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[11px] font-black text-white" style="background:linear-gradient(135deg,#3ed598,#1f9d6e)">MK</span>
                <div>
                    <div class="font-black text-win">+12 b</div>
                    <div class="text-[10px] text-white/40">Marek vystihl skóre</div>
                </div>
            </div>
            <div class="glass absolute -right-6 top-[22%] hidden items-center gap-2.5 rounded-[14px] px-3.5 py-3 text-xs lg:flex">
                <twig:Pill label="1. místo" variant="success" />
                <div class="font-black text-white">147</div>
                <div class="text-[10px] text-white/40">/ 248</div>
            </div>
            <div class="glass absolute -left-14 bottom-[14%] hidden items-center gap-2.5 rounded-[14px] px-3.5 py-3 text-xs lg:flex">
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-[11px] font-black text-white" style="background:linear-gradient(135deg,#ff5d7a,#c8324d)">AP</span>
                <div>
                    <div class="font-black text-loss">+9 b</div>
                    <div class="text-[10px] text-white/40">Ana trefila výsledek</div>
                </div>
            </div>
        </div>
    </div>
</section>

{# ───────────────────────────────────────────────────────────────────
   1b. JOIN BY PIN — quick strip
   ─────────────────────────────────────────────────────────────────── #}
<section class="bg-navy-900 py-10 sm:py-14">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <div class="mb-4 text-center">
            <span class="eyebrow">Máte pozvánku?</span>
            <h2 class="mt-2 text-xl font-bold text-white sm:text-2xl">Připojte se k soutěži přes PIN</h2>
        </div>
        {{ include('_partials/join_by_pin_form.html.twig') }}
    </div>
</section>

{# ───────────────────────────────────────────────────────────────────
   2. JAK TO FUNGUJE — 3 numbered steps
   ─────────────────────────────────────────────────────────────────── #}
<section class="bg-navy-850 py-20 sm:py-24">
    <div class="mx-auto max-w-[80rem] px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
            <span class="eyebrow">Jak to funguje</span>
            <h2 class="mt-3 text-3xl font-black tracking-tight text-white sm:text-4xl">Tři kroky a&nbsp;máte party tipovačku</h2>
            <p class="mt-4 text-lg text-white/60">
                Žádné stahování, žádné zdlouhavé registrace pro hráče. Pošlete jim odkaz a&nbsp;tipuje se.
            </p>
        </div>

        <div class="mt-14 grid grid-cols-1 gap-5 md:grid-cols-3">
            {# Step 01 — create #}
            <div class="card overflow-hidden p-7">
                <span class="text-[13px] font-black uppercase tracking-[0.1em] text-accent-300">01</span>
                <h3 class="mt-3.5 text-[1.35rem] font-extrabold leading-tight tracking-[-0.02em] text-white">Vytvořte soutěž</h3>
                <p class="mt-2 text-sm leading-relaxed text-white/60">
                    Vyberte turnaj — MS, NHL, Liga mistrů, Premier League. {{ brand_name }} automaticky natáhne rozpis zápasů a&nbsp;soupisky.
                </p>
                <div class="mt-6 flex h-[132px] items-center justify-center rounded-xl border border-accent-500/20 bg-gradient-to-br from-accent-500/10 to-accent-500/[0.02] p-4">
                    <div class="text-center">
                        <div class="mb-2 text-[11px] uppercase tracking-[0.08em] text-white/40">Dostupné turnaje</div>
                        <div class="flex max-w-[18rem] flex-wrap justify-center gap-2">
                            {% for t in ['MS 2026', 'EPL', 'NHL', 'UCL', 'NBA', 'Euro 2028'] %}
                                <twig:Pill label="{{ t }}" variant="accent" />
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>

            {# Step 02 — invite #}
            <div class="card overflow-hidden p-7">
                <span class="text-[13px] font-black uppercase tracking-[0.1em] text-accent-300">02</span>
                <h3 class="mt-3.5 text-[1.35rem] font-extrabold leading-tight tracking-[-0.02em] text-white">Pozvěte hráče</h3>
                <p class="mt-2 text-sm leading-relaxed text-white/60">
                    Pošlete odkaz na Slack, Teams nebo do skupinového chatu. Hráč klikne, tipuje — účet vytvoří jedním kliknutím.
                </p>
                <div class="mt-6 flex h-[132px] items-center justify-center rounded-xl border border-accent-500/20 bg-gradient-to-br from-accent-500/10 to-accent-500/[0.02] p-4">
                    <div class="flex w-full max-w-[20rem] items-center gap-2.5 rounded-lg border border-white/10 bg-surface-2 px-3.5 py-2.5 text-[11px]">
                        <span class="font-bold text-accent-300">wtips.cz/</span>
                        <span class="font-semibold text-white">firemni-ms-2026</span>
                        <span class="ml-auto inline-flex items-center gap-1.5 rounded-md border border-accent-500/40 bg-accent-500/20 px-2 py-1 text-[10px] font-bold uppercase tracking-[0.06em] text-accent-300">
                            <twig:ux:icon name="lucide:link" class="h-3 w-3" />
                            Kopírovat
                        </span>
                    </div>
                </div>
            </div>

            {# Step 03 — leaderboard #}
            <div class="card overflow-hidden p-7">
                <span class="text-[13px] font-black uppercase tracking-[0.1em] text-accent-300">03</span>
                <h3 class="mt-3.5 text-[1.35rem] font-extrabold leading-tight tracking-[-0.02em] text-white">Sledujte žebříček</h3>
                <p class="mt-2 text-sm leading-relaxed text-white/60">
                    Body padají automaticky po každém zápase. {{ brand_name }} ukáže, kdo vede, kdo se posunul a&nbsp;kdo to zase netrefil.
                </p>
                <div class="mt-6 flex h-[132px] items-center rounded-xl border border-accent-500/20 bg-gradient-to-br from-accent-500/10 to-accent-500/[0.02] p-4">
                    <div class="w-full max-w-[18rem]">
                        {% set mini_lb = [
                            { pos: 1, name: 'Marek K.', delta: '+12', pts: 147, dc: 'text-gold', vr: 'success' },
                            { pos: 2, name: 'Ana P.', delta: '+9', pts: 142, dc: 'text-silver', vr: 'success' },
                            { pos: 3, name: 'Tomáš L.', delta: '−4', pts: 138, dc: 'text-bronze', vr: 'warn' },
                        ] %}
                        {% for r in mini_lb %}
                            <div class="flex items-center justify-between py-1.5 text-xs {{ not loop.first ? 'border-t border-white/[0.06]' }}">
                                <span class="w-5 font-black tabular-nums {{ r.dc }}">{{ r.pos }}</span>
                                <span class="flex-1 px-2 font-semibold text-white">{{ r.name }}</span>
                                <twig:Pill label="{{ r.delta }}" variant="{{ r.vr }}" />
                                <span class="ml-2 w-9 text-right font-extrabold tabular-nums text-white">{{ r.pts }}</span>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

{# ───────────────────────────────────────────────────────────────────
   3. PROČ WTIPS — 6 feature cards
   ─────────────────────────────────────────────────────────────────── #}
<section class="bg-navy-900 py-20 sm:py-24">
    <div class="mx-auto max-w-[80rem] px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
            <span class="eyebrow">Proč {{ brand_name }}</span>
            <h2 class="mt-3 text-3xl font-black tracking-tight text-white sm:text-4xl">Postaveno na kámošské&nbsp;rivalitě</h2>
            <p class="mt-4 text-lg text-white/60">
                Tipovačku jsme dělali primárně pro sebe. Pak ji chtěli kolegové, pak kámošovo IT oddělení. Tady je proč.
            </p>
        </div>

        <div class="mt-12 grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
            {% set features = [
                { icon: 'zap',          title: 'Živé skóre, živé body', body: 'Body padají hráčům na účet ve chvíli, kdy padá gól. Žádné „zítra to dopočítáme“. Žebříček se hýbe.' },
                { icon: 'users',        title: '5 hráčů zdarma',        body: 'Free plán bez časového limitu. Pro firmy, klub nebo větší partu jsou připravené placené plány.' },
                { icon: 'shield',       title: 'Bez sázek, bez stresu', body: 'Wtips nesází ani neoperuje s penězi. Co se vyhraje, je interní záležitost vás a vašich kolegů.' },
                { icon: 'flame',        title: 'Vychloubání vítané',    body: 'Žebříček naživo, série úspěšných tipů a přehled, kdo to zrovna nevystihl. Mockování je půlka zábavy.' },
                { icon: 'target',       title: 'Vlastní bodování',      body: 'Standardní 3/1/0, nebo si nastavte body za přesné skóre, za správnou tendenci i za váhu kola.' },
                { icon: 'list-ordered', title: 'Web i mobil',           body: 'Funguje v prohlížeči i v telefonu. Žádná aplikace v App Store, žádná žádost o instalaci přes IT.' },
            ] %}
            {% for f in features %}
                <div class="card-glass p-7">
                    <span class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-xl border border-accent-500/40 bg-accent-500/15 text-accent-300">
                        <twig:ux:icon name="lucide:{{ f.icon }}" class="h-[22px] w-[22px]" />
                    </span>
                    <h3 class="text-lg font-bold tracking-[-0.01em] text-white">{{ f.title }}</h3>
                    <p class="mt-2 text-[13px] leading-relaxed text-white/60">{{ f.body }}</p>
                </div>
            {% endfor %}
        </div>
    </div>
</section>

{# ───────────────────────────────────────────────────────────────────
   4. UKÁZKA APLIKACE — static glass mock
   ─────────────────────────────────────────────────────────────────── #}
<section class="relative overflow-hidden bg-navy-850 py-20 sm:py-24">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 bg-[radial-gradient(60%_50%_at_80%_50%,rgba(70,153,208,0.18)_0%,transparent_60%),radial-gradient(40%_60%_at_10%_50%,rgba(31,93,142,0.14)_0%,transparent_60%)]"></div>

    <div class="relative z-10 mx-auto max-w-[80rem] px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
            <span class="eyebrow">Ukázka aplikace</span>
            <h2 class="mt-3 text-3xl font-black tracking-tight text-white sm:text-4xl">Takhle to vypadá v&nbsp;ostrém provozu</h2>
            <p class="mt-4 text-lg text-white/60">
                Detail soutěže s&nbsp;živým zápasem, žebříčkem a&nbsp;rozpisem zápasů.
            </p>
        </div>

        {# Static styled app mock #}
        <div class="glass mx-auto mt-12 max-w-5xl overflow-hidden rounded-[22px] p-5 sm:p-7">
            {# fake window bar #}
            <div class="mb-5 flex items-center gap-2">
                <span class="h-3 w-3 rounded-full bg-white/15"></span>
                <span class="h-3 w-3 rounded-full bg-white/15"></span>
                <span class="h-3 w-3 rounded-full bg-white/15"></span>
                <span class="ml-3 text-[11px] uppercase tracking-[0.08em] text-white/40">Firemní MS 2026 · detail soutěže</span>
            </div>

            <div class="grid grid-cols-1 gap-5 lg:grid-cols-[1.4fr_1fr]">
                {# Left — match + distribution #}
                <div class="rounded-2xl border border-white/[0.06] bg-surface-2 p-5">
                    <div class="mb-4 flex items-center justify-between">
                        <twig:Pill label="Živě · 67'" variant="live" dot />
                        <span class="text-[11px] uppercase tracking-[0.08em] text-white/40">Skupina C · MD4</span>
                    </div>
                    <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-4 py-2">
                        <div class="flex flex-row-reverse items-center gap-3 text-right">
                            <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-[10px] border border-white/20 text-[11px] font-black text-white" style="background:linear-gradient(135deg,#11457e,#0a2a4f)">CZE</span>
                            <span class="text-base font-bold text-white">Česko</span>
                        </div>
                        <div class="text-center text-4xl font-black tracking-[-0.04em] text-white tabular-nums">1<span class="mx-1.5 align-[4px] text-lg text-white/40">–</span>1</div>
                        <div class="flex items-center gap-3">
                            <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-[10px] border border-white/20 text-[11px] font-black text-white" style="background:linear-gradient(135deg,#1a1a1a,#3d3d3d)">GER</span>
                            <span class="text-base font-bold text-white">Německo</span>
                        </div>
                    </div>
                    <div class="mt-4 rounded-xl border border-win/30 bg-win/10 px-4 py-3 text-center text-sm text-white">
                        Váš tip <b class="font-extrabold">2 : 1</b> · zatím <b class="font-extrabold text-win">+3 b</b>
                    </div>
                    <div class="mt-4 border-t border-white/[0.06] pt-4">
                        <div class="mb-2.5 flex items-center justify-between text-xs text-white/50">
                            <span>Distribuce tipů · 248 hráčů</span>
                        </div>
                        <div class="dist-bar">
                            <span class="b1" style="width:32%"></span>
                            <span class="bx" style="width:28%"></span>
                            <span class="b2" style="width:40%"></span>
                        </div>
                        <div class="mt-2.5 flex gap-4 text-[11px] tabular-nums text-white/50">
                            <span><span class="font-extrabold text-accent-300">1</span> 32 %</span>
                            <span><span class="font-extrabold text-draw">X</span> 28 %</span>
                            <span><span class="font-extrabold text-loss">2</span> 40 %</span>
                        </div>
                    </div>
                </div>

                {# Right — mini leaderboard #}
                <div class="rounded-2xl border border-white/[0.06] bg-surface-2 p-5">
                    <div class="mb-3 flex items-center justify-between">
                        <span class="text-sm font-bold text-white">Žebříček</span>
                        <twig:Pill label="Live" variant="live" dot />
                    </div>
                    {% set show_lb = [
                        { pos: 1, name: 'Jakub Kratochvíl', handle: '@jakub.k', pts: 182, dc: 'text-gold', me: false },
                        { pos: 2, name: 'Petra Nováková', handle: '@petra.n', pts: 175, dc: 'text-silver', me: false },
                        { pos: 3, name: 'Tomáš Svoboda', handle: '@tom.s', pts: 169, dc: 'text-bronze', me: false },
                        { pos: 7, name: 'Marek Konečný', handle: '@marek.k · vy', pts: 147, dc: 'text-white/50', me: true },
                    ] %}
                    {% for r in show_lb %}
                        <div class="flex items-center gap-3 rounded-lg px-2 py-2 text-sm {{ r.me ? 'bg-accent-500/10 ring-1 ring-accent-500/30' : (not loop.first ? 'border-t border-white/[0.04]') }}">
                            <span class="w-5 text-center font-black tabular-nums {{ r.dc }}">{{ r.pos }}</span>
                            <div class="min-w-0 flex-1">
                                <div class="truncate font-semibold text-white">{{ r.name }}</div>
                                <div class="truncate text-[11px] text-white/40">{{ r.handle }}</div>
                            </div>
                            <span class="font-extrabold tabular-nums text-white">{{ r.pts }}</span>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>

        <div class="mt-9 flex flex-wrap justify-center gap-8 text-xs text-white/40">
            <span><b class="font-bold text-white">248</b> aktivních hráčů v&nbsp;ukázce</span>
            <span><b class="font-bold text-white">14</b> matchdayů sledovaných naživo</span>
            <span><b class="font-bold text-white">3</b> bodovací modely</span>
        </div>
    </div>
</section>

{# ───────────────────────────────────────────────────────────────────
   5. FINAL CTA — surface-accent gradient card
   ─────────────────────────────────────────────────────────────────── #}
<section class="bg-navy-900 py-20 sm:py-24">
    <div class="mx-auto max-w-[80rem] px-4 sm:px-6 lg:px-8">
        <div class="surface-accent px-8 py-16 sm:px-14 sm:py-20">
            <div class="relative z-10 max-w-2xl">
                <span class="inline-flex items-center rounded-full border border-white/30 bg-white/15 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.06em] text-white">Začněte zdarma</span>
                <h2 class="mt-5 text-[clamp(2.25rem,5vw,4rem)] font-black leading-[1.0] tracking-[-0.03em] text-white">
                    MS 2026 začíná za chvíli. Kdo to letos vystihne?
                </h2>
                <p class="mt-5 max-w-[50ch] text-lg leading-relaxed text-white/85">
