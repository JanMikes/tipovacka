{% extends 'base.html.twig' %}

{% block title %}Tipovačka — tipuj s kamarády{% endblock %}

{% block body %}
<section class="bg-[#081e44] text-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center">
        <h1 class="text-4xl sm:text-5xl font-bold mb-4">Tipuj, vyhrávej s kamarády</h1>
        <p class="text-lg text-gray-300 mb-8">Jednoduchá aplikace na tipování fotbalových zápasů.</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href="{{ path('app_register') }}" class="bg-[#149AD5] hover:bg-blue-500 text-white px-6 py-3 rounded-lg font-medium transition-colors">
                Zaregistruj se zdarma
            </a>
            <a href="{{ path('public_tournaments_list') }}" class="bg-white/10 hover:bg-white/20 text-white px-6 py-3 rounded-lg font-medium transition-colors">
                Prohlédni si turnaje
            </a>
        </div>
    </div>
</section>

<section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <div class="bg-white rounded-2xl shadow-sm p-6 text-center">
            <h2 class="text-lg font-semibold text-[#081e44] mb-2">Vytvoř skupinu</h2>
            <p class="text-gray-600 text-sm">Založ si vlastní tipovací partu a pozvi kamarády.</p>
        </div>
        <div class="bg-white rounded-2xl shadow-sm p-6 text-center">
            <h2 class="text-lg font-semibold text-[#081e44] mb-2">Tipuj zápasy</h2>
            <p class="text-gray-600 text-sm">Odhadni výsledky a utkej se o body.</p>
        </div>
        <div class="bg-white rounded-2xl shadow-sm p-6 text-center">
            <h2 class="text-lg font-semibold text-[#081e44] mb-2">Sleduj žebříček</h2>
            <p class="text-gray-600 text-sm">Průběžné pořadí v každé skupině.</p>
        </div>
    </div>
</section>

<section class="bg-gray-100">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 text-center">
        <h2 class="text-2xl font-bold text-[#081e44] mb-3">Připoj se zdarma</h2>
        <p class="text-gray-600 mb-6">Žádné poplatky, žádné složité nastavení.</p>
        <a href="{{ path('app_register') }}" class="inline-block bg-[#149AD5] hover:bg-blue-500 text-white px-6 py-3 rounded-lg font-medium transition-colors">
            Zaregistruj se zdarma
        </a>
    </div>
</section>
{% endblock %}
