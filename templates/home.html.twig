{% extends 'base.html.twig' %}

{% block title %}Tipovačka — tipuj zápasy, poraz kamarády{% endblock %}
{% block meta_description %}Založ soukromou skupinu, zvi kamarády a bojujte o prvenství v tabulce. Tipování fotbalových zápasů zdarma.{% endblock %}

{% block og_title %}Tipovačka — Tipuj zápasy. Poraz kamarády.{% endblock %}
{% block og_description %}Založ skupinu, zvi přátele a bojujte o prvenství v tabulce.{% endblock %}

{% block body %}
{# ───────── Hero ───────── #}
<section class="relative overflow-hidden bg-gradient-to-br from-navy-50 via-white to-white">
    <div aria-hidden="true" class="pointer-events-none absolute -top-32 -right-32 h-96 w-96 rounded-full bg-cyan-400/10 blur-3xl"></div>
    <div aria-hidden="true" class="pointer-events-none absolute -bottom-32 -left-32 h-96 w-96 rounded-full bg-navy-500/10 blur-3xl"></div>

    <div class="relative mx-auto grid max-w-[88rem] grid-cols-1 items-center gap-10 px-4 pb-16 pt-12 sm:px-6 sm:pt-16 lg:grid-cols-12 lg:gap-12 lg:px-8 lg:pb-24 lg:pt-20">
        <div class="lg:col-span-6">
            <span class="inline-flex items-center gap-1.5 rounded-full bg-cyan-100 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-cyan-600">
                <twig:ux:icon name="lucide:trophy" class="h-3.5 w-3.5" />
                Fotbalová tipovací liga
            </span>
            <h1 class="mt-5 text-4xl font-bold tracking-tight text-navy-900 sm:text-5xl lg:text-6xl">
                Tipuj zápasy.<br>
                <span class="bg-gradient-to-r from-cyan-500 to-cyan-600 bg-clip-text text-transparent">Poraz kamarády.</span>
            </h1>
            <p class="mt-6 max-w-xl text-lg text-navy-900/70 sm:text-xl">
                Založ soukromou skupinu, zvi přátele a bojujte o prvenství v tabulce. Zdarma a bez reklam.
            </p>
            <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center sm:gap-4">
                <a href="{{ path('app_register') }}" class="inline-flex items-center justify-center gap-2 rounded-xl bg-cyan-500 px-6 py-3.5 text-base font-semibold text-white shadow-lg shadow-cyan-500/20 transition-all hover:-translate-y-0.5 hover:bg-cyan-600 hover:shadow-xl hover:shadow-cyan-500/30">
                    Zaregistruj se zdarma
                    <twig:ux:icon name="lucide:arrow-right" class="h-5 w-5" />
                </a>
                <a href="{{ path('public_tournaments_list') }}" class="inline-flex items-center justify-center gap-1.5 rounded-xl px-4 py-3.5 text-base font-semibold text-navy-900 transition-colors hover:text-cyan-600">
                    Procházet turnaje
                    <twig:ux:icon name="lucide:chevron-right" class="h-5 w-5" />
                </a>
            </div>

            {# Trust strip #}
            <dl class="mt-10 grid max-w-xl grid-cols-2 gap-4 sm:grid-cols-4">
                {% set badges = [
                    { icon: 'lucide:shield-check', label: 'Zdarma' },
                    { icon: 'lucide:users',        label: 'Soukromé skupiny' },
                    { icon: 'lucide:trophy',       label: 'Žebříček naživo' },
                    { icon: 'lucide:clock',        label: 'Tipuj do výkopu' },
                ] %}
                {% for b in badges %}
                    <div class="flex items-center gap-2 text-sm text-navy-900/70">
                        <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-white text-cyan-500 shadow-card">
                            <twig:ux:icon name="{{ b.icon }}" class="h-4 w-4" />
                        </span>
                        <span class="font-medium">{{ b.label }}</span>
                    </div>
                {% endfor %}
            </dl>
        </div>

        <div class="relative lg:col-span-6">
            <picture>
                <source media="(max-width: 767px)" srcset="{{ asset('images/hero/hero-portrait.png') }}">
                <source media="(min-width: 768px)" srcset="{{ asset('images/hero/hero-desktop.png') }}">
                <img
                    src="{{ asset('images/hero/hero-desktop.png') }}"
                    alt=""
                    role="presentation"
                    class="mx-auto h-auto w-full max-w-xl drop-shadow-xl"
                    loading="eager"
                    fetchpriority="high"
                    decoding="async"
                >
            </picture>
        </div>
    </div>
</section>

{# ───────── How it works ───────── #}
<section class="bg-white py-20 sm:py-24">
    <div class="mx-auto max-w-[88rem] px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
            <span class="inline-block rounded-full bg-navy-100 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-navy-700">Jak to funguje</span>
            <h2 class="mt-4 text-3xl font-bold tracking-tight text-navy-900 sm:text-4xl">Tři kroky od registrace k první výhře</h2>
            <p class="mt-4 text-lg text-navy-900/70">Celý proces trvá méně než dvě minuty.</p>
        </div>

        <div class="mx-auto mt-16 grid max-w-6xl grid-cols-1 gap-8 md:grid-cols-3">
            {% set steps = [
                { img: 'step-1-create-group.png', title: 'Vytvoř skupinu', body: 'Založ soukromou skupinu a pozvi kamarády přes odkaz nebo PIN.' },
                { img: 'step-2-predict.png',     title: 'Tipuj zápasy',   body: 'Zadej svůj tip na každý zápas až do výkopu.' },
                { img: 'step-3-climb.png',       title: 'Získej body',    body: 'Správné tipy ti nasbírají body a vyženou tě na špici tabulky.' }
            ] %}
            {% for step in steps %}
                <div class="group relative flex flex-col items-center rounded-2xl bg-white p-8 text-center shadow-card ring-1 ring-navy-900/5 transition-all hover:-translate-y-1 hover:shadow-card-hover">
                    <span class="absolute -top-4 left-1/2 flex h-9 w-9 -translate-x-1/2 items-center justify-center rounded-full bg-cyan-500 text-sm font-bold text-white shadow-lg shadow-cyan-500/30">
                        {{ loop.index }}
                    </span>
                    <img
                        src="{{ asset('images/how-it-works/' ~ step.img) }}"
                        alt=""
                        role="presentation"
                        class="mt-2 h-40 w-40 sm:h-48 sm:w-48"
                        loading="lazy"
                        decoding="async"
                    >
                    <h3 class="mt-6 text-xl font-semibold text-navy-900">{{ step.title }}</h3>
                    <p class="mt-2 text-base text-navy-900/70">{{ step.body }}</p>
                </div>
            {% endfor %}
        </div>
    </div>
</section>

{# ───────── Features ───────── #}
<section class="bg-navy-50/60 py-20 sm:py-24">
    <div class="mx-auto max-w-[88rem] px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
            <span class="inline-block rounded-full bg-cyan-100 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-cyan-600">Co všechno umíme</span>
            <h2 class="mt-4 text-3xl font-bold tracking-tight text-navy-900 sm:text-4xl">Funkce, které fanoušky baví</h2>
        </div>

        <div class="mx-auto mt-14 grid max-w-6xl grid-cols-1 gap-6 md:grid-cols-3">
            {% set features = [
                { icon: 'lucide:users',        title: 'Neomezeně skupin',    body: 'Hraj v několika skupinách najednou — s kolegy, s rodinou, se spolužáky. Každá má vlastní žebříček.' },
                { icon: 'lucide:list-ordered', title: 'Živý žebříček',       body: 'Tabulka se přepočítá po každém zápase. Uvidíš, kdo právě skočil nahoru.' },
                { icon: 'lucide:share-2',      title: 'Pozvánky na pár kliků', body: 'Nasdílej odkaz, zvi přes PIN, nebo tipuj za hráče, kteří nechtějí účet.' }
            ] %}
            {% for f in features %}
                <div class="group flex flex-col rounded-2xl bg-white p-8 shadow-card ring-1 ring-navy-900/5 transition-all hover:-translate-y-1 hover:shadow-card-hover">
                    <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-cyan-400 to-cyan-600 text-white shadow-md shadow-cyan-500/20">
                        <twig:ux:icon name="{{ f.icon }}" class="h-6 w-6" />
                    </span>
                    <h3 class="mt-6 text-lg font-semibold text-navy-900">{{ f.title }}</h3>
                    <p class="mt-2 text-sm leading-relaxed text-navy-900/70">{{ f.body }}</p>
                </div>
            {% endfor %}
        </div>
    </div>
</section>

{# ───────── Final CTA ───────── #}
<section class="relative overflow-hidden bg-gradient-to-br from-navy-900 via-navy-800 to-navy-700 py-16 sm:py-20">
    <div aria-hidden="true" class="pointer-events-none absolute -right-20 -top-20 h-80 w-80 rounded-full bg-cyan-500/20 blur-3xl"></div>
    <div aria-hidden="true" class="pointer-events-none absolute -bottom-20 -left-20 h-80 w-80 rounded-full bg-cyan-500/10 blur-3xl"></div>

    <div class="relative mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">Připoj se zdarma</h2>
        <p class="mt-3 text-lg text-white/70">Žádné poplatky, žádné reklamy, žádné složité nastavení.</p>
        <a href="{{ path('app_register') }}" class="mt-8 inline-flex items-center justify-center gap-2 rounded-xl bg-cyan-500 px-7 py-3.5 text-base font-semibold text-white shadow-xl shadow-cyan-500/30 transition-all hover:-translate-y-0.5 hover:bg-cyan-600">
            Vytvořit účet
            <twig:ux:icon name="lucide:arrow-right" class="h-5 w-5" />
        </a>
    </div>
</section>
{% endblock %}
