{% extends 'auth/_layout.html.twig' %}

{% block title %}Nové heslo — Tipovačka{% endblock %}

{% block auth_panel_tagline %}Ještě pár vteřin — nastav si nové heslo a jsi zpátky ve hře.{% endblock %}

{% block auth_card %}
<div class="rounded-2xl bg-white p-8 shadow-card ring-1 ring-navy-900/5 sm:p-10">
    <div class="mb-8 text-center">
        <h1 class="text-3xl font-bold tracking-tight text-navy-900">Nové heslo</h1>
        <p class="mt-2 text-navy-900/60">Zvol si nové heslo pro svůj účet.</p>
    </div>

    {{ form_start(form, {attr: {class: 'space-y-5', novalidate: 'novalidate'}}) }}

        <div data-controller="password-visibility">
            {{ form_label(form.newPassword.first, null, {label_attr: {class: 'block text-sm font-medium text-navy-900 mb-1.5'}}) }}
            <div class="relative">
                <span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-navy-900/40">
                    <twig:ux:icon name="lucide:lock" class="h-5 w-5" />
                </span>
                {{ form_widget(form.newPassword.first, {attr: {class: 'w-full rounded-lg border border-navy-100 bg-white py-2.5 pl-10 pr-12 text-navy-900 outline-none transition focus:border-transparent focus:ring-2 focus:ring-cyan-500', 'data-password-visibility-target': 'input'}}) }}
                <button type="button" data-action="password-visibility#toggle" class="absolute inset-y-0 right-2 flex items-center rounded-md px-2 text-navy-900/40 transition-colors hover:text-navy-900" aria-label="Zobrazit/skrýt heslo">
                    <span data-password-visibility-target="iconShow"><twig:ux:icon name="lucide:eye" class="h-5 w-5" /></span>
                    <span class="hidden" data-password-visibility-target="iconHide"><twig:ux:icon name="lucide:eye-off" class="h-5 w-5" /></span>
                </button>
            </div>
            {{ form_errors(form.newPassword.first) }}
        </div>

        <div>
            {{ form_label(form.newPassword.second, null, {label_attr: {class: 'block text-sm font-medium text-navy-900 mb-1.5'}}) }}
            <div class="relative">
                <span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-navy-900/40">
                    <twig:ux:icon name="lucide:lock" class="h-5 w-5" />
                </span>
                {{ form_widget(form.newPassword.second, {attr: {class: 'w-full rounded-lg border border-navy-100 bg-white py-2.5 pl-10 pr-4 text-navy-900 outline-none transition focus:border-transparent focus:ring-2 focus:ring-cyan-500'}}) }}
            </div>
            {{ form_errors(form.newPassword.second) }}
            {{ form_errors(form.newPassword) }}
        </div>

        <button type="submit" class="inline-flex w-full items-center justify-center gap-2 rounded-lg bg-cyan-500 px-4 py-3 text-sm font-semibold text-white transition-colors hover:bg-cyan-600">
            <twig:ux:icon name="lucide:shield-check" class="h-4 w-4" />
            Uložit nové heslo
        </button>

    {{ form_end(form) }}
</div>
{% endblock %}
