{% extends 'auth/_layout.html.twig' %}

{% block title %}Nové heslo — {{ brand_name }}{% endblock %}

{% block auth_panel_tagline %}Ještě pár vteřin — nastavte si nové heslo a jste zpátky ve hře.{% endblock %}

{% block auth_card %}
<div class="card-glass p-8 sm:p-10">
    <div class="mb-8 text-center">
        <div class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-2xl border border-accent-500/40 bg-accent-500/10 text-accent-300">
            <twig:ux:icon name="lucide:lock" class="h-7 w-7" />
        </div>
        <span class="eyebrow">Nové heslo</span>
        <h2 class="mt-3 text-2xl font-bold tracking-tight text-white">Nastavte si nové heslo</h2>
        <p class="mt-2 text-sm text-white/60">Zvolte si nové heslo pro svůj účet.</p>
    </div>

    <twig:Auth:ResetPasswordForm />
</div>
{% endblock %}
