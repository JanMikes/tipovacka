{% extends 'auth/_layout.html.twig' %}

{% block title %}Zapomenuté heslo — Tipovačka{% endblock %}

{% block auth_panel_tagline %}Nastavíme ti nové heslo přes odkaz zaslaný na e-mail.{% endblock %}

{% block auth_card %}
<div class="rounded-2xl bg-white p-8 shadow-card ring-1 ring-navy-900/5 sm:p-10">
    <div class="mb-8 text-center">
        <h1 class="text-3xl font-bold tracking-tight text-navy-900">Obnovení hesla</h1>
        <p class="mt-2 text-navy-900/60">Zadej e-mail a pošleme ti odkaz pro obnovení.</p>
    </div>

    <twig:Auth:RequestPasswordResetForm />

    <p class="mt-6 text-center text-sm">
        <a href="{{ path('app_login') }}" class="font-medium text-cyan-600 hover:text-cyan-700 hover:underline">← Zpět na přihlášení</a>
    </p>
</div>
{% endblock %}
