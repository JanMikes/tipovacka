{% extends 'auth/_layout.html.twig' %}

{% block title %}Zapomenuté heslo — Tipovačka{% endblock %}

{% block auth_panel_tagline %}Nastavíme ti nové heslo přes odkaz zaslaný na e-mail.{% endblock %}

{% block auth_card %}
<div class="rounded-2xl bg-white p-8 shadow-card ring-1 ring-navy-900/5 sm:p-10">
    <div class="mb-8 text-center">
        <h1 class="text-3xl font-bold tracking-tight text-navy-900">Obnovení hesla</h1>
        <p class="mt-2 text-navy-900/60">Zadej e-mail a pošleme ti odkaz pro obnovení.</p>
    </div>

    {{ form_start(form, {attr: {class: 'space-y-5', novalidate: 'novalidate'}}) }}

        <div>
            {{ form_label(form.email, null, {label_attr: {class: 'block text-sm font-medium text-navy-900 mb-1.5'}}) }}
            <div class="relative">
                <span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-navy-900/40">
                    <twig:ux:icon name="lucide:mail" class="h-5 w-5" />
                </span>
                {{ form_widget(form.email, {attr: {class: 'w-full rounded-lg border border-navy-100 bg-white py-2.5 pl-10 pr-4 text-navy-900 outline-none transition focus:border-transparent focus:ring-2 focus:ring-cyan-500'}}) }}
            </div>
            {{ form_errors(form.email) }}
        </div>

        <button type="submit" class="inline-flex w-full items-center justify-center gap-2 rounded-lg bg-navy-900 px-4 py-3 text-sm font-semibold text-white transition-colors hover:bg-navy-700">
            Odeslat odkaz pro obnovení
            <twig:ux:icon name="lucide:arrow-right" class="h-4 w-4" />
        </button>

    {{ form_end(form) }}

    <p class="mt-6 text-center text-sm">
        <a href="{{ path('app_login') }}" class="font-medium text-cyan-600 hover:text-cyan-700 hover:underline">← Zpět na přihlášení</a>
    </p>
</div>
{% endblock %}
