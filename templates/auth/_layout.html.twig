{% extends 'base.html.twig' %}

{#
    Auth shell — centered form card on a light background with a subtle cyan/navy gradient accent.
    Child templates fill:
      - {% block auth_panel_tagline %} (small copy shown above the card, optional)
      - {% block auth_card %} (main form/content card — required)
#}

{% block body %}
<section class="relative flex flex-1 items-center justify-center overflow-hidden bg-white px-4 py-16 sm:px-6 lg:px-8">
    {# Decorative background accents #}
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10">
        <div class="absolute -top-40 left-1/2 h-[32rem] w-[32rem] -translate-x-1/2 rounded-full bg-cyan-200/40 blur-3xl"></div>
        <div class="absolute -bottom-48 -right-32 h-[28rem] w-[28rem] rounded-full bg-navy-200/50 blur-3xl"></div>
        <div class="absolute -bottom-40 -left-32 h-[24rem] w-[24rem] rounded-full bg-cyan-100/60 blur-3xl"></div>
    </div>

    <div class="relative w-full max-w-md">
        {% block auth_panel_tagline_wrapper %}
            {% set tagline = block('auth_panel_tagline') ?? null %}
            {% if tagline %}
                <p class="mb-6 text-center text-sm text-navy-900/60">{{ tagline|raw }}</p>
            {% endif %}
        {% endblock %}

        {% block auth_card %}{% endblock %}
    </div>
</section>
{% endblock %}

{% block auth_panel_tagline %}{% endblock %}
