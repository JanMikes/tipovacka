{% extends 'base.html.twig' %}

{#
    Auth shell — dark navy canvas with ambient accent glows (Wtips).
    Child templates override ONE of:
      - {% block auth_card %}   — for simple centered status/form cards
                                   (reset, verify, check-email). Rendered inside a
                                   centered max-w-md column.
      - {% block auth_content %} — for full layout control (login/register 2-col).
    Optional: {% block auth_panel_tagline %} small copy above the centered card.
#}

{% block body %}
    <section class="bg-radial relative flex flex-1 items-center justify-center px-4 py-12 sm:px-6 lg:py-16">
        <div class="relative mx-auto w-full max-w-[80rem]">
            {% block auth_content %}
                <div class="mx-auto w-full max-w-md">
                    {% set tagline %}{% block auth_panel_tagline %}{% endblock %}{% endset %}
                    {% if tagline|trim %}
                        <p class="mb-6 text-center text-sm text-white/60">{{ tagline|raw }}</p>
                    {% endif %}
                    {% block auth_card %}{% endblock %}
                </div>
            {% endblock %}
        </div>
    </section>
{% endblock %}
