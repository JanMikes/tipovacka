{% extends 'auth/_layout.html.twig' %}

{% block title %}E-mail odeslán — {{ brand_name }}{% endblock %}

{% block auth_panel_tagline %}Zkontrolujte schránku, odkaz dorazil do pár vteřin.{% endblock %}

{% block auth_card %}
<div class="card-glass p-8 text-center sm:p-10">
    <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl border border-win/30 bg-win/10 text-win">
        <twig:ux:icon name="lucide:circle-check" class="h-7 w-7" />
    </div>

    <span class="eyebrow mt-6 block">Odkaz odeslán</span>
    <h2 class="mt-3 text-2xl font-bold tracking-tight text-white">Zkontrolujte schránku</h2>
    <p class="mt-3 text-sm text-white/60">
        Pokud u nás máte zaregistrovaný účet s tímto e-mailem, odeslali jsme vám odkaz pro obnovení hesla. Odkaz je platný 1 hodinu.
    </p>

    <a href="{{ path('app_login') }}" class="btn btn-link mt-8 inline-flex items-center gap-1.5 text-sm">
        <twig:ux:icon name="lucide:arrow-left" class="h-4 w-4" />
        Zpět na přihlášení
    </a>
</div>
{% endblock %}
