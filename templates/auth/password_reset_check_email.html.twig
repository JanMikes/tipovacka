{% extends 'base.html.twig' %}

{% block title %}E-mail odeslán — Tipovačka{% endblock %}

{% block body %}
<div class="flex-1 flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-md text-center">
        <div class="bg-white rounded-2xl shadow-lg p-8">
            <div class="flex justify-center mb-6">
                <div class="bg-green-100 rounded-full p-4">
                    <svg class="w-12 h-12 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
            </div>

            <h1 class="text-2xl font-bold text-[#081e44] mb-3">Zkontrolujte svoji schránku</h1>
            <p class="text-gray-500 mb-8">
                Pokud u nás máte zaregistrovaný účet s tímto e-mailem, odeslali jsme vám odkaz pro obnovení hesla.
                Odkaz je platný 1 hodinu.
            </p>

            <a href="{{ path('app_login') }}" class="text-sm text-[#149AD5] hover:underline">
                Zpět na přihlášení
            </a>
        </div>
    </div>
</div>
{% endblock %}
