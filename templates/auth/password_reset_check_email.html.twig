{% extends 'auth/_layout.html.twig' %}

{% block title %}E-mail odeslán — Tipovačka{% endblock %}

{% block auth_panel_tagline %}Zkontroluj schránku, odkaz dorazil do pár vteřin.{% endblock %}

{% block auth_card %}
<div class="rounded-2xl bg-white p-8 text-center shadow-card ring-1 ring-navy-900/5 sm:p-10">
    <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-green-100 text-green-600">
        <twig:ux:icon name="lucide:mail" class="h-8 w-8" />
    </div>

    <h1 class="mt-6 text-2xl font-bold tracking-tight text-navy-900">Zkontroluj svoji schránku</h1>
    <p class="mt-3 text-navy-900/60">
        Pokud u nás máš zaregistrovaný účet s tímto e-mailem, odeslali jsme ti odkaz pro obnovení hesla. Odkaz je platný 1 hodinu.
    </p>

    <a href="{{ path('app_login') }}" class="mt-8 inline-flex items-center gap-1.5 text-sm font-medium text-cyan-600 hover:text-cyan-700 hover:underline">
        ← Zpět na přihlášení
    </a>
</div>
{% endblock %}
