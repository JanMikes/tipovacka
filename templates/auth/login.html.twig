{% extends 'auth/_layout.html.twig' %}

{% block title %}Přihlášení — Tipovačka{% endblock %}

{% block auth_card %}
<div class="rounded-2xl bg-white p-8 shadow-card ring-1 ring-navy-900/5 sm:p-10">
    <div class="mb-8 text-center">
        <h1 class="text-3xl font-bold tracking-tight text-navy-900">Vítej zpátky</h1>
        <p class="mt-2 text-navy-900/60">Přihlas se do svého účtu</p>
    </div>

    {% if error %}
        <div class="mb-6 flex items-start gap-2.5 rounded-r-lg border-l-4 border-red-400 bg-red-50 px-4 py-3 text-sm text-red-800" role="alert">
            <twig:ux:icon name="lucide:circle-alert" class="mt-0.5 h-5 w-5 shrink-0" />
            <span>{{ error.messageKey|trans(error.messageData, 'security') }}</span>
        </div>
    {% endif %}

    <form method="post" action="{{ path('app_login') }}" class="space-y-5">
        <div>
            <label for="email" class="mb-1.5 block text-sm font-medium text-navy-900">E-mailová adresa</label>
            <div class="relative">
                <span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-navy-900/40">
                    <twig:ux:icon name="lucide:mail" class="h-5 w-5" />
                </span>
                <input
                    type="email"
                    id="email"
                    name="_username"
                    value="{{ lastUsername }}"
                    autocomplete="email"
                    required
                    class="w-full rounded-lg border border-navy-100 bg-white py-2.5 pl-10 pr-4 text-navy-900 outline-none transition focus:border-transparent focus:ring-2 focus:ring-cyan-500"
                    placeholder="vas@email.cz"
                >
            </div>
        </div>

        <div data-controller="password-visibility">
            <div class="mb-1.5 flex items-center justify-between">
                <label for="password" class="block text-sm font-medium text-navy-900">Heslo</label>
                <a href="{{ path('app_forgot_password_request') }}" class="text-sm font-medium text-cyan-600 hover:text-cyan-700 hover:underline">Zapomněli jste heslo?</a>
            </div>
            <div class="relative">
                <span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-navy-900/40">
                    <twig:ux:icon name="lucide:lock" class="h-5 w-5" />
                </span>
                <input
                    type="password"
                    id="password"
                    name="_password"
                    autocomplete="current-password"
                    required
                    data-password-visibility-target="input"
                    class="w-full rounded-lg border border-navy-100 bg-white py-2.5 pl-10 pr-12 text-navy-900 outline-none transition focus:border-transparent focus:ring-2 focus:ring-cyan-500"
                    placeholder="Vaše heslo"
                >
                <button
                    type="button"
                    data-action="password-visibility#toggle"
                    class="absolute inset-y-0 right-2 flex items-center rounded-md px-2 text-navy-900/40 transition-colors hover:text-navy-900"
                    aria-label="Zobrazit/skrýt heslo"
                >
                    <span data-password-visibility-target="iconShow"><twig:ux:icon name="lucide:eye" class="h-5 w-5" /></span>
                    <span class="hidden" data-password-visibility-target="iconHide"><twig:ux:icon name="lucide:eye-off" class="h-5 w-5" /></span>
                </button>
            </div>
        </div>

        <label class="flex items-center gap-2 text-sm text-navy-900/70">
            <input type="checkbox" name="_remember_me" class="h-4 w-4 rounded border-navy-200 text-cyan-500 focus:ring-cyan-500">
            Zapamatovat si mě
        </label>

        <button type="submit" class="inline-flex w-full items-center justify-center gap-2 rounded-lg bg-navy-900 px-4 py-3 text-sm font-semibold text-white transition-colors hover:bg-navy-700">
            Přihlásit se
            <twig:ux:icon name="lucide:arrow-right" class="h-4 w-4" />
        </button>
    </form>

    <p class="mt-6 text-center text-sm text-navy-900/60">
        Nemáš účet?
        <a href="{{ path('app_register') }}" class="font-semibold text-cyan-600 hover:text-cyan-700 hover:underline">Zaregistruj se</a>
    </p>
</div>
{% endblock %}
