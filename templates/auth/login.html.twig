{% extends 'auth/_layout.html.twig' %}

{% block title %}Přihlášení — {{ brand_name }}{% endblock %}

{% block auth_content %}
    <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:gap-16">

        {# LEFT — value prop (after the card on mobile) #}
        <section class="order-2 flex flex-col gap-6 lg:order-1">
            {{ include('_partials/join_by_pin_form.html.twig') }}

            <span class="pill pill-live w-max"><span class="ring"></span> 247 hráčů tipuje právě teď</span>

            <div class="flex flex-col gap-4">
                <span class="eyebrow">Vítejte zpátky · pokračování v soutěži</span>
                <h1 class="grad-headline text-5xl font-black leading-[1.02] tracking-tight sm:text-6xl">
                    Tipy <span class="display-gradient">nečekají.</span>
                </h1>
                <p class="max-w-[46ch] text-base leading-relaxed text-white/70">
                    Přihlaste se a podívejte se, jak se daří vaší partičce v evropských ligách, klubové lize i kancelářské soutěži.
                </p>
            </div>

            <div class="mt-1 flex flex-wrap gap-x-9 gap-y-6">
                <div class="flex items-center gap-3">
                    <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-accent-500/30 bg-gradient-to-br from-accent-500/[0.18] to-accent-deep/10 text-accent-300">
                        <twig:ux:icon name="lucide:users" class="h-5 w-5" />
                    </span>
                    <span>
                        <span class="block text-2xl font-black leading-none tracking-tight text-white tabular-nums">12 400+</span>
                        <span class="mt-1 block text-[10px] font-bold uppercase tracking-[0.1em] text-white/50">Hráčů</span>
                    </span>
                </div>
                <div class="flex items-center gap-3">
                    <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-accent-500/30 bg-gradient-to-br from-accent-500/[0.18] to-accent-deep/10 text-accent-300">
                        <twig:ux:icon name="lucide:trophy" class="h-5 w-5" />
                    </span>
                    <span>
                        <span class="block text-2xl font-black leading-none tracking-tight text-white tabular-nums">340</span>
                        <span class="mt-1 block text-[10px] font-bold uppercase tracking-[0.1em] text-white/50">Aktivních soutěží</span>
                    </span>
                </div>
                <div class="flex items-center gap-3">
                    <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-accent-500/30 bg-gradient-to-br from-accent-500/[0.18] to-accent-deep/10 text-accent-300">
                        <twig:ux:icon name="lucide:zap" class="h-5 w-5" />
                    </span>
                    <span>
                        <span class="block text-2xl font-black leading-none tracking-tight text-accent-300 tabular-nums">98 %</span>
                        <span class="mt-1 block text-[10px] font-bold uppercase tracking-[0.1em] text-white/50">Doporučí dál</span>
                    </span>
                </div>
            </div>
        </section>

        {# RIGHT — form card (first on mobile) #}
        <section class="card-glass order-1 w-full p-8 sm:p-10 lg:order-2 lg:max-w-[30rem] lg:justify-self-end">
            <span class="eyebrow">Přihlášení</span>
            <h2 class="mb-2 mt-2 text-3xl font-black leading-tight tracking-tight text-white sm:text-4xl">Pojďte tipovat.</h2>
            <p class="mb-7 text-sm leading-relaxed text-white/70">Zadejte e-mail a heslo. Bez sázek, bez peněz — jen pro radost.</p>

            {% if error %}
                <div class="mb-6 flex items-start gap-2.5 rounded-xl border border-loss/30 bg-loss/10 px-4 py-3 text-sm text-loss" role="alert">
                    <twig:ux:icon name="lucide:circle-alert" class="mt-0.5 h-5 w-5 shrink-0" />
                    <span>{{ error.messageKey|trans(error.messageData, 'security') }}</span>
                </div>
            {% endif %}

            <form method="post" action="{{ path('app_login') }}" class="flex flex-col gap-4">
                <div class="field">
                    <label for="email">E-mail</label>
                    <div class="relative">
                        <span class="pointer-events-none absolute inset-y-0 left-3.5 flex items-center text-white/50">
                            <twig:ux:icon name="lucide:mail" class="h-[18px] w-[18px]" />
                        </span>
                        <input
                            type="email"
                            id="email"
                            name="_username"
                            value="{{ lastUsername }}"
                            autocomplete="email"
                            required
                            class="input !pl-[42px]"
                            placeholder="marek@firma.cz"
                        >
                    </div>
                </div>

                <div class="field" data-controller="password-visibility">
                    <div class="flex items-center justify-between">
                        <label for="password">Heslo</label>
                        <a href="{{ path('app_forgot_password_request') }}" class="text-[13px] font-semibold normal-case tracking-normal text-accent-300 hover:text-white">Zapomenuté heslo?</a>
                    </div>
                    <div class="relative">
                        <span class="pointer-events-none absolute inset-y-0 left-3.5 flex items-center text-white/50">
                            <twig:ux:icon name="lucide:lock" class="h-[18px] w-[18px]" />
                        </span>
                        <input
                            type="password"
                            id="password"
                            name="_password"
                            autocomplete="current-password"
                            required
                            data-password-visibility-target="input"
                            class="input !pl-[42px] !pr-12"
                            placeholder="••••••••"
                        >
                        <button
                            type="button"
                            data-action="password-visibility#toggle"
                            class="absolute inset-y-0 right-2 my-auto flex h-[30px] w-[30px] items-center justify-center rounded-lg text-white/50 transition-colors hover:bg-white/5 hover:text-white"
                            aria-label="Zobrazit/skrýt heslo"
                        >
                            <span data-password-visibility-target="iconShow"><twig:ux:icon name="lucide:eye" class="h-[18px] w-[18px]" /></span>
                            <span class="hidden" data-password-visibility-target="iconHide"><twig:ux:icon name="lucide:eye-off" class="h-[18px] w-[18px]" /></span>
                        </button>
                    </div>
                </div>

                <label class="flex cursor-pointer select-none items-center gap-2.5 text-[13px] font-medium text-white/70">
                    <input type="checkbox" name="_remember_me" class="h-[17px] w-[17px] rounded-md border-white/20 bg-inset text-accent-500 focus:ring-accent-500 focus:ring-offset-0">
                    Pamatovat si mě
                </label>

                <button type="submit" class="btn btn-primary mt-2 w-full">
                    Přihlásit se
                    <twig:ux:icon name="lucide:arrow-right" class="h-4 w-4" />
                </button>
            </form>

            <p class="mt-6 text-center text-[13px] text-white/70">
                Nemáte ještě účet?
                <a href="{{ path('app_register') }}" class="font-bold text-white underline decoration-white/20 underline-offset-2 transition-colors hover:decoration-accent-400">Vytvořte si ho zdarma</a>
            </p>
        </section>

    </div>
{% endblock %}
