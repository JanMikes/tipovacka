{% extends 'auth/_layout.html.twig' %}

{% block title %}Ověření e-mailu čeká — {{ brand_name }}{% endblock %}

{% block auth_panel_tagline %}Ověřte svůj e-mail a soutěže na vás už čekají.{% endblock %}

{% block auth_card %}
<div class="card-glass p-8 text-center sm:p-10">
    <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl border border-accent-500/40 bg-accent-500/10 text-accent-300">
        <twig:ux:icon name="lucide:mail" class="h-7 w-7" />
    </div>

    <span class="eyebrow mt-6 block">Ověření e-mailu</span>
    <h2 class="mt-3 text-2xl font-bold tracking-tight text-white">Zkontrolujte schránku</h2>
    <p class="mt-3 text-sm text-white/60">
        Odeslali jsme vám ověřovací e-mail. Klikněte na odkaz v e-mailu pro aktivaci svého účtu. Odkaz je platný 7 dní.
    </p>

    {% if app.user %}
        <form method="post" action="{{ path('app_resend_verification_email') }}" class="mt-8">
            <input type="hidden" name="_token" value="{{ csrf_token('resend_verification') }}">
            <button type="submit" class="btn btn-primary w-full">
                <twig:ux:icon name="lucide:mail" class="h-4 w-4" />
                Odeslat ověřovací e-mail znovu
            </button>
        </form>
    {% endif %}

    <a href="{{ path('app_login') }}" class="btn btn-link mt-6 inline-flex items-center gap-1.5 text-sm">
        <twig:ux:icon name="lucide:arrow-left" class="h-4 w-4" />
        Zpět na přihlášení
    </a>
</div>
{% endblock %}
