{% extends 'auth/_layout.html.twig' %}

{% block title %}Ověření e-mailu čeká — Tipovačka{% endblock %}

{% block auth_panel_tagline %}Ověř svůj e-mail a ty skupiny na tebe už čekají.{% endblock %}

{% block auth_card %}
<div class="rounded-2xl bg-white p-8 text-center shadow-card ring-1 ring-navy-900/5 sm:p-10">
    <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-cyan-100 text-cyan-600">
        <twig:ux:icon name="lucide:mail" class="h-8 w-8" />
    </div>

    <h1 class="mt-6 text-2xl font-bold tracking-tight text-navy-900">Zkontroluj svoji schránku</h1>
    <p class="mt-3 text-navy-900/60">
        Odeslali jsme ti ověřovací e-mail. Klikni na odkaz v e-mailu pro aktivaci tvého účtu. Odkaz je platný 7 dní.
    </p>

    {% if app.user %}
        <form method="post" action="{{ path('app_resend_verification_email') }}" class="mt-8">
            <input type="hidden" name="_token" value="{{ csrf_token('resend_verification') }}">
            <button type="submit" class="inline-flex w-full items-center justify-center gap-2 rounded-lg bg-navy-900 px-4 py-3 text-sm font-semibold text-white transition-colors hover:bg-navy-700">
                <twig:ux:icon name="lucide:mail" class="h-4 w-4" />
                Odeslat ověřovací e-mail znovu
            </button>
        </form>
    {% endif %}

    <a href="{{ path('app_login') }}" class="mt-6 inline-flex items-center gap-1.5 text-sm font-medium text-cyan-600 hover:text-cyan-700 hover:underline">
        ← Zpět na přihlášení
    </a>
</div>
{% endblock %}
