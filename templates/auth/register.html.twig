{% extends 'auth/_layout.html.twig' %}

{% block title %}Registrace — Tipovačka{% endblock %}

{% block auth_panel_tagline %}Zaregistruj se zdarma a za pár kliků založ vlastní skupinu.{% endblock %}

{% block auth_card %}
<div class="rounded-2xl bg-white p-8 shadow-card ring-1 ring-navy-900/5 sm:p-10">
    <div class="mb-8 text-center">
        <h1 class="text-3xl font-bold tracking-tight text-navy-900">Vytvoř si účet</h1>
        <p class="mt-2 text-navy-900/60">Připoj se k Tipovačce zdarma</p>
    </div>

    <twig:Auth:RegistrationForm />

    <p class="mt-6 text-center text-sm text-navy-900/60">
        Už máš účet?
        <a href="{{ path('app_login') }}" class="font-semibold text-cyan-600 hover:text-cyan-700 hover:underline">Přihlas se</a>
    </p>
</div>
{% endblock %}
