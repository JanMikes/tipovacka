{% extends 'auth/_layout.html.twig' %}

{% block title %}Registrace — {{ brand_name }}{% endblock %}

{% block auth_content %}
    <div class="mx-auto flex w-full max-w-[60rem] flex-col gap-5">

        {{ include('_partials/join_by_pin_form.html.twig') }}

        <section class="card-glass w-full p-8 sm:p-10">
            <span class="eyebrow">Registrace</span>
            <h2 class="mb-2 mt-2 text-3xl font-black leading-tight tracking-tight text-white sm:text-4xl">Vytvořte si účet.</h2>
            <p class="mb-7 text-sm leading-relaxed text-white/70">Připojte se k {{ brand_name }} zdarma. Žádné sázky, žádné peníze — jen radost z tipování s kamarády.</p>

            <twig:Auth:RegistrationForm />

            <p class="mt-6 text-center text-[13px] text-white/70">
                Už máte účet?
                <a href="{{ path('app_login') }}" class="font-bold text-white underline decoration-white/20 underline-offset-2 transition-colors hover:decoration-accent-400">Přihlaste se</a>
            </p>
        </section>

    </div>
{% endblock %}
