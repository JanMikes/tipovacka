{% extends 'base.html.twig' %}

{% block title %}Registrace — Tipovačka{% endblock %}

{% block body %}
<div class="min-h-[calc(100vh-10rem)] flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-md">
        <div class="bg-white rounded-2xl shadow-lg p-8">
            <div class="text-center mb-8">
                <h1 class="text-3xl font-bold text-[#081e44]">Vytvořit účet</h1>
                <p class="text-gray-500 mt-2">Připojte se k Tipovačce</p>
            </div>

            {{ form_start(form, {attr: {class: 'space-y-5', novalidate: 'novalidate'}}) }}

                <div>
                    {{ form_label(form.email, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.email, {attr: {class: 'w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#149AD5] focus:border-transparent outline-none transition'}}) }}
                    {{ form_errors(form.email) }}
                </div>

                <div>
                    {{ form_label(form.nickname, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.nickname, {attr: {class: 'w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#149AD5] focus:border-transparent outline-none transition'}}) }}
                    <p class="text-xs text-gray-400 mt-1">3–30 znaků, pouze písmena, čísla, podtržítko, tečka nebo pomlčka.</p>
                    {{ form_errors(form.nickname) }}
                </div>

                <div data-controller="password-visibility">
                    {{ form_label(form.password.first, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    <div class="relative">
                        {{ form_widget(form.password.first, {attr: {class: 'w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#149AD5] focus:border-transparent outline-none transition pr-12', 'data-password-visibility-target': 'input'}}) }}
                        <button type="button" data-action="password-visibility#toggle" class="absolute inset-y-0 right-3 flex items-center text-gray-400 hover:text-gray-600" aria-label="Zobrazit/skrýt heslo">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0zM2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                            </svg>
                        </button>
                    </div>
                    {{ form_errors(form.password.first) }}
                </div>

                <div>
                    {{ form_label(form.password.second, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.password.second, {attr: {class: 'w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#149AD5] focus:border-transparent outline-none transition'}}) }}
                    {{ form_errors(form.password.second) }}
                    {{ form_errors(form.password) }}
                </div>

                <button
                    type="submit"
                    class="w-full bg-[#081e44] hover:bg-[#0f2d5f] text-white py-3 px-4 rounded-lg font-medium transition-colors"
                >
                    Vytvořit účet
                </button>

            {{ form_end(form) }}

            <p class="text-center text-sm text-gray-500 mt-6">
                Již máte účet?
                <a href="{{ path('app_login') }}" class="text-[#149AD5] hover:underline font-medium">
                    Přihlaste se
                </a>
            </p>
        </div>
    </div>
</div>
{% endblock %}
