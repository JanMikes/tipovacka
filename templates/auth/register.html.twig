{% extends 'auth/_layout.html.twig' %}

{% block title %}Registrace — Tipovačka{% endblock %}

{% block auth_panel_tagline %}Zaregistruj se zdarma a za pár kliků založ vlastní skupinu.{% endblock %}

{% block auth_card %}
<div class="rounded-2xl bg-white p-8 shadow-card ring-1 ring-navy-900/5 sm:p-10">
    <div class="mb-8 text-center">
        <h1 class="text-3xl font-bold tracking-tight text-navy-900">Vytvoř si účet</h1>
        <p class="mt-2 text-navy-900/60">Připoj se k Tipovačce zdarma</p>
    </div>

    {{ form_start(form, {attr: {class: 'space-y-5', novalidate: 'novalidate'}}) }}

        <div>
            {{ form_label(form.email, null, {label_attr: {class: 'block text-sm font-medium text-navy-900 mb-1.5'}}) }}
            <div class="relative">
                <span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-navy-900/40">
                    <twig:ux:icon name="lucide:mail" class="h-5 w-5" />
                </span>
                {{ form_widget(form.email, {attr: {class: 'w-full rounded-lg border border-navy-100 bg-white py-2.5 pl-10 pr-4 text-navy-900 outline-none transition focus:border-transparent focus:ring-2 focus:ring-cyan-500'}}) }}
            </div>
            {{ form_errors(form.email) }}
        </div>

        <div>
            {{ form_label(form.nickname, null, {label_attr: {class: 'block text-sm font-medium text-navy-900 mb-1.5'}}) }}
            <div class="relative">
                <span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-navy-900/40">
                    <twig:ux:icon name="lucide:user" class="h-5 w-5" />
                </span>
                {{ form_widget(form.nickname, {attr: {class: 'w-full rounded-lg border border-navy-100 bg-white py-2.5 pl-10 pr-4 text-navy-900 outline-none transition focus:border-transparent focus:ring-2 focus:ring-cyan-500'}}) }}
            </div>
            <p class="mt-1 text-xs text-navy-900/50">3–30 znaků, pouze písmena, čísla, podtržítko, tečka nebo pomlčka.</p>
            {{ form_errors(form.nickname) }}
        </div>

        <div data-controller="password-visibility">
            {{ form_label(form.password.first, null, {label_attr: {class: 'block text-sm font-medium text-navy-900 mb-1.5'}}) }}
            <div class="relative">
                <span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-navy-900/40">
                    <twig:ux:icon name="lucide:lock" class="h-5 w-5" />
                </span>
                {{ form_widget(form.password.first, {attr: {class: 'w-full rounded-lg border border-navy-100 bg-white py-2.5 pl-10 pr-12 text-navy-900 outline-none transition focus:border-transparent focus:ring-2 focus:ring-cyan-500', 'data-password-visibility-target': 'input'}}) }}
                <button type="button" data-action="password-visibility#toggle" class="absolute inset-y-0 right-2 flex items-center rounded-md px-2 text-navy-900/40 transition-colors hover:text-navy-900" aria-label="Zobrazit/skrýt heslo">
                    <span data-password-visibility-target="iconShow"><twig:ux:icon name="lucide:eye" class="h-5 w-5" /></span>
                    <span class="hidden" data-password-visibility-target="iconHide"><twig:ux:icon name="lucide:eye-off" class="h-5 w-5" /></span>
                </button>
            </div>
            {{ form_errors(form.password.first) }}
        </div>

        <div>
            {{ form_label(form.password.second, null, {label_attr: {class: 'block text-sm font-medium text-navy-900 mb-1.5'}}) }}
            <div class="relative">
                <span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-navy-900/40">
                    <twig:ux:icon name="lucide:lock" class="h-5 w-5" />
                </span>
                {{ form_widget(form.password.second, {attr: {class: 'w-full rounded-lg border border-navy-100 bg-white py-2.5 pl-10 pr-4 text-navy-900 outline-none transition focus:border-transparent focus:ring-2 focus:ring-cyan-500'}}) }}
            </div>
            {{ form_errors(form.password.second) }}
            {{ form_errors(form.password) }}
        </div>

        <button type="submit" class="inline-flex w-full items-center justify-center gap-2 rounded-lg bg-cyan-500 px-4 py-3 text-sm font-semibold text-white shadow-lg shadow-cyan-500/20 transition-colors hover:bg-cyan-600">
            Vytvořit účet
            <twig:ux:icon name="lucide:arrow-right" class="h-4 w-4" />
        </button>

    {{ form_end(form) }}

    <p class="mt-6 text-center text-sm text-navy-900/60">
        Už máš účet?
        <a href="{{ path('app_login') }}" class="font-semibold text-cyan-600 hover:text-cyan-700 hover:underline">Přihlas se</a>
    </p>
</div>
{% endblock %}
