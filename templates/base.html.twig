<!DOCTYPE html>
<html lang="cs" class="scroll-smooth">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}{{ brand_name }}{% endblock %}</title>
        <meta name="description" content="{% block meta_description %}{{ brand_name }} — tipovací soutěže pro firmy, partičky i kámoše. Bez sázek, jen pro radost.{% endblock %}">

        <meta property="og:site_name" content="{{ brand_name }}">
        <meta property="og:type" content="website">
        <meta property="og:url" content="{{ app.request.uri }}">
        <meta property="og:title" content="{% block og_title %}{{ brand_name }}{% endblock %}">
        <meta property="og:description" content="{% block og_description %}{{ brand_name }}{% endblock %}">
        <meta property="og:image" content="{{ absolute_url(asset('og-default.png')) }}">
        <meta property="og:image:width" content="1200">
        <meta property="og:image:height" content="630">
        <meta property="og:locale" content="cs_CZ">

        <meta name="twitter:card" content="summary_large_image">
        <meta name="twitter:title" content="{% block twitter_title %}{{ brand_name }}{% endblock %}">
        <meta name="twitter:description" content="{% block twitter_description %}{{ brand_name }}{% endblock %}">
        <meta name="twitter:image" content="{{ absolute_url(asset('og-default.png')) }}">

        <link rel="icon" type="image/png" href="{{ asset('favicon-96x96.png') }}" sizes="96x96">
        <link rel="icon" type="image/svg+xml" href="{{ asset('favicon.svg') }}">
        <link rel="shortcut icon" href="{{ asset('favicon.ico') }}">
        <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('apple-touch-icon.png') }}">
        <meta name="apple-mobile-web-app-title" content="{{ brand_name }}">
        <link rel="manifest" href="{{ asset('site.webmanifest') }}">
        <meta name="theme-color" content="#0f1726">

        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body data-turbo="false" class="min-h-screen flex flex-col antialiased {% block body_class %}{% endblock %}">

        {# ───────── Navigation ───────── #}
        <twig:Layout:Nav />

        {# ───────── Main content ───────── #}
        <main class="flex flex-1 flex-col">
            {# `app.flashes` consumes the flash bag on each call, so capture once. #}
            {% set flash_messages = app.flashes %}
            {% set flash_config = {
                'success': { icon: 'lucide:circle-check-big', classes: 'border-win/40 bg-win/10 text-win' },
                'error':   { icon: 'lucide:circle-alert',     classes: 'border-loss/40 bg-loss/10 text-loss' },
                'warning': { icon: 'lucide:triangle-alert',   classes: 'border-draw/40 bg-draw/10 text-draw' },
                'info':    { icon: 'lucide:info',             classes: 'border-accent/40 bg-accent/10 text-accent-300' },
            } %}
            {% if flash_messages|length %}
                <div class="mx-auto w-full max-w-[80rem] px-4 pt-4 sm:px-6 lg:px-8">
                    {% for type, messages in flash_messages %}
                        {% set cfg = flash_config[type] ?? { icon: 'lucide:info', classes: 'border-white/15 bg-white/5 text-white/80' } %}
                        {% for message in messages %}
                            <div class="mb-3 flex items-start gap-3 rounded-xl border px-4 py-3 {{ cfg.classes }}" role="alert">
                                <twig:ux:icon name="{{ cfg.icon }}" class="mt-0.5 h-5 w-5 shrink-0" />
                                <div class="text-sm">{{ message }}</div>
                            </div>
                        {% endfor %}
                    {% endfor %}
                </div>
            {% endif %}

            {% block body %}{% endblock %}
        </main>

        {# ───────── Footer ───────── #}
        <twig:Layout:Footer variant="{{ app.user ? 'app' : 'marketing' }}" />

    </body>
</html>
