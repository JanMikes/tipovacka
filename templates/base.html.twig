<!DOCTYPE html>
<html lang="cs" class="scroll-smooth">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Tipovačka{% endblock %}</title>
        <meta name="description" content="{% block meta_description %}Tipovačka — tipuj výsledky fotbalových zápasů{% endblock %}">

        <meta property="og:site_name" content="Tipovačka">
        <meta property="og:type" content="website">
        <meta property="og:url" content="{{ app.request.uri }}">
        <meta property="og:title" content="{% block og_title %}Tipovačka{% endblock %}">
        <meta property="og:description" content="{% block og_description %}Tipovačka{% endblock %}">
        <meta property="og:image" content="{{ absolute_url(asset('og-default.png')) }}">
        <meta property="og:image:width" content="1200">
        <meta property="og:image:height" content="630">
        <meta property="og:locale" content="cs_CZ">

        <meta name="twitter:card" content="summary_large_image">
        <meta name="twitter:title" content="{% block twitter_title %}Tipovačka{% endblock %}">
        <meta name="twitter:description" content="{% block twitter_description %}Tipovačka{% endblock %}">
        <meta name="twitter:image" content="{{ absolute_url(asset('og-default.png')) }}">

        <link rel="icon" type="image/png" href="{{ asset('favicon-96x96.png') }}" sizes="96x96">
        <link rel="icon" type="image/svg+xml" href="{{ asset('favicon.svg') }}">
        <link rel="shortcut icon" href="{{ asset('favicon.ico') }}">
        <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('apple-touch-icon.png') }}">
        <meta name="apple-mobile-web-app-title" content="Tipovačka">
        <link rel="manifest" href="{{ asset('site.webmanifest') }}">
        <meta name="theme-color" content="#081e44">

        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body data-turbo="false" class="min-h-screen flex flex-col bg-gray-50 text-gray-900">

        {# Navigation #}
        <header class="bg-[#081e44] text-white shadow-lg" data-controller="mobile-nav">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex items-center justify-between h-16">

                    {# Logo #}
                    <a href="{{ app.user ? path('portal_dashboard') : path('app_home') }}" class="flex items-center gap-2 text-white font-bold text-xl tracking-tight hover:text-[#149AD5] transition-colors" aria-label="Tipovačka — domovská stránka">
                        <img
                            src="{{ asset('images/logo/logo-icon.png') }}"
                            alt=""
                            class="h-8 w-8 rounded-md bg-white p-0.5"
                            width="32"
                            height="32"
                            loading="eager"
                            decoding="async"
                        >
                        Tipovačka
                    </a>

                    {# Desktop nav #}
                    <nav class="hidden md:flex items-center gap-6">
                        {% if app.user %}
                            <a href="{{ path('portal_dashboard') }}" class="text-gray-300 hover:text-white transition-colors text-sm font-medium">
                                Nástěnka
                            </a>
                            <a href="{{ path('public_tournaments_list') }}" class="text-gray-300 hover:text-white transition-colors text-sm font-medium">
                                Turnaje
                            </a>
                            <a href="{{ path('portal_profile_edit') }}" class="text-gray-300 hover:text-white transition-colors text-sm font-medium">
                                Profil
                            </a>
                            {% if is_granted('ROLE_ADMIN') %}
                                <a href="{{ path('admin_tournament_list') }}" class="text-[#149AD5] hover:text-white transition-colors text-sm font-medium">
                                    Admin
                                </a>
                            {% endif %}
                            <a href="{{ path('app_logout') }}" class="bg-[#149AD5] hover:bg-blue-500 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors">
                                Odhlásit se
                            </a>
                        {% else %}
                            <a href="{{ path('app_home') }}" class="text-gray-300 hover:text-white transition-colors text-sm font-medium">
                                Domů
                            </a>
                            <a href="{{ path('public_tournaments_list') }}" class="text-gray-300 hover:text-white transition-colors text-sm font-medium">
                                Turnaje
                            </a>
                            <a href="{{ path('app_login') }}" class="text-gray-300 hover:text-white transition-colors text-sm font-medium">
                                Přihlásit se
                            </a>
                            <a href="{{ path('app_register') }}" class="bg-[#149AD5] hover:bg-blue-500 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors">
                                Registrace
                            </a>
                        {% endif %}
                    </nav>

                    {# Mobile menu button #}
                    <button
                        data-action="mobile-nav#toggle"
                        class="md:hidden p-2 rounded-lg text-gray-300 hover:text-white hover:bg-white/10 transition-colors"
                        aria-label="Otevřít menu"
                        aria-expanded="false"
                        data-mobile-nav-target="button"
                    >
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path data-mobile-nav-target="iconOpen" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                            <path data-mobile-nav-target="iconClose" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                    </button>
                </div>
            </div>

            {# Mobile menu #}
            <div class="hidden md:hidden border-t border-white/10" data-mobile-nav-target="menu">
                <div class="px-4 py-3 space-y-2">
                    {% if app.user %}
                        <a href="{{ path('portal_dashboard') }}" class="block py-2 text-gray-300 hover:text-white text-sm font-medium">Nástěnka</a>
                        <a href="{{ path('public_tournaments_list') }}" class="block py-2 text-gray-300 hover:text-white text-sm font-medium">Turnaje</a>
                        <a href="{{ path('portal_profile_edit') }}" class="block py-2 text-gray-300 hover:text-white text-sm font-medium">Profil</a>
                        {% if is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('admin_tournament_list') }}" class="block py-2 text-[#149AD5] hover:text-white text-sm font-medium">Admin</a>
                        {% endif %}
                        <a href="{{ path('app_logout') }}" class="block py-2 text-[#149AD5] hover:text-white text-sm font-medium">Odhlásit se</a>
                    {% else %}
                        <a href="{{ path('app_home') }}" class="block py-2 text-gray-300 hover:text-white text-sm font-medium">Domů</a>
                        <a href="{{ path('public_tournaments_list') }}" class="block py-2 text-gray-300 hover:text-white text-sm font-medium">Turnaje</a>
                        <a href="{{ path('app_login') }}" class="block py-2 text-gray-300 hover:text-white text-sm font-medium">Přihlásit se</a>
                        <a href="{{ path('app_register') }}" class="block py-2 text-[#149AD5] hover:text-white text-sm font-medium">Registrace</a>
                    {% endif %}
                </div>
            </div>
        </header>

        {# Main content #}
        <main class="flex-1 flex flex-col">
            {# Flash messages #}
            {% set flash_types = {
                'success': 'bg-green-50 border-green-400 text-green-800',
                'error': 'bg-red-50 border-red-400 text-red-800',
                'warning': 'bg-yellow-50 border-yellow-400 text-yellow-800',
                'info': 'bg-blue-50 border-blue-400 text-blue-800',
            } %}
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="border-l-4 px-4 py-3 {{ flash_types[type] ?? 'bg-gray-50 border-gray-400 text-gray-800' }} mx-4 mt-3 rounded-r-lg" role="alert">
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </main>

        {# Footer #}
        <footer class="bg-[#081e44] text-gray-400 py-6 mt-auto">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-sm">
                <p>&copy; {{ "now"|date("Y") }} Tipovačka. Všechna práva vyhrazena.</p>
            </div>
        </footer>

    </body>
</html>
