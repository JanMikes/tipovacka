{% use 'form_div_layout.html.twig' %}

{# Default Tailwind classes for form widgets.
   Per-field `attr.class` / `label_attr.class` still wins — the |default filter
   only fills in when nothing was passed. Invalid widgets get aria-invalid="true"
   (assets/styles/app.css applies the red-border style via attribute selector),
   and required fields — which Symfony automatically tags with class="required"
   on their <label> — get a red asterisk via CSS in assets/styles/app.css. #}

{%- block form_errors -%}
    {%- if errors|length > 0 -%}
        <ul class="mt-1 space-y-0.5 text-sm text-red-600">
            {%- for error in errors -%}
                <li>{{ error.message }}</li>
            {%- endfor -%}
        </ul>
    {%- endif -%}
{%- endblock form_errors -%}

{%- block form_label -%}
    {%- if label is not same as(false) -%}
        {%- if 'checkbox' in block_prefixes or 'radio' in block_prefixes -%}
            {%- set label_attr = label_attr|merge({class: label_attr.class|default('inline-block text-sm text-navy-900 ml-2 align-middle')}) -%}
            {# Option labels inside expanded choices inherit the child's `required`
               flag, which would trigger the shared `label.required::after` asterisk
               once per option. Only the parent field label should show it. #}
            {%- set required = false -%}
        {%- else -%}
            {%- set label_attr = label_attr|merge({class: label_attr.class|default('block text-sm font-medium text-navy-900 mb-1.5')}) -%}
        {%- endif -%}
    {%- endif -%}
    {{- parent() -}}
{%- endblock form_label -%}

{%- block choice_widget_expanded -%}
    {%- set attr = attr|merge({class: attr.class|default('flex flex-wrap items-center gap-x-4 gap-y-2')}) -%}
    <div {{ block('widget_container_attributes') }}>
        {%- for child in form %}
            <div class="inline-flex items-center">
                {{- form_widget(child) -}}
                {{- form_label(child, null, {translation_domain: choice_translation_domain}) -}}
            </div>
        {% endfor %}
    </div>
{%- endblock choice_widget_expanded -%}

{# Single-text date / datetime / time widgets get upgraded to the flatpickr
   Stimulus controller. Form types must set `html5 => false` + an explicit
   `format` so Symfony renders a plain text input whose value matches what
   flatpickr writes (see datepicker_controller.js MODES table). #}
{%- block date_widget -%}
    {%- if widget == 'single_text' -%}
        {%- set attr = attr|merge({
            'data-controller': ('datepicker ' ~ attr['data-controller']|default(''))|trim,
            'data-datepicker-mode-value': 'date',
        }) -%}
    {%- endif -%}
    {{- parent() -}}
{%- endblock date_widget -%}

{%- block datetime_widget -%}
    {%- if widget == 'single_text' -%}
        {%- set attr = attr|merge({
            'data-controller': ('datepicker ' ~ attr['data-controller']|default(''))|trim,
            'data-datepicker-mode-value': 'datetime',
        }) -%}
    {%- endif -%}
    {{- parent() -}}
{%- endblock datetime_widget -%}

{%- block time_widget -%}
    {%- if widget == 'single_text' -%}
        {%- set attr = attr|merge({
            'data-controller': ('datepicker ' ~ attr['data-controller']|default(''))|trim,
            'data-datepicker-mode-value': 'time',
        }) -%}
    {%- endif -%}
    {{- parent() -}}
{%- endblock time_widget -%}

{%- block form_widget_simple -%}
    {%- set type = type|default('text') -%}
    {%- if type != 'hidden' -%}
        {%- set attr = attr|merge({class: attr.class|default('w-full px-4 py-2.5 border border-navy-100 rounded-lg focus:ring-2 focus:ring-cyan-500 focus:border-transparent outline-none transition bg-white text-navy-900')}) -%}
        {%- if not valid -%}
            {%- set attr = attr|merge({'aria-invalid': 'true'}) -%}
        {%- endif -%}
    {%- endif -%}
    {{- parent() -}}
{%- endblock form_widget_simple -%}

{%- block textarea_widget -%}
    {%- set attr = attr|merge({class: attr.class|default('w-full px-4 py-2.5 border border-navy-100 rounded-lg focus:ring-2 focus:ring-cyan-500 focus:border-transparent outline-none transition bg-white text-navy-900')}) -%}
    {%- if not valid -%}
        {%- set attr = attr|merge({'aria-invalid': 'true'}) -%}
    {%- endif -%}
    {{- parent() -}}
{%- endblock textarea_widget -%}

{%- block choice_widget_collapsed -%}
    {%- set attr = attr|merge({class: attr.class|default('w-full px-4 py-2.5 border border-navy-100 rounded-lg focus:ring-2 focus:ring-cyan-500 focus:border-transparent outline-none transition bg-white text-navy-900')}) -%}
    {%- if not valid -%}
        {%- set attr = attr|merge({'aria-invalid': 'true'}) -%}
    {%- endif -%}
    {{- parent() -}}
{%- endblock choice_widget_collapsed -%}

{%- block checkbox_widget -%}
    {%- set attr = attr|merge({class: attr.class|default('h-4 w-4 rounded border-navy-200 text-cyan-500 focus:ring-cyan-500')}) -%}
    {{- parent() -}}
{%- endblock checkbox_widget -%}

{%- block radio_widget -%}
    {%- set attr = attr|merge({class: attr.class|default('h-4 w-4 border-navy-200 text-cyan-500 focus:ring-cyan-500')}) -%}
    {{- parent() -}}
{%- endblock radio_widget -%}

{%- block button_widget -%}
    {%- set attr = attr|merge({class: attr.class|default('inline-flex items-center justify-center bg-navy-900 hover:bg-navy-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors')}) -%}
    {{- parent() -}}
{%- endblock button_widget -%}
