{% extends 'base.html.twig' %}

{% block title %}Stránka nenalezena — {{ brand_name }}{% endblock %}

{% block body %}
    <div class="bg-radial flex flex-1 items-center justify-center px-4 py-16">
        <div class="card-glass w-full max-w-md p-8 text-center">
            <div class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-2xl border border-accent-500/30 bg-accent-500/15 text-accent-300">
                <twig:ux:icon name="lucide:search" class="h-7 w-7" />
            </div>
            <p class="eyebrow mb-2">Chyba 404</p>
            <h1 class="text-2xl font-extrabold tracking-tight text-white">Stránka nenalezena</h1>
            <p class="mt-3 text-sm leading-relaxed text-white/60">
                Tahle stránka neexistuje nebo se přesunula. Zkuste se vrátit zpět nebo na úvod.
            </p>
            <div class="mt-7 flex flex-wrap justify-center gap-2.5">
                <a href="{{ path('app_home') }}" class="btn btn-primary btn-sm">Zpět na úvod</a>
                {% if is_granted('ROLE_USER') %}
                    <a href="{{ path('portal_profile_edit') }}" class="btn btn-ghost btn-sm">Můj profil</a>
                {% else %}
                    <a href="{{ path('app_login') }}" class="btn btn-ghost btn-sm">Přihlásit se</a>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
