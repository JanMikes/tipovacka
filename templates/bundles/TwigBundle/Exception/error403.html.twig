{% extends 'base.html.twig' %}

{% block title %}Přístup odepřen — {{ brand_name }}{% endblock %}

{% block body %}
    <div class="bg-radial flex flex-1 items-center justify-center px-4 py-16">
        <div class="card-glass w-full max-w-md p-8 text-center">
            <div class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-2xl border border-draw/30 bg-draw/15 text-draw">
                <twig:ux:icon name="lucide:lock" class="h-7 w-7" />
            </div>
            <p class="eyebrow mb-2">Chyba 403</p>
            <h1 class="text-2xl font-extrabold tracking-tight text-white">Přístup odepřen</h1>
            <p class="mt-3 text-sm leading-relaxed text-white/60">
                {% if is_granted('ROLE_USER') %}
                    K této stránce nemáte oprávnění — je nejspíš jen pro organizátory nebo administraci.
                {% else %}
                    K tomuto obsahu se musíte nejdřív přihlásit.
                {% endif %}
            </p>
            <div class="mt-7 flex flex-wrap justify-center gap-2.5">
                <a href="{{ path('app_home') }}" class="btn btn-primary btn-sm">Zpět na úvod</a>
                {% if not is_granted('ROLE_USER') %}
                    <a href="{{ path('app_login') }}" class="btn btn-ghost btn-sm">Přihlásit se</a>
                {% else %}
                    <button type="button" onclick="history.back()" class="btn btn-ghost btn-sm">Zpět</button>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
