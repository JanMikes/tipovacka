{% extends 'base.html.twig' %}

{% block title %}Přístup odepřen - Tipovačka{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center px-4 bg-gray-50">
    <div class="card w-full max-w-md">
        <div class="card-body text-center">
            <div class="text-6xl mb-4">🚫</div>
            <h1 class="text-3xl font-bold text-gray-900 mb-2">403 - Přístup odepřen</h1>
            <p class="text-gray-600 mb-6">
                Nemáte oprávnění k přístupu na tuto stránku.
                {% if is_granted('ROLE_USER') %}
                    Tato oblast je pravděpodobně přístupná pouze administrátorům.
                {% else %}
                    Pro přístup k tomuto obsahu se prosím přihlaste.
                {% endif %}
            </p>

            <div class="flex justify-center gap-2 flex-wrap">
                <a href="{{ path('app_home') }}" class="btn btn-primary">
                    Zpět na úvodní stránku
                </a>
                {% if not is_granted('ROLE_USER') %}
                <a href="{{ path('app_login') }}" class="btn btn-secondary">
                    Přihlásit se
                </a>
                {% endif %}
                <button onclick="history.back()" class="btn btn-ghost">
                    Zpět
                </button>
            </div>
        </div>
    </div>
</div>
{% endblock %}
