{% extends 'base.html.twig' %}

{% block title %}Chyba serveru — {{ brand_name }}{% endblock %}

{% block body %}
    <div class="bg-radial flex flex-1 items-center justify-center px-4 py-16">
        <div class="card-glass w-full max-w-md p-8 text-center">
            <div class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-2xl border border-loss/30 bg-loss/15 text-loss">
                <twig:ux:icon name="lucide:triangle-alert" class="h-7 w-7" />
            </div>
            <p class="eyebrow mb-2">Chyba 500</p>
            <h1 class="text-2xl font-extrabold tracking-tight text-white">Chyba serveru</h1>
            <p class="mt-3 text-sm leading-relaxed text-white/60">
                Na naší straně se něco rozbilo. Náš tým o tom ví. Zkuste to prosím za chvíli znovu.
            </p>
            <div class="mt-7 flex flex-wrap justify-center gap-2.5">
                <a href="{{ path('app_home') }}" class="btn btn-primary btn-sm">Zpět na úvod</a>
                <button type="button" onclick="location.reload()" class="btn btn-ghost btn-sm">Zkusit znovu</button>
            </div>
        </div>
    </div>
{% endblock %}
