{% extends 'base.html.twig' %}

{% block title %}Chyba serveru - Tipovačka{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center px-4 bg-gray-50">
    <div class="card w-full max-w-md">
        <div class="card-body text-center">
            <div class="text-6xl mb-4">💥</div>
            <h1 class="text-3xl font-bold text-gray-900 mb-2">500 - Chyba serveru</h1>
            <p class="text-gray-600 mb-6">
                Došlo k technickým potížím. Náš tým byl informován
                a pracuje na vyřešení problému. Zkuste to prosím později.
            </p>

            <div class="flex justify-center gap-2">
                <a href="{{ path('app_home') }}" class="btn btn-primary">
                    Zpět na úvodní stránku
                </a>
                <button onclick="location.reload()" class="btn btn-secondary">
                    Zkusit znovu
                </button>
            </div>
        </div>
    </div>
</div>
{% endblock %}
