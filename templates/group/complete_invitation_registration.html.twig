{% extends 'base.html.twig' %}

{% block title %}Dokončit registraci — Tipovačka{% endblock %}

{% block body %}
<div class="max-w-md mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="bg-white rounded-2xl shadow-lg p-8">
        {% if state == 'invalid' %}
            <h1 class="text-2xl font-bold text-[#081e44] mb-3 text-center">Pozvánka nenalezena</h1>
            <p class="text-gray-500 text-center mb-6">Odkaz je neplatný nebo již neexistuje.</p>
            <div class="text-center">
                <a href="{{ path('app_login') }}" class="inline-block bg-[#081e44] hover:bg-[#0f2d5f] text-white py-2 px-4 rounded-lg text-sm font-medium">Přihlášení</a>
            </div>
        {% elseif state == 'expired' %}
            <h1 class="text-2xl font-bold text-[#081e44] mb-3 text-center">Pozvánka vypršela</h1>
            <p class="text-gray-500 text-center mb-6">Požádej pozvatele o novou pozvánku.</p>
        {% elseif state == 'revoked' %}
            <h1 class="text-2xl font-bold text-[#081e44] mb-3 text-center">Pozvánka byla zrušena</h1>
            <p class="text-gray-500 text-center mb-6">Tato pozvánka již není platná.</p>
        {% elseif state == 'accepted' %}
            <h1 class="text-2xl font-bold text-[#081e44] mb-3 text-center">Pozvánka již byla přijata</h1>
            <div class="text-center">
                <a href="{{ path('app_login') }}" class="inline-block bg-[#081e44] hover:bg-[#0f2d5f] text-white py-2 px-4 rounded-lg text-sm font-medium">Přihlášení</a>
            </div>
        {% else %}
            <div class="text-center mb-6">
                <h1 class="text-2xl font-bold text-[#081e44]">Dokončení registrace</h1>
                <p class="text-gray-500 mt-2">
                    Pozvánka do skupiny <strong>{{ invitation.group.name }}</strong>.
                    Zvol si heslo a rovnou tě připojíme.
                </p>
            </div>

            {{ form_start(form, {attr: {class: 'space-y-5', novalidate: 'novalidate'}}) }}
                <div>
                    {{ form_label(form.password.first, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.password.first, {attr: {class: 'w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#149AD5] focus:border-transparent outline-none'}}) }}
                    {{ form_errors(form.password.first) }}
                </div>
                <div>
                    {{ form_label(form.password.second, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.password.second, {attr: {class: 'w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#149AD5] focus:border-transparent outline-none'}}) }}
                    {{ form_errors(form.password.second) }}
                    {{ form_errors(form.password) }}
                </div>
                <button type="submit" class="w-full bg-[#081e44] hover:bg-[#0f2d5f] text-white py-3 px-4 rounded-lg font-medium">
                    Dokončit registraci a připojit se
                </button>
            {{ form_end(form) }}
        {% endif %}
    </div>
</div>
{% endblock %}
