{% extends 'auth/_layout.html.twig' %}

{% block title %}Dokončit registraci — Tipovačka{% endblock %}

{% block auth_panel_tagline %}Už jen heslo a rovnou hraješ s kamarády.{% endblock %}

{% block auth_card %}
{% if state == 'invalid' %}
    <div class="rounded-2xl bg-white p-8 text-center shadow-card ring-1 ring-navy-900/5 sm:p-10">
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-red-100 text-red-600">
            <twig:ux:icon name="lucide:triangle-alert" class="h-8 w-8" />
        </div>
        <h1 class="mt-6 text-2xl font-bold tracking-tight text-navy-900">Pozvánka nenalezena</h1>
        <p class="mt-3 text-navy-900/60">Odkaz je neplatný nebo už neexistuje.</p>
        <a href="{{ path('app_login') }}" class="mt-8 inline-flex w-full items-center justify-center gap-2 rounded-lg bg-navy-900 px-4 py-3 text-sm font-semibold text-white transition-colors hover:bg-navy-700">
            <twig:ux:icon name="lucide:log-in" class="h-4 w-4" />
            Přihlášení
        </a>
    </div>
{% elseif state == 'expired' %}
    <div class="rounded-2xl bg-white p-8 text-center shadow-card ring-1 ring-navy-900/5 sm:p-10">
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-yellow-100 text-yellow-600">
            <twig:ux:icon name="lucide:clock" class="h-8 w-8" />
        </div>
        <h1 class="mt-6 text-2xl font-bold tracking-tight text-navy-900">Pozvánka vypršela</h1>
        <p class="mt-3 text-navy-900/60">Požádej pozvatele o novou pozvánku.</p>
    </div>
{% elseif state == 'revoked' %}
    <div class="rounded-2xl bg-white p-8 text-center shadow-card ring-1 ring-navy-900/5 sm:p-10">
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-red-100 text-red-600">
            <twig:ux:icon name="lucide:triangle-alert" class="h-8 w-8" />
        </div>
        <h1 class="mt-6 text-2xl font-bold tracking-tight text-navy-900">Pozvánka byla zrušena</h1>
        <p class="mt-3 text-navy-900/60">Tato pozvánka už není platná.</p>
    </div>
{% elseif state == 'accepted' %}
    <div class="rounded-2xl bg-white p-8 text-center shadow-card ring-1 ring-navy-900/5 sm:p-10">
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-green-100 text-green-600">
            <twig:ux:icon name="lucide:circle-check-big" class="h-8 w-8" />
        </div>
        <h1 class="mt-6 text-2xl font-bold tracking-tight text-navy-900">Pozvánka už byla přijata</h1>
        <a href="{{ path('app_login') }}" class="mt-8 inline-flex w-full items-center justify-center gap-2 rounded-lg bg-navy-900 px-4 py-3 text-sm font-semibold text-white transition-colors hover:bg-navy-700">
            <twig:ux:icon name="lucide:log-in" class="h-4 w-4" />
            Přihlášení
        </a>
    </div>
{% else %}
    <div class="rounded-2xl bg-white p-8 shadow-card ring-1 ring-navy-900/5 sm:p-10">
        <div class="mb-8 text-center">
            <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-cyan-100 text-cyan-600">
                <twig:ux:icon name="lucide:users" class="h-7 w-7" />
            </div>
            <h1 class="mt-5 text-2xl font-bold tracking-tight text-navy-900">Dokončení registrace</h1>
            <p class="mt-2 text-navy-900/60">
                Pozvánka do skupiny <strong class="text-navy-900">{{ invitation.group.name }}</strong>. Zvol si heslo a rovnou tě připojíme.
            </p>
        </div>

        {{ form_start(form, {attr: {class: 'space-y-5', novalidate: 'novalidate'}}) }}
            <div>
                {{ form_label(form.password.first, null, {label_attr: {class: 'block text-sm font-medium text-navy-900 mb-1.5'}}) }}
                <div class="relative">
                    <span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-navy-900/40">
                        <twig:ux:icon name="lucide:lock" class="h-5 w-5" />
                    </span>
                    {{ form_widget(form.password.first, {attr: {class: 'w-full rounded-lg border border-navy-100 bg-white py-2.5 pl-10 pr-4 text-navy-900 outline-none transition focus:border-transparent focus:ring-2 focus:ring-cyan-500'}}) }}
                </div>
                {{ form_errors(form.password.first) }}
            </div>
            <div>
                {{ form_label(form.password.second, null, {label_attr: {class: 'block text-sm font-medium text-navy-900 mb-1.5'}}) }}
                <div class="relative">
                    <span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-navy-900/40">
                        <twig:ux:icon name="lucide:lock" class="h-5 w-5" />
                    </span>
                    {{ form_widget(form.password.second, {attr: {class: 'w-full rounded-lg border border-navy-100 bg-white py-2.5 pl-10 pr-4 text-navy-900 outline-none transition focus:border-transparent focus:ring-2 focus:ring-cyan-500'}}) }}
                </div>
                {{ form_errors(form.password.second) }}
                {{ form_errors(form.password) }}
            </div>
            <button type="submit" class="inline-flex w-full items-center justify-center gap-2 rounded-lg bg-cyan-500 px-4 py-3 text-sm font-semibold text-white shadow-lg shadow-cyan-500/20 transition-colors hover:bg-cyan-600">
                Dokončit registraci a připojit se
                <twig:ux:icon name="lucide:arrow-right" class="h-4 w-4" />
            </button>
        {{ form_end(form) }}
    </div>
{% endif %}
{% endblock %}
