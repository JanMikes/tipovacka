{% extends 'base.html.twig' %}

{% block title %}Pozvánka do skupiny — Tipovačka{% endblock %}

{% block body %}
<div class="max-w-md mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="bg-white rounded-2xl shadow-lg p-8 text-center">
        {% if state == 'invalid' %}
            <h1 class="text-2xl font-bold text-[#081e44] mb-3">Pozvánka nenalezena</h1>
            <p class="text-gray-500 mb-6">Odkaz je neplatný nebo již neexistuje.</p>
            <a href="{{ path('app_login') }}" class="inline-block bg-[#081e44] hover:bg-[#0f2d5f] text-white py-2 px-4 rounded-lg text-sm font-medium transition-colors">
                Zpět na přihlášení
            </a>
        {% elseif state == 'expired' %}
            <h1 class="text-2xl font-bold text-[#081e44] mb-3">Pozvánka vypršela</h1>
            {% if invitation %}
                <p class="text-gray-500 mb-3">Pozvánka do skupiny <strong>{{ invitation.groupName }}</strong> vypršela {{ invitation.expiresAt|date('d.m.Y H:i') }}.</p>
            {% endif %}
            <p class="text-gray-500 mb-6">Požádej pozvatele o novou pozvánku.</p>
            <a href="{{ path('app_login') }}" class="inline-block bg-[#081e44] hover:bg-[#0f2d5f] text-white py-2 px-4 rounded-lg text-sm font-medium transition-colors">
                Zpět na přihlášení
            </a>
        {% elseif state == 'revoked' %}
            <h1 class="text-2xl font-bold text-[#081e44] mb-3">Pozvánka byla zrušena</h1>
            <p class="text-gray-500 mb-6">Tato pozvánka již není platná.</p>
            <a href="{{ path('app_login') }}" class="inline-block bg-[#081e44] hover:bg-[#0f2d5f] text-white py-2 px-4 rounded-lg text-sm font-medium transition-colors">
                Zpět na přihlášení
            </a>
        {% elseif state == 'accepted' %}
            <h1 class="text-2xl font-bold text-[#081e44] mb-3">Pozvánka již byla přijata</h1>
            {% if invitation %}
                <p class="text-gray-500 mb-6">Pozvánka do skupiny <strong>{{ invitation.groupName }}</strong> již byla uplatněna.</p>
            {% endif %}
            <a href="{{ path('app_login') }}" class="inline-block bg-[#081e44] hover:bg-[#0f2d5f] text-white py-2 px-4 rounded-lg text-sm font-medium transition-colors">
                Přihlásit se
            </a>
        {% else %}
            <h1 class="text-2xl font-bold text-[#081e44] mb-3">Pozvánka do skupiny</h1>
            <p class="text-gray-500 mb-6">Přesměrováváme tě…</p>
        {% endif %}
    </div>
</div>
{% endblock %}
