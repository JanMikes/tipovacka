{% extends 'auth/_layout.html.twig' %}

{% block title %}Pozvánka do skupiny — Tipovačka{% endblock %}

{% block auth_panel_tagline %}Klikáš na pozvánku od přátel. Vítej!{% endblock %}

{% block auth_card %}
{% set states = {
    'invalid':  { icon: 'lucide:triangle-alert', color: 'bg-red-100 text-red-600',    title: 'Pozvánka nenalezena',    body: 'Odkaz je neplatný nebo už neexistuje.' },
    'expired':  { icon: 'lucide:clock',          color: 'bg-yellow-100 text-yellow-600', title: 'Pozvánka vypršela',      body: 'Požádej pozvatele o novou pozvánku.' },
    'revoked':  { icon: 'lucide:triangle-alert', color: 'bg-red-100 text-red-600',    title: 'Pozvánka byla zrušena',  body: 'Tato pozvánka už není platná.' },
    'accepted': { icon: 'lucide:circle-check-big', color: 'bg-green-100 text-green-600', title: 'Pozvánka už byla přijata', body: 'Pozvánka už byla uplatněna — přihlas se a jdi hrát.' },
} %}
{% set s = states[state] ?? { icon: 'lucide:info', color: 'bg-navy-100 text-navy-600', title: 'Pozvánka do skupiny', body: 'Přesměrováváme tě…' } %}

<div class="rounded-2xl bg-white p-8 text-center shadow-card ring-1 ring-navy-900/5 sm:p-10">
    <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl {{ s.color }}">
        <twig:ux:icon name="{{ s.icon }}" class="h-8 w-8" />
    </div>

    <h1 class="mt-6 text-2xl font-bold tracking-tight text-navy-900">{{ s.title }}</h1>

    {% if state == 'expired' and invitation %}
        <p class="mt-3 text-navy-900/60">
            Pozvánka do skupiny <strong class="text-navy-900">{{ invitation.groupName }}</strong> vypršela {{ invitation.expiresAt|date('d.m.Y H:i') }}.
        </p>
        <p class="mt-2 text-navy-900/60">{{ s.body }}</p>
    {% elseif state == 'accepted' and invitation %}
        <p class="mt-3 text-navy-900/60">
            Pozvánka do skupiny <strong class="text-navy-900">{{ invitation.groupName }}</strong> už byla uplatněna.
        </p>
    {% else %}
        <p class="mt-3 text-navy-900/60">{{ s.body }}</p>
    {% endif %}

    <a href="{{ path('app_login') }}" class="mt-8 inline-flex w-full items-center justify-center gap-2 rounded-lg bg-navy-900 px-4 py-3 text-sm font-semibold text-white transition-colors hover:bg-navy-700">
        {% if state == 'accepted' %}
            <twig:ux:icon name="lucide:log-in" class="h-4 w-4" />
            Přihlásit se
        {% else %}
            ← Zpět na přihlášení
        {% endif %}
    </a>
</div>
{% endblock %}
