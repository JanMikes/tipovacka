{% extends 'admin/layout.html.twig' %}

{% block title %}Turnaje — Admin — Tipovačka{% endblock %}

{% block admin_breadcrumbs %}
    <li aria-hidden="true" class="text-gray-300">/</li>
    <li class="text-gray-700 font-medium" aria-current="page">Turnaje</li>
{% endblock %}

{% block admin_title %}Turnaje{% endblock %}
{% block admin_subtitle %}Přehled veřejných i soukromých turnajů.{% endblock %}
{% block admin_actions %}
    <a href="{{ path('admin_tournament_create') }}" class="inline-flex items-center gap-2 bg-[#081e44] hover:bg-[#0f2d5f] text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Nový turnaj
    </a>
{% endblock %}

{% block admin_body %}
<div class="bg-white rounded-2xl shadow-sm ring-1 ring-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 text-gray-600">
                <tr>
                    <th class="text-left px-4 py-3 font-semibold">Název</th>
                    <th class="text-left px-4 py-3 font-semibold">Viditelnost</th>
                    <th class="text-left px-4 py-3 font-semibold">Sport</th>
                    <th class="text-left px-4 py-3 font-semibold">Vlastník</th>
                    <th class="text-left px-4 py-3 font-semibold">Skupiny</th>
                    <th class="text-left px-4 py-3 font-semibold">Stav</th>
                    <th class="text-right px-4 py-3 font-semibold">Akce</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                {% for tournament in tournaments %}
                    <tr class="{% if tournament.isDeleted %}text-gray-400{% else %}text-gray-800 hover:bg-gray-50{% endif %}">
                        <td class="px-4 py-3 font-medium">{{ tournament.name }}{% if tournament.isDeleted %} <span class="text-xs font-normal">(smazáno)</span>{% endif %}</td>
                        <td class="px-4 py-3">{{ tournament.visibility.label }}</td>
                        <td class="px-4 py-3">{{ tournament.sportCode }}</td>
                        <td class="px-4 py-3">{{ tournament.ownerNickname }}</td>
                        <td class="px-4 py-3">{{ tournament.groupCount }}</td>
                        <td class="px-4 py-3">
                            {% if tournament.isFinished %}
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700">ukončen</span>
                            {% else %}
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">aktivní</span>
                            {% endif %}
                        </td>
                        <td class="px-4 py-3">
                            <div class="flex items-center justify-end gap-3 whitespace-nowrap">
                                <a href="{{ path('admin_tournament_edit', {id: tournament.id.toRfc4122}) }}" class="text-[#149AD5] hover:underline text-sm">Upravit</a>
                                <a href="{{ path('admin_tournament_rule_configuration', {id: tournament.id.toRfc4122}) }}" class="text-[#149AD5] hover:underline text-sm">Pravidla</a>
                                <a href="{{ path('admin_sport_match_list', {tournamentId: tournament.id.toRfc4122}) }}" class="text-[#149AD5] hover:underline text-sm">Zápasy</a>
                                <a href="{{ path('admin_group_list', {tournament: tournament.id.toRfc4122}) }}" class="text-[#149AD5] hover:underline text-sm">Skupiny</a>
                                {% if not tournament.isFinished and not tournament.isDeleted %}
                                    <form method="post" action="{{ path('admin_tournament_finish', {id: tournament.id.toRfc4122}) }}" class="inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('admin_tournament_finish_' ~ tournament.id.toRfc4122) }}">
                                        <button type="submit" class="text-yellow-700 hover:underline text-sm">Ukončit</button>
                                    </form>
                                {% endif %}
                                {% if not tournament.isDeleted %}
                                    <form method="post" action="{{ path('admin_tournament_delete', {id: tournament.id.toRfc4122}) }}" class="inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('admin_tournament_delete_' ~ tournament.id.toRfc4122) }}">
                                        <button type="submit" class="text-red-600 hover:underline text-sm">Smazat</button>
                                    </form>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="7" class="px-4 py-8 text-center text-gray-500">Žádné turnaje.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
