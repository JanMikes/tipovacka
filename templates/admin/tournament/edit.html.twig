{% extends 'admin/layout.html.twig' %}

{% block title %}Upravit turnaj — Admin — Tipovačka{% endblock %}

{% block admin_body %}
<h1 class="text-2xl font-bold text-[#081e44] mb-4">Upravit turnaj</h1>
<p class="text-gray-500 mb-6">{{ tournament.name }}</p>

<div class="bg-white rounded-2xl shadow p-6">
    {{ form_start(form, {attr: {class: 'space-y-4', novalidate: 'novalidate'}}) }}
        <div>
            {{ form_label(form.name) }}
            {{ form_widget(form.name) }}
            {{ form_errors(form.name) }}
        </div>
        <div>
            {{ form_label(form.description) }}
            {{ form_widget(form.description) }}
            {{ form_errors(form.description) }}
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
                {{ form_label(form.startAt) }}
                {{ form_widget(form.startAt) }}
                {{ form_errors(form.startAt) }}
            </div>
            <div>
                {{ form_label(form.endAt) }}
                {{ form_widget(form.endAt) }}
                {{ form_errors(form.endAt) }}
            </div>
        </div>
        <div class="flex gap-3">
            <button type="submit" class="bg-[#081e44] text-white py-2 px-4 rounded">Uložit změny</button>
            <a href="{{ path('admin_tournament_list') }}" class="bg-gray-100 text-gray-700 py-2 px-4 rounded">Zrušit</a>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}
