{% extends 'admin/layout.html.twig' %}

{% block title %}Upravit turnaj — Admin — Tipovačka{% endblock %}

{% block admin_breadcrumbs %}
    <li aria-hidden="true" class="text-gray-300">/</li>
    <li><a href="{{ path('admin_tournament_list') }}" class="hover:text-[#149AD5] transition-colors">Turnaje</a></li>
    <li aria-hidden="true" class="text-gray-300">/</li>
    <li class="text-gray-700 font-medium" aria-current="page">Upravit</li>
{% endblock %}

{% block admin_title %}Upravit turnaj{% endblock %}
{% block admin_subtitle %}{{ tournament.name }}{% endblock %}
{% block admin_actions %}
    <a href="{{ path('admin_tournament_list') }}" class="inline-flex items-center gap-2 bg-white hover:bg-gray-50 text-gray-700 border border-gray-200 px-4 py-2 rounded-lg text-sm font-medium transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Zpět na turnaje
    </a>
{% endblock %}

{% block admin_body %}
<div class="bg-white rounded-2xl shadow-sm ring-1 ring-gray-100 p-6 md:p-8 max-w-3xl">
    {{ form_start(form, {attr: {class: 'space-y-5', novalidate: 'novalidate'}}) }}
        <div>
            {{ form_label(form.name) }}
            {{ form_widget(form.name) }}
            {{ form_errors(form.name) }}
        </div>
        <div>
            {{ form_label(form.description) }}
            {{ form_widget(form.description) }}
            {{ form_errors(form.description) }}
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
                {{ form_label(form.startAt) }}
                {{ form_widget(form.startAt) }}
                {{ form_errors(form.startAt) }}
            </div>
            <div>
                {{ form_label(form.endAt) }}
                {{ form_widget(form.endAt) }}
                {{ form_errors(form.endAt) }}
            </div>
        </div>
        {% if form.creationPin is defined %}
            <div>
                {{ form_label(form.creationPin) }}
                {{ form_widget(form.creationPin) }}
                {{ form_help(form.creationPin) }}
                {{ form_errors(form.creationPin) }}
            </div>
        {% endif %}
        <div class="flex flex-wrap gap-3 pt-2">
            <button type="submit" class="inline-flex items-center justify-center bg-[#081e44] hover:bg-[#0f2d5f] text-white px-5 py-2.5 rounded-lg text-sm font-medium transition-colors">
                Uložit změny
            </button>
            <a href="{{ path('admin_tournament_list') }}" class="inline-flex items-center justify-center bg-white hover:bg-gray-50 text-gray-700 border border-gray-200 px-5 py-2.5 rounded-lg text-sm font-medium transition-colors">
                Zrušit
            </a>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}
