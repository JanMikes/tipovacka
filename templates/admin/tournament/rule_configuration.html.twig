{% extends 'admin/layout.html.twig' %}

{% block title %}Pravidla — {{ tournament.name }} — Admin{% endblock %}

{% block admin_body %}
<h1 class="text-2xl font-bold text-[#081e44] mb-2">Pravidla bodování</h1>
<p class="text-gray-600 mb-6">Turnaj: {{ tournament.name }}</p>

{{ form_start(form, {'attr': {
    'data-controller': 'confirm-recalculation',
    'data-confirm-recalculation-count-value': evaluationCount,
    'data-action': 'submit->confirm-recalculation#confirmIfNeeded',
}}) }}

<div class="bg-white rounded-2xl shadow p-6 mb-6 space-y-6">
    {% for item in items %}
        {% set entryForm = form.rules[item.identifier] %}
        <div class="border border-gray-100 rounded-lg p-4">
            <div class="flex items-start justify-between gap-4 mb-2">
                <div>
                    <h2 class="text-lg font-semibold text-[#081e44]">{{ item.label }}</h2>
                    <p class="text-sm text-gray-500">{{ item.description }}</p>
                    <p class="text-xs text-gray-400 mt-1">Výchozí body: {{ item.defaultPoints }}</p>
                </div>
                <div>
                    {{ form_widget(entryForm.enabled) }}
                    {{ form_label(entryForm.enabled) }}
                </div>
            </div>
            <div class="flex items-center gap-2">
                {{ form_label(entryForm.points) }}
                {{ form_widget(entryForm.points, {'attr': {'class': 'border rounded px-2 py-1 w-24'}}) }}
            </div>
            {{ form_errors(entryForm.points) }}
        </div>
    {% endfor %}
</div>

<div class="flex gap-3">
    <button type="submit" class="bg-[#081e44] text-white py-2 px-4 rounded">Uložit pravidla</button>
    <a href="{{ path('admin_tournament_list') }}" class="bg-gray-100 text-gray-800 py-2 px-4 rounded">Zpět</a>
</div>

{{ form_end(form) }}
{% endblock %}
