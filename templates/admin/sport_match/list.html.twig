{% extends 'admin/layout.html.twig' %}

{% block title %}Zápasy — {{ match_source.name }} — Admin{% endblock %}

{% set _state_pills = {
    'scheduled': {label: 'Naplánován', variant: 'soon'},
    'live':      {label: 'Probíhá',    variant: 'locked'},
    'finished':  {label: 'Odehrán',    variant: 'done'},
    'postponed': {label: 'Odložen',    variant: 'warn'},
    'cancelled': {label: 'Zrušen',     variant: 'locked'},
} %}

{% block admin_breadcrumbs %}
    <li aria-hidden="true" class="text-white/30">/</li>
    <li><a href="{{ path('admin_match_source_list') }}" class="transition-colors hover:text-accent-300">Zdroje zápasů</a></li>
    <li aria-hidden="true" class="text-white/30">/</li>
    <li><a href="{{ path('admin_match_source_edit', {id: match_source.id.toRfc4122}) }}" class="transition-colors hover:text-accent-300">{{ match_source.name }}</a></li>
    <li aria-hidden="true" class="text-white/30">/</li>
    <li class="font-medium text-white/80" aria-current="page">Zápasy</li>
{% endblock %}

{% block admin_title %}Zápasy{% endblock %}
{% block admin_subtitle %}{{ match_source.name }}{% endblock %}
{% block admin_actions %}
    <a href="{{ path('admin_match_source_list') }}" class="btn btn-ghost btn-sm">
        <twig:ux:icon name="lucide:arrow-left" class="h-4 w-4" />
        Zpět
    </a>
    <a href="{{ path('portal_sport_match_create', {matchSourceId: match_source.id.toRfc4122}) }}" class="btn btn-primary btn-sm">
        <twig:ux:icon name="lucide:plus" class="h-4 w-4" />
        Nový zápas
    </a>
    <a href="{{ path('portal_sport_match_import', {matchSourceId: match_source.id.toRfc4122}) }}" class="btn btn-success btn-sm">
        <twig:ux:icon name="lucide:table-2" class="h-4 w-4" />
        Nahrát z Excelu/CSV
    </a>
{% endblock %}

{% block admin_body %}
<div class="card-glass overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-white/10 text-xs uppercase tracking-wider text-white/50">
                    <th class="px-4 py-3 text-left font-semibold">Zápas</th>
                    <th class="px-4 py-3 text-left font-semibold">Výkop</th>
                    <th class="px-4 py-3 text-left font-semibold">Místo</th>
                    <th class="px-4 py-3 text-left font-semibold">Stav</th>
                    <th class="px-4 py-3 text-left font-semibold">Skóre</th>
                    <th class="px-4 py-3 text-right font-semibold">Akce</th>
                </tr>
            </thead>
            <tbody>
                {% for match in matches %}
                    <tr class="border-b border-white/[0.06] text-white/80 hover:bg-white/[0.03]">
                        <td class="px-4 py-3 font-medium text-white">{{ match.homeTeam }} vs {{ match.awayTeam }}</td>
                        <td class="px-4 py-3">{{ match.kickoffAt|date('d. m. Y H:i') }}</td>
                        <td class="px-4 py-3">{{ match.venue ?? '—' }}</td>
                        <td class="px-4 py-3">
                            <span class="flex items-center gap-1.5">
                                {% set _pill = _state_pills[match.state.value] ?? {label: match.state.value, variant: 'neutral'} %}
                                <twig:Pill label="{{ _pill.label }}" variant="{{ _pill.variant }}" />
                                {% if match.isPlayoff %}
                                    <twig:Pill label="Playoff" variant="neutral" />
                                {% endif %}
                            </span>
                        </td>
                        <td class="px-4 py-3">
                            {% if match.homeScore is not null and match.awayScore is not null %}
                                <span class="font-semibold text-white">{{ match.homeScore }}:{{ match.awayScore }}</span>
                            {% else %}
                                <span class="text-white/40">—</span>
                            {% endif %}
                        </td>
                        <td class="px-4 py-3">
                            <div class="flex items-center justify-end gap-2 whitespace-nowrap">
                                <a href="{{ path('portal_sport_match_detail', {id: match.id.toRfc4122}) }}" class="btn btn-ghost btn-sm">
                                    <twig:ux:icon name="lucide:eye" class="h-3.5 w-3.5" />
                                    Detail
                                </a>
                                <a href="{{ path('portal_sport_match_edit', {id: match.id.toRfc4122}) }}" class="btn btn-ghost btn-sm">
                                    <twig:ux:icon name="lucide:pencil" class="h-3.5 w-3.5" />
                                    Upravit
                                </a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="6" class="px-4 py-10 text-center text-white/50">Žádné zápasy.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
