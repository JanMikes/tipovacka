{% extends 'admin/layout.html.twig' %}

{% block title %}Uživatelé — Admin — Tipovačka{% endblock %}

{% block admin_breadcrumbs %}
    <li aria-hidden="true" class="text-gray-300">/</li>
    <li class="text-gray-700 font-medium" aria-current="page">Uživatelé</li>
{% endblock %}

{% block admin_title %}Uživatelé{% endblock %}
{% block admin_subtitle %}Správa účtů, rolí a přístupu.{% endblock %}

{% block admin_body %}
<div class="bg-white rounded-2xl shadow-card ring-1 ring-navy-900/5 p-5 md:p-6">
    {{ form_start(form, {attr: {class: 'space-y-4'}}) }}
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
                {{ form_label(form.search) }}
                {{ form_widget(form.search) }}
            </div>
            <div>
                {{ form_label(form.verified) }}
                {{ form_widget(form.verified) }}
            </div>
            <div>
                {{ form_label(form.active) }}
                {{ form_widget(form.active) }}
            </div>
        </div>
        <div>
            <button type="submit" class="inline-flex items-center justify-center bg-navy-900 hover:bg-navy-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors">
                Filtrovat
            </button>
        </div>
    {{ form_end(form) }}
</div>

<div class="bg-white rounded-2xl shadow-card ring-1 ring-navy-900/5 overflow-hidden mt-6">
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead class="bg-navy-50/40 text-gray-600">
                <tr>
                    <th class="text-left px-4 py-3 font-semibold">E-mail</th>
                    <th class="text-left px-4 py-3 font-semibold">Přezdívka</th>
                    <th class="text-left px-4 py-3 font-semibold">Role</th>
                    <th class="text-left px-4 py-3 font-semibold">Stav</th>
                    <th class="text-right px-4 py-3 font-semibold">Akce</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-navy-100/70">
                {% for user in users %}
                    <tr class="{% if user.isDeleted %}text-gray-400{% else %}text-gray-800 hover:bg-navy-50/40{% endif %}">
                        <td class="px-4 py-3">{{ user.email }}{% if user.isDeleted %} <span class="text-xs">(smazán)</span>{% endif %}</td>
                        <td class="px-4 py-3">{{ user.nickname }}</td>
                        <td class="px-4 py-3">
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700">
                                {{ user.roles|join(', ') }}
                            </span>
                        </td>
                        <td class="px-4 py-3">
                            {% if not user.isVerified %}
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">neověřený</span>
                            {% endif %}
                            {% if not user.isActive %}
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">zablokovaný</span>
                            {% endif %}
                            {% if user.isVerified and user.isActive %}
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">aktivní</span>
                            {% endif %}
                        </td>
                        <td class="px-4 py-3">
                            <div class="flex items-center justify-end gap-3 whitespace-nowrap">
                                <a href="{{ path('admin_user_list', {_switch_user: user.email}) }}" class="text-cyan-500 hover:underline text-sm">Přihlásit se jako</a>
                                {% if user.isActive %}
                                    <form method="post" action="{{ path('admin_user_block', {id: user.id.toRfc4122}) }}" class="inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('admin_user_block_' ~ user.id.toRfc4122) }}">
                                        <button type="submit" class="text-red-600 hover:underline text-sm">Zablokovat</button>
                                    </form>
                                {% else %}
                                    <form method="post" action="{{ path('admin_user_unblock', {id: user.id.toRfc4122}) }}" class="inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('admin_user_unblock_' ~ user.id.toRfc4122) }}">
                                        <button type="submit" class="text-green-700 hover:underline text-sm">Odblokovat</button>
                                    </form>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="5" class="px-4 py-8 text-center text-navy-900/60">Žádní uživatelé.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
