{% extends 'admin/layout.html.twig' %}

{% block title %}Uživatelé — Admin — {{ brand_name }}{% endblock %}

{% block admin_breadcrumbs %}
    <li aria-hidden="true" class="text-white/30">/</li>
    <li class="font-medium text-white/80" aria-current="page">Uživatelé</li>
{% endblock %}

{% block admin_title %}Uživatelé{% endblock %}
{% block admin_subtitle %}Správa účtů, rolí a přístupu.{% endblock %}

{% block admin_body %}
<div class="card-glass p-5 md:p-6">
    {{ form_start(form, {attr: {class: 'space-y-4'}}) }}
        <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
            <div class="field">
                {{ form_label(form.search, null, {label_attr: {class: 'field-label'}}) }}
                {{ form_widget(form.search, {attr: {class: 'input'}}) }}
            </div>
            <div class="field">
                {{ form_label(form.verified, null, {label_attr: {class: 'field-label'}}) }}
                {{ form_widget(form.verified) }}
            </div>
            <div class="field">
                {{ form_label(form.active, null, {label_attr: {class: 'field-label'}}) }}
                {{ form_widget(form.active) }}
            </div>
        </div>
        <div>
            <button type="submit" class="btn btn-primary">
                <twig:ux:icon name="lucide:sliders-horizontal" class="h-4 w-4" />
                Filtrovat
            </button>
        </div>
    {{ form_end(form) }}
</div>

<div class="card-glass mt-6 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-white/10 text-xs uppercase tracking-wider text-white/50">
                    <th class="px-4 py-3 text-left font-semibold">E-mail</th>
                    <th class="px-4 py-3 text-left font-semibold">Uživatel</th>
                    <th class="px-4 py-3 text-left font-semibold">Role</th>
                    <th class="px-4 py-3 text-left font-semibold">Stav</th>
                    <th class="px-4 py-3 text-right font-semibold">Akce</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                    <tr class="border-b border-white/[0.06] {% if user.isDeleted %}text-white/40{% else %}text-white/80 hover:bg-white/[0.03]{% endif %}">
                        <td class="px-4 py-3">
                            {% if user.email is not null %}
                                {{ user.email }}
                            {% else %}
                                <span class="italic text-white/40">— anonymní —</span>
                            {% endif %}
                            {% if user.isDeleted %} <span class="text-xs text-white/40">(smazán)</span>{% endif %}
                        </td>
                        <td class="px-4 py-3">
                            <div class="flex items-center gap-3">
                                <twig:Avatar name="{{ user.nickname ?? user.fullName ?? '?' }}" size="32" />
                                <div class="min-w-0">
                                    {% if user.nickname is not null %}
                                        <span class="{{ user.isDeleted ? 'text-white/40' : 'text-white' }}">{{ user.nickname }}</span>
                                        {% if user.fullName %}<br><small class="text-xs font-normal text-white/40">{{ user.fullName }}</small>{% endif %}
                                    {% elseif user.fullName %}
                                        <span class="{{ user.isDeleted ? 'text-white/40' : 'text-white' }}">{{ user.fullName }}</span>
                                    {% else %}
                                        <span class="italic text-white/40">— anonymní —</span>
                                    {% endif %}
                                </div>
                            </div>
                        </td>
                        <td class="px-4 py-3">
                            <span class="badge badge-group">{{ user.roles|join(', ') }}</span>
                        </td>
                        <td class="px-4 py-3">
                            <div class="flex flex-wrap items-center gap-1.5">
                                {% if not user.isVerified %}
                                    <twig:Pill label="neověřený" variant="warn" />
                                {% endif %}
                                {% if not user.isActive %}
                                    <twig:Pill label="zablokovaný" variant="locked" icon="lock" />
                                {% endif %}
                                {% if user.isVerified and user.isActive %}
                                    <twig:Pill label="aktivní" variant="success" :dot="true" />
                                {% endif %}
                            </div>
                        </td>
                        <td class="px-4 py-3">
                            <div class="flex items-center justify-end gap-2 whitespace-nowrap">
                                {% if not user.isDeleted %}
                                    <a href="{{ path('admin_user_credits', {id: user.id.toRfc4122}) }}" class="btn btn-ghost btn-sm">
                                        <twig:ux:icon name="lucide:wallet" class="h-3.5 w-3.5" />
                                        Kredity
                                    </a>
                                {% endif %}
                                {% if user.email is not null %}
                                    <a href="{{ path('admin_user_list', {_switch_user: user.email}) }}" class="btn btn-ghost btn-sm">
                                        <twig:ux:icon name="lucide:log-in" class="h-3.5 w-3.5" />
                                        Přihlásit se jako
                                    </a>
                                {% endif %}
                                {% if user.isActive %}
                                    <form method="post" action="{{ path('admin_user_block', {id: user.id.toRfc4122}) }}" class="inline"
                                        data-controller="confirm"
                                        data-confirm-title-value="Zablokovat uživatele"
                                        data-confirm-message-value="Opravdu chcete uživatele {{ user.email ?? user.id.toRfc4122 }} zablokovat? Přestane se moct přihlásit."
                                        data-confirm-confirm-label-value="Ano, zablokovat">
                                        <input type="hidden" name="_token" value="{{ csrf_token('admin_user_block_' ~ user.id.toRfc4122) }}">
                                        <button type="submit" class="btn btn-danger btn-sm">Zablokovat</button>
                                    </form>
                                {% else %}
                                    <form method="post" action="{{ path('admin_user_unblock', {id: user.id.toRfc4122}) }}" class="inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('admin_user_unblock_' ~ user.id.toRfc4122) }}">
                                        <button type="submit" class="btn btn-success btn-sm">Odblokovat</button>
                                    </form>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="5" class="px-4 py-10 text-center text-white/50">Žádní uživatelé.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
