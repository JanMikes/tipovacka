{% extends 'admin/layout.html.twig' %}

{% block title %}Nový zdroj zápasů — Admin — {{ brand_name }}{% endblock %}

{% block admin_breadcrumbs %}
    <li aria-hidden="true" class="text-white/30">/</li>
    <li><a href="{{ path('admin_match_source_list') }}" class="hover:text-accent-300 transition-colors">Zdroje zápasů</a></li>
    <li aria-hidden="true" class="text-white/30">/</li>
    <li class="text-white/80 font-medium" aria-current="page">Nový zdroj zápasů</li>
{% endblock %}

{% block admin_title %}Nový zdroj zápasů{% endblock %}
{% block admin_subtitle %}Kurátorované zdroje zápasů může použít každý uživatel pro svou soutěž.{% endblock %}
{% block admin_actions %}
    <a href="{{ path('admin_match_source_list') }}" class="btn btn-ghost btn-sm">
        <twig:ux:icon name="lucide:arrow-left" class="h-4 w-4" />
        Zpět na zdroje zápasů
    </a>
{% endblock %}

{% block admin_body %}
<div class="card-glass p-6 md:p-8 max-w-3xl">
    {{ form_start(form, {attr: {class: 'space-y-5', novalidate: 'novalidate'}}) }}
        <div class="field">
            {{ form_label(form.name) }}
            {{ form_widget(form.name) }}
            {{ form_errors(form.name) }}
        </div>
        <div class="field">
            {{ form_label(form.description) }}
            {{ form_widget(form.description) }}
            {{ form_errors(form.description) }}
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="field">
                {{ form_label(form.startAt) }}
                {{ form_widget(form.startAt) }}
                {{ form_errors(form.startAt) }}
            </div>
            <div class="field">
                {{ form_label(form.endAt) }}
                {{ form_widget(form.endAt) }}
                {{ form_errors(form.endAt) }}
            </div>
        </div>
        <div class="flex flex-wrap gap-3 pt-2">
            <button type="submit" class="btn btn-primary">
                Vytvořit zdroj zápasů
            </button>
            <a href="{{ path('admin_match_source_list') }}" class="btn btn-ghost">
                Zrušit
            </a>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}
