{% extends 'admin/layout.html.twig' %}

{% block title %}Zdroje zápasů — Admin — {{ brand_name }}{% endblock %}

{% block admin_breadcrumbs %}
    <li aria-hidden="true" class="text-white/30">/</li>
    <li class="text-white/80 font-medium" aria-current="page">Zdroje zápasů</li>
{% endblock %}

{% block admin_title %}Zdroje zápasů{% endblock %}
{% block admin_subtitle %}Přehled kurátorovaných i soukromých zdrojů zápasů.{% endblock %}
{% block admin_actions %}
    <a href="{{ path('admin_match_source_create') }}" class="btn btn-primary btn-sm">
        <twig:ux:icon name="lucide:plus" class="h-4 w-4" />
        Nový zdroj zápasů
    </a>
{% endblock %}

{% block admin_body %}
<div class="card-glass overflow-hidden p-0">
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-white/10 text-xs uppercase tracking-wider text-white/50">
                    <th class="text-left px-4 py-3 font-semibold">Název</th>
                    <th class="text-left px-4 py-3 font-semibold">Typ</th>
                    <th class="text-left px-4 py-3 font-semibold">Sport</th>
                    <th class="text-left px-4 py-3 font-semibold">Vlastník</th>
                    <th class="text-left px-4 py-3 font-semibold">Soutěže</th>
                    <th class="text-left px-4 py-3 font-semibold">Stav</th>
                    <th class="text-right px-4 py-3 font-semibold">Akce</th>
                </tr>
            </thead>
            <tbody>
                {% for match_source in match_sources %}
                    <tr class="border-b border-white/[0.06] transition-colors {% if match_source.isDeleted %}text-white/40{% else %}text-white/80 hover:bg-white/[0.03]{% endif %}">
                        <td class="px-4 py-3 font-medium text-white">{{ match_source.name }}{% if match_source.isDeleted %} <span class="text-xs font-normal text-white/40">(smazáno)</span>{% endif %}</td>
                        <td class="px-4 py-3">{{ match_source.kind.label }}</td>
                        <td class="px-4 py-3">{{ match_source.sportCode }}</td>
                        <td class="px-4 py-3">{{ match_source.ownerNickname }}</td>
                        <td class="px-4 py-3">{{ match_source.competitionCount }}</td>
                        <td class="px-4 py-3">
                            {% if match_source.isFinished %}
                                <twig:Pill label="Ukončen" variant="done" />
                            {% else %}
                                <twig:Pill label="Aktivní" variant="success" dot />
                            {% endif %}
                        </td>
                        <td class="px-4 py-3">
                            <div class="flex items-center justify-end gap-2 whitespace-nowrap">
                                <a href="{{ path('portal_match_source_detail', {id: match_source.id.toRfc4122}) }}" class="btn btn-ghost btn-sm">Otevřít</a>
                                <a href="{{ path('admin_match_source_edit', {id: match_source.id.toRfc4122}) }}" class="btn btn-ghost btn-sm">Upravit</a>
                                <a href="{{ path('admin_match_source_rule_configuration', {id: match_source.id.toRfc4122}) }}" class="btn btn-ghost btn-sm">Pravidla</a>
                                <a href="{{ path('admin_sport_match_list', {matchSourceId: match_source.id.toRfc4122}) }}" class="btn btn-ghost btn-sm">Zápasy</a>
                                <a href="{{ path('admin_competition_list', {match_source: match_source.id.toRfc4122}) }}" class="btn btn-ghost btn-sm">Soutěže</a>
                                {% if not match_source.isFinished and not match_source.isDeleted %}
                                    <form method="post" action="{{ path('admin_match_source_finish', {id: match_source.id.toRfc4122}) }}" class="inline"
                                        data-controller="confirm"
                                        data-confirm-variant-value="warning"
                                        data-confirm-title-value="Ukončit zdroj zápasů"
                                        data-confirm-message-value="Opravdu chcete zdroj zápasů „{{ match_source.name }}“ ukončit? Další tipy už nepůjde zadávat a výsledek žebříčku bude finální."
                                        data-confirm-confirm-label-value="Ano, ukončit">
                                        <input type="hidden" name="_token" value="{{ csrf_token('admin_match_source_finish_' ~ match_source.id.toRfc4122) }}">
                                        <button type="submit" class="btn btn-ghost btn-sm text-win">Ukončit</button>
                                    </form>
                                {% endif %}
                                {% if not match_source.isDeleted %}
                                    <form method="post" action="{{ path('admin_match_source_delete', {id: match_source.id.toRfc4122}) }}" class="inline"
                                        data-controller="confirm"
                                        data-confirm-title-value="Smazat zdroj zápasů"
                                        data-confirm-message-value="Opravdu chcete zdroj zápasů „{{ match_source.name }}“ smazat? Společně s ním zmizí všechny zápasy, soutěže i tipy."
                                        data-confirm-confirm-label-value="Ano, smazat">
                                        <input type="hidden" name="_token" value="{{ csrf_token('admin_match_source_delete_' ~ match_source.id.toRfc4122) }}">
                                        <button type="submit" class="btn btn-ghost btn-sm text-loss">Smazat</button>
                                    </form>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="7" class="px-4 py-8 text-center text-white/50">Žádné zdroje zápasů.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
