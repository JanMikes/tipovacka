{% extends 'admin/layout.html.twig' %}

{% block title %}Skupiny — Admin — Tipovačka{% endblock %}

{% block admin_breadcrumbs %}
    <li aria-hidden="true" class="text-gray-300">/</li>
    <li class="text-gray-700 font-medium" aria-current="page">Skupiny</li>
{% endblock %}

{% block admin_title %}Skupiny{% endblock %}
{% block admin_subtitle %}Všechny skupiny napříč turnaji.{% endblock %}

{% block admin_body %}
<div class="bg-white rounded-2xl shadow-card ring-1 ring-navy-900/5 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead class="bg-navy-50/40 text-gray-600">
                <tr>
                    <th class="text-left px-4 py-3 font-semibold">Název</th>
                    <th class="text-left px-4 py-3 font-semibold">Turnaj</th>
                    <th class="text-left px-4 py-3 font-semibold">Vlastník</th>
                    <th class="text-left px-4 py-3 font-semibold">Členové</th>
                    <th class="text-right px-4 py-3 font-semibold">Akce</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-navy-100/70">
                {% for group in groups %}
                    <tr class="{% if group.isDeleted %}text-gray-400{% else %}text-gray-800 hover:bg-navy-50/40{% endif %}">
                        <td class="px-4 py-3 font-medium">{{ group.name }}{% if group.isDeleted %} <span class="text-xs font-normal">(smazáno)</span>{% endif %}</td>
                        <td class="px-4 py-3">{{ group.tournamentName }}</td>
                        <td class="px-4 py-3">{{ group.ownerNickname }}</td>
                        <td class="px-4 py-3">{{ group.memberCount }}</td>
                        <td class="px-4 py-3">
                            <div class="flex items-center justify-end gap-3 whitespace-nowrap">
                                <a href="{{ path('portal_group_detail', {id: group.id.toRfc4122}) }}" class="text-cyan-500 hover:underline text-sm">Detail</a>
                                {% if not group.isDeleted %}
                                    <form method="post" action="{{ path('admin_group_delete', {id: group.id.toRfc4122}) }}" class="inline"
                                        data-controller="confirm"
                                        data-confirm-title-value="Smazat skupinu"
                                        data-confirm-message-value="Opravdu chceš skupinu „{{ group.name }}“ smazat? Všichni členové přijdou o své tipy a skupina zmizí ze žebříčku."
                                        data-confirm-confirm-label-value="Ano, smazat">
                                        <input type="hidden" name="_token" value="{{ csrf_token('admin_group_delete_' ~ group.id.toRfc4122) }}">
                                        <button type="submit" class="text-red-600 hover:underline text-sm">Smazat</button>
                                    </form>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="5" class="px-4 py-8 text-center text-navy-900/60">Žádné skupiny.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
