{% extends 'admin/layout.html.twig' %}

{% block title %}Upravit globální soutěž — Admin — {{ brand_name }}{% endblock %}

{% block admin_breadcrumbs %}
    <li aria-hidden="true" class="text-white/30">/</li>
    <li><a href="{{ path('admin_competition_list') }}" class="hover:text-accent-300 transition-colors">Soutěže</a></li>
    <li aria-hidden="true" class="text-white/30">/</li>
    <li class="text-white/80 font-medium" aria-current="page">{{ competition.name }}</li>
{% endblock %}

{% block admin_title %}Upravit globální soutěž{% endblock %}
{% block admin_subtitle %}{{ competition.name }}{% endblock %}
{% block admin_actions %}
    <a href="{{ path('portal_competition_detail', {id: competition.id.toRfc4122}) }}" class="btn btn-ghost btn-sm">
        <twig:ux:icon name="lucide:arrow-left" class="h-4 w-4" />
        Zpět na soutěž
    </a>
{% endblock %}

{% block admin_body %}
<div class="card-glass p-6 md:p-8 max-w-3xl">
    {% if fee_locked %}
        <div class="mb-6 flex items-start gap-3 rounded-xl border border-warn/30 bg-warn/10 p-4 text-sm text-warn">
            <twig:ux:icon name="lucide:triangle-alert" class="mt-0.5 h-5 w-5 shrink-0" />
            <div>
                <p class="font-semibold">Vstupné je uzamčeno</p>
                <p class="mt-1 text-warn/80">Do soutěže se už připojil první hráč, takže vstupné ani monetizaci nelze změnit — hráči se přidali za původních podmínek.</p>
            </div>
        </div>
    {% endif %}

    {{ form_start(form, {attr: {class: 'space-y-5', novalidate: 'novalidate'}}) }}
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="field">
                {{ form_label(form.entryFeeCredits) }}
                {{ form_widget(form.entryFeeCredits, {attr: fee_locked ? {disabled: 'disabled'} : {}}) }}
                {{ form_errors(form.entryFeeCredits) }}
            </div>
            <div class="field">
                {{ form_label(form.monetization) }}
                {{ form_widget(form.monetization, {attr: fee_locked ? {disabled: 'disabled'} : {}}) }}
                {{ form_errors(form.monetization) }}
            </div>
        </div>
        <div class="flex flex-wrap gap-3 pt-2">
            <button type="submit" class="btn btn-primary"{{ fee_locked ? ' disabled' : '' }}>
                Uložit nastavení
            </button>
            <a href="{{ path('portal_competition_detail', {id: competition.id.toRfc4122}) }}" class="btn btn-ghost">
                Zrušit
            </a>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}
