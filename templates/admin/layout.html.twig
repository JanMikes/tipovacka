{% extends 'base.html.twig' %}

{# Blocks declared at top level — referenced via `block()` below so they render
   only inside the page header, not duplicated. Child templates override these. #}
{% block admin_title %}{% endblock %}
{% block admin_subtitle %}{% endblock %}
{% block admin_actions %}{% endblock %}
{% block admin_breadcrumbs %}{% endblock %}

{% block body %}
{% set _route = app.request.attributes.get('_route') %}
{% set _nav = [
    {route: 'admin_tournament_list', label: 'Turnaje',   icon: 'lucide:trophy',   match: ['admin_tournament_list', 'admin_tournament_edit', 'admin_tournament_create', 'admin_tournament_rule_configuration', 'admin_sport_match_list']},
    {route: 'admin_group_list',      label: 'Skupiny',   icon: 'lucide:users',    match: ['admin_group_list']},
    {route: 'admin_user_list',       label: 'Uživatelé', icon: 'lucide:user',     match: ['admin_user_list', 'admin_user_credits']},
    {route: 'admin_credit_purchases', label: 'Kredity',  icon: 'lucide:wallet',   match: ['admin_credit_purchases']},
    {route: 'admin_rule_list',       label: 'Pravidla',  icon: 'lucide:activity', match: ['admin_rule_list']},
] %}
{% set _title = block('admin_title')|trim %}
{% set _subtitle = block('admin_subtitle')|trim %}
{% set _actions = block('admin_actions')|trim %}

<div class="mx-auto w-full max-w-[88rem] px-4 py-6 sm:px-6 md:py-10 lg:px-8">
    <div class="grid grid-cols-1 gap-6 md:grid-cols-[260px_1fr]">

        <aside class="md:sticky md:top-24 md:self-start">
            <div class="rounded-2xl border border-white/10 bg-surface p-3 shadow-card">
                <p class="px-3 pb-3 pt-2 flex items-center gap-1.5 text-[11px] font-semibold uppercase tracking-wider text-white/50">
                    <twig:ux:icon name="lucide:shield-check" class="h-3.5 w-3.5 text-accent-400" />
                    Administrace
                </p>
                <nav class="flex flex-col gap-0.5 text-sm">
                    {% for item in _nav %}
                        {% set is_active = _route in item.match %}
                        <a href="{{ path(item.route) }}"
                           class="flex items-center gap-2.5 rounded-lg px-3 py-2 transition-colors {{ is_active ? 'bg-accent-500 font-semibold text-white shadow-sm' : 'text-white/70 hover:bg-white/5 hover:text-white' }}">
                            <twig:ux:icon name="{{ item.icon }}" class="h-4 w-4 {{ is_active ? 'text-white' : 'text-white/40' }}" />
                            {{ item.label }}
                        </a>
                    {% endfor %}
                </nav>
                <div class="mt-3 border-t border-white/10 px-1 pt-3">
                    <a href="{{ path('admin_tournament_create') }}"
                       class="flex items-center gap-2 rounded-lg px-3 py-2 text-sm font-semibold text-accent-300 transition-colors hover:bg-white/5 hover:text-accent-200">
                        <twig:ux:icon name="lucide:plus" class="h-4 w-4" />
                        Nový veřejný turnaj
                    </a>
                </div>
            </div>
        </aside>

        <section class="min-w-0 space-y-6">
            <nav aria-label="Breadcrumb" class="text-sm">
                <ol class="flex flex-wrap items-center gap-1 text-white/50">
                    <li class="flex items-center">
                        <a href="{{ path('admin_tournament_list') }}" class="transition-colors hover:text-accent-300">Admin</a>
                    </li>
                    {{ block('admin_breadcrumbs') }}
                </ol>
            </nav>

            {% if _title is not empty %}
                <header class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                    <div class="min-w-0">
                        <h1 class="break-words text-2xl font-bold tracking-tight text-white md:text-3xl">
                            {{- _title|raw -}}
                        </h1>
                        {% if _subtitle is not empty %}
                            <p class="mt-1 text-white/70">{{ _subtitle|raw }}</p>
                        {% endif %}
                    </div>
                    {% if _actions is not empty %}
                        <div class="flex flex-wrap gap-2 shrink-0">
                            {{ _actions|raw }}
                        </div>
                    {% endif %}
                </header>
            {% endif %}

            {% block admin_body %}{% endblock %}
        </section>
    </div>
</div>
{% endblock %}
