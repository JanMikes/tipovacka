{% extends 'admin/layout.html.twig' %}

{% block title %}Pravidla — Admin — Tipovačka{% endblock %}

{% block admin_body %}
<h1 class="text-2xl font-bold text-[#081e44] mb-4">Registrovaná pravidla</h1>

<p class="text-sm text-gray-600 mb-4">Tento přehled je pouze pro čtení. Body pro konkrétní turnaj lze upravit v jeho nastavení.</p>

<div class="bg-white rounded-2xl shadow overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-gray-50">
            <tr>
                <th class="text-left px-4 py-2">Identifikátor</th>
                <th class="text-left px-4 py-2">Název</th>
                <th class="text-left px-4 py-2">Popis</th>
                <th class="text-left px-4 py-2">Výchozí body</th>
            </tr>
        </thead>
        <tbody>
            {% for rule in rules %}
                <tr class="border-t">
                    <td class="px-4 py-2 font-mono text-xs">{{ rule.identifier }}</td>
                    <td class="px-4 py-2">{{ rule.label }}</td>
                    <td class="px-4 py-2 text-gray-600">{{ rule.description }}</td>
                    <td class="px-4 py-2">{{ rule.defaultPoints }}</td>
                </tr>
            {% else %}
                <tr><td colspan="4" class="px-4 py-6 text-center text-gray-500">Žádná pravidla nejsou registrována.</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
