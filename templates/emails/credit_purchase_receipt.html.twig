<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kredity připsány</title>
</head>
<body style="margin:0;padding:0;background-color:#0a111e;font-family:Arial,Helvetica,sans-serif;">
    <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#0a111e;padding:40px 0;">
        <tr>
            <td align="center">
                <table width="600" cellpadding="0" cellspacing="0" style="background-color:#141e36;border:1px solid #1b2742;border-radius:12px;overflow:hidden;">
                    <tr>
                        <td style="background-color:#0f1726;padding:32px 40px;text-align:center;">
                            <h1 style="color:#ffffff;margin:0;font-size:24px;font-weight:bold;letter-spacing:-0.02em;">{{ brand_name }}</h1>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:40px;">
                            <h2 style="color:#ffffff;font-size:20px;margin:0 0 16px;">Děkujeme za nákup, {{ nickname }}!</h2>
                            <p style="color:#c4cddd;line-height:1.6;margin:0 0 24px;">
                                Na váš účet jsme právě připsali <strong style="color:#ffffff;">{{ credits }} kreditů</strong>.
                                Aktuální zůstatek je <strong style="color:#ffffff;">{{ balance }} kreditů</strong>.
                            </p>
                            <table width="100%" cellpadding="0" cellspacing="0">
                                <tr>
                                    <td align="center" style="padding:24px 0;">
                                        <a href="{{ creditsUrl }}" style="background-color:#4699d0;color:#ffffff;text-decoration:none;padding:14px 32px;border-radius:8px;font-weight:bold;font-size:16px;display:inline-block;">
                                            Zobrazit kredity
                                        </a>
                                    </td>
                                </tr>
                            </table>
                            {% if invoiceUrl %}
                                <p style="color:#96a3c1;font-size:14px;line-height:1.6;margin:0;">
                                    Fakturu si můžete stáhnout <a href="{{ invoiceUrl }}" style="color:#4699d0;">zde</a>.
                                </p>
                            {% endif %}
                        </td>
                    </tr>
                    <tr>
                        <td style="background-color:#0a111e;padding:24px 40px;text-align:center;">
                            <p style="color:#6b7ca3;font-size:12px;margin:0;">&copy; {{ "now"|date("Y") }} {{ brand_name }}. Vše hraje, nic se nesází.</p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
