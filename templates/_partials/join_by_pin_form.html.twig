{#
    Shared PIN join form (Wtips dark .pin-card, 8 numeric boxes via pin-input controller).
    Params:
      - size: 'large' (default) or 'compact'
      - collapsible: bool — kept for caller compatibility (no longer changes layout materially)
#}
{% set size = size|default('large') %}
{% set redirect_to = app.request.requestUri %}

<form method="post" action="{{ path('portal_group_join_by_pin_quick') }}"
      data-controller="pin-input"
      class="pin-card relative overflow-hidden rounded-2xl border border-white/10 bg-gradient-to-br from-accent-500/10 to-navy-900/40 p-4 backdrop-blur sm:p-5">
    <input type="hidden" name="_token" value="{{ csrf_token('join_by_pin_quick') }}">
    <input type="hidden" name="redirect_to" value="{{ redirect_to }}">
    <input type="hidden" name="pin" data-pin-input-target="value">

    <div class="flex flex-col gap-3 {{ size == 'compact' ? '' : 'sm:flex-row sm:items-end sm:justify-between' }}">
        <div>
            <p class="eyebrow mb-2 flex items-center gap-2">
                <twig:ux:icon name="lucide:key-round" class="h-3.5 w-3.5" />
                Připojit se k soutěži
            </p>
            <div class="pin-inputs" aria-label="PIN soutěže (8 číslic)">
                {% for i in 1..8 %}
                    <input type="text" inputmode="numeric" maxlength="1" autocomplete="off"
                           aria-label="PIN znak {{ i }}" data-pin-input-target="box">
                    {% if i == 4 %}<span class="pin-sep" aria-hidden="true">—</span>{% endif %}
                {% endfor %}
            </div>
        </div>

        <button type="submit" data-pin-input-target="submit" disabled
                class="btn btn-primary btn-sm shrink-0 disabled:opacity-40">
            <twig:ux:icon name="lucide:arrow-right" class="h-4 w-4" />
            Připojit se
        </button>
    </div>
</form>
