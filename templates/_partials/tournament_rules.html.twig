{# Compact read-only list of scoring rules for a tournament.
   Usage: {{ include('_partials/tournament_rules.html.twig', { items: rule_items }) }}
   `items` is a list of App\Query\GetTournamentRuleConfiguration\RuleConfigurationItem. #}
{% set enabledItems = items|filter(item => item.enabled) %}
{% if enabledItems|length > 0 %}
    <section class="card-glass overflow-hidden">
        <header class="flex items-center gap-2.5 border-b border-white/10 px-6 py-4">
            <twig:ux:icon name="lucide:activity" class="h-5 w-5 text-accent-400" />
            <h2 class="text-lg font-semibold text-white">Pravidla bodování</h2>
        </header>
        <ul class="divide-y divide-white/[0.06]">
            {% for item in enabledItems %}
                <li class="flex items-center justify-between gap-3 px-6 py-3">
                    <span class="text-sm font-medium text-white/80">{{ item.label }}</span>
                    <span class="shrink-0 rounded-md border border-white/10 bg-white/5 px-2 py-0.5 text-sm font-semibold tabular-nums text-white">
                        {{ item.points }} b.
                    </span>
                </li>
            {% endfor %}
        </ul>
    </section>
{% endif %}
