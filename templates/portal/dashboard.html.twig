{% extends 'base.html.twig' %}

{% block title %}Nástěnka — {{ brand_name }}{% endblock %}

{% block body %}
<div class="bg-radial">
<div class="mx-auto w-full max-w-6xl px-4 py-10 sm:px-6 sm:py-14 lg:px-8">

    {# ───── Hero ───── #}
    <header class="mb-10">
        <p class="eyebrow mb-3">Nástěnka</p>
        <h1 class="grad-headline text-3xl font-extrabold tracking-tight sm:text-4xl">
            <span>Ahoj, {{ app.user.nickname }}.</span>
        </h1>
        <p class="mt-3 max-w-2xl text-white/60">Vaše soutěže, nadcházející zápasy a vyhodnocené tipy přehledně na jednom místě.</p>
    </header>

    {# ───── Moje výsledky — osobní statistiky ve vybrané soutěži ───── #}
    {% if member_stats is not null and selected_competition is not null %}
        <section class="mb-10">
            <div class="mb-5 flex flex-wrap items-end justify-between gap-4">
                <div>
                    <h2 class="flex items-center gap-2 text-xl font-semibold text-white">
                        <twig:ux:icon name="lucide:activity" class="h-5 w-5 text-accent-300" />
                        Moje výsledky
                    </h2>
                    <p class="mt-1.5 text-sm text-white/50">
                        Vaše statistiky v soutěži <span class="font-semibold text-white/70">{{ selected_competition.competitionName }}</span>.
                    </p>
                </div>
                {% if my_competitions|length > 1 %}
                    <twig:SoutezSwitcher
                        :competitions="my_competitions"
                        currentId="{{ selected_competition.competitionId.toRfc4122 }}"
                        route="portal_dashboard"
                        param="soutez"
                        label="Zobrazená soutěž"
                    />
                {% endif %}
            </div>

            {% if member_stats.evaluatedCount == 0 %}
                <div class="card-glass flex flex-col items-center gap-2 p-8 text-center sm:flex-row sm:items-center sm:gap-4 sm:text-left">
                    <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl border border-accent-500/30 bg-accent-500/15 text-accent-300">
                        <twig:ux:icon name="lucide:hourglass" class="h-6 w-6" />
                    </span>
                    <div>
                        <h3 class="text-base font-semibold text-white">Zatím bez výsledků</h3>
                        <p class="mt-1 text-sm text-white/55">Jakmile se odehrají zápasy a vyhodnotí vaše tipy, uvidíte tu pořadí, úspěšnost, přesné tipy i streak.</p>
                    </div>
                </div>
            {% else %}
                <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
                    <twig:StatCard
                        label="POŘADÍ"
                        value="{{ member_stats.rank }}."
                        meta="z {{ member_stats.totalMembers }} {{ member_stats.totalMembers == 1 ? 'hráče' : 'hráčů' }}"
                        tone="accent"
                        icon="medal"
                    />
                    <twig:StatCard
                        label="BODY"
                        value="{{ member_stats.totalPoints }}"
                        meta="celkem v soutěži"
                        icon="star"
                    />
                    <twig:StatCard
                        label="ÚSPĚŠNOST"
                        value="{{ member_stats.accuracyPercent }} %"
                        meta="{{ member_stats.scoredCount }}/{{ member_stats.evaluatedCount }} bodujících tipů"
                        icon="target"
                    />
                    <twig:StatCard
                        label="PŘESNÉ"
                        value="{{ member_stats.exactCount }}"
                        meta="přesných tipů"
                        tone="{{ member_stats.exactCount > 0 ? 'win' : null }}"
                        icon="circle-check-big"
                    />
                    <twig:StatCard
                        label="STREAK"
                        value="{{ member_stats.streak }}"
                        meta="tipů v řadě"
                        tone="{{ member_stats.streak > 0 ? 'win' : null }}"
                        icon="flame"
                    />
                </div>
            {% endif %}
        </section>
    {% endif %}

    {# ───── Mini žebříček vybrané soutěže ───── #}
    {% if mini_leaderboard_rows|length >= 2 %}
        <section class="mb-10">
            <div class="card-glass overflow-hidden p-0">
                <div class="flex items-center justify-between gap-3 border-b border-white/[0.06] px-5 py-4">
                    <h2 class="flex items-center gap-2 text-base font-bold text-white">
                        <twig:ux:icon name="lucide:trophy" class="h-5 w-5 text-accent-400" />
                        Žebříček · {{ selected_competition.competitionName }}
                    </h2>
                    <a href="{{ path('portal_competition_leaderboard', {competitionId: selected_competition.competitionId.toRfc4122}) }}" class="btn btn-ghost btn-sm">
                        Celý žebříček
                        <twig:ux:icon name="lucide:arrow-right" class="h-4 w-4" />
                    </a>
                </div>
                <div>
                    {% for row in mini_leaderboard_rows %}
                        {% set is_me = app.user and row.userId.equals(app.user.id) %}
                        <div class="lb-row{{ is_me ? ' me' }}">
                            <span class="lb-pos{{ row.rank <= 3 ? ' rank-' ~ row.rank }}">{{ row.rank }}.</span>
                            <a href="{{ path('portal_competition_leaderboard_member', {competitionId: selected_competition.competitionId.toRfc4122, userId: row.userId.toRfc4122}) }}" class="flex min-w-0 items-center gap-3 hover:opacity-90">
                                <twig:Avatar name="{{ row.fullName ?: row.nickname }}" size="30" rank="{{ row.rank <= 3 ? row.rank : null }}" />
                                <span class="flex min-w-0 items-center gap-2">
                                    <span class="truncate text-sm font-bold text-white">{{ row.nickname }}</span>
                                    {% if is_me %}<span class="lb-ty">TY</span>{% endif %}
                                </span>
                            </a>
                            <span class="text-right">
                                {% if row.streak > 0 %}<span class="lb-streak inline-flex items-center gap-1"><twig:ux:icon name="lucide:flame" class="h-3.5 w-3.5" />{{ row.streak }}</span>{% endif %}
                            </span>
                            <span class="text-right"><span class="lb-pts">{{ row.totalPoints }}</span> <span class="text-[11px] font-light text-white/50">b</span></span>
                        </div>
                    {% endfor %}
                    {% if mini_me_row is not null %}
                        <div class="border-t border-white/[0.06] py-1 text-center text-[11px] text-white/30">…</div>
                        <div class="lb-row me">
                            <span class="lb-pos">{{ mini_me_row.rank }}.</span>
                            <a href="{{ path('portal_competition_leaderboard_member', {competitionId: selected_competition.competitionId.toRfc4122, userId: mini_me_row.userId.toRfc4122}) }}" class="flex min-w-0 items-center gap-3 hover:opacity-90">
                                <twig:Avatar name="{{ mini_me_row.fullName ?: mini_me_row.nickname }}" size="30" />
                                <span class="flex min-w-0 items-center gap-2">
                                    <span class="truncate text-sm font-bold text-white">{{ mini_me_row.nickname }}</span>
                                    <span class="lb-ty">TY</span>
                                </span>
                            </a>
                            <span class="text-right">
                                {% if mini_me_row.streak > 0 %}<span class="lb-streak inline-flex items-center gap-1"><twig:ux:icon name="lucide:flame" class="h-3.5 w-3.5" />{{ mini_me_row.streak }}</span>{% endif %}
                            </span>
                            <span class="text-right"><span class="lb-pts">{{ mini_me_row.totalPoints }}</span> <span class="text-[11px] font-light text-white/50">b</span></span>
                        </div>
                    {% endif %}
                </div>
            </div>
        </section>
    {% endif %}

    {# ───── Přehledové statistiky — pouze hodnoty odvozené z dostupných dat ───── #}
    <div class="mb-10 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <twig:StatCard
            label="MOJE SOUTĚŽE"
            value="{{ my_competitions|length }}"
            meta="{{ my_competitions|length == 1 ? '1 soutěž' : (my_competitions|length >= 2 and my_competitions|length <= 4 ? my_competitions|length ~ ' soutěže' : my_competitions|length ~ ' soutěží') }}, ve kterých hrajete"
            tone="accent"
            icon="users"
        />
        <twig:StatCard
            label="NADCHÁZEJÍCÍ ZÁPASY"
            value="{{ upcoming_matches|length }}"
            meta="{{ upcoming_matches|length == 1 ? 'čeká 1 zápas' : (upcoming_matches|length >= 2 and upcoming_matches|length <= 4 ? 'čekají ' ~ upcoming_matches|length ~ ' zápasy' : 'čeká ' ~ upcoming_matches|length ~ ' zápasů') }} k tipnutí"
            icon="calendar"
        />
        <twig:StatCard
            label="VYHODNOCENÉ TIPY"
            value="{{ evaluated_guesses|length }}"
            meta="poslední uzavřené výsledky"
            icon="trophy"
        />
    </div>

    {# Primární CTA: připojení k soutěži přes PIN. Sbalí se, pokud už nějaké soutěže má. #}
    <div class="mb-12">
        {{ include('_partials/join_by_pin_form.html.twig', { size: 'large', collapsible: my_competitions|length > 0 }) }}
    </div>

    {# ───── Moje soutěže ───── #}
    <section class="mb-14">
        <div class="mb-5 flex flex-wrap items-end justify-between gap-3">
            <div>
                <h2 class="flex items-center gap-2 text-xl font-semibold text-white">
                    <twig:ux:icon name="lucide:users" class="h-5 w-5 text-accent-300" />
                    Moje soutěže
                    {% if my_competitions|length > 0 %}
                        <span class="rounded-full border border-white/10 bg-white/5 px-2.5 py-0.5 text-xs font-semibold text-white/70">{{ my_competitions|length }}</span>
                    {% endif %}
                </h2>
                <p class="mt-1.5 text-sm text-white/50">Soutěže, ve kterých tipujete s přáteli.</p>
            </div>
        </div>

        {% if my_competitions|length == 0 %}
            <div class="card-glass p-10 text-center">
                <span class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-2xl border border-accent-500/30 bg-accent-500/15 text-accent-300">
                    <twig:ux:icon name="lucide:trophy" class="h-7 w-7" />
                </span>
                <h3 class="text-lg font-semibold text-white">Zatím nehrajete v žádné soutěži</h3>
                <p class="mx-auto mt-2 max-w-md text-sm text-white/60">Založte si vlastní soutěž, nebo se přidejte k některé přes PIN či pozvánku.</p>
                <a href="{{ path('portal_competition_create') }}" class="btn btn-primary btn-sm mt-6">
                    <twig:ux:icon name="lucide:plus" class="h-4 w-4" />
                    Vytvořit soutěž
                </a>
            </div>
        {% else %}
            <ul class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
                {% for g in my_competitions %}
                    <li>
                        <a
                            href="{{ path('portal_competition_detail', {id: g.competitionId.toRfc4122}) }}"
                            class="card-glass group flex h-full flex-col justify-between p-6 transition-transform duration-200 hover:-translate-y-1"
                        >
                            <div>
                                <div class="mb-4 flex items-start justify-between gap-3">
                                    <span class="flex h-11 w-11 items-center justify-center rounded-xl border border-accent-500/30 bg-accent-500/15 text-accent-300">
                                        <twig:ux:icon name="lucide:users" class="h-5 w-5" />
                                    </span>
                                    <div class="flex flex-wrap items-center gap-1.5">
                                        {% if g.isOwner %}
                                            <twig:Badge label="Vlastník" variant="organizer" icon="crown" />
                                        {% endif %}
                                        {% if g.matchSourceIsFinished %}
                                            <twig:Pill label="Ukončen" variant="done" />
                                        {% endif %}
                                    </div>
                                </div>

                                <h3 class="flex items-center gap-1.5 text-lg font-semibold leading-tight text-white transition-colors group-hover:text-accent-300">
                                    <twig:ux:icon name="lucide:trophy" class="h-4 w-4 shrink-0 text-white/40" />
                                    {{ g.matchSourceName }}
                                </h3>

                                <p class="mt-2 flex items-center gap-1.5 text-sm text-white/50">
                                    <twig:ux:icon name="lucide:layout-grid" class="h-4 w-4 text-white/40" />
                                    {{ g.competitionName }}
                                </p>
                            </div>

                            <div class="mt-5 flex items-center justify-end text-sm font-semibold text-accent-300">
                                Otevřít soutěž
                                <twig:ux:icon name="lucide:arrow-right" class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-0.5" />
                            </div>
                        </a>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    </section>

    {# ───── Moje zdroje zápasů — zdroje vlastněné uživatelem ───── #}
    {% if my_owned_match_sources|length > 0 %}
        <section class="mb-14">
            <div class="mb-5 flex flex-wrap items-end justify-between gap-3">
                <div>
                    <h2 class="flex items-center gap-2 text-xl font-semibold text-white">
                        <twig:ux:icon name="lucide:crown" class="h-5 w-5 text-accent-300" />
                        Moje zdroje zápasů
                        <span class="rounded-full border border-white/10 bg-white/5 px-2.5 py-0.5 text-xs font-semibold text-white/70">{{ my_owned_match_sources|length }}</span>
                    </h2>
                    <p class="mt-1.5 text-sm text-white/50">Zdroje zápasů, které jste založili a spravujete.</p>
                </div>
            </div>

            <ul class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
                {% for t in my_owned_match_sources %}
                    {% set is_private = t.kind.value == 'private' %}
                    <li>
                        <a
                            href="{{ path('portal_match_source_detail', {id: t.id.toRfc4122}) }}"
                            class="card-glass group flex h-full flex-col justify-between p-6 transition-transform duration-200 hover:-translate-y-1"
                        >
                            <div>
                                <div class="mb-4 flex items-start justify-between gap-3">
                                    <span class="flex h-11 w-11 items-center justify-center rounded-xl border border-accent-500/30 bg-accent-500/15 text-accent-300">
                                        <twig:ux:icon name="lucide:trophy" class="h-5 w-5" />
                                    </span>
                                    <div class="flex flex-wrap items-center gap-1.5">
                                        <twig:Badge label="Vlastník" variant="organizer" icon="crown" />
                                        {% if is_private %}
                                            <twig:Pill label="Soukromý" variant="locked" icon="lock" />
                                        {% else %}
                                            <twig:Pill label="Veřejný" variant="accent" icon="globe" />
                                        {% endif %}
                                        {% if t.finishedAt %}
                                            <twig:Pill label="Ukončen" variant="done" />
                                        {% endif %}
                                    </div>
                                </div>

                                <h3 class="text-lg font-semibold leading-tight text-white transition-colors group-hover:text-accent-300">{{ t.name }}</h3>

                                {% if t.startAt or t.endAt %}
                                    <p class="mt-3 flex items-center gap-1.5 text-sm text-white/50">
                                        <twig:ux:icon name="lucide:calendar" class="h-4 w-4 text-white/40" />
                                        <span>
                                            {% if t.startAt %}{{ t.startAt|date('d. m. Y') }}{% endif %}
                                            {% if t.startAt and t.endAt %} – {% endif %}
                                            {% if t.endAt %}{{ t.endAt|date('d. m. Y') }}{% endif %}
                                        </span>
                                    </p>
                                {% endif %}
                            </div>

                            <div class="mt-5 flex items-center justify-end text-sm font-semibold text-accent-300">
                                Spravovat zdroj zápasů
                                <twig:ux:icon name="lucide:arrow-right" class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-0.5" />
                            </div>
                        </a>
                    </li>
                {% endfor %}
            </ul>
        </section>
    {% endif %}

    {# ───── Nadcházející zápasy ───── #}
    {% set upcoming_visible = 5 %}
    <section class="mb-14" data-controller="reveal" data-reveal-visible-value="{{ upcoming_visible }}">
        <div class="mb-5 flex flex-wrap items-end justify-between gap-3">
            <div>
                <h2 class="flex items-center gap-2 text-xl font-semibold text-white">
                    <twig:ux:icon name="lucide:calendar" class="h-5 w-5 text-accent-300" />
                    Nadcházející zápasy
                    {% if upcoming_matches|length > 0 %}
                        <span class="rounded-full border border-white/10 bg-white/5 px-2.5 py-0.5 text-xs font-semibold text-white/70">{{ upcoming_matches|length }}</span>
                    {% endif %}
                </h2>
                <p class="mt-1.5 text-sm text-white/50">Zápasy čekající na váš tip.</p>
            </div>
        </div>

        {% if upcoming_matches|length == 0 %}
            <div class="card-glass p-10 text-center">
                <span class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-2xl border border-accent-500/30 bg-accent-500/15 text-accent-300">
                    <twig:ux:icon name="lucide:calendar" class="h-7 w-7" />
                </span>
                <h3 class="text-lg font-semibold text-white">Žádné nadcházející zápasy</h3>
                <p class="mx-auto mt-2 max-w-md text-sm text-white/60">Jakmile budou naplánované nové zápasy, objeví se zde.</p>
            </div>
        {% else %}
            <ul class="flex flex-col gap-3">
                {% for m in upcoming_matches %}
                    {# stavová pilulka: chybí tip → „soon", vše natipováno → „tipped" #}
                    {% set is_tipped = m.competitionsCount > 0 and m.pendingCompetitionsCount == 0 %}
                    <li data-reveal-target="item" class="{% if loop.index0 >= upcoming_visible %}hidden{% endif %}">
                        <twig:Match:MatchRow
                            :homeTeam="m.homeTeam"
                            :awayTeam="m.awayTeam"
                            :kickoffAt="m.kickoffAt"
                            :round="m.round"
                            :isPlayoff="m.isPlayoff"
                            :state="is_tipped ? 'tipped' : 'open'"
                            :pillVariant="m.pendingCompetitionsCount > 0 ? 'soon' : (is_tipped ? 'tipped' : null)"
                            :pillIcon="m.pendingCompetitionsCount > 0 ? 'circle-alert' : (is_tipped ? 'check' : null)"
                            :pillLabel="m.pendingCompetitionsCount > 0
                                ? (m.competitionsCount > 1 ? 'Chybí tip v ' ~ m.pendingCompetitionsCount ~ ' z ' ~ m.competitionsCount ~ ' soutěží' : 'Chybí tip')
                                : (is_tipped ? (m.competitionsCount > 1 ? 'Tip odeslán (' ~ m.guessedCompetitionsCount ~ '/' ~ m.competitionsCount ~ ')' : 'Tip odeslán') : null)"
                            :detailUrl="path('portal_sport_match_detail', {id: m.id.toRfc4122})"
                            detailLabel="Tipovat"
                        />

                        {% if m.matchSourceName or m.venue %}
                            <p class="mt-1.5 px-4 text-xs text-white/40 sm:px-5">
                                {{ m.matchSourceName }}{% if m.venue %} · {{ m.venue }}{% endif %}
                            </p>
                        {% endif %}
                    </li>
                {% endfor %}
            </ul>

            {% if upcoming_matches|length > upcoming_visible %}
                <div class="mt-5 flex justify-center">
                    <button type="button"
                            data-reveal-target="toggle"
                            data-action="reveal#toggle"
                            data-reveal-more-label-value="Zobrazit další"
                            data-reveal-less-label-value="Zobrazit méně"
                            class="btn btn-ghost btn-sm">
                        Zobrazit další ({{ upcoming_matches|length - upcoming_visible }})
                    </button>
                </div>
            {% endif %}
        {% endif %}
    </section>

    {# ───── Moje vyhodnocené tipy ───── #}
    {% set evaluated_visible = 5 %}
    <section class="mb-14" data-controller="reveal" data-reveal-visible-value="{{ evaluated_visible }}">
        <div class="mb-5 flex flex-wrap items-end justify-between gap-3">
            <div>
                <h2 class="flex items-center gap-2 text-xl font-semibold text-white">
                    <twig:ux:icon name="lucide:trophy" class="h-5 w-5 text-accent-300" />
                    Moje vyhodnocené tipy
                    {% if evaluated_guesses|length > 0 %}
                        <span class="rounded-full border border-white/10 bg-white/5 px-2.5 py-0.5 text-xs font-semibold text-white/70">{{ evaluated_guesses|length }}</span>
                    {% endif %}
                </h2>
                <p class="mt-1.5 text-sm text-white/50">Poslední uzavřené zápasy a body, které jste získali.</p>
            </div>
        </div>

        {% if evaluated_guesses|length == 0 %}
            <div class="card-glass p-10 text-center">
                <span class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-2xl border border-accent-500/30 bg-accent-500/15 text-accent-300">
                    <twig:ux:icon name="lucide:trophy" class="h-7 w-7" />
                </span>
                <h3 class="text-lg font-semibold text-white">Zatím nemáte žádné vyhodnocené tipy</h3>
                <p class="mx-auto mt-2 max-w-md text-sm text-white/60">Jakmile se vaše tipy vyhodnotí, uvidíte zde získané body.</p>
            </div>
        {% else %}
            <div class="card-glass overflow-hidden p-0">
                <ul class="divide-y divide-white/[0.06]">
                    {% for g in evaluated_guesses %}
                        {% set is_exact = g.myHomeScore == g.actualHomeScore and g.myAwayScore == g.actualAwayScore %}
                        {# barva chipu výsledku: přesně → exact, jinak se ziskem → partial #}
                        {% set hit_class = is_exact ? 'exact' : (g.totalPoints > 0 ? 'partial' : null) %}
                        <li data-reveal-target="item" class="px-4 py-4 sm:px-5{% if loop.index0 >= evaluated_visible %} hidden{% endif %}">
                            <twig:Match:MatchRow
                                :homeTeam="g.homeTeam"
                                :awayTeam="g.awayTeam"
                                :kickoffAt="g.kickoffAt"
                                :round="g.competitionName"
                                state="finished"
                                :pillVariant="is_exact ? 'success' : null"
                                :pillIcon="is_exact ? 'check' : null"
                                :pillLabel="is_exact ? 'Přesně' : null"
                                :myHome="g.myHomeScore"
                                :myAway="g.myAwayScore"
                                :resultHome="g.actualHomeScore"
                                :resultAway="g.actualAwayScore"
                                :points="g.totalPoints"
                                :hitClass="hit_class"
                                :detailUrl="path('portal_sport_match_detail', {id: g.sportMatchId.toRfc4122})"
                            />
                            <p class="mt-1.5 px-4 text-xs text-white/40 sm:px-5">{{ g.matchSourceName }}</p>
                        </li>
                    {% endfor %}
                </ul>
            </div>

            {% if evaluated_guesses|length > evaluated_visible %}
                <div class="mt-5 flex justify-center">
                    <button type="button"
                            data-reveal-target="toggle"
                            data-action="reveal#toggle"
                            data-reveal-more-label-value="Zobrazit další"
                            data-reveal-less-label-value="Zobrazit méně"
                            class="btn btn-ghost btn-sm">
                        Zobrazit další ({{ evaluated_guesses|length - evaluated_visible }})
                    </button>
                </div>
            {% endif %}
        {% endif %}
    </section>

    {# ───── Objev další zdroje zápasů ───── #}
    <section>
        <div class="mb-5 flex flex-wrap items-end justify-between gap-3">
            <div>
                <h2 class="flex items-center gap-2 text-xl font-semibold text-white">
                    <twig:ux:icon name="lucide:globe" class="h-5 w-5 text-accent-300" />
                    Objev další zdroje zápasů
                </h2>
                <p class="mt-1.5 text-sm text-white/50">Veřejné zdroje zápasů, ve kterých se můžete přidat do soutěže.</p>
            </div>
        </div>

        {% if discoverable_match_sources|length == 0 %}
            <div class="card-glass p-10 text-center">
                <span class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-2xl border border-accent-500/30 bg-accent-500/15 text-accent-300">
                    <twig:ux:icon name="lucide:search" class="h-7 w-7" />
                </span>
                <h3 class="text-lg font-semibold text-white">Žádné další dostupné zdroje zápasů</h3>
                <p class="mx-auto mt-2 max-w-md text-sm text-white/60">Aktuálně tu nejsou žádné další veřejné zdroje zápasů k objevení.</p>
            </div>
        {% else %}
            <ul class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
                {% for t in discoverable_match_sources %}
                    <li>
                        <a
                            href="{{ path('public_match_source_detail', {id: t.matchSourceId.toRfc4122}) }}"
                            class="card-glass group flex h-full flex-col justify-between p-6 transition-transform duration-200 hover:-translate-y-1"
                        >
                            <div>
                                <span class="mb-4 flex h-11 w-11 items-center justify-center rounded-xl border border-accent-500/30 bg-accent-500/15 text-accent-300">
                                    <twig:ux:icon name="lucide:trophy" class="h-5 w-5" />
                                </span>

                                <h3 class="text-lg font-semibold leading-tight text-white transition-colors group-hover:text-accent-300">{{ t.name }}</h3>

                                <div class="mt-3 flex flex-wrap items-center gap-4 text-sm text-white/50">
                                    <span class="flex items-center gap-1.5">
                                        <twig:ux:icon name="lucide:layout-grid" class="h-4 w-4 text-white/40" />
                                        {{ t.competitionCount }} {% if t.competitionCount == 1 %}soutěž{% elseif t.competitionCount >= 2 and t.competitionCount <= 4 %}soutěže{% else %}soutěží{% endif %}
                                    </span>
                                    <span class="flex items-center gap-1.5">
                                        <twig:ux:icon name="lucide:users" class="h-4 w-4 text-white/40" />
                                        {{ t.memberCount }} {% if t.memberCount == 1 %}hráč{% elseif t.memberCount >= 2 and t.memberCount <= 4 %}hráči{% else %}hráčů{% endif %}
                                    </span>
                                </div>

                                {% if t.startAt or t.endAt %}
                                    <p class="mt-2 flex items-center gap-1.5 text-sm text-white/50">
                                        <twig:ux:icon name="lucide:calendar" class="h-4 w-4 text-white/40" />
                                        <span>
                                            {% if t.startAt %}{{ t.startAt|date('d. m. Y') }}{% endif %}
                                            {% if t.startAt and t.endAt %} – {% endif %}
                                            {% if t.endAt %}{{ t.endAt|date('d. m. Y') }}{% endif %}
                                        </span>
                                    </p>
                                {% endif %}
                            </div>

                            <div class="mt-5 flex items-center justify-end text-sm font-semibold text-accent-300">
                                Zobrazit zdroj zápasů
                                <twig:ux:icon name="lucide:arrow-right" class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-0.5" />
                            </div>
                        </a>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    </section>
</div>
</div>
{% endblock %}
