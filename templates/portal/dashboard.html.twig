{% extends 'base.html.twig' %}

{% block title %}Nástěnka — Tipovačka{% endblock %}

{% block body %}
<div class="mx-auto w-full max-w-6xl px-4 py-8 sm:px-6 sm:py-12 lg:px-8">

    {# Page header #}
    <header class="mb-8 flex flex-wrap items-end justify-between gap-4">
        <div>
            <p class="text-sm font-medium uppercase tracking-wider text-navy-900/50">Nástěnka</p>
            <h1 class="mt-1 text-3xl font-bold tracking-tight text-navy-900 sm:text-4xl">Vítej, {{ app.user.nickname }}</h1>
            <p class="mt-2 max-w-xl text-navy-900/70">Tvoje skupiny, nadcházející zápasy a turnaje na jednom místě.</p>
        </div>
        <a href="{{ path('portal_tournament_create') }}" class="inline-flex items-center gap-1.5 rounded-lg bg-navy-900 px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-navy-700">
            <twig:ux:icon name="lucide:plus" class="h-4 w-4" />
            Vytvořit turnaj
        </a>
    </header>

    {# Primary CTA: join a group by PIN. Collapse when user already has groups — the
       full intro just takes space for someone who knows the drill. #}
    <div class="mb-10">
        {{ include('_partials/join_by_pin_form.html.twig', { size: 'large', collapsible: my_groups|length > 0 }) }}
    </div>

    {# Section 1: Moje skupiny #}
    <section class="mb-12">
        <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
            <h2 class="flex items-center gap-2 text-xl font-semibold text-navy-900">
                <twig:ux:icon name="lucide:users" class="h-5 w-5 text-cyan-500" />
                Moje soutěže
                {% if my_groups|length > 0 %}
                    <span class="rounded-full bg-navy-50 px-2.5 py-0.5 text-xs font-semibold text-navy-700">{{ my_groups|length }}</span>
                {% endif %}
            </h2>
        </div>

        {% if my_groups|length == 0 %}
            <div class="rounded-2xl bg-white shadow-card ring-1 ring-navy-900/5">
                <twig:EmptyState
                    illustration="tournaments"
                    title="Ještě nehraješ v žádném turnaji"
                    body="Založ si vlastní turnaj se skupinou, nebo se přidej k veřejnému."
                    ctaLabel="Vytvořit turnaj"
                    ctaPath="{{ path('portal_tournament_create') }}"
                    secondaryLabel="Procházet turnaje"
                    secondaryPath="{{ path('public_tournaments_list') }}"
                />
            </div>
        {% else %}
            <ul class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-3">
                {% for g in my_groups %}
                    <li>
                        <a href="{{ path('portal_group_detail', {id: g.groupId.toRfc4122}) }}" class="group flex h-full flex-col rounded-2xl bg-white p-5 shadow-card ring-1 ring-navy-900/5 transition-shadow hover:shadow-card-hover hover:ring-cyan-500/30">
                            <div class="flex items-start justify-between gap-3">
                                <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-cyan-100 text-cyan-600">
                                    <twig:ux:icon name="lucide:users" class="h-5 w-5" />
                                </span>
                                <div class="flex flex-wrap justify-end gap-1.5">
                                    {% if g.isOwner %}
                                        <span class="inline-flex items-center gap-1 rounded-full bg-purple-100 px-2.5 py-0.5 text-xs font-semibold text-purple-800">
                                            <twig:ux:icon name="lucide:crown" class="h-3 w-3" />Vlastník
                                        </span>
                                    {% endif %}
                                    {% if g.tournamentIsFinished %}
                                        <span class="inline-flex items-center rounded-full bg-gray-200 px-2.5 py-0.5 text-xs font-semibold text-gray-800">Ukončen</span>
                                    {% endif %}
                                </div>
                            </div>
                            <h3 class="mt-3 text-lg font-semibold leading-tight text-navy-900 transition-colors group-hover:text-cyan-600 flex items-center gap-1.5">
                                <twig:ux:icon name="lucide:trophy" class="h-4 w-4" />{{ g.tournamentName }}
                            </h3>
                            <p class="mt-1 flex items-center gap-1.5 text-sm text-navy-900/60">
                                {{ g.groupName }}
                            </p>
                        </a>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    </section>

    {# Section 2: Nadcházející zápasy #}
    {% set upcoming_visible = 5 %}
    <section class="mb-12" data-controller="reveal" data-reveal-visible-value="{{ upcoming_visible }}">
        <h2 class="mb-4 flex items-center gap-2 text-xl font-semibold text-navy-900">
            <twig:ux:icon name="lucide:calendar" class="h-5 w-5 text-cyan-500" />
            Nadcházející zápasy
            {% if upcoming_matches|length > 0 %}
                <span class="rounded-full bg-navy-50 px-2.5 py-0.5 text-xs font-semibold text-navy-700">{{ upcoming_matches|length }}</span>
            {% endif %}
        </h2>

        {% if upcoming_matches|length == 0 %}
            <div class="rounded-2xl bg-white p-10 text-center shadow-card ring-1 ring-navy-900/5">
                <p class="text-sm text-navy-900/60">Žádné nadcházející zápasy.</p>
            </div>
        {% else %}
            <ul class="divide-y divide-navy-100/70 rounded-2xl bg-white shadow-card ring-1 ring-navy-900/5">
                {% for m in upcoming_matches %}
                    <li data-reveal-target="item" class="grid grid-cols-[auto_1fr_auto] items-center gap-4 px-5 py-4{% if loop.index0 >= upcoming_visible %} hidden{% endif %}">
                        <div class="flex flex-col text-xs text-navy-900/60 sm:w-24">
                            <span class="font-medium">{{ m.kickoffAt|date('d. m.') }}</span>
                            <span>{{ m.kickoffAt|date('H:i') }}</span>
                        </div>
                        <div class="min-w-0">
                            <p class="truncate font-medium text-navy-900">{{ m.homeTeam }} <span class="text-navy-900/40">vs</span> {{ m.awayTeam }}</p>
                            <p class="truncate text-xs text-navy-900/60">{{ m.tournamentName }}{% if m.venue %} · {{ m.venue }}{% endif %}</p>
                            {% if m.pendingGroupsCount > 0 %}
                                <p class="mt-1 inline-flex items-center gap-1 rounded-full bg-amber-50 px-2 py-0.5 text-xs font-medium text-amber-700 ring-1 ring-amber-200">
                                    <twig:ux:icon name="lucide:circle-alert" class="h-3 w-3" />
                                    Chybí tip{% if m.groupsCount > 1 %} v {{ m.pendingGroupsCount }} z {{ m.groupsCount }} skupin{% endif %}
                                </p>
                            {% elseif m.groupsCount > 0 %}
                                <p class="mt-1 inline-flex items-center gap-1 rounded-full bg-emerald-50 px-2 py-0.5 text-xs font-medium text-emerald-700 ring-1 ring-emerald-200">
                                    <twig:ux:icon name="lucide:check" class="h-3 w-3" />
                                    {% if m.groupsCount > 1 %}Tipy odeslány ({{ m.guessedGroupsCount }}/{{ m.groupsCount }}){% else %}Tip odeslán{% endif %}
                                </p>
                            {% endif %}
                        </div>
                        <a href="{{ path('portal_sport_match_detail', {id: m.id.toRfc4122}) }}" class="inline-flex items-center gap-1.5 rounded-lg bg-cyan-500 px-3.5 py-2 text-sm font-semibold text-white transition-colors hover:bg-cyan-600">
                            <twig:ux:icon name="lucide:target" class="h-4 w-4" />
                            Tipovat
                        </a>
                    </li>
                {% endfor %}
            </ul>

            {% if upcoming_matches|length > upcoming_visible %}
                <div class="mt-4 flex justify-center">
                    <button type="button"
                            data-reveal-target="toggle"
                            data-action="reveal#toggle"
                            data-reveal-more-label-value="Zobrazit další"
                            data-reveal-less-label-value="Zobrazit méně"
                            class="inline-flex items-center gap-1.5 rounded-lg bg-white px-4 py-2 text-sm font-semibold text-navy-900 shadow-card ring-1 ring-navy-900/5 transition-colors hover:bg-navy-50">
                        Zobrazit další ({{ upcoming_matches|length - upcoming_visible }})
                    </button>
                </div>
            {% endif %}
        {% endif %}
    </section>

    {# Section 3: Moje vyhodnocené tipy #}
    {% set evaluated_visible = 5 %}
    <section class="mb-12" data-controller="reveal" data-reveal-visible-value="{{ evaluated_visible }}">
        <h2 class="mb-4 flex items-center gap-2 text-xl font-semibold text-navy-900">
            <twig:ux:icon name="lucide:trophy" class="h-5 w-5 text-cyan-500" />
            Moje vyhodnocené tipy
            {% if evaluated_guesses|length > 0 %}
                <span class="rounded-full bg-navy-50 px-2.5 py-0.5 text-xs font-semibold text-navy-700">{{ evaluated_guesses|length }}</span>
            {% endif %}
        </h2>

        {% if evaluated_guesses|length == 0 %}
            <div class="rounded-2xl bg-white p-10 text-center shadow-card ring-1 ring-navy-900/5">
                <p class="text-sm text-navy-900/60">Zatím nemáš žádné vyhodnocené tipy.</p>
            </div>
        {% else %}
            <ul class="divide-y divide-navy-100/70 rounded-2xl bg-white shadow-card ring-1 ring-navy-900/5">
                {% for g in evaluated_guesses %}
                    {% set is_exact = g.myHomeScore == g.actualHomeScore and g.myAwayScore == g.actualAwayScore %}
                    <li data-reveal-target="item" class="grid grid-cols-[auto_1fr_auto] items-center gap-4 px-5 py-4{% if loop.index0 >= evaluated_visible %} hidden{% endif %}">
                        <div class="flex flex-col text-xs text-navy-900/60 sm:w-24">
                            <span class="font-medium">{{ g.kickoffAt|date('d. m.') }}</span>
                            <span>{{ g.kickoffAt|date('H:i') }}</span>
                        </div>
                        <div class="min-w-0">
                            <p class="truncate font-medium text-navy-900">
                                {{ g.homeTeam }}
                                <span class="tabular-nums text-navy-900/80">{{ g.actualHomeScore }}:{{ g.actualAwayScore }}</span>
                                {{ g.awayTeam }}
                            </p>
                            <p class="truncate text-xs text-navy-900/60">
                                {{ g.tournamentName }} · {{ g.groupName }}
                            </p>
                            <p class="mt-1 inline-flex items-center gap-1.5 text-xs text-navy-900/70">
                                <span class="inline-flex items-center gap-1 rounded-full bg-navy-50 px-2 py-0.5 font-medium tabular-nums">
                                    <twig:ux:icon name="lucide:target" class="h-3 w-3" />
                                    Tvůj tip {{ g.myHomeScore }}:{{ g.myAwayScore }}
                                </span>
                                {% if is_exact %}
                                    <span class="inline-flex items-center gap-1 rounded-full bg-emerald-50 px-2 py-0.5 font-medium text-emerald-700 ring-1 ring-emerald-200">
                                        <twig:ux:icon name="lucide:check" class="h-3 w-3" />
                                        Přesně
                                    </span>
                                {% endif %}
                            </p>
                        </div>
                        <a href="{{ path('portal_sport_match_detail', {id: g.sportMatchId.toRfc4122}) }}" class="inline-flex items-center gap-1.5 rounded-lg px-3.5 py-2 text-sm font-semibold transition-colors
                            {% if g.totalPoints > 0 %}bg-emerald-500 text-white hover:bg-emerald-600{% else %}bg-navy-50 text-navy-900 hover:bg-navy-100{% endif %}">
                            <span class="tabular-nums">{{ g.totalPoints }}</span>
                            {% if g.totalPoints == 1 %}bod{% elseif g.totalPoints >= 2 and g.totalPoints <= 4 %}body{% else %}bodů{% endif %}
                        </a>
                    </li>
                {% endfor %}
            </ul>

            {% if evaluated_guesses|length > evaluated_visible %}
                <div class="mt-4 flex justify-center">
                    <button type="button"
                            data-reveal-target="toggle"
                            data-action="reveal#toggle"
                            data-reveal-more-label-value="Zobrazit další"
                            data-reveal-less-label-value="Zobrazit méně"
                            class="inline-flex items-center gap-1.5 rounded-lg bg-white px-4 py-2 text-sm font-semibold text-navy-900 shadow-card ring-1 ring-navy-900/5 transition-colors hover:bg-navy-50">
                        Zobrazit další ({{ evaluated_guesses|length - evaluated_visible }})
                    </button>
                </div>
            {% endif %}
        {% endif %}
    </section>

    {# Section 3: Objevte další turnaje #}
    <section>
        <h2 class="mb-4 flex items-center gap-2 text-xl font-semibold text-navy-900">
            <twig:ux:icon name="lucide:trophy" class="h-5 w-5 text-cyan-500" />
            Objev další turnaje
        </h2>

        {% if discoverable_tournaments|length == 0 %}
            <div class="rounded-2xl bg-white p-10 text-center shadow-card ring-1 ring-navy-900/5">
                <p class="text-sm text-navy-900/60">Žádné další dostupné turnaje.</p>
            </div>
        {% else %}
            <ul class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-3">
                {% for t in discoverable_tournaments %}
                    <li>
                        <a href="{{ path('public_tournament_detail', {id: t.tournamentId.toRfc4122}) }}" class="group flex h-full flex-col rounded-2xl bg-white p-5 shadow-card ring-1 ring-navy-900/5 transition-shadow hover:shadow-card-hover hover:ring-cyan-500/30">
                            <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-cyan-100 text-cyan-600">
                                <twig:ux:icon name="lucide:trophy" class="h-5 w-5" />
                            </span>
                            <h3 class="mt-3 text-lg font-semibold leading-tight text-navy-900 transition-colors group-hover:text-cyan-600">{{ t.name }}</h3>
                            <p class="mt-1.5 flex items-center gap-3 text-sm text-navy-900/60">
                                <span class="flex items-center gap-1"><twig:ux:icon name="lucide:users" class="h-4 w-4" />{{ t.groupCount }}</span>
                                <span class="flex items-center gap-1"><twig:ux:icon name="lucide:user" class="h-4 w-4" />{{ t.memberCount }}</span>
                            </p>
                            {% if t.startAt or t.endAt %}
                                <p class="mt-1 flex items-center gap-1.5 text-xs text-navy-900/60">
                                    <twig:ux:icon name="lucide:calendar" class="h-3.5 w-3.5" />
                                    {% if t.startAt %}{{ t.startAt|date('d. m. Y') }}{% endif %}
                                    {% if t.startAt and t.endAt %} – {% endif %}
                                    {% if t.endAt %}{{ t.endAt|date('d. m. Y') }}{% endif %}
                                </p>
                            {% endif %}
                        </a>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    </section>
</div>
{% endblock %}
