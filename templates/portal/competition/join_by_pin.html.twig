{% extends 'base.html.twig' %}

{% block title %}Připojit se k soutěži — {{ brand_name }}{% endblock %}

{% block body %}
    <div class="bg-radial mx-auto w-full max-w-md px-4 py-12 sm:px-6 lg:px-8">
        <twig:Breadcrumbs :items="[
            {label: 'Nástěnka', path: path('portal_dashboard')},
            {label: 'Připojit se k soutěži'},
        ]" />

        <header class="mb-8">
            <span class="eyebrow inline-flex items-center gap-2">
                <twig:ux:icon name="lucide:key-round" class="h-3.5 w-3.5" />
                Připojit se k soutěži
            </span>
            <h1 class="mt-2 text-3xl font-extrabold tracking-tight text-white">Zadejte PIN soutěže</h1>
            <p class="mt-2 text-sm leading-relaxed text-white/60">Zadejte 8místný PIN, který vám dal organizátor — a rovnou se připojíte.</p>
        </header>

        <div class="card-glass p-8">
            {{ form_start(form, {attr: {class: 'space-y-5', novalidate: 'novalidate'}}) }}

                <div class="field">
                    {{ form_label(form.pin, null, {label_attr: {class: 'field-label mb-1.5 block'}}) }}
                    {{ form_widget(form.pin, {attr: {class: 'input text-center font-mono text-lg tracking-[0.3em]'}}) }}
                    {{ form_errors(form.pin) }}
                </div>

                <button type="submit" class="btn btn-primary w-full">
                    <twig:ux:icon name="lucide:arrow-right" class="h-4 w-4" />
                    Připojit se
                </button>

            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
