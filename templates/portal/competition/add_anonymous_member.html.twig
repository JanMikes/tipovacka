{% extends 'base.html.twig' %}

{% block title %}Přidat tipujícího bez e-mailu — {{ brand_name }}{% endblock %}

{% block body %}
<div class="mx-auto w-full max-w-2xl px-4 py-8 sm:px-6 sm:py-12 lg:px-8">
    <twig:Breadcrumbs :items="[
        {label: 'Nástěnka', path: path('portal_dashboard')},
        {label: competition.name, path: path('portal_competition_detail', {id: competition.id.toRfc4122})},
        {label: 'Přidat tipujícího bez e-mailu'},
    ]" />

    <header class="mb-8 mt-2">
        <span class="eyebrow">{{ competition.name }}</span>
        <h1 class="mt-2 text-3xl font-black tracking-tight text-white sm:text-4xl">Přidat tipujícího bez e-mailu</h1>
        <p class="mt-2 text-sm leading-relaxed text-white/70">
            Tipujícího můžete přidat ručně — bez e-mailu se nemůže přihlásit, ale jeho tipy za něj můžete zadávat vy.
            Později mu stačí přidat e-mail a dostane pozvánku k nastavení hesla.
        </p>
    </header>

    <div class="card-glass p-6 sm:p-8">
        {{ form_start(form, {attr: {class: 'space-y-6', novalidate: 'novalidate'}}) }}

            <div class="field">
                {{ form_label(form.firstName) }}
                {{ form_widget(form.firstName, {attr: {class: 'input'}}) }}
                {{ form_errors(form.firstName) }}
            </div>

            <div class="field">
                {{ form_label(form.lastName) }}
                {{ form_widget(form.lastName, {attr: {class: 'input'}}) }}
                {{ form_errors(form.lastName) }}
            </div>

            <div class="field">
                {{ form_label(form.nickname) }}
                {{ form_widget(form.nickname, {attr: {class: 'input'}}) }}
                {% if form.nickname.vars.help %}
                    <p class="text-xs leading-relaxed text-white/50">{{ form.nickname.vars.help }}</p>
                {% endif %}
                {{ form_errors(form.nickname) }}
            </div>

            <div class="flex flex-wrap gap-3 pt-2">
                <button type="submit" class="btn btn-primary">
                    <twig:ux:icon name="lucide:user-round-plus" class="h-4 w-4" />
                    Přidat tipujícího
                </button>
                <a href="{{ path('portal_competition_detail', {id: competition.id.toRfc4122}) }}" class="btn btn-ghost">
                    Zrušit
                </a>
            </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
