{% extends 'base.html.twig' %}

{% block title %}Upravit soutěž — {{ brand_name }}{% endblock %}

{% block body %}
<div class="mx-auto w-full max-w-2xl px-4 py-8 sm:px-6 sm:py-12 lg:px-8">
    <twig:Breadcrumbs :items="[
        {label: 'Nástěnka', path: path('portal_dashboard')},
        {label: competition.name, path: path('portal_competition_detail', {id: competition.id.toRfc4122})},
        {label: 'Upravit soutěž'},
    ]" />

    <header class="mb-8 mt-2">
        <span class="eyebrow">Nastavení soutěže</span>
        <h1 class="mt-2 text-3xl font-black tracking-tight text-white sm:text-4xl">Upravit soutěž</h1>
        <p class="mt-2 text-sm leading-relaxed text-white/70">{{ competition.name }}</p>
    </header>

    <div class="card-glass p-6 sm:p-8">
        {{ form_start(form, {attr: {class: 'space-y-6', novalidate: 'novalidate'}}) }}

            <div class="field">
                {{ form_label(form.name) }}
                {{ form_widget(form.name, {attr: {class: 'input'}}) }}
                {{ form_errors(form.name) }}
            </div>

            <div class="field">
                {{ form_label(form.description) }}
                {{ form_widget(form.description, {attr: {class: 'input'}}) }}
                {{ form_errors(form.description) }}
            </div>

            <div>
                <label class="flex items-start gap-3 {{ form.withPin.vars.disabled ? 'cursor-not-allowed opacity-60' : 'cursor-pointer' }}">
                    {{ form_widget(form.withPin, {attr: {class: 'mt-0.5 h-5 w-5 shrink-0 rounded border-white/20 bg-inset text-accent-500 focus:ring-accent-500'}}) }}
                    <span class="text-sm">
                        <span class="block font-medium text-white">{{ form.withPin.vars.label }}</span>
                        {% if form.withPin.vars.help %}
                            <span class="mt-1 block text-xs leading-relaxed text-white/50">{{ form.withPin.vars.help }}</span>
                        {% endif %}
                    </span>
                </label>
                {{ form_errors(form.withPin) }}
            </div>

            <div class="space-y-5 border-t border-white/10 pt-6">
                <span class="eyebrow">Tipy a uzávěrka</span>

                <div>
                    <label class="flex cursor-pointer items-start gap-3">
                        {{ form_widget(form.hideOthersTipsBeforeDeadline, {attr: {class: 'mt-0.5 h-5 w-5 shrink-0 rounded border-white/20 bg-inset text-accent-500 focus:ring-accent-500'}}) }}
                        <span class="text-sm">
                            <span class="block font-medium text-white">{{ form.hideOthersTipsBeforeDeadline.vars.label }}</span>
                            {% if form.hideOthersTipsBeforeDeadline.vars.help %}
                                <span class="mt-1 block text-xs leading-relaxed text-white/50">{{ form.hideOthersTipsBeforeDeadline.vars.help }}</span>
                            {% endif %}
                        </span>
                    </label>
                    {{ form_errors(form.hideOthersTipsBeforeDeadline) }}
                </div>

                <div class="rounded-xl border border-white/10 bg-inset px-4 py-3 text-xs leading-relaxed text-white/60">
                    {% if tips_locked %}
                        <p class="flex items-center gap-1.5 font-semibold text-white/80">
                            <twig:ux:icon name="lucide:lock" class="h-3.5 w-3.5" />
                            Tipy jsou uzamčeny.
                        </p>
                        <p class="mt-1">Soutěž už odstartovala{% if competition.tipsLockedAt %}, nebo byly tipy uzamčeny ručně{% endif %}. Zápasy přidané později se tipují až do svého výkopu.</p>
                    {% else %}
                        <p>
                            Tipy se uzamknou startem soutěže{% if lock_moment %} —
                            <span class="font-semibold text-white/80">{{ lock_moment|date('j. n. Y H:i') }}</span>{% endif %}.
                            Uzamknout je můžete i dřív tlačítkem „Uzamknout tipy“ v detailu soutěže.
                        </p>
                    {% endif %}
                </div>
            </div>

            <div class="flex flex-wrap gap-3 pt-2">
                <button type="submit" class="btn btn-primary">
                    <twig:ux:icon name="lucide:check" class="h-4 w-4" />
                    Uložit změny
                </button>

                <a href="{{ path('portal_competition_detail', {id: competition.id.toRfc4122}) }}" class="btn btn-ghost">
                    Zrušit
                </a>
            </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
