{% extends 'base.html.twig' %}

{% block title %}Prémiové nastavení — {{ brand_name }}{% endblock %}

{% block body %}
<div class="mx-auto w-full max-w-2xl px-4 py-8 sm:px-6 sm:py-12 lg:px-8">
    <twig:Breadcrumbs :items="[
        {label: 'Nástěnka', path: path('portal_dashboard')},
        {label: competition.name, path: path('portal_competition_detail', {id: competition.id.toRfc4122})},
        {label: 'Prémium'},
    ]" />

    <header class="mb-8 mt-2">
        <span class="eyebrow">Nastavení soutěže</span>
        <h1 class="mt-2 flex flex-wrap items-center gap-3 text-3xl font-black tracking-tight text-white sm:text-4xl">
            Prémium
            <twig:Pill label="Prémiová soutěž" variant="done" icon="crown" />
        </h1>
        <p class="mt-2 text-sm leading-relaxed text-white/70">
            Za členy platíte vy. Zapněte, co uvidí nebo mohou dělat všichni v soutěži „{{ competition.name }}“.
        </p>
    </header>

    <div class="card-glass p-6 sm:p-8">
        {{ form_start(form, {attr: {class: 'space-y-6', novalidate: 'novalidate'}}) }}

            <div class="space-y-5">
                {% for field in [form.showDistribution, form.showOthersTips, form.allowTipChanges] %}
                    <div>
                        <label class="flex cursor-pointer items-start gap-3">
                            {{ form_widget(field, {attr: {class: 'mt-0.5 h-5 w-5 shrink-0 rounded border-white/20 bg-inset text-accent-500 focus:ring-accent-500'}}) }}
                            <span class="text-sm">
                                <span class="block font-medium text-white">{{ field.vars.label }}</span>
                                {% if field.vars.help %}
                                    <span class="mt-1 block text-xs leading-relaxed text-white/50">{{ field.vars.help }}</span>
                                {% endif %}
                            </span>
                        </label>
                        {{ form_errors(field) }}
                    </div>
                {% endfor %}
            </div>

            <div class="field border-t border-white/10 pt-6">
                {{ form_label(form.tipChangeOffsetMinutes) }}
                {{ form_widget(form.tipChangeOffsetMinutes, {attr: {class: 'input max-w-[12rem]'}}) }}
                {% if form.tipChangeOffsetMinutes.vars.help %}
                    <p class="mt-1.5 text-xs leading-relaxed text-white/50">{{ form.tipChangeOffsetMinutes.vars.help }}</p>
                {% endif %}
                {{ form_errors(form.tipChangeOffsetMinutes) }}
            </div>

            <div class="flex flex-wrap gap-3 pt-2">
                <button type="submit" class="btn btn-primary">
                    <twig:ux:icon name="lucide:check" class="h-4 w-4" />
                    Uložit nastavení
                </button>

                <a href="{{ path('portal_competition_detail', {id: competition.id.toRfc4122}) }}" class="btn btn-ghost">
                    Zpět na soutěž
                </a>
            </div>

        {{ form_end(form) }}
    </div>

    {# Switch away from premium (refunds every charged player). #}
    <div class="card-glass mt-6 p-6 sm:p-8">
        <div class="flex items-center gap-2.5">
            <twig:ux:icon name="lucide:hand-coins" class="h-5 w-5 text-accent-400" />
            <h2 class="text-lg font-semibold text-white">Přepnout na příspěvky</h2>
        </div>
        <p class="mt-2 text-sm leading-relaxed text-white/60">
            Přejdete na model, kde si vylepšení kupuje každý hráč sám. Prémiové platby, které jste
            za členy zaplatil, se vám vrátí do peněženky.
        </p>
        <form method="post" action="{{ path('portal_competition_switch_to_boosts', {id: competition.id.toRfc4122}) }}"
            class="mt-4"
            data-controller="confirm"
            data-confirm-variant-value="warning"
            data-confirm-title-value="Přepnout na příspěvky"
            data-confirm-message-value="Prémium se vypne a zaplacené platby za členy se vám vrátí. Vylepšení si pak kupuje každý hráč sám."
            data-confirm-confirm-label-value="Ano, přepnout">
            <input type="hidden" name="_token" value="{{ csrf_token('competition_switch_to_boosts_' ~ competition.id.toRfc4122) }}">
            <button type="submit" class="btn btn-ghost btn-sm">
                <twig:ux:icon name="lucide:hand-coins" class="h-4 w-4" />
                Přepnout na příspěvky
            </button>
        </form>
    </div>
</div>
{% endblock %}
