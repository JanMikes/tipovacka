{% extends 'base.html.twig' %}

{% block title %}Nová soutěž — {{ brand_name }}{% endblock %}

{% block body %}
<div class="mx-auto w-full max-w-2xl px-4 py-8 sm:px-6 sm:py-12 lg:px-8">
    <twig:Breadcrumbs :items="[
        {label: 'Nástěnka', path: path('portal_dashboard')},
        {label: 'Nová soutěž'},
    ]" />

    <header class="mb-8 mt-2">
        <span class="eyebrow">Nová soutěž</span>
        <h1 class="mt-2 text-3xl font-black tracking-tight text-white sm:text-4xl">Nová soutěž</h1>
        <p class="mt-2 text-sm leading-relaxed text-white/70">Vyberte zdroj zápasů, nastavte pravidla tipování a pozvěte své kamarády.</p>
    </header>

    <div class="card-glass p-6 sm:p-8" data-controller="competition-matches">
        {{ form_start(form, {attr: {class: 'space-y-6', novalidate: 'novalidate'}}) }}

            <div class="field">
                {{ form_label(form.name) }}
                {{ form_widget(form.name, {attr: {class: 'input'}}) }}
                {{ form_errors(form.name) }}
            </div>

            <div class="field">
                {{ form_label(form.description) }}
                {{ form_widget(form.description, {attr: {class: 'input'}}) }}
                {{ form_errors(form.description) }}
            </div>

            <div class="space-y-5 border-t border-white/10 pt-6">
                <span class="eyebrow">Zápasy</span>

                <div class="field">
                    {{ form_label(form.matchSourceId) }}
                    {{ form_widget(form.matchSourceId, {attr: {
                        class: 'input',
                        'data-action': 'change->competition-matches#sourceChanged',
                    }}) }}
                    {% if form.matchSourceId.vars.help %}
                        <p class="text-xs leading-relaxed text-white/50">{{ form.matchSourceId.vars.help }}</p>
                    {% endif %}
                    {{ form_errors(form.matchSourceId) }}
                    <p class="text-xs leading-relaxed text-white/50">
                        Nenašli jste svůj turnaj? Vytvořte si vlastní zdroj zápasů.
                        <a href="{{ path('portal_match_source_create') }}" class="font-medium text-accent-300 transition-colors hover:text-accent-200">Nový zdroj zápasů →</a>
                    </p>
                </div>

                <div class="field">
                    {{ form_label(form.selectionMode) }}
                    <div class="space-y-2">
                        {% for radio in form.selectionMode %}
                            <label class="flex cursor-pointer items-center gap-3">
                                {{ form_widget(radio, {attr: {
                                    class: 'h-4 w-4 shrink-0 border-white/20 bg-inset text-accent-500 focus:ring-accent-500',
                                    'data-competition-matches-target': 'modeRadio',
                                    'data-action': 'change->competition-matches#modeChanged',
                                }}) }}
                                <span class="text-sm font-medium text-white">{{ radio.vars.label }}</span>
                            </label>
                        {% endfor %}
                    </div>
                    {{ form_errors(form.selectionMode) }}
                </div>

                <div data-competition-matches-target="playoffSection">
                    <label class="flex cursor-pointer items-start gap-3">
                        {{ form_widget(form.includePlayoff, {attr: {class: 'mt-0.5 h-5 w-5 shrink-0 rounded border-white/20 bg-inset text-accent-500 focus:ring-accent-500'}}) }}
                        <span class="text-sm">
                            <span class="block font-medium text-white">{{ form.includePlayoff.vars.label }}</span>
                            {% if form.includePlayoff.vars.help %}
                                <span class="mt-1 block text-xs leading-relaxed text-white/50">{{ form.includePlayoff.vars.help }}</span>
                            {% endif %}
                        </span>
                    </label>
                    {{ form_errors(form.includePlayoff) }}
                </div>

                <div data-competition-matches-target="subsetSection" class="space-y-3">
                    {{ form_errors(form.selectedMatchIds) }}

                    {% if form.selectedMatchIds|length == 0 %}
                        <p class="rounded-xl border border-white/10 bg-inset px-4 py-3 text-sm text-white/60">
                            Nejdříve vyberte zdroj zápasů — pak si tu zaškrtnete konkrétní zápasy.
                        </p>
                    {% else %}
                        {% set currentGroup = null %}
                        {% for child in form.selectedMatchIds %}
                            {% set group = child.vars.attr['data-group']|default('') %}
                            {% if group != currentGroup %}
                                {% if currentGroup is not null %}
                                    </div></div>
                                {% endif %}
                                {% set currentGroup = group %}
                                <div class="rounded-xl border border-white/10 bg-inset p-4" data-group-block>
                                    <div class="mb-2 flex items-center justify-between gap-3">
                                        <span class="text-xs font-semibold uppercase tracking-wider text-white/50">{{ group }}</span>
                                        <button type="button" class="btn btn-ghost btn-sm" data-action="competition-matches#toggleGroup">
                                            Vybrat vše
                                        </button>
                                    </div>
                                    <div class="space-y-1.5">
                            {% endif %}
                            <label class="flex cursor-pointer items-center gap-3">
                                {{ form_widget(child, {attr: {class: 'h-4 w-4 shrink-0 rounded border-white/20 bg-inset text-accent-500 focus:ring-accent-500'}}) }}
                                <span class="text-sm text-white/80">{{ child.vars.label }}</span>
                                {% if child.vars.attr['data-playoff']|default('0') == '1' %}
                                    <twig:Pill label="Playoff" variant="neutral" />
                                {% endif %}
                            </label>
                        {% endfor %}
                        </div></div>
                    {% endif %}
                </div>
            </div>

            <div class="space-y-5 border-t border-white/10 pt-6">
                <span class="eyebrow">Tipy a uzávěrka</span>

                <div>
                    <label class="flex cursor-pointer items-start gap-3">
                        {{ form_widget(form.hideOthersTipsBeforeDeadline, {attr: {class: 'mt-0.5 h-5 w-5 shrink-0 rounded border-white/20 bg-inset text-accent-500 focus:ring-accent-500'}}) }}
                        <span class="text-sm">
                            <span class="block font-medium text-white">{{ form.hideOthersTipsBeforeDeadline.vars.label }}</span>
                            {% if form.hideOthersTipsBeforeDeadline.vars.help %}
                                <span class="mt-1 block text-xs leading-relaxed text-white/50">{{ form.hideOthersTipsBeforeDeadline.vars.help }}</span>
                            {% endif %}
                        </span>
                    </label>
                    {{ form_errors(form.hideOthersTipsBeforeDeadline) }}
                </div>

                <p class="rounded-xl border border-white/10 bg-inset px-4 py-3 text-xs leading-relaxed text-white/60">
                    Tipy se uzamknou startem soutěže — výkopem jejího prvního zápasu (nebo dřív ručním
                    uzamknutím v detailu soutěže). Zápasy přidané později, třeba playoff, se tipují až do
                    svého výkopu.
                </p>
            </div>

            <div>
                <label class="flex cursor-pointer items-start gap-3">
                    {{ form_widget(form.withPin, {attr: {class: 'mt-0.5 h-5 w-5 shrink-0 rounded border-white/20 bg-inset text-accent-500 focus:ring-accent-500'}}) }}
                    <span class="text-sm">
                        <span class="block font-medium text-white">{{ form.withPin.vars.label }}</span>
                        <span class="mt-1 block text-xs leading-relaxed text-white/50">8místný kód, který můžete sdílet se svými kamarády.</span>
                    </span>
                </label>
                {{ form_errors(form.withPin) }}
            </div>

            <div class="flex flex-wrap gap-3 pt-2">
                <button type="submit" class="btn btn-primary">
                    <twig:ux:icon name="lucide:plus" class="h-4 w-4" />
                    Vytvořit soutěž
                </button>

                <a href="{{ path('portal_dashboard') }}" class="btn btn-ghost">
                    Zrušit
                </a>
            </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
