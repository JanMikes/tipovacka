{% extends 'base.html.twig' %}

{% block title %}Nová soutěž — {{ brand_name }}{% endblock %}

{% block body %}
<div class="mx-auto w-full max-w-2xl px-4 py-8 sm:px-6 sm:py-12 lg:px-8">
    <twig:Breadcrumbs :items="[
        {label: 'Nástěnka', path: path('portal_dashboard')},
        {label: match_source.name, path: path('portal_match_source_detail', {id: match_source.id.toRfc4122})},
        {label: 'Nová soutěž'},
    ]" />

    <header class="mb-8 mt-2">
        <span class="eyebrow">{{ match_source.name }}</span>
        <h1 class="mt-2 text-3xl font-black tracking-tight text-white sm:text-4xl">Nová soutěž</h1>
        <p class="mt-2 text-sm leading-relaxed text-white/70">Založte soutěž nad turnajem a pozvěte své kamarády.</p>
    </header>

    <div class="card-glass p-6 sm:p-8">
        {{ form_start(form, {attr: {class: 'space-y-6', novalidate: 'novalidate'}}) }}

            {% if pinGate ?? false %}
                <div class="surface-accent rounded-xl p-4">
                    <div class="flex items-start gap-3">
                        <twig:ux:icon name="lucide:lock" class="mt-0.5 h-5 w-5 shrink-0 text-accent-300" />
                        <div class="space-y-3">
                            <p class="text-sm leading-relaxed text-white/80">
                                Tento turnaj je soukromý. Pro založení soutěže je potřeba zadat PIN, který vám poskytne vlastník turnaje.
                            </p>
                            <div class="field">
                                {{ form_label(form.matchSourceCreationPin) }}
                                {{ form_widget(form.matchSourceCreationPin, {attr: {class: 'input font-mono uppercase tracking-[0.3em]'}}) }}
                                {{ form_errors(form.matchSourceCreationPin) }}
                            </div>
                        </div>
                    </div>
                </div>
            {% endif %}

            <div class="field">
                {{ form_label(form.name) }}
                {{ form_widget(form.name, {attr: {class: 'input'}}) }}
                {{ form_errors(form.name) }}
            </div>

            <div class="field">
                {{ form_label(form.description) }}
                {{ form_widget(form.description, {attr: {class: 'input'}}) }}
                {{ form_errors(form.description) }}
            </div>

            <div>
                <label class="flex cursor-pointer items-start gap-3">
                    {{ form_widget(form.withPin, {attr: {class: 'mt-0.5 h-5 w-5 shrink-0 rounded border-white/20 bg-inset text-accent-500 focus:ring-accent-500'}}) }}
                    <span class="text-sm">
                        <span class="block font-medium text-white">{{ form.withPin.vars.label }}</span>
                        <span class="mt-1 block text-xs leading-relaxed text-white/50">8místný kód, který můžete sdílet se svými kamarády.</span>
                    </span>
                </label>
                {{ form_errors(form.withPin) }}
            </div>

            <div class="space-y-5 border-t border-white/10 pt-6">
                <span class="eyebrow">Tipy a uzávěrka</span>

                <div>
                    <label class="flex cursor-pointer items-start gap-3">
                        {{ form_widget(form.hideOthersTipsBeforeDeadline, {attr: {class: 'mt-0.5 h-5 w-5 shrink-0 rounded border-white/20 bg-inset text-accent-500 focus:ring-accent-500'}}) }}
                        <span class="text-sm">
                            <span class="block font-medium text-white">{{ form.hideOthersTipsBeforeDeadline.vars.label }}</span>
                            {% if form.hideOthersTipsBeforeDeadline.vars.help %}
                                <span class="mt-1 block text-xs leading-relaxed text-white/50">{{ form.hideOthersTipsBeforeDeadline.vars.help }}</span>
                            {% endif %}
                        </span>
                    </label>
                    {{ form_errors(form.hideOthersTipsBeforeDeadline) }}
                </div>

                <div class="field">
                    {{ form_label(form.tipsDeadline) }}
                    {{ form_widget(form.tipsDeadline, {attr: {class: 'input'}}) }}
                    {% if form.tipsDeadline.vars.help %}
                        <p class="text-xs leading-relaxed text-white/50">{{ form.tipsDeadline.vars.help }}</p>
                    {% endif %}
                    {{ form_errors(form.tipsDeadline) }}
                </div>
            </div>

            <div class="flex flex-wrap gap-3 pt-2">
                <button type="submit" class="btn btn-primary">
                    <twig:ux:icon name="lucide:plus" class="h-4 w-4" />
                    Vytvořit soutěž
                </button>

                <a href="{{ path('portal_match_source_detail', {id: match_source.id.toRfc4122}) }}" class="btn btn-ghost">
                    Zrušit
                </a>
            </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
