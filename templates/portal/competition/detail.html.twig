{% extends 'base.html.twig' %}

{% block title %}{{ detail.name }} — {{ brand_name }}{% endblock %}

{% block body %}
<div class="bg-radial mx-auto w-full max-w-6xl px-4 py-8 sm:px-6 sm:py-12 lg:px-8">

    <twig:Breadcrumbs :items="[
        {label: 'Nástěnka', path: path('portal_dashboard')},
        {label: detail.matchSourceName, path: path('portal_match_source_detail', {id: detail.matchSourceId.toRfc4122})},
        {label: detail.name},
    ]" />

    {# Hero #}
    <header class="mb-6">
        <div class="flex flex-wrap items-center gap-3">
            <h1 class="text-3xl font-black tracking-tight text-white sm:text-4xl">{{ detail.name }}</h1>
            {% if detail.matchSourceIsFinished %}
                <twig:Pill label="Zdroj zápasů ukončen" variant="done" />
            {% endif %}
        </div>
        <p class="mt-2 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-white/50">
            <span class="inline-flex items-center gap-1.5">
                <twig:ux:icon name="lucide:trophy" class="h-4 w-4 text-accent-400" />
                <a href="{{ path('portal_match_source_detail', {id: detail.matchSourceId.toRfc4122}) }}" class="transition-colors hover:text-accent-300">{{ detail.matchSourceName }}</a>
            </span>
            <span class="inline-flex items-center gap-1.5">
                <twig:ux:icon name="lucide:user" class="h-4 w-4 text-white/40" />{{ detail.ownerNickname }}
            </span>
        </p>
    </header>

    {% if detail.description %}
        <section class="card-glass mb-6 p-6">
            <p class="whitespace-pre-line text-white/80">{{ detail.description }}</p>
        </section>
    {% endif %}

    <div class="grid gap-6 lg:grid-cols-12">

        {# ───── Main column ───── #}
        <div class="space-y-6 lg:col-span-8">

            {# Quick-tip CTA: batch-fill all my guesses for this competition at once.
               Only shown to members while the match_source is still running. #}
            {% if isMember and not detail.matchSourceIsFinished %}
                <a href="{{ path('portal_competition_my_tips_batch', {id: competition.id.toRfc4122}) }}"
                   class="surface-accent group flex items-center gap-4 p-5 text-white">
                    <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-white/15 ring-1 ring-white/20">
                        <twig:ux:icon name="lucide:zap" class="h-6 w-6" />
                    </span>
                    <div class="min-w-0 flex-1">
                        <p class="text-base font-semibold">Tipněte si všechny zápasy najednou</p>
                        <p class="mt-0.5 text-sm text-white/80">Vyplňte nebo upravte své tipy v jedné tabulce. Prázdná pole se přeskočí.</p>
                    </div>
                    <twig:ux:icon name="lucide:arrow-right" class="h-5 w-5 shrink-0 transition-transform group-hover:translate-x-1" />
                </a>
            {% endif %}

            {# Members #}
            <section class="card-glass overflow-hidden p-0">
                <details class="group">
                    <summary class="flex cursor-pointer list-none items-center justify-between gap-3 px-6 py-4 transition-colors hover:bg-white/[0.03] [&::-webkit-details-marker]:hidden">
                        <div class="flex items-center gap-2.5">
                            <twig:ux:icon name="lucide:users" class="h-5 w-5 text-accent-400" />
                            <h2 class="text-lg font-semibold text-white">Členové</h2>
                            <span class="rounded-full border border-white/10 bg-white/5 px-2.5 py-0.5 text-xs font-semibold tabular-nums text-white/70">{{ detail.members|length }}</span>
                        </div>
                        <twig:ux:icon name="lucide:chevron-down" class="h-5 w-5 text-white/40 transition-transform group-open:rotate-180" />
                    </summary>

                    <ul class="divide-y divide-white/[0.06] border-t border-white/10">
                    {% for member in detail.members %}
                        {% set score = score_by_user_id[member.userId.toRfc4122] ?? null %}
                        <li class="flex flex-wrap items-center justify-between gap-3 px-6 py-4">
                            <div class="min-w-0 flex-1">
                                <div class="flex flex-wrap items-center gap-2">
                                    <twig:Avatar name="{{ member.displayName }}" size="32" rank="{{ score ? score.rank : null }}" />
                                    <a href="{{ path('portal_competition_leaderboard_member', {competitionId: competition.id.toRfc4122, userId: member.userId.toRfc4122}) }}" class="min-w-0 font-medium text-white transition-colors hover:text-accent-300 hover:underline">
                                        <span class="block truncate">{{ member.displayName }}</span>
                                        {% if member.fullName %}<small class="block truncate text-xs font-normal text-white/50">{{ member.fullName }}</small>{% endif %}
                                    </a>
                                    {% if member.isOwner %}
                                        <twig:Badge label="Organizátor" variant="organizer" icon="crown" />
                                    {% endif %}
                                    {% if member.isAnonymous %}
                                        <twig:Pill label="Anonymní" variant="warn" icon="user" />
                                    {% endif %}
                                </div>
                                <p class="mt-1 pl-10 text-xs text-white/40">Přidán {{ member.joinedAt|date('j. n. Y') }}</p>
                            </div>

                            <div class="flex shrink-0 items-center gap-3">
                                {% if score %}
                                    <div class="text-right">
                                        <p class="text-xs font-medium uppercase tracking-wider text-white/40">
                                            {{ score.rank }}. místo
                                        </p>
                                        <p class="text-lg font-bold tabular-nums text-white">
                                            {{ score.totalPoints }}<span class="ml-0.5 text-xs font-medium text-white/50">b.</span>
                                        </p>
                                    </div>
                                {% endif %}
                                {% if is_granted('competition_manage_members', competition) and member.isAnonymous %}
                                    <a href="{{ path('portal_competition_promote_anonymous_member', {id: competition.id.toRfc4122, userId: member.userId.toRfc4122}) }}" class="text-sm font-medium text-accent-400 transition-colors hover:text-accent-300 hover:underline">
                                        Přidat e-mail
                                    </a>
                                {% endif %}
                                {% if is_granted('competition_manage_members', competition) and not member.isOwner %}
                                    <form method="post" action="{{ path('portal_competition_remove_member', {id: competition.id.toRfc4122, userId: member.userId.toRfc4122}) }}" class="inline"
                                        data-controller="confirm"
                                        data-confirm-title-value="Odebrat člena"
                                        data-confirm-message-value="Opravdu chcete člena {{ member.displayName }} odebrat ze soutěže? Ztratí všechny své tipy v této soutěži."
                                        data-confirm-confirm-label-value="Ano, odebrat">
                                        <input type="hidden" name="_token" value="{{ csrf_token('competition_remove_member_' ~ competition.id.toRfc4122 ~ '_' ~ member.userId.toRfc4122) }}">
                                        <button type="submit" class="text-sm font-medium text-loss transition-colors hover:text-loss/80 hover:underline">
                                            Odebrat
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        </li>
                    {% else %}
                        <li class="px-6 py-10 text-center text-sm text-white/50">Zatím žádní členové.</li>
                    {% endfor %}
                    </ul>
                </details>
            </section>

            {# My guesses #}
            {% if my_guesses|length > 0 %}
                <section class="card-glass overflow-hidden p-0">
                    <details class="group">
                        <summary class="flex cursor-pointer list-none items-center justify-between gap-3 px-6 py-4 transition-colors hover:bg-white/[0.03] [&::-webkit-details-marker]:hidden">
                            <div class="flex items-center gap-2.5">
                                <twig:ux:icon name="lucide:target" class="h-5 w-5 text-accent-400" />
                                <h2 class="text-lg font-semibold text-white">Moje tipy</h2>
                                <span class="rounded-full border border-white/10 bg-white/5 px-2.5 py-0.5 text-xs font-semibold tabular-nums text-white/70">{{ my_guesses|length }}</span>
                            </div>
                            <twig:ux:icon name="lucide:chevron-down" class="h-5 w-5 text-white/40 transition-transform group-open:rotate-180" />
                        </summary>
                    <ul class="divide-y divide-white/[0.06] border-t border-white/10">
                        {% for row in my_guesses %}
                            {%- set state = row.state.value -%}
                            <li>
                                <a href="{{ path('portal_sport_match_detail', {id: row.sportMatchId.toRfc4122}) }}" class="grid grid-cols-[auto_1fr_auto_auto] items-center gap-3 px-6 py-4 transition-colors hover:bg-white/[0.03] sm:gap-5">
                                    <div class="flex w-16 flex-col text-xs text-white/50">
                                        <span class="font-medium">{{ row.kickoffAt|date('j. n.') }}</span>
                                        <span>{{ row.kickoffAt|date('H:i') }}</span>
                                    </div>

                                    <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-2 text-sm">
                                        <span class="truncate text-right font-medium text-white">{{ row.homeTeam }}</span>
                                        {% if state == 'finished' and row.actualHomeScore is not null %}
                                            <span class="rounded-md border border-white/10 bg-white/5 px-2 py-0.5 text-sm font-bold tabular-nums text-white">
                                                {{ row.actualHomeScore }} : {{ row.actualAwayScore }}
                                            </span>
                                        {% else %}
                                            <span class="text-xs font-semibold uppercase tracking-wider text-white/40">vs</span>
                                        {% endif %}
                                        <span class="truncate font-medium text-white">{{ row.awayTeam }}</span>
                                    </div>

                                    <div class="text-right">
                                        <p class="text-[10px] font-semibold uppercase tracking-wider text-white/40">Můj tip</p>
                                        <p class="rounded-md border border-accent-500/40 bg-accent-500/15 px-2 py-0.5 text-sm font-bold tabular-nums text-accent-300">
                                            {{ row.myHomeScore }} : {{ row.myAwayScore }}
                                        </p>
                                    </div>

                                    {% if state == 'scheduled' %}
                                        <twig:Pill label="Naplánován" variant="soon" />
                                    {% elseif state == 'live' %}
                                        <twig:Pill label="Uzamčeno" variant="locked" />
                                    {% elseif state == 'finished' %}
                                        <twig:Pill label="Odehrán" variant="done" />
                                    {% elseif state == 'postponed' %}
                                        <twig:Pill label="Odložen" variant="warn" />
                                    {% else %}
                                        <twig:Pill label="Zrušen" variant="locked" />
                                    {% endif %}
                                </a>
                            </li>
                        {% endfor %}
                    </ul>
                    </details>
                </section>
            {% endif %}

            {# Pending join requests (public match_sources only) #}
            {% if is_granted('competition_manage_members', competition) and competition.matchSource.isCurated %}
                <section class="card-glass overflow-hidden p-0">
                    <header class="flex items-center gap-2.5 border-b border-white/10 px-6 py-4">
                        <twig:ux:icon name="lucide:log-in" class="h-5 w-5 text-accent-400" />
                        <h2 class="text-lg font-semibold text-white">Žádosti o připojení</h2>
                        {% if pendingJoinRequests|length > 0 %}
                            <span class="rounded-full border border-accent-500/40 bg-accent-500/15 px-2.5 py-0.5 text-xs font-semibold tabular-nums text-accent-300">{{ pendingJoinRequests|length }}</span>
                        {% endif %}
                    </header>

                    {% if pendingJoinRequests|length > 0 %}
                        <ul class="divide-y divide-white/[0.06]">
                            {% for req in pendingJoinRequests %}
                                <li class="flex flex-wrap items-center justify-between gap-3 px-6 py-4">
                                    <div>
                                        <span class="font-medium text-white">{{ req.nickname }}</span>
                                        <p class="text-xs text-white/40">Žádost {{ req.requestedAt|date('j. n. Y H:i') }}</p>
                                    </div>
                                    <div class="flex gap-2">
                                        <form method="post" action="{{ path('portal_join_request_approve', {requestId: req.requestId.toRfc4122}) }}" class="inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('join_request_approve_' ~ req.requestId.toRfc4122) }}">
                                            <button type="submit" class="btn btn-success btn-sm">
                                                <twig:ux:icon name="lucide:check" class="h-3.5 w-3.5" />Schválit
                                            </button>
                                        </form>
                                        <form method="post" action="{{ path('portal_join_request_reject', {requestId: req.requestId.toRfc4122}) }}" class="inline"
                                            data-controller="confirm"
                                            data-confirm-title-value="Zamítnout žádost"
                                            data-confirm-message-value="Opravdu chcete zamítnout žádost od {{ req.nickname }}?"
                                            data-confirm-confirm-label-value="Ano, zamítnout">
                                            <input type="hidden" name="_token" value="{{ csrf_token('join_request_reject_' ~ req.requestId.toRfc4122) }}">
                                            <button type="submit" class="btn btn-danger btn-sm">
                                                <twig:ux:icon name="lucide:x" class="h-3.5 w-3.5" />Zamítnout
                                            </button>
                                        </form>
                                    </div>
                                </li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        <p class="px-6 py-10 text-center text-sm text-white/50">Žádné čekající žádosti.</p>
                    {% endif %}
                </section>
            {% endif %}

            {# Email invitations — admin / owner only #}
            {% if is_granted('competition_manage_members', competition) %}
                <section class="card-glass overflow-hidden p-0">
                    <header class="flex items-center gap-2.5 border-b border-white/10 px-6 py-4">
                        <twig:ux:icon name="lucide:mail" class="h-5 w-5 text-accent-400" />
                        <h2 class="text-lg font-semibold text-white">Pozvánky e-mailem</h2>
                    </header>

                    <div class="px-6 py-5">
                        {{ form_start(invitationForm) }}
                            <div class="flex flex-wrap items-end gap-3">
                                <div class="field min-w-[220px] flex-1">
                                    {{ form_label(invitationForm.email, null, {label_attr: {class: 'field-label mb-1.5 block'}}) }}
                                    {{ form_widget(invitationForm.email, {attr: {class: 'input'}}) }}
                                    {{ form_errors(invitationForm.email) }}
                                </div>
                                <button type="submit" class="btn btn-primary">
                                    <twig:ux:icon name="lucide:mail" class="h-4 w-4" />
                                    Odeslat pozvánku
                                </button>
                            </div>
                        {{ form_end(invitationForm) }}

                        {% if bulkInvitationForm %}
                            <details class="mt-5 border-t border-white/10 pt-5">
                                <summary class="cursor-pointer text-sm font-semibold text-white transition-colors hover:text-accent-300">
                                    Pozvat více lidí najednou
                                </summary>
                                <div class="mt-3">
                                    <p class="mb-3 text-xs text-white/50">
                                        Pro neznámé e-maily založíme prázdný účet a odešleme odkaz na dokončení registrace — pozvaný si jen zvolí heslo a rovnou se připojí.
                                    </p>
                                    {{ form_start(bulkInvitationForm) }}
                                        <div class="space-y-3">
                                            <div class="field">
                                                {{ form_label(bulkInvitationForm.emails, null, {label_attr: {class: 'field-label mb-1.5 block'}}) }}
                                                {{ form_widget(bulkInvitationForm.emails, {attr: {class: 'input'}}) }}
                                                {{ form_errors(bulkInvitationForm.emails) }}
                                            </div>
                                            <button type="submit" class="btn btn-primary">
                                                <twig:ux:icon name="lucide:users" class="h-4 w-4" />
                                                Odeslat hromadně
                                            </button>
                                        </div>
                                    {{ form_end(bulkInvitationForm) }}
                                </div>
                            </details>
                        {% endif %}

                        <div class="mt-5 border-t border-white/10 pt-5">
                            <p class="mb-3 text-xs text-white/50">
                                Někdo nechce e-mail? Přidejte ho ručně a zadávejte jeho tipy za něj. Později mu stačí přidat e-mail a pozveme ho k nastavení hesla.
                            </p>
                            <a href="{{ path('portal_competition_add_anonymous_member', {id: competition.id.toRfc4122}) }}" class="btn btn-ghost btn-sm">
                                <twig:ux:icon name="lucide:user" class="h-4 w-4" />
                                Přidat tipujícího bez e-mailu
                            </a>
                        </div>


                        {% if pendingInvitations|length > 0 %}
                            <div class="mt-6 border-t border-white/10 pt-5">
                                <p class="mb-3 text-xs font-semibold uppercase tracking-wider text-white/40">Čekající pozvánky</p>
                                <ul class="divide-y divide-white/[0.06]">
                                    {% for inv in pendingInvitations %}
                                        <li class="flex flex-wrap items-center justify-between gap-3 py-3">
                                            <div>
                                                <span class="font-medium text-white">{{ inv.email }}</span>
                                                <p class="text-xs text-white/40">Pozval {{ inv.inviterNickname }} · odesláno {{ inv.sentAt|date('j. n. Y H:i') }} · vyprší {{ inv.expiresAt|date('j. n. Y') }}</p>
                                            </div>
                                            <form method="post" action="{{ path('portal_invitation_revoke', {invitationId: inv.invitationId.toRfc4122}) }}" class="inline"
                                                data-controller="confirm"
                                                data-confirm-title-value="Zrušit pozvánku"
                                                data-confirm-message-value="Opravdu chcete zrušit pozvánku pro {{ inv.email }}? Odkaz z e-mailu přestane fungovat."
                                                data-confirm-confirm-label-value="Ano, zrušit">
                                                <input type="hidden" name="_token" value="{{ csrf_token('invitation_revoke_' ~ inv.invitationId.toRfc4122) }}">
                                                <button type="submit" class="text-sm font-medium text-loss transition-colors hover:text-loss/80 hover:underline">
                                                    Zrušit
                                                </button>
                                            </form>
                                        </li>
                                    {% endfor %}
                                </ul>
                            </div>
                        {% endif %}
                    </div>
                </section>
            {% endif %}
        </div>

        {# ───── Sidebar ───── #}
        <aside class="space-y-6 lg:col-span-4">

            {# Leaderboard CTA #}
            {% if is_granted('leaderboard_view', competition) %}
                <section class="surface-accent p-6 text-white">
                    <div class="flex items-center gap-2.5">
                        <twig:ux:icon name="lucide:trophy" class="h-5 w-5 text-white" />
                        <h2 class="text-sm font-semibold uppercase tracking-wider">Žebříček</h2>
                    </div>
                    <p class="mt-2 text-sm text-white/80">Podívejte se, kdo vede a kolik má bodů.</p>
                    <a href="{{ path('portal_competition_leaderboard', {competitionId: competition.id.toRfc4122}) }}" class="mt-4 inline-flex w-full items-center justify-center gap-1.5 rounded-xl bg-white/15 px-4 py-2.5 text-sm font-semibold text-white ring-1 ring-white/25 transition-colors hover:bg-white/25">
                        Zobrazit žebříček
                        <twig:ux:icon name="lucide:arrow-right" class="h-4 w-4" />
                    </a>
                </section>
            {% endif %}

            {{ include('_partials/competition_rules.html.twig', { items: rule_items }) }}

            {# Invites (PIN + shareable link) #}
            {% if is_granted('competition_manage_members', competition) %}
                <section class="card-glass overflow-hidden p-0">
                    <header class="flex items-center gap-2.5 border-b border-white/10 px-6 py-4">
                        <twig:ux:icon name="lucide:key-round" class="h-5 w-5 text-accent-400" />
                        <h2 class="text-lg font-semibold text-white">Rychlé pozvánky</h2>
                    </header>
                    <div class="space-y-5 px-6 py-5">
                        <div>
                            <p class="mb-2 text-xs font-semibold uppercase tracking-wider text-white/40">PIN</p>
                            {% if detail.pin %}
                                <div class="space-y-2">
                                    <div class="copy-field" data-controller="copy">
                                        <input type="text" readonly value="{{ detail.pin }}"
                                            data-copy-target="source"
                                            onclick="this.select()"
                                            class="text-center font-mono text-lg tracking-[0.3em]"
                                            aria-label="PIN soutěže">
                                        <button type="button"
                                            data-copy-target="button"
                                            data-action="copy#copy"
                                            aria-label="Kopírovat PIN">
                                            <span data-copy-target="labelCopy" class="inline-flex" title="Kopírovat">
                                                <twig:ux:icon name="lucide:copy" class="h-4 w-4" />
                                            </span>
                                            <span data-copy-target="labelCopied" class="hidden items-center gap-1 text-xs font-semibold" title="Zkopírováno">
                                                <twig:ux:icon name="lucide:check" class="h-4 w-4" />
                                                Zkopírováno
                                            </span>
                                        </button>
                                    </div>
                                    <div class="flex flex-wrap gap-3 text-xs">
                                        <form method="post" action="{{ path('portal_competition_pin_regenerate', {id: competition.id.toRfc4122}) }}" class="inline"
                                            data-controller="confirm"
                                            data-confirm-variant-value="warning"
                                            data-confirm-title-value="Obnovit PIN"
                                            data-confirm-message-value="Vygenerujeme nový PIN a stávající přestane platit. Pokud jste starý PIN někomu poslal, přestane se s ním dát připojit."
                                            data-confirm-confirm-label-value="Ano, obnovit">
                                            <input type="hidden" name="_token" value="{{ csrf_token('competition_pin_regenerate_' ~ competition.id.toRfc4122) }}">
                                            <button type="submit" class="btn-link">Obnovit</button>
                                        </form>
                                        <form method="post" action="{{ path('portal_competition_pin_revoke', {id: competition.id.toRfc4122}) }}" class="inline"
                                            data-controller="confirm"
                                            data-confirm-title-value="Zrušit PIN"
                                            data-confirm-message-value="PIN bude zneplatněn a nikdo se podle něj nebude moct připojit. Nový PIN můžete kdykoli vygenerovat znovu."
                                            data-confirm-confirm-label-value="Ano, zrušit">
                                            <input type="hidden" name="_token" value="{{ csrf_token('competition_pin_revoke_' ~ competition.id.toRfc4122) }}">
                                            <button type="submit" class="btn-link text-loss hover:text-loss/80">Zrušit</button>
                                        </form>
                                    </div>
                                </div>
                            {% else %}
                                <p class="text-sm text-white/50">PIN není aktivní.</p>
                                <form method="post" action="{{ path('portal_competition_pin_regenerate', {id: competition.id.toRfc4122}) }}" class="mt-2 inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('competition_pin_regenerate_' ~ competition.id.toRfc4122) }}">
                                    <button type="submit" class="btn-link">Vygenerovat PIN</button>
                                </form>
                            {% endif %}
                        </div>

                        <div class="border-t border-white/10 pt-4">
                            <p class="mb-2 flex items-center gap-1.5 text-xs font-semibold uppercase tracking-wider text-white/40">
                                <twig:ux:icon name="lucide:share-2" class="h-3.5 w-3.5" />
                                Odkaz
                            </p>
                            {% if detail.shareableLinkToken %}
                                <div class="space-y-2">
                                    <div class="copy-field" data-controller="copy">
                                        <input type="text" readonly value="{{ url('competition_join_by_link', {token: detail.shareableLinkToken}) }}"
                                            data-copy-target="source"
                                            onclick="this.select()"
                                            class="text-xs"
                                            aria-label="Odkaz pro připojení">
                                        <button type="button"
                                            data-copy-target="button"
                                            data-action="copy#copy"
                                            aria-label="Kopírovat odkaz">
                                            <span data-copy-target="labelCopy" class="inline-flex" title="Kopírovat">
                                                <twig:ux:icon name="lucide:copy" class="h-4 w-4" />
                                            </span>
                                            <span data-copy-target="labelCopied" class="hidden items-center gap-1 text-xs font-semibold" title="Zkopírováno">
                                                <twig:ux:icon name="lucide:check" class="h-4 w-4" />
                                                Zkopírováno
                                            </span>
                                        </button>
                                    </div>
                                    <div class="flex flex-wrap gap-3 text-xs">
                                        <form method="post" action="{{ path('portal_competition_link_regenerate', {id: competition.id.toRfc4122}) }}" class="inline"
                                            data-controller="confirm"
                                            data-confirm-variant-value="warning"
                                            data-confirm-title-value="Obnovit odkaz"
                                            data-confirm-message-value="Vygenerujeme nový odkaz a ten stávající přestane fungovat. Pokud jste ho někomu poslal, nebude se přes něj dát připojit."
                                            data-confirm-confirm-label-value="Ano, obnovit">
                                            <input type="hidden" name="_token" value="{{ csrf_token('competition_link_regenerate_' ~ competition.id.toRfc4122) }}">
                                            <button type="submit" class="btn-link">Obnovit</button>
                                        </form>
                                        <form method="post" action="{{ path('portal_competition_link_revoke', {id: competition.id.toRfc4122}) }}" class="inline"
                                            data-controller="confirm"
                                            data-confirm-title-value="Zrušit odkaz"
                                            data-confirm-message-value="Odkaz bude zneplatněn a nikdo se podle něj nebude moct připojit. Nový odkaz můžete kdykoli vygenerovat znovu."
                                            data-confirm-confirm-label-value="Ano, zrušit">
                                            <input type="hidden" name="_token" value="{{ csrf_token('competition_link_revoke_' ~ competition.id.toRfc4122) }}">
                                            <button type="submit" class="btn-link text-loss hover:text-loss/80">Zrušit</button>
                                        </form>
                                    </div>
                                </div>
                            {% else %}
                                <p class="text-sm text-white/50">Odkaz není aktivní.</p>
                                <form method="post" action="{{ path('portal_competition_link_regenerate', {id: competition.id.toRfc4122}) }}" class="mt-2 inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('competition_link_regenerate_' ~ competition.id.toRfc4122) }}">
                                    <button type="submit" class="btn-link">Vygenerovat odkaz</button>
                                </form>
                            {% endif %}
                        </div>
                    </div>
                </section>
            {% endif %}

            {# Actions #}
            <section class="card-glass overflow-hidden p-0">
                <header class="flex items-center gap-2.5 border-b border-white/10 px-6 py-4">
                    <twig:ux:icon name="lucide:settings" class="h-5 w-5 text-accent-400" />
                    <h2 class="text-lg font-semibold text-white">Správa</h2>
                </header>
                <div class="space-y-2 px-6 py-5">
                    {% if is_granted('competition_edit', competition) %}
                        <a href="{{ path('portal_competition_edit', {id: competition.id.toRfc4122}) }}" class="btn btn-ghost btn-sm w-full justify-start">
                            <twig:ux:icon name="lucide:pencil" class="h-4 w-4" />Upravit soutěž
                        </a>
                        <a href="{{ path('portal_competition_rules', {id: competition.id.toRfc4122}) }}" class="btn btn-ghost btn-sm w-full justify-start">
                            <twig:ux:icon name="lucide:activity" class="h-4 w-4" />Pravidla bodování
                        </a>
                        {% if competition.selectionMode.value == 'subset' %}
                            <a href="{{ path('portal_competition_match_selection', {id: competition.id.toRfc4122}) }}" class="btn btn-ghost btn-sm w-full justify-start">
                                <twig:ux:icon name="lucide:list-checks" class="h-4 w-4" />Výběr zápasů
                            </a>
                        {% endif %}
                    {% endif %}

                    {% if isMember and not detail.matchSourceIsFinished %}
                        <a href="{{ path('portal_competition_my_tips_batch', {id: competition.id.toRfc4122}) }}" class="btn btn-ghost btn-sm w-full justify-start">
                            <twig:ux:icon name="lucide:zap" class="h-4 w-4" />Tipnout vše najednou
                        </a>
                    {% endif %}

                    {% if is_granted('competition_manage_members', competition) %}
                        <a href="{{ path('portal_competition_manage_member_tips', {id: competition.id.toRfc4122}) }}" class="btn btn-ghost btn-sm w-full justify-start">
                            <twig:ux:icon name="lucide:target" class="h-4 w-4" />Tipovat za členy
                        </a>
                    {% endif %}

                    {% if is_granted('competition_leave', competition) %}
                        <form method="post" action="{{ path('portal_competition_leave', {id: competition.id.toRfc4122}) }}"
                            data-controller="confirm"
                            data-confirm-variant-value="warning"
                            data-confirm-title-value="Opustit soutěž"
                            data-confirm-message-value="Opravdu chcete soutěž opustit? Přijdete o všechny tipy, které jste v ní zadal."
                            data-confirm-confirm-label-value="Ano, opustit">
                            <input type="hidden" name="_token" value="{{ csrf_token('competition_leave_' ~ competition.id.toRfc4122) }}">
                            <button type="submit" class="flex w-full items-center gap-2 rounded-xl border border-draw/30 bg-draw/10 px-4 py-2.5 text-sm font-semibold text-draw transition-colors hover:bg-draw/20">
                                <twig:ux:icon name="lucide:log-out" class="h-4 w-4" />Opustit soutěž
                            </button>
                        </form>
                    {% endif %}

                    {% if is_granted('competition_delete', competition) %}
                        <form method="post" action="{{ path('portal_competition_delete', {id: competition.id.toRfc4122}) }}"
                            data-controller="confirm"
                            data-confirm-title-value="Smazat soutěž"
                            data-confirm-message-value="Opravdu chcete soutěž „{{ detail.name }}“ smazat? Všichni členové přijdou o své tipy a soutěž zmizí ze žebříčku."
                            data-confirm-confirm-label-value="Ano, smazat">
                            <input type="hidden" name="_token" value="{{ csrf_token('competition_delete_' ~ competition.id.toRfc4122) }}">
                            <button type="submit" class="btn btn-danger btn-sm w-full justify-start">
                                <twig:ux:icon name="lucide:trash-2" class="h-4 w-4" />Smazat soutěž
                            </button>
                        </form>
                    {% endif %}
                </div>
            </section>
        </aside>
    </div>
</div>
{% endblock %}
