{% extends 'base.html.twig' %}

{% block title %}Pravidla — {{ competition.name }}{% endblock %}

{% block body %}
<div class="mx-auto w-full max-w-3xl px-4 py-8 sm:px-6 sm:py-12 lg:px-8">
    <twig:Breadcrumbs :items="[
        {label: 'Nástěnka', path: path('portal_dashboard')},
        {label: competition.name, path: path('portal_competition_detail', {id: competition.id.toRfc4122})},
        {label: 'Pravidla bodování'},
    ]" />

    <header class="mb-8 mt-2">
        <span class="eyebrow">Správa soutěže</span>
        <h1 class="mt-2 text-3xl font-black tracking-tight text-white sm:text-4xl">Pravidla bodování</h1>
        <p class="mt-2 text-sm leading-relaxed text-white/70">{{ competition.name }}</p>
    </header>

    {{ form_start(form, {'attr': {
        'data-controller': 'confirm-recalculation',
        'data-confirm-recalculation-count-value': evaluationCount,
        'data-action': 'submit->confirm-recalculation#confirmIfNeeded',
    }}) }}

    <p class="mb-4 text-sm leading-relaxed text-white/60">
        Bodování ovlivní pořadí v žebříčku. Hodnoty lze kdykoli upravit.
    </p>

    <div class="card-glass mb-6 p-5 sm:p-6">
        <twig:Scoring:RuleFields :form="form" />
    </div>

    <div class="flex flex-wrap gap-3">
        <button type="submit" class="btn btn-primary">
            <twig:ux:icon name="lucide:save" class="h-4 w-4" />
            Uložit pravidla
        </button>
        <a href="{{ path('portal_competition_detail', {id: competition.id.toRfc4122}) }}" class="btn btn-ghost">
            Zpět na soutěž
        </a>
    </div>

    {{ form_end(form) }}
</div>
{% endblock %}
