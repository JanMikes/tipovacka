{% extends 'base.html.twig' %}

{% block title %}Správa tipů členů — {{ competition.name }} — {{ brand_name }}{% endblock %}

{% block body %}
<div class="mx-auto max-w-3xl px-4 py-12 pb-32 sm:px-6 lg:px-8">
    <twig:Breadcrumbs :items="[
        {label: 'Nástěnka', path: path('portal_dashboard')},
        {label: competition.name, path: path('portal_competition_detail', {id: competition.id.toRfc4122})},
        {label: 'Správa tipů členů'},
    ]" />

    <header class="mb-8">
        <span class="eyebrow">{{ competition.name }}</span>
        <h1 class="mt-2 text-3xl font-black leading-tight tracking-tight text-white sm:text-4xl">Správa tipů členů</h1>
        <p class="mt-3 text-sm leading-relaxed text-white/70">
            Vyberte člena a zadejte nebo upravte jeho tipy na všechny nadcházející zápasy.
            Užitečné pro členy, kteří sami do aplikace nechodí.
        </p>
    </header>

    <form method="get" action="{{ path('portal_competition_manage_member_tips', {id: competition.id.toRfc4122}) }}"
          class="card-glass mb-6 p-6">
        <div class="field">
            <label for="member-select" class="field-label">Tipující</label>
            <select id="member-select"
                    name="member"
                    data-controller="tom-select"
                    data-tom-select-placeholder-value="Vyhledejte tipujícího…"
                    data-tom-select-submit-on-change-value="true"
                    data-tom-select-no-results-text-value="Žádný tipující nenalezen">
                <option value=""></option>
                {% for member in members %}
                    {% set hasNickname = member.nickname is not null and member.nickname != '' %}
                    {% set hasFullName = member.fullName != '' %}
                    <option value="{{ member.id.toRfc4122 }}"
                            data-data="{{ {
                                nickname: hasNickname ? member.nickname : '',
                                fullName: hasFullName ? member.fullName : '',
                                unverified: not member.isVerified,
                            }|json_encode }}"
                            {% if selectedMember and selectedMember.id.equals(member.id) %}selected{% endif %}>
                        {{ member.displayName }}{% if hasNickname and hasFullName %} {{ member.fullName }}{% endif %}{% if not member.isVerified %} (neověřený){% endif %}
                    </option>
                {% endfor %}
            </select>
        </div>
        <noscript>
            <button type="submit" class="btn btn-primary btn-sm mt-3">
                Vybrat
            </button>
        </noscript>
    </form>

    {% if selectedMember is null %}
        <div class="card-glass flex flex-col items-center gap-3 p-10 text-center">
            <twig:ux:icon name="lucide:user-search" class="h-8 w-8 text-white/40" />
            <p class="text-sm text-white/70">Vyberte tipujícího ve výběru výše.</p>
        </div>
    {% elseif rows|length == 0 %}
        <div class="card-glass flex flex-col items-center gap-3 p-10 text-center">
            <twig:ux:icon name="lucide:calendar" class="h-8 w-8 text-white/40" />
            <p class="text-sm text-white/70">Žádné nadcházející zápasy k tipování.</p>
        </div>
    {% else %}
        <form method="post"
              action="{{ path('portal_competition_guess_on_behalf_batch', {
                  competitionId: competition.id.toRfc4122,
                  memberId: selectedMember.id.toRfc4122,
              }) }}"
              data-controller="tip-fill">
            <input type="hidden" name="_token"
                   value="{{ csrf_token('guess_on_behalf_batch_' ~ competition.id.toRfc4122 ~ '_' ~ selectedMember.id.toRfc4122) }}">

            <section class="card overflow-hidden p-0">
                <header class="border-b border-white/[0.06] px-6 py-5">
                    <div class="flex items-center gap-3">
                        <twig:Avatar name="{{ selectedMember.displayName }}" size="40" />
                        <div class="min-w-0 flex-1">
                            <h2 class="truncate text-lg font-bold text-white">
                                Tipy pro {{ selectedMember.displayName }}
                            </h2>
                            <p class="mt-0.5 text-xs text-white/50">
                                Vyplňte skóre u zápasů, které chcete uložit. Nevyplněné zápasy se přeskočí.
                            </p>
                            {% if features.scorerTips or features.overtimeTip %}
                                <p class="mt-1 flex items-center gap-1.5 text-xs text-accent-300">
                                    <twig:ux:icon name="lucide:info" class="h-3.5 w-3.5 shrink-0" />
                                    Střelce a prodloužení tipnete v detailu zápasu.
                                </p>
                            {% endif %}
                        </div>
                        <span class="shrink-0 text-xs font-semibold tabular-nums text-white/60"
                              data-tip-fill-target="counter">0/{{ rows|length }} vyplněno</span>
                    </div>

                    <div class="mt-4 flex flex-wrap items-center gap-2">
                        <span class="mr-1 text-[11px] font-medium uppercase tracking-[0.14em] text-white/40">Hromadně</span>
                        <button type="button" class="btn btn-ghost btn-sm" data-action="tip-fill#fillHomeWin">
                            <twig:ux:icon name="lucide:arrow-left" class="h-3.5 w-3.5" />
                            Domácí 2:1
                        </button>
                        <button type="button" class="btn btn-ghost btn-sm" data-action="tip-fill#fillDraw">
                            <twig:ux:icon name="lucide:equal" class="h-3.5 w-3.5" />
                            Remíza 1:1
                        </button>
                        <button type="button" class="btn btn-ghost btn-sm" data-action="tip-fill#fillAwayWin">
                            <twig:ux:icon name="lucide:arrow-right" class="h-3.5 w-3.5" />
                            Hosté 1:2
                        </button>
                        <button type="button" class="btn btn-ghost btn-sm" data-action="tip-fill#clearAll">
                            <twig:ux:icon name="lucide:trash-2" class="h-3.5 w-3.5" />
                            Smazat vše
                        </button>
                    </div>
                </header>

                <ul class="divide-y divide-white/[0.06]">
                    {% for row in rows %}
                        <li class="flex flex-wrap items-center justify-between gap-4 px-6 py-5">
                            <div class="flex min-w-0 flex-1 items-center gap-3">
                                <twig:TeamFlag :name="row.match.homeTeam" size="40" />
                                <div class="min-w-0">
                                    <div class="flex flex-wrap items-center gap-x-2 gap-y-0.5 text-sm font-bold leading-tight text-white">
                                        <span class="truncate">{{ row.match.homeTeam }}</span>
                                        <span class="text-[11px] font-medium uppercase tracking-[0.18em] text-white/40">vs</span>
                                        <span class="truncate">{{ row.match.awayTeam }}</span>
                                    </div>
                                    <p class="mt-1 flex items-center gap-1.5 text-[11px] font-light tracking-wide text-white/50">
                                        <twig:ux:icon name="lucide:calendar" class="h-3.5 w-3.5 shrink-0" />
                                        {{ row.match.kickoffAt|date('d. m. Y') }} · {{ row.match.kickoffAt|date('H:i') }}
                                    </p>
                                </div>
                                <span class="ml-auto sm:ml-0">
                                    <twig:TeamFlag :name="row.match.awayTeam" size="40" />
                                </span>
                            </div>

                            <div class="flex flex-col items-end gap-2">
                                <div class="flex items-center gap-2.5">
                                    <input type="number"
                                           name="guesses[{{ row.match.id.toRfc4122 }}][homeScore]"
                                           min="0" max="99"
                                           value="{{ row.guess ? row.guess.homeScore : '' }}"
                                           class="score-input"
                                           data-tip-fill-target="score"
                                           data-match="{{ row.match.id.toRfc4122 }}"
                                           aria-label="Domácí – {{ row.match.homeTeam }}">
                                    <span class="text-lg font-bold text-white/40">:</span>
                                    <input type="number"
                                           name="guesses[{{ row.match.id.toRfc4122 }}][awayScore]"
                                           min="0" max="99"
                                           value="{{ row.guess ? row.guess.awayScore : '' }}"
                                           class="score-input"
                                           data-tip-fill-target="score"
                                           data-match="{{ row.match.id.toRfc4122 }}"
                                           aria-label="Hosté – {{ row.match.awayTeam }}">
                                </div>
                                {% if features.periodTips %}
                                    {% set guess_periods = row.guess and row.guess.periodScores is not null ? row.guess.periodScores.toArray : null %}
                                    <div class="flex flex-wrap items-center justify-end gap-x-3 gap-y-1.5">
                                        {% for number in 1..sport.periodCount %}
                                            <span class="inline-flex items-center gap-1 text-[11px] text-white/50">
                                                {{ number }}. {{ sport.periodLabelSingular }}
                                                <input type="number"
                                                       name="guesses[{{ row.match.id.toRfc4122 }}][periods][{{ number }}][home]"
                                                       min="0" max="99"
                                                       value="{{ guess_periods and guess_periods[number - 1] is defined ? guess_periods[number - 1][0] : '' }}"
                                                       class="input h-8 w-12 px-1 text-center text-sm"
                                                       aria-label="{{ number }}. {{ sport.periodLabelSingular }} – domácí">
                                                <span class="text-white/30">:</span>
                                                <input type="number"
                                                       name="guesses[{{ row.match.id.toRfc4122 }}][periods][{{ number }}][away]"
                                                       min="0" max="99"
                                                       value="{{ guess_periods and guess_periods[number - 1] is defined ? guess_periods[number - 1][1] : '' }}"
                                                       class="input h-8 w-12 px-1 text-center text-sm"
                                                       aria-label="{{ number }}. {{ sport.periodLabelSingular }} – hosté">
                                            </span>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </div>
                        </li>
                    {% endfor %}
                </ul>
            </section>

            <div class="fixed inset-x-0 bottom-0 z-30 border-t border-white/10 bg-navy-900/90 backdrop-blur-xl">
                <div class="mx-auto flex max-w-3xl items-center justify-between gap-3 px-4 py-3 sm:px-6 lg:px-8">
                    <p class="hidden text-xs tabular-nums text-white/50 sm:block"
                       data-tip-fill-target="counter">0/{{ rows|length }} vyplněno</p>
                    <button type="submit"
                            class="btn btn-primary w-full justify-center sm:w-auto">
                        <twig:ux:icon name="lucide:save" class="h-4 w-4" />
                        Uložit vše
                    </button>
                </div>
            </div>
        </form>
    {% endif %}
</div>
{% endblock %}
