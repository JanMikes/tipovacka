{% extends 'base.html.twig' %}

{% block title %}Smazat účet — {{ brand_name }}{% endblock %}

{% block body %}
<div class="mx-auto w-full max-w-md px-4 py-12 sm:px-6 lg:px-8">
    <twig:Breadcrumbs :items="[
        {label: 'Nástěnka', path: path('portal_dashboard')},
        {label: 'Profil', path: path('portal_profile_edit')},
        {label: 'Smazat účet'},
    ]" />

    <div class="card border-loss/30 mt-2 p-8 text-center sm:p-10">
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl border border-loss/30 bg-loss/10 text-loss">
            <twig:ux:icon name="lucide:triangle-alert" class="h-8 w-8" />
        </div>

        <h1 class="mt-6 text-2xl font-black tracking-tight text-white">Opravdu chcete smazat účet?</h1>
        <p class="mt-3 text-sm leading-relaxed text-white/70">
            Tato akce je <strong class="font-semibold text-white">nevratná</strong>. Váš účet a všechna přidružená data budou trvale smazána.
        </p>

        <form method="post" action="{{ path('portal_account_delete') }}" class="mt-8 space-y-3">
            <input type="hidden" name="_token" value="{{ csrf_token('delete_account') }}">

            <button type="submit" class="btn btn-danger btn-block">
                <twig:ux:icon name="lucide:trash-2" class="h-4 w-4" />
                Ano, smazat můj účet
            </button>

            <a href="{{ path('portal_profile_edit') }}" class="btn btn-ghost btn-block">
                Zrušit
            </a>
        </form>
    </div>
</div>
{% endblock %}
