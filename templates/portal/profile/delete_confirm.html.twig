{% extends 'base.html.twig' %}

{% block title %}Smazat účet — Tipovačka{% endblock %}

{% block body %}
<div class="mx-auto w-full max-w-md px-4 py-12 sm:px-6 lg:px-8">
    <twig:Breadcrumbs :items="[
        {label: 'Nástěnka', path: path('portal_dashboard')},
        {label: 'Profil', path: path('portal_profile_edit')},
        {label: 'Smazat účet'},
    ]" />
    <div>
        <div class="rounded-2xl bg-white p-8 text-center shadow-card ring-1 ring-navy-900/5 sm:p-10">
            <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-red-100 text-red-600">
                <twig:ux:icon name="lucide:triangle-alert" class="h-8 w-8" />
            </div>

            <h1 class="mt-6 text-2xl font-bold tracking-tight text-navy-900">Opravdu chceš smazat účet?</h1>
            <p class="mt-3 text-navy-900/70">
                Tato akce je <strong>nevratná</strong>. Tvůj účet a všechna přidružená data budou trvale smazána.
            </p>

            <form method="post" action="{{ path('portal_account_delete') }}" class="mt-8 space-y-3">
                <input type="hidden" name="_token" value="{{ csrf_token('delete_account') }}">

                <button type="submit" class="inline-flex w-full items-center justify-center gap-1.5 rounded-lg bg-red-600 px-4 py-3 text-sm font-semibold text-white transition-colors hover:bg-red-700">
                    <twig:ux:icon name="lucide:trash-2" class="h-4 w-4" />
                    Ano, smazat můj účet
                </button>

                <a href="{{ path('portal_profile_edit') }}" class="block w-full rounded-lg bg-navy-50 px-4 py-3 text-sm font-semibold text-navy-900 transition-colors hover:bg-navy-100">
                    Zrušit
                </a>
            </form>
        </div>
    </div>
</div>
{% endblock %}
