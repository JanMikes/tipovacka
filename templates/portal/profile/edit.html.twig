{% extends 'base.html.twig' %}

{% block title %}Profil — Tipovačka{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-[#081e44]">Můj profil</h1>
        <p class="text-gray-500 mt-1">Upravte své osobní údaje.</p>
    </div>

    <div class="bg-white rounded-2xl shadow-lg p-8 mb-6">
        <div class="mb-6 pb-6 border-b border-gray-100">
            <p class="text-sm font-medium text-gray-500 mb-1">Přezdívka (nelze změnit)</p>
            <p class="text-lg font-semibold text-[#081e44]">{{ user.nickname }}</p>
        </div>

        <div class="mb-6 pb-6 border-b border-gray-100">
            <p class="text-sm font-medium text-gray-500 mb-1">E-mailová adresa</p>
            <p class="text-lg font-semibold text-[#081e44]">{{ user.email }}</p>
        </div>

        {{ form_start(form, {attr: {class: 'space-y-5', novalidate: 'novalidate'}}) }}

            <div>
                {{ form_label(form.firstName, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.firstName, {attr: {class: 'w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#149AD5] focus:border-transparent outline-none transition'}}) }}
                {{ form_errors(form.firstName) }}
            </div>

            <div>
                {{ form_label(form.lastName, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.lastName, {attr: {class: 'w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#149AD5] focus:border-transparent outline-none transition'}}) }}
                {{ form_errors(form.lastName) }}
            </div>

            <div>
                {{ form_label(form.phone, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.phone, {attr: {class: 'w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#149AD5] focus:border-transparent outline-none transition'}}) }}
                {{ form_errors(form.phone) }}
            </div>

            <button
                type="submit"
                class="bg-[#081e44] hover:bg-[#0f2d5f] text-white py-3 px-6 rounded-lg font-medium transition-colors"
            >
                Uložit změny
            </button>

        {{ form_end(form) }}
    </div>

    <div class="bg-red-50 border border-red-200 rounded-2xl p-6">
        <h2 class="text-lg font-semibold text-red-800 mb-2">Nebezpečná zóna</h2>
        <p class="text-red-600 text-sm mb-4">
            Smazání účtu je nevratná akce. Přijdete o veškerá svá data.
        </p>
        <a href="{{ path('portal_account_delete') }}" class="inline-block bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors">
            Smazat účet
        </a>
    </div>
</div>
{% endblock %}
