{% extends 'base.html.twig' %}

{% block title %}Profil — {{ brand_name }}{% endblock %}

{% block body %}
<div class="mx-auto w-full max-w-4xl px-4 py-8 sm:px-6 sm:py-12 lg:px-8">

    <twig:Breadcrumbs :items="[
        {label: 'Nástěnka', path: path('portal_dashboard')},
        {label: 'Profil'},
    ]" />

    <header class="mb-8 mt-2">
        <span class="eyebrow">Můj účet</span>
        <h1 class="mt-2 text-3xl font-black tracking-tight text-white sm:text-4xl">Můj profil</h1>
        <p class="mt-2 text-sm leading-relaxed text-white/70">Spravujte své osobní údaje.</p>
    </header>

    <div class="grid gap-6 lg:grid-cols-3">
        <div class="space-y-6 lg:col-span-2">
            {# Account card — read-only details #}
            <section class="card overflow-hidden p-0">
                <header class="flex items-center gap-2.5 border-b border-white/[0.06] px-6 py-4">
                    <twig:ux:icon name="lucide:user" class="h-5 w-5 text-accent-400" />
                    <h2 class="text-base font-semibold text-white">Účet</h2>
                </header>
                <dl class="grid gap-4 px-6 py-5 sm:grid-cols-2">
                    <div>
                        <dt class="text-xs font-medium uppercase tracking-wider text-white/40">Přezdívka</dt>
                        <dd class="mt-1 text-base font-semibold text-white">{{ user.nickname }}</dd>
                    </div>
                    <div>
                        <dt class="text-xs font-medium uppercase tracking-wider text-white/40">E-mail</dt>
                        <dd class="mt-1 text-base font-semibold text-white">{{ user.email }}</dd>
                    </div>
                </dl>
            </section>

            {# Personal details form #}
            <section class="card-glass overflow-hidden p-0">
                <header class="flex items-center gap-2.5 border-b border-white/[0.06] px-6 py-4">
                    <twig:ux:icon name="lucide:pencil" class="h-5 w-5 text-accent-400" />
                    <h2 class="text-base font-semibold text-white">Osobní údaje</h2>
                </header>

                <div class="px-6 py-6">
                    <twig:Profile:ProfileForm />
                </div>
            </section>
        </div>

        {# Danger zone sidebar #}
        <aside>
            <div class="card border-loss/30 p-6">
                <div class="flex items-center gap-2.5 text-loss">
                    <twig:ux:icon name="lucide:triangle-alert" class="h-5 w-5" />
                    <h2 class="text-xs font-semibold uppercase tracking-wider">Nebezpečná zóna</h2>
                </div>
                <p class="mt-3 text-sm leading-relaxed text-white/70">
                    Smazání účtu je nevratná akce. Přijdete o veškerá svá data.
                </p>
                <a href="{{ path('portal_account_delete') }}" class="btn btn-danger btn-sm mt-4">
                    <twig:ux:icon name="lucide:trash-2" class="h-4 w-4" />
                    Smazat účet
                </a>
            </div>
        </aside>
    </div>
</div>
{% endblock %}
