{% extends 'base.html.twig' %}

{% block title %}Profil — Tipovačka{% endblock %}

{% block body %}
<div class="mx-auto w-full max-w-4xl px-4 py-8 sm:px-6 sm:py-12 lg:px-8">

    <twig:Breadcrumbs :items="[
        {label: 'Nástěnka', path: path('portal_dashboard')},
        {label: 'Profil'},
    ]" />

    <header class="mb-8">
        <h1 class="text-3xl font-bold tracking-tight text-navy-900 sm:text-4xl">Můj profil</h1>
        <p class="mt-2 text-navy-900/70">Uprav své osobní údaje.</p>
    </header>

    <div class="grid gap-6 lg:grid-cols-3">
        <div class="lg:col-span-2 space-y-6">
            {# Account card — read-only details #}
            <section class="rounded-2xl bg-white shadow-card ring-1 ring-navy-900/5">
                <header class="flex items-center gap-2.5 border-b border-navy-100/70 px-6 py-4">
                    <twig:ux:icon name="lucide:user" class="h-5 w-5 text-cyan-500" />
                    <h2 class="text-lg font-semibold text-navy-900">Účet</h2>
                </header>
                <dl class="grid gap-4 px-6 py-5 sm:grid-cols-2">
                    <div>
                        <dt class="text-xs font-medium uppercase tracking-wider text-navy-900/50">Přezdívka</dt>
                        <dd class="mt-1 text-base font-semibold text-navy-900">{{ user.nickname }}</dd>
                    </div>
                    <div>
                        <dt class="text-xs font-medium uppercase tracking-wider text-navy-900/50">E-mail</dt>
                        <dd class="mt-1 text-base font-semibold text-navy-900">{{ user.email }}</dd>
                    </div>
                </dl>
            </section>

            {# Personal details form #}
            <section class="rounded-2xl bg-white shadow-card ring-1 ring-navy-900/5">
                <header class="flex items-center gap-2.5 border-b border-navy-100/70 px-6 py-4">
                    <twig:ux:icon name="lucide:pencil" class="h-5 w-5 text-cyan-500" />
                    <h2 class="text-lg font-semibold text-navy-900">Osobní údaje</h2>
                </header>

                <div class="px-6 py-5">
                    <twig:Profile:ProfileForm />
                </div>
            </section>
        </div>

        {# Danger zone sidebar #}
        <aside>
            <div class="rounded-2xl border border-red-200 bg-red-50 p-6">
                <div class="flex items-center gap-2.5 text-red-800">
                    <twig:ux:icon name="lucide:triangle-alert" class="h-5 w-5" />
                    <h2 class="text-sm font-semibold uppercase tracking-wider">Nebezpečná zóna</h2>
                </div>
                <p class="mt-3 text-sm text-red-700">
                    Smazání účtu je nevratná akce. Přijdeš o veškerá svá data.
                </p>
                <a href="{{ path('portal_account_delete') }}" class="mt-4 inline-flex items-center gap-1.5 rounded-lg bg-red-600 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-red-700">
                    <twig:ux:icon name="lucide:trash-2" class="h-4 w-4" />
                    Smazat účet
                </a>
            </div>
        </aside>
    </div>
</div>
{% endblock %}
