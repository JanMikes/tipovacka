{% extends 'base.html.twig' %}

{% block title %}{{ match_source.name }} — {{ brand_name }}{% endblock %}

{% block body %}
<div class="mx-auto w-full max-w-6xl px-4 py-8 sm:px-6 sm:py-12 lg:px-8">

    <twig:Breadcrumbs :items="[
        {label: 'Nástěnka', path: path('portal_dashboard')},
        {label: match_source.name},
    ]" />

    {# Hero card #}
    <section class="card-glass bg-radial relative overflow-hidden p-6 text-white sm:p-8">
        <div aria-hidden="true" class="pointer-events-none absolute -right-16 -top-16 h-60 w-60 rounded-full bg-accent-500/15 blur-3xl"></div>

        <div class="relative flex flex-wrap items-start gap-4">
            <span class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl border border-white/10 bg-white/5 backdrop-blur">
                <twig:ux:icon name="lucide:trophy" class="h-7 w-7 text-accent-300" />
            </span>
            <div class="min-w-0 flex-1">
                <div class="mb-2 flex flex-wrap items-center gap-2">
                    {% if match_source.isCurated %}
                        <twig:Pill label="VEŘEJNÝ" variant="accent" />
                    {% else %}
                        <twig:Pill label="SOUKROMÝ" variant="neutral" />
                    {% endif %}
                    {% if match_source.isCompleted %}
                        <twig:Pill label="UKONČEN" variant="done" />
                    {% endif %}
                </div>
                <h1 class="grad-headline text-3xl font-black tracking-tight sm:text-4xl">{{ match_source.name }}</h1>
                <div class="mt-3 flex flex-wrap items-center gap-x-5 gap-y-1.5 text-sm text-white/70">
                    <span class="inline-flex items-center gap-1.5">
                        <twig:ux:icon name="lucide:user" class="h-4 w-4 text-white/50" />{{ match_source.owner.nickname }}
                    </span>
                    {% if match_source.startAt or match_source.endAt %}
                        <span class="inline-flex items-center gap-1.5">
                            <twig:ux:icon name="lucide:calendar" class="h-4 w-4 text-white/50" />
                            {% if match_source.startAt %}{{ match_source.startAt|date('d. m. Y') }}{% endif %}
                            {% if match_source.startAt and match_source.endAt %} – {% endif %}
                            {% if match_source.endAt %}{{ match_source.endAt|date('d. m. Y') }}{% endif %}
                        </span>
                    {% endif %}
                </div>
            </div>
        </div>

        {% if match_source.description %}
            <p class="relative mt-6 max-w-3xl whitespace-pre-line text-white/70">{{ match_source.description }}</p>
        {% endif %}
    </section>

    {% set canCreateCompetition = is_granted('match_source_create_competition', match_source) %}

    <div class="mt-8 grid gap-6 lg:grid-cols-12">

        {# ───── Main column ───── #}
        <div class="space-y-6 lg:col-span-8">

            {# Matches #}
            <section class="card-glass overflow-hidden p-0">
                <header class="flex flex-wrap items-center justify-between gap-3 border-b border-white/10 px-6 py-4">
                    <div class="flex items-center gap-2.5">
                        <twig:ux:icon name="lucide:calendar" class="h-5 w-5 text-accent-400" />
                        <h2 class="text-lg font-semibold text-white">Zápasy</h2>
                        {% set matches = sport_matches ?? [] %}
                        {% if matches|length > 0 %}
                            <span class="rounded-full border border-white/10 bg-white/5 px-2.5 py-0.5 text-xs font-semibold text-white/70">{{ matches|length }}</span>
                        {% endif %}
                    </div>
                    {% if is_granted('sport_match_create', match_source) %}
                        <div class="flex flex-wrap gap-2">
                            <a href="{{ path('portal_sport_match_create', {matchSourceId: match_source.id.toRfc4122}) }}" class="btn btn-primary btn-sm">
                                <twig:ux:icon name="lucide:plus" class="h-4 w-4" />Přidat zápas
                            </a>
                            <a href="{{ path('portal_sport_match_import', {matchSourceId: match_source.id.toRfc4122}) }}" class="btn btn-success btn-sm">
                                <twig:ux:icon name="lucide:list-ordered" class="h-4 w-4" />Nahrát z Excelu
                            </a>
                        </div>
                    {% endif %}
                </header>

                {% if matches|length == 0 %}
                    {% if is_granted('sport_match_create', match_source) %}
                        <twig:EmptyState
                            illustration="matches"
                            title="Žádné zápasy v plánu"
                            body="Přidejte první zápas ručně, nebo nahrajte celý rozpis z Excelu či CSV."
                            ctaLabel="Přidat zápas"
                            ctaPath="{{ path('portal_sport_match_create', {matchSourceId: match_source.id.toRfc4122}) }}"
                            secondaryLabel="Nahrát z Excelu/CSV"
                            secondaryPath="{{ path('portal_sport_match_import', {matchSourceId: match_source.id.toRfc4122}) }}"
                        />
                    {% else %}
                        <twig:EmptyState
                            illustration="matches"
                            title="Žádné zápasy v plánu"
                            body="Správce brzy přidá zápasy. Zatím můžete pozvat další kamarády."
                        />
                    {% endif %}
                {% else %}
                    <ul class="divide-y divide-white/[0.06]">
                        {% for m in matches %}
                            {%- set state = m.state.value -%}
                            <li>
                                <a href="{{ path('portal_sport_match_detail', {id: m.id.toRfc4122}) }}" class="grid grid-cols-[auto_1fr_auto] items-center gap-3 px-6 py-4 transition-colors hover:bg-white/[0.03] sm:gap-6">
                                    <div class="flex flex-col text-xs text-white/50 sm:w-24">
                                        <span class="font-medium text-white/70">{{ m.kickoffAt|date('d. m.') }}</span>
                                        <span>{{ m.kickoffAt|date('H:i') }}</span>
                                    </div>
                                    <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-3 text-sm">
                                        <span class="truncate text-right font-medium text-white">{{ m.homeTeam }}</span>
                                        {% if state == 'finished' or (state == 'live' and m.homeScore is not null) %}
                                            <span class="flex flex-col items-center gap-0.5">
                                                <span class="rounded-md border border-white/10 bg-white/5 px-2 py-0.5 text-sm font-bold tabular-nums text-white">{{ m.homeScore }} : {{ m.awayScore }}</span>
                                                {% if m.periodScores is not null or m.overtimeHomeScore is not null %}
                                                    <span class="whitespace-nowrap text-[11px] tabular-nums text-white/45">
                                                        {%- if m.periodScores is not null -%}
                                                            ({% for p in m.periodScores.toArray %}{{ p[0] }}:{{ p[1] }}{% if not loop.last %}, {% endif %}{% endfor %})
                                                        {%- endif -%}
                                                        {%- if m.overtimeHomeScore is not null %} po prodl. {{ m.overtimeHomeScore }}:{{ m.overtimeAwayScore }}{% endif -%}
                                                    </span>
                                                {% endif %}
                                            </span>
                                        {% else %}
                                            <span class="text-xs font-semibold text-white/40">vs</span>
                                        {% endif %}
                                        <span class="truncate font-medium text-white">{{ m.awayTeam }}</span>
                                    </div>
                                    <span class="flex shrink-0 items-center gap-1.5">
                                        {% if m.isPlayoff %}
                                            <span class="pill shrink-0">Playoff</span>
                                        {% endif %}
                                        {% if state == 'scheduled' %}
                                            <span class="pill pill-soon shrink-0">Naplánován</span>
                                        {% elseif state == 'live' %}
                                            <span class="pill pill-locked shrink-0">Uzamčeno</span>
                                        {% elseif state == 'finished' %}
                                            <span class="pill pill-done shrink-0">Odehrán</span>
                                        {% elseif state == 'postponed' %}
                                            <span class="pill pill-warn shrink-0">Odložen</span>
                                        {% else %}
                                            <span class="pill pill-locked shrink-0">Zrušen</span>
                                        {% endif %}
                                    </span>
                                </a>
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </section>

            {# Competitions #}
            <section class="card-glass overflow-hidden p-0">
                <header class="flex flex-wrap items-center justify-between gap-3 border-b border-white/10 px-6 py-4">
                    <div class="flex items-center gap-2.5">
                        <twig:ux:icon name="lucide:users" class="h-5 w-5 text-accent-400" />
                        <h2 class="text-lg font-semibold text-white">Soutěže</h2>
                        {% if competitions|length > 0 %}
                            <span class="rounded-full border border-white/10 bg-white/5 px-2.5 py-0.5 text-xs font-semibold text-white/70">{{ competitions|length }}</span>
                        {% endif %}
                    </div>
                    {% if canCreateCompetition %}
                        <a href="{{ path('portal_competition_create', {zdroj: match_source.id.toRfc4122}) }}" class="btn btn-primary btn-sm">
                            <twig:ux:icon name="lucide:plus" class="h-4 w-4" />
                            Založit soutěž
                        </a>
                    {% endif %}
                </header>

                {% if competitions|length == 0 %}
                    <p class="px-6 py-10 text-center text-sm text-white/50">U tohoto zdroje zápasů zatím nejsou žádné soutěže.</p>
                {% else %}
                    <ul class="divide-y divide-white/[0.06]">
                        {% for g in competitions %}
                            <li>
                                <a href="{{ path('portal_competition_detail', {id: g.competitionId.toRfc4122}) }}" class="flex items-center justify-between gap-3 px-6 py-4 transition-colors hover:bg-white/[0.03]">
                                    <div class="min-w-0">
                                        <p class="font-medium text-white">{{ g.competitionName }}</p>
                                        <p class="mt-0.5 flex items-center gap-1.5 text-xs text-white/50">
                                            <twig:ux:icon name="lucide:user" class="h-3.5 w-3.5" />{{ g.ownerNickname }}
                                        </p>
                                    </div>
                                    <twig:ux:icon name="lucide:chevron-right" class="h-4 w-4 shrink-0 text-white/40" />
                                </a>
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </section>
        </div>

        {# ───── Sidebar ───── #}
        <aside class="space-y-6 lg:col-span-4">
            {# A completed source revokes EDIT for the owner, but the management box must stay reachable for the reopen toggle. #}
            {% if is_granted('match_source_edit', match_source) or is_granted('match_source_reopen', match_source) %}
                <section class="card-glass overflow-hidden p-0">
                    <header class="flex items-center gap-2.5 border-b border-white/10 px-6 py-4">
                        <twig:ux:icon name="lucide:settings" class="h-5 w-5 text-accent-400" />
                        <h2 class="text-lg font-semibold text-white">Správa zdroje zápasů</h2>
                    </header>
                    <div class="space-y-2 px-6 py-5">
                        {% if is_granted('match_source_edit', match_source) %}
                            <a href="{{ path('portal_match_source_edit', {id: match_source.id.toRfc4122}) }}" class="btn btn-ghost w-full justify-start">
                                <twig:ux:icon name="lucide:pencil" class="h-4 w-4" />Upravit
                            </a>
                        {% endif %}

                        {% if is_granted('match_source_complete', match_source) %}
                            <form method="post" action="{{ path('portal_match_source_complete', {id: match_source.id.toRfc4122}) }}"
                                data-controller="confirm"
                                data-confirm-variant-value="warning"
                                data-confirm-title-value="Ukončit zdroj zápasů"
                                data-confirm-message-value="Opravdu chcete zdroj zápasů ukončit? Další tipy už nepůjde zadávat a výsledek žebříčku bude finální."
                                data-confirm-confirm-label-value="Ano, ukončit">
                                <input type="hidden" name="_token" value="{{ csrf_token('match_source_complete_' ~ match_source.id.toRfc4122) }}">
                                <button type="submit" class="btn w-full justify-start border border-draw/30 bg-draw/10 text-draw hover:bg-draw/20">
                                    <twig:ux:icon name="lucide:award" class="h-4 w-4" />Ukončit zdroj zápasů
                                </button>
                            </form>
                        {% endif %}

                        {% if is_granted('match_source_reopen', match_source) %}
                            <form method="post" action="{{ path('portal_match_source_reopen', {id: match_source.id.toRfc4122}) }}"
                                data-controller="confirm"
                                data-confirm-variant-value="warning"
                                data-confirm-title-value="Znovu otevřít zdroj zápasů"
                                data-confirm-message-value="Opravdu chcete zdroj zápasů znovu otevřít? Soutěže nad ním přestanou být považovány za ukončené."
                                data-confirm-confirm-label-value="Ano, otevřít">
                                <input type="hidden" name="_token" value="{{ csrf_token('match_source_reopen_' ~ match_source.id.toRfc4122) }}">
                                <button type="submit" class="btn btn-ghost w-full justify-start">
                                    <twig:ux:icon name="lucide:rotate-ccw" class="h-4 w-4" />Znovu otevřít zdroj zápasů
                                </button>
                            </form>
                        {% endif %}

                        {% if is_granted('match_source_delete', match_source) %}
                            <form method="post" action="{{ path('portal_match_source_delete', {id: match_source.id.toRfc4122}) }}"
                                data-controller="confirm"
                                data-confirm-title-value="Smazat zdroj zápasů"
                                data-confirm-message-value="Opravdu chcete zdroj zápasů „{{ match_source.name }}“ smazat? Společně s ním zmizí všechny zápasy, soutěže i tipy."
                                data-confirm-confirm-label-value="Ano, smazat">
                                <input type="hidden" name="_token" value="{{ csrf_token('match_source_delete_' ~ match_source.id.toRfc4122) }}">
                                <button type="submit" class="btn btn-danger w-full justify-start">
                                    <twig:ux:icon name="lucide:trash-2" class="h-4 w-4" />Smazat zdroj zápasů
                                </button>
                            </form>
                        {% endif %}
                    </div>
                </section>
            {% endif %}
        </aside>
    </div>
</div>
{% endblock %}
