{% extends 'base.html.twig' %}

{% block title %}Nový zdroj zápasů — {{ brand_name }}{% endblock %}

{% block body %}
<div class="mx-auto w-full max-w-2xl px-4 py-8 sm:px-6 sm:py-12 lg:px-8">
    <twig:Breadcrumbs :items="[
        {label: 'Nástěnka', path: path('portal_dashboard')},
        {label: 'Nový zdroj zápasů'},
    ]" />

    <header class="mb-8 mt-2">
        <span class="eyebrow">Nový zdroj zápasů</span>
        <h1 class="mt-2 text-3xl font-black tracking-tight text-white sm:text-4xl">Nový zdroj zápasů</h1>
        <p class="mt-2 text-sm leading-relaxed text-white/70">Vlastní rozpis zápasů pro vaše soutěže — zápasy zadáte ručně nebo nahrajete z Excelu.</p>
    </header>

    <div class="card-glass p-6 sm:p-8">
        {{ form_start(form, {attr: {class: 'space-y-5', novalidate: 'novalidate'}}) }}

            <div class="field">
                {{ form_label(form.sport, null, {label_attr: {class: 'field-label'}}) }}
                {{ form_widget(form.sport, {attr: {class: 'input'}}) }}
                {{ form_errors(form.sport) }}
            </div>

            <div class="field">
                {{ form_label(form.name, null, {label_attr: {class: 'field-label'}}) }}
                {{ form_widget(form.name, {attr: {class: 'input'}}) }}
                {{ form_errors(form.name) }}
            </div>

            <div class="field">
                {{ form_label(form.description, null, {label_attr: {class: 'field-label'}}) }}
                {{ form_widget(form.description, {attr: {class: 'input'}}) }}
                {{ form_errors(form.description) }}
            </div>

            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                <div class="field">
                    {{ form_label(form.startAt, null, {label_attr: {class: 'field-label'}}) }}
                    {{ form_widget(form.startAt, {attr: {class: 'input'}}) }}
                    {{ form_errors(form.startAt) }}
                </div>

                <div class="field">
                    {{ form_label(form.endAt, null, {label_attr: {class: 'field-label'}}) }}
                    {{ form_widget(form.endAt, {attr: {class: 'input'}}) }}
                    {{ form_errors(form.endAt) }}
                </div>
            </div>

            <button type="submit" class="btn btn-primary">
                <twig:ux:icon name="lucide:trophy" class="h-4 w-4" />
                Vytvořit zdroj zápasů
            </button>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
