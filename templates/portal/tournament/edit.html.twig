{% extends 'base.html.twig' %}

{% block title %}Upravit turnaj — Tipovačka{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <twig:Breadcrumbs :items="[
        {label: 'Nástěnka', path: path('portal_dashboard')},
        {label: tournament.name, path: path('portal_tournament_detail', {id: tournament.id.toRfc4122})},
        {label: 'Upravit turnaj'},
    ]" />
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-navy-900">Upravit turnaj</h1>
        <p class="text-navy-900/60 mt-1">{{ tournament.name }}</p>
    </div>

    <div class="bg-white rounded-2xl shadow-card ring-1 ring-navy-900/5 p-8">
        {{ form_start(form, {attr: {class: 'space-y-5', novalidate: 'novalidate'}}) }}

            <div>
                {{ form_label(form.name, null, {label_attr: {class: 'block text-sm font-medium text-navy-900 mb-1.5'}}) }}
                {{ form_widget(form.name, {attr: {class: 'w-full px-4 py-2.5 border border-navy-100 rounded-lg focus:ring-2 focus:ring-cyan-500 focus:border-transparent outline-none transition'}}) }}
                {{ form_errors(form.name) }}
            </div>

            <div>
                {{ form_label(form.description, null, {label_attr: {class: 'block text-sm font-medium text-navy-900 mb-1.5'}}) }}
                {{ form_widget(form.description, {attr: {class: 'w-full px-4 py-2.5 border border-navy-100 rounded-lg focus:ring-2 focus:ring-cyan-500 focus:border-transparent outline-none transition'}}) }}
                {{ form_errors(form.description) }}
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    {{ form_label(form.startAt, null, {label_attr: {class: 'block text-sm font-medium text-navy-900 mb-1.5'}}) }}
                    {{ form_widget(form.startAt, {attr: {class: 'w-full px-4 py-2.5 border border-navy-100 rounded-lg focus:ring-2 focus:ring-cyan-500 focus:border-transparent outline-none transition'}}) }}
                    {{ form_errors(form.startAt) }}
                </div>

                <div>
                    {{ form_label(form.endAt, null, {label_attr: {class: 'block text-sm font-medium text-navy-900 mb-1.5'}}) }}
                    {{ form_widget(form.endAt, {attr: {class: 'w-full px-4 py-2.5 border border-navy-100 rounded-lg focus:ring-2 focus:ring-cyan-500 focus:border-transparent outline-none transition'}}) }}
                    {{ form_errors(form.endAt) }}
                </div>
            </div>

            {% if form.creationPin is defined %}
                <div>
                    {{ form_label(form.creationPin, null, {label_attr: {class: 'block text-sm font-medium text-navy-900 mb-1.5'}}) }}
                    {{ form_widget(form.creationPin, {attr: {class: 'w-full px-4 py-2.5 border border-navy-100 rounded-lg focus:ring-2 focus:ring-cyan-500 focus:border-transparent outline-none transition font-mono tracking-wider uppercase'}}) }}
                    {{ form_help(form.creationPin) }}
                    {{ form_errors(form.creationPin) }}
                </div>
            {% endif %}

            <div class="flex gap-3">
                <button
                    type="submit"
                    class="bg-navy-900 hover:bg-navy-700 text-white py-3 px-6 rounded-lg font-medium transition-colors"
                >
                    Uložit změny
                </button>

                <a
                    href="{{ path('portal_tournament_detail', {id: tournament.id.toRfc4122}) }}"
                    class="bg-navy-50 hover:bg-navy-100 text-navy-900 py-3 px-6 rounded-lg font-medium transition-colors"
                >
                    Zrušit
                </a>
            </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
