{% extends 'base.html.twig' %}

{% block title %}Pravidla — {{ tournament.name }}{% endblock %}

{% block body %}
<div class="mx-auto w-full max-w-3xl px-4 py-8 sm:px-6 sm:py-12 lg:px-8">
    <twig:Breadcrumbs :items="[
        {label: 'Nástěnka', path: path('portal_dashboard')},
        {label: tournament.name, path: path('portal_tournament_detail', {id: tournament.id.toRfc4122})},
        {label: 'Pravidla bodování'},
    ]" />

    <header class="mb-8 mt-2">
        <span class="eyebrow">Správa turnaje</span>
        <h1 class="mt-2 text-3xl font-black tracking-tight text-white sm:text-4xl">Pravidla bodování</h1>
        <p class="mt-2 text-sm leading-relaxed text-white/70">{{ tournament.name }}</p>
    </header>

    {{ form_start(form, {'attr': {
        'data-controller': 'confirm-recalculation',
        'data-confirm-recalculation-count-value': evaluationCount,
        'data-action': 'submit->confirm-recalculation#confirmIfNeeded',
    }}) }}

    <div class="card-glass mb-6 space-y-4 p-5 sm:p-6">
        {% for item in items %}
            {% set entryForm = form.rules[item.identifier] %}
            <div class="rounded-xl border border-white/10 bg-white/[0.03] p-4">
                <div class="mb-3 flex items-start justify-between gap-4">
                    <div class="min-w-0">
                        <h2 class="text-base font-semibold text-white">{{ item.label }}</h2>
                        <p class="mt-0.5 text-sm text-white/70">{{ item.description }}</p>
                        <p class="mt-1 text-xs text-white/40">Výchozí body: {{ item.defaultPoints }}</p>
                    </div>
                    <label class="flex shrink-0 cursor-pointer items-center gap-2 text-sm text-white/70">
                        {{ form_widget(entryForm.enabled) }}
                        {{ form_label(entryForm.enabled, null, {label_attr: {class: 'cursor-pointer'}}) }}
                    </label>
                </div>
                <div class="flex items-center gap-3">
                    {{ form_label(entryForm.points, null, {label_attr: {class: 'field-label mb-0'}}) }}
                    {{ form_widget(entryForm.points, {'attr': {'class': 'num-input w-24'}}) }}
                </div>
                {{ form_errors(entryForm.points) }}
            </div>
        {% endfor %}
    </div>

    <div class="flex flex-wrap gap-3">
        <button type="submit" class="btn btn-primary">
            <twig:ux:icon name="lucide:save" class="h-4 w-4" />
            Uložit pravidla
        </button>
        <a href="{{ path('portal_tournament_detail', {id: tournament.id.toRfc4122}) }}" class="btn btn-ghost">
            Zpět na turnaj
        </a>
    </div>

    {{ form_end(form) }}
</div>
{% endblock %}
