{% extends 'base.html.twig' %}

{% block title %}{{ tournament.name }} — Tipovačka{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8">
        <div class="flex items-center gap-3 mb-2">
            <h1 class="text-3xl font-bold text-[#081e44]">{{ tournament.name }}</h1>
            {% if tournament.isPublic %}
                <span class="px-3 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">Veřejný</span>
            {% else %}
                <span class="px-3 py-1 rounded-full text-xs font-medium bg-purple-100 text-purple-800">Soukromý</span>
            {% endif %}
            {% if tournament.isFinished %}
                <span class="px-3 py-1 rounded-full text-xs font-medium bg-gray-200 text-gray-800">Ukončen</span>
            {% endif %}
        </div>
        <p class="text-gray-500">Vlastník: {{ tournament.owner.nickname }}</p>
    </div>

    <div class="bg-white rounded-2xl shadow-lg p-8 mb-6">
        {% if tournament.description %}
            <div class="mb-6 pb-6 border-b border-gray-100">
                <p class="text-sm font-medium text-gray-500 mb-1">Popis</p>
                <p class="text-[#081e44] whitespace-pre-line">{{ tournament.description }}</p>
            </div>
        {% endif %}

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {% if tournament.startAt %}
                <div>
                    <p class="text-sm font-medium text-gray-500 mb-1">Začátek</p>
                    <p class="text-[#081e44]">{{ tournament.startAt|date('d. m. Y H:i') }}</p>
                </div>
            {% endif %}
            {% if tournament.endAt %}
                <div>
                    <p class="text-sm font-medium text-gray-500 mb-1">Konec</p>
                    <p class="text-[#081e44]">{{ tournament.endAt|date('d. m. Y H:i') }}</p>
                </div>
            {% endif %}
        </div>
    </div>

    {% if is_granted('tournament_edit', tournament) %}
        <div class="bg-white rounded-2xl shadow-lg p-6 mb-6">
            <h2 class="text-lg font-semibold text-[#081e44] mb-4">Správa turnaje</h2>
            <div class="flex flex-wrap gap-3">
                <a
                    href="{{ path('portal_tournament_edit', {id: tournament.id.toRfc4122}) }}"
                    class="bg-[#081e44] hover:bg-[#0f2d5f] text-white py-2 px-4 rounded-lg text-sm font-medium transition-colors"
                >
                    Upravit
                </a>

                {% if is_granted('tournament_finish', tournament) %}
                    <form method="post" action="{{ path('portal_tournament_finish', {id: tournament.id.toRfc4122}) }}" class="inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('tournament_finish_' ~ tournament.id.toRfc4122) }}">
                        <button
                            type="submit"
                            class="bg-yellow-500 hover:bg-yellow-600 text-white py-2 px-4 rounded-lg text-sm font-medium transition-colors"
                        >
                            Ukončit turnaj
                        </button>
                    </form>
                {% endif %}

                {% if is_granted('tournament_delete', tournament) %}
                    <form method="post" action="{{ path('portal_tournament_delete', {id: tournament.id.toRfc4122}) }}" class="inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('tournament_delete_' ~ tournament.id.toRfc4122) }}">
                        <button
                            type="submit"
                            class="bg-red-600 hover:bg-red-700 text-white py-2 px-4 rounded-lg text-sm font-medium transition-colors"
                            onclick="return confirm('Opravdu chcete turnaj smazat?')"
                        >
                            Smazat turnaj
                        </button>
                    </form>
                {% endif %}
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}
