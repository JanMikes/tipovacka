{% extends 'base.html.twig' %}

{% block title %}{{ tournament.name }} — Tipovačka{% endblock %}

{% block body %}
<div class="mx-auto w-full max-w-6xl px-4 py-8 sm:px-6 sm:py-12 lg:px-8">

    {# Breadcrumb #}
    <nav class="mb-4 flex items-center gap-1.5 text-sm text-navy-900/60" aria-label="Breadcrumb">
        <a href="{{ path('portal_dashboard') }}" class="hover:text-cyan-600">Nástěnka</a>
        <twig:ux:icon name="lucide:chevron-right" class="h-4 w-4" />
        <span class="truncate text-navy-900/80">{{ tournament.name }}</span>
    </nav>

    {# Hero card #}
    <section class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-navy-900 via-navy-800 to-navy-700 p-6 text-white shadow-card sm:p-8">
        <div aria-hidden="true" class="pointer-events-none absolute -right-16 -top-16 h-60 w-60 rounded-full bg-cyan-500/15 blur-3xl"></div>

        <div class="relative flex flex-wrap items-start gap-4">
            <span class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-white/10 backdrop-blur">
                <twig:ux:icon name="lucide:trophy" class="h-7 w-7 text-cyan-400" />
            </span>
            <div class="min-w-0 flex-1">
                <div class="mb-2 flex flex-wrap items-center gap-2">
                    {% if tournament.isPublic %}
                        <span class="inline-flex items-center rounded-full bg-cyan-500/20 px-2.5 py-0.5 text-xs font-semibold text-cyan-300">Veřejný</span>
                    {% else %}
                        <span class="inline-flex items-center rounded-full bg-purple-500/20 px-2.5 py-0.5 text-xs font-semibold text-purple-300">Soukromý</span>
                    {% endif %}
                    {% if tournament.isFinished %}
                        <span class="inline-flex items-center rounded-full bg-white/20 px-2.5 py-0.5 text-xs font-semibold text-white">Ukončen</span>
                    {% endif %}
                </div>
                <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{{ tournament.name }}</h1>
                <div class="mt-3 flex flex-wrap items-center gap-x-5 gap-y-1.5 text-sm text-white/75">
                    <span class="inline-flex items-center gap-1.5">
                        <twig:ux:icon name="lucide:user" class="h-4 w-4" />{{ tournament.owner.nickname }}
                    </span>
                    {% if tournament.startAt or tournament.endAt %}
                        <span class="inline-flex items-center gap-1.5">
                            <twig:ux:icon name="lucide:calendar" class="h-4 w-4" />
                            {% if tournament.startAt %}{{ tournament.startAt|date('d. m. Y') }}{% endif %}
                            {% if tournament.startAt and tournament.endAt %} – {% endif %}
                            {% if tournament.endAt %}{{ tournament.endAt|date('d. m. Y') }}{% endif %}
                        </span>
                    {% endif %}
                </div>
            </div>
        </div>

        {% if tournament.description %}
            <p class="relative mt-6 max-w-3xl whitespace-pre-line text-white/80">{{ tournament.description }}</p>
        {% endif %}
    </section>

    {% set canCreateGroup = is_granted('tournament_create_group', tournament) %}
    {% set canUsePinGate = not canCreateGroup and app.user and app.user.isVerified and tournament.isActive and tournament.hasCreationPin %}

    <div class="mt-8 grid gap-6 lg:grid-cols-12">

        {# ───── Main column ───── #}
        <div class="space-y-6 lg:col-span-8">

            {# Matches #}
            <section class="rounded-2xl bg-white shadow-card ring-1 ring-navy-900/5">
                <header class="flex flex-wrap items-center justify-between gap-3 border-b border-navy-100/70 px-6 py-4">
                    <div class="flex items-center gap-2.5">
                        <twig:ux:icon name="lucide:calendar" class="h-5 w-5 text-cyan-500" />
                        <h2 class="text-lg font-semibold text-navy-900">Zápasy</h2>
                        {% set matches = sport_matches ?? [] %}
                        {% if matches|length > 0 %}
                            <span class="rounded-full bg-navy-50 px-2.5 py-0.5 text-xs font-semibold text-navy-700">{{ matches|length }}</span>
                        {% endif %}
                    </div>
                    {% if is_granted('sport_match_create', tournament) %}
                        <div class="flex flex-wrap gap-2">
                            <a href="{{ path('portal_sport_match_create', {tournamentId: tournament.id.toRfc4122}) }}" class="inline-flex items-center gap-1.5 rounded-lg bg-navy-900 px-3 py-1.5 text-sm font-semibold text-white transition-colors hover:bg-navy-700">
                                <twig:ux:icon name="lucide:plus" class="h-4 w-4" />Přidat zápas
                            </a>
                            <a href="{{ path('portal_sport_match_import', {tournamentId: tournament.id.toRfc4122}) }}" class="inline-flex items-center gap-1.5 rounded-lg bg-green-600 px-3 py-1.5 text-sm font-semibold text-white transition-colors hover:bg-green-700">
                                <twig:ux:icon name="lucide:list-ordered" class="h-4 w-4" />Nahrát z Excelu
                            </a>
                        </div>
                    {% endif %}
                </header>

                {% if matches|length == 0 %}
                    {% if is_granted('sport_match_create', tournament) %}
                        <twig:EmptyState
                            illustration="matches"
                            title="Žádné zápasy v plánu"
                            body="Přidej první zápas ručně, nebo nahraj celý rozpis z Excelu či CSV."
                            ctaLabel="Přidat zápas"
                            ctaPath="{{ path('portal_sport_match_create', {tournamentId: tournament.id.toRfc4122}) }}"
                            secondaryLabel="Nahrát z Excelu/CSV"
                            secondaryPath="{{ path('portal_sport_match_import', {tournamentId: tournament.id.toRfc4122}) }}"
                        />
                    {% else %}
                        <twig:EmptyState
                            illustration="matches"
                            title="Žádné zápasy v plánu"
                            body="Správce brzy přidá zápasy. Můžeš zatím pozvat další kamarády."
                        />
                    {% endif %}
                {% else %}
                    <ul class="divide-y divide-navy-100/70">
                        {% for m in matches %}
                            {%- set state = m.state.value -%}
                            <li>
                                <a href="{{ path('portal_sport_match_detail', {id: m.id.toRfc4122}) }}" class="grid grid-cols-[auto_1fr_auto] items-center gap-3 px-6 py-4 transition-colors hover:bg-navy-50/40 sm:gap-6">
                                    <div class="flex flex-col text-xs text-navy-900/60 sm:w-24">
                                        <span class="font-medium">{{ m.kickoffAt|date('d. m.') }}</span>
                                        <span>{{ m.kickoffAt|date('H:i') }}</span>
                                    </div>
                                    <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-3 text-sm">
                                        <span class="truncate text-right font-medium text-navy-900">{{ m.homeTeam }}</span>
                                        {% if state == 'finished' %}
                                            <span class="rounded-md bg-navy-50 px-2 py-0.5 text-sm font-bold tabular-nums text-navy-900">{{ m.homeScore }} : {{ m.awayScore }}</span>
                                        {% else %}
                                            <span class="text-xs font-semibold text-navy-900/40">vs</span>
                                        {% endif %}
                                        <span class="truncate font-medium text-navy-900">{{ m.awayTeam }}</span>
                                    </div>
                                    <span class="shrink-0 rounded-full px-2.5 py-0.5 text-xs font-semibold
                                        {%- if state == 'scheduled' %} bg-blue-100 text-blue-800
                                        {%- elseif state == 'live' %} bg-orange-100 text-orange-800 animate-pulse
                                        {%- elseif state == 'finished' %} bg-green-100 text-green-800
                                        {%- elseif state == 'postponed' %} bg-yellow-100 text-yellow-800
                                        {%- else %} bg-gray-200 text-gray-800{% endif %}">
                                        {% if state == 'scheduled' %}Naplánován
                                        {% elseif state == 'live' %}Živě
                                        {% elseif state == 'finished' %}Odehrán
                                        {% elseif state == 'postponed' %}Odložen
                                        {% else %}Zrušen{% endif %}
                                    </span>
                                </a>
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </section>

            {# Groups #}
            <section class="rounded-2xl bg-white shadow-card ring-1 ring-navy-900/5">
                <header class="flex flex-wrap items-center justify-between gap-3 border-b border-navy-100/70 px-6 py-4">
                    <div class="flex items-center gap-2.5">
                        <twig:ux:icon name="lucide:users" class="h-5 w-5 text-cyan-500" />
                        <h2 class="text-lg font-semibold text-navy-900">Skupiny</h2>
                        {% if groups|length > 0 %}
                            <span class="rounded-full bg-navy-50 px-2.5 py-0.5 text-xs font-semibold text-navy-700">{{ groups|length }}</span>
                        {% endif %}
                    </div>
                    {% if canCreateGroup or canUsePinGate %}
                        <a href="{{ path('portal_group_create', {tournamentId: tournament.id.toRfc4122}) }}" class="inline-flex items-center gap-1.5 rounded-lg bg-cyan-500 px-3 py-1.5 text-sm font-semibold text-white transition-colors hover:bg-cyan-600">
                            <twig:ux:icon name="lucide:plus" class="h-4 w-4" />
                            {% if canUsePinGate %}Založit s PINem{% else %}Založit skupinu{% endif %}
                        </a>
                    {% endif %}
                </header>

                {% if groups|length == 0 %}
                    <p class="px-6 py-10 text-center text-sm text-navy-900/60">V tomto turnaji zatím nejsou žádné skupiny.</p>
                {% else %}
                    <ul class="divide-y divide-navy-100/70">
                        {% for g in groups %}
                            <li>
                                <a href="{{ path('portal_group_detail', {id: g.groupId.toRfc4122}) }}" class="flex items-center justify-between gap-3 px-6 py-4 transition-colors hover:bg-navy-50/40">
                                    <div class="min-w-0">
                                        <p class="font-medium text-navy-900">{{ g.groupName }}</p>
                                        <p class="mt-0.5 flex items-center gap-1.5 text-xs text-navy-900/60">
                                            <twig:ux:icon name="lucide:user" class="h-3.5 w-3.5" />{{ g.ownerNickname }}
                                        </p>
                                    </div>
                                    <twig:ux:icon name="lucide:chevron-right" class="h-4 w-4 shrink-0 text-navy-900/40" />
                                </a>
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </section>
        </div>

        {# ───── Sidebar ───── #}
        <aside class="space-y-6 lg:col-span-4">
            {% if is_granted('tournament_edit', tournament) %}
                <section class="rounded-2xl bg-white shadow-card ring-1 ring-navy-900/5">
                    <header class="flex items-center gap-2.5 border-b border-navy-100/70 px-6 py-4">
                        <twig:ux:icon name="lucide:settings" class="h-5 w-5 text-cyan-500" />
                        <h2 class="text-lg font-semibold text-navy-900">Správa turnaje</h2>
                    </header>
                    <div class="space-y-2 px-6 py-5">
                        <a href="{{ path('portal_tournament_edit', {id: tournament.id.toRfc4122}) }}" class="flex w-full items-center gap-2 rounded-lg bg-navy-50 px-4 py-2.5 text-sm font-semibold text-navy-900 transition-colors hover:bg-navy-100">
                            <twig:ux:icon name="lucide:pencil" class="h-4 w-4" />Upravit
                        </a>
                        <a href="{{ path('portal_tournament_rule_configuration', {id: tournament.id.toRfc4122}) }}" class="flex w-full items-center gap-2 rounded-lg bg-navy-50 px-4 py-2.5 text-sm font-semibold text-navy-900 transition-colors hover:bg-navy-100">
                            <twig:ux:icon name="lucide:activity" class="h-4 w-4" />Pravidla
                        </a>

                        {% if is_granted('tournament_finish', tournament) %}
                            <form method="post" action="{{ path('portal_tournament_finish', {id: tournament.id.toRfc4122}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('tournament_finish_' ~ tournament.id.toRfc4122) }}">
                                <button type="submit" class="flex w-full items-center gap-2 rounded-lg bg-yellow-50 px-4 py-2.5 text-sm font-semibold text-yellow-800 transition-colors hover:bg-yellow-100">
                                    <twig:ux:icon name="lucide:award" class="h-4 w-4" />Ukončit turnaj
                                </button>
                            </form>
                        {% endif %}

                        {% if is_granted('tournament_delete', tournament) %}
                            <form method="post" action="{{ path('portal_tournament_delete', {id: tournament.id.toRfc4122}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('tournament_delete_' ~ tournament.id.toRfc4122) }}">
                                <button type="submit" class="flex w-full items-center gap-2 rounded-lg bg-red-50 px-4 py-2.5 text-sm font-semibold text-red-700 transition-colors hover:bg-red-100" onclick="return confirm('Opravdu chcete turnaj smazat?')">
                                    <twig:ux:icon name="lucide:trash-2" class="h-4 w-4" />Smazat turnaj
                                </button>
                            </form>
                        {% endif %}
                    </div>
                </section>
            {% endif %}
        </aside>
    </div>
</div>
{% endblock %}
