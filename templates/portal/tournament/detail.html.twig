{% extends 'base.html.twig' %}

{% block title %}{{ tournament.name }} — Tipovačka{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8">
        <div class="flex items-center gap-3 mb-2">
            <h1 class="text-3xl font-bold text-[#081e44]">{{ tournament.name }}</h1>
            {% if tournament.isPublic %}
                <span class="px-3 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">Veřejný</span>
            {% else %}
                <span class="px-3 py-1 rounded-full text-xs font-medium bg-purple-100 text-purple-800">Soukromý</span>
            {% endif %}
            {% if tournament.isFinished %}
                <span class="px-3 py-1 rounded-full text-xs font-medium bg-gray-200 text-gray-800">Ukončen</span>
            {% endif %}
        </div>
        <p class="text-gray-500">Vlastník: {{ tournament.owner.nickname }}</p>
    </div>

    <div class="bg-white rounded-2xl shadow-lg p-8 mb-6">
        {% if tournament.description %}
            <div class="mb-6 pb-6 border-b border-gray-100">
                <p class="text-sm font-medium text-gray-500 mb-1">Popis</p>
                <p class="text-[#081e44] whitespace-pre-line">{{ tournament.description }}</p>
            </div>
        {% endif %}

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {% if tournament.startAt %}
                <div>
                    <p class="text-sm font-medium text-gray-500 mb-1">Začátek</p>
                    <p class="text-[#081e44]">{{ tournament.startAt|date('d. m. Y H:i') }}</p>
                </div>
            {% endif %}
            {% if tournament.endAt %}
                <div>
                    <p class="text-sm font-medium text-gray-500 mb-1">Konec</p>
                    <p class="text-[#081e44]">{{ tournament.endAt|date('d. m. Y H:i') }}</p>
                </div>
            {% endif %}
        </div>
    </div>

    {% set canCreateGroup = is_granted('tournament_create_group', tournament) %}
    {% set canUsePinGate = not canCreateGroup and app.user and app.user.isVerified and tournament.isActive and tournament.hasCreationPin %}

    <div class="bg-white rounded-2xl shadow-lg p-6 mb-6">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-semibold text-[#081e44]">Skupiny</h2>
            {% if canCreateGroup or canUsePinGate %}
                <a href="{{ path('portal_group_create', {tournamentId: tournament.id.toRfc4122}) }}"
                   class="bg-[#149AD5] hover:bg-[#0f7fb0] text-white py-2 px-4 rounded-lg text-sm font-medium">
                    {% if canUsePinGate %}Založit skupinu s PINem{% else %}Založit skupinu{% endif %}
                </a>
            {% endif %}
        </div>

        {% if groups|length == 0 %}
            <p class="text-sm text-gray-500">V tomto turnaji zatím nejsou žádné skupiny.</p>
        {% else %}
            <ul class="divide-y divide-gray-100">
                {% for g in groups %}
                    <li class="py-3 flex items-center justify-between">
                        <a href="{{ path('portal_group_detail', {id: g.groupId.toRfc4122}) }}"
                           class="flex-1 hover:text-[#149AD5]">
                            <span class="font-medium">{{ g.groupName }}</span>
                            <span class="text-xs text-gray-500 ml-2">{{ g.ownerNickname }}</span>
                        </a>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    </div>

    <div class="bg-white rounded-2xl shadow-lg p-6 mb-6">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-semibold text-[#081e44]">Zápasy</h2>
            {% if is_granted('sport_match_create', tournament) %}
                <div class="flex gap-2">
                    <a href="{{ path('portal_sport_match_create', {tournamentId: tournament.id.toRfc4122}) }}"
                       class="bg-[#081e44] hover:bg-[#0f2d5f] text-white py-2 px-4 rounded-lg text-sm font-medium">
                        Přidat zápas
                    </a>
                    <a href="{{ path('portal_sport_match_import', {tournamentId: tournament.id.toRfc4122}) }}"
                       class="bg-green-600 hover:bg-green-700 text-white py-2 px-4 rounded-lg text-sm font-medium">
                        Nahrát z Excelu/CSV
                    </a>
                </div>
            {% endif %}
        </div>

        {% set matches = sport_matches ?? [] %}
        {% if matches|length == 0 %}
            {% if is_granted('sport_match_create', tournament) %}
                <twig:EmptyState
                    illustration="matches"
                    title="Žádné zápasy v plánu"
                    body="Přidej první zápas ručně, nebo nahraj celý rozpis z Excelu či CSV."
                    ctaLabel="Přidat zápas"
                    ctaPath="{{ path('portal_sport_match_create', {tournamentId: tournament.id.toRfc4122}) }}"
                    secondaryLabel="Nahrát z Excelu/CSV"
                    secondaryPath="{{ path('portal_sport_match_import', {tournamentId: tournament.id.toRfc4122}) }}"
                />
            {% else %}
                <twig:EmptyState
                    illustration="matches"
                    title="Žádné zápasy v plánu"
                    body="Správce brzy přidá zápasy. Můžeš zatím pozvat další kamarády."
                />
            {% endif %}
        {% else %}
            <ul class="divide-y divide-gray-100">
                {% for m in matches %}
                    <li class="py-3 flex items-center justify-between">
                        <a href="{{ path('portal_sport_match_detail', {id: m.id.toRfc4122}) }}"
                           class="flex-1 hover:text-[#149AD5]">
                            <span class="font-medium">{{ m.homeTeam }} vs {{ m.awayTeam }}</span>
                            <span class="text-xs text-gray-500 ml-2">{{ m.kickoffAt|date('d. m. Y H:i') }}</span>
                        </a>
                        <span class="ml-3 text-xs px-2 py-0.5 rounded
                            {% if m.state.value == 'scheduled' %}bg-blue-100 text-blue-800
                            {% elseif m.state.value == 'live' %}bg-orange-100 text-orange-800
                            {% elseif m.state.value == 'finished' %}bg-green-100 text-green-800
                            {% elseif m.state.value == 'postponed' %}bg-yellow-100 text-yellow-800
                            {% else %}bg-gray-200 text-gray-800{% endif %}">
                            {% if m.state.value == 'scheduled' %}Naplánován
                            {% elseif m.state.value == 'live' %}Probíhá
                            {% elseif m.state.value == 'finished' %}{{ m.homeScore }} : {{ m.awayScore }}
                            {% elseif m.state.value == 'postponed' %}Odložen
                            {% else %}Zrušen{% endif %}
                        </span>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    </div>

    {% if is_granted('tournament_edit', tournament) %}
        <div class="bg-white rounded-2xl shadow-lg p-6 mb-6">
            <h2 class="text-lg font-semibold text-[#081e44] mb-4">Správa turnaje</h2>
            <div class="flex flex-wrap gap-3">
                <a
                    href="{{ path('portal_tournament_edit', {id: tournament.id.toRfc4122}) }}"
                    class="bg-[#081e44] hover:bg-[#0f2d5f] text-white py-2 px-4 rounded-lg text-sm font-medium transition-colors"
                >
                    Upravit
                </a>

                <a
                    href="{{ path('portal_tournament_rule_configuration', {id: tournament.id.toRfc4122}) }}"
                    class="bg-[#081e44] hover:bg-[#0f2d5f] text-white py-2 px-4 rounded-lg text-sm font-medium transition-colors"
                >
                    Pravidla
                </a>

                {% if is_granted('tournament_finish', tournament) %}
                    <form method="post" action="{{ path('portal_tournament_finish', {id: tournament.id.toRfc4122}) }}" class="inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('tournament_finish_' ~ tournament.id.toRfc4122) }}">
                        <button
                            type="submit"
                            class="bg-yellow-500 hover:bg-yellow-600 text-white py-2 px-4 rounded-lg text-sm font-medium transition-colors"
                        >
                            Ukončit turnaj
                        </button>
                    </form>
                {% endif %}

                {% if is_granted('tournament_delete', tournament) %}
                    <form method="post" action="{{ path('portal_tournament_delete', {id: tournament.id.toRfc4122}) }}" class="inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('tournament_delete_' ~ tournament.id.toRfc4122) }}">
                        <button
                            type="submit"
                            class="bg-red-600 hover:bg-red-700 text-white py-2 px-4 rounded-lg text-sm font-medium transition-colors"
                            onclick="return confirm('Opravdu chcete turnaj smazat?')"
                        >
                            Smazat turnaj
                        </button>
                    </form>
                {% endif %}
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}
