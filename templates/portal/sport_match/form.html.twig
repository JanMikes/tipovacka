{% extends 'base.html.twig' %}

{% block title %}{{ mode == 'create' ? 'Nový zápas' : 'Upravit zápas' }} — {{ brand_name }}{% endblock %}

{% block body %}
<div class="bg-radial">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        {% if mode == 'create' %}
            <twig:Breadcrumbs :items="[
                {label: 'Nástěnka', path: path('portal_dashboard')},
                {label: tournament.name, path: path('portal_tournament_detail', {id: tournament.id.toRfc4122})},
                {label: 'Nový zápas'},
            ]" />
        {% else %}
            <twig:Breadcrumbs :items="[
                {label: 'Nástěnka', path: path('portal_dashboard')},
                {label: tournament.name, path: path('portal_tournament_detail', {id: tournament.id.toRfc4122})},
                {label: sport_match.homeTeam ~ ' vs ' ~ sport_match.awayTeam, path: path('portal_sport_match_detail', {id: sport_match.id.toRfc4122})},
                {label: 'Upravit zápas'},
            ]" />
        {% endif %}

        <header class="mb-8">
            <p class="eyebrow mb-3">{{ tournament.name }}</p>
            <h1 class="grad-headline text-3xl font-extrabold tracking-tight sm:text-4xl">
                {{ mode == 'create' ? 'Nový zápas' : 'Upravit zápas' }}
            </h1>
        </header>

        <div class="card-glass p-6 sm:p-8">
            {% set action = mode == 'create'
                ? path('portal_sport_match_create', {tournamentId: tournament.id.toRfc4122})
                : path('portal_sport_match_edit', {id: sport_match.id.toRfc4122}) %}

            {{ form_start(form, {action: action, attr: {class: 'space-y-5', novalidate: 'novalidate'}}) }}

                <div class="field">
                    {{ form_label(form.homeTeam, null, {label_attr: {class: 'field-label'}}) }}
                    {{ form_widget(form.homeTeam, {attr: {class: 'input'}}) }}
                    {{ form_errors(form.homeTeam) }}
                </div>

                <div class="field">
                    {{ form_label(form.awayTeam, null, {label_attr: {class: 'field-label'}}) }}
                    {{ form_widget(form.awayTeam, {attr: {class: 'input'}}) }}
                    {{ form_errors(form.awayTeam) }}
                </div>

                <div class="field">
                    {{ form_label(form.kickoffAt, null, {label_attr: {class: 'field-label'}}) }}
                    {{ form_widget(form.kickoffAt, {attr: {class: 'input'}}) }}
                    {{ form_errors(form.kickoffAt) }}
                </div>

                <div class="field">
                    {{ form_label(form.venue, null, {label_attr: {class: 'field-label'}}) }}
                    {{ form_widget(form.venue, {attr: {class: 'input'}}) }}
                    {{ form_errors(form.venue) }}
                </div>

                <div class="flex flex-wrap gap-3 pt-2">
                    <button type="submit" class="btn btn-primary">
                        <twig:ux:icon name="lucide:{{ mode == 'create' ? 'plus' : 'save' }}" class="h-4 w-4" />
                        {{ mode == 'create' ? 'Vytvořit zápas' : 'Uložit změny' }}
                    </button>
                    <a href="{{ path('portal_tournament_detail', {id: tournament.id.toRfc4122}) }}" class="btn btn-ghost">
                        Zrušit
                    </a>
                </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
