{% extends 'base.html.twig' %}

{% block title %}{{ mode == 'create' ? 'Nový zápas' : 'Upravit zápas' }} — {{ brand_name }}{% endblock %}

{% block body %}
<div class="bg-radial">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        {% if mode == 'create' %}
            <twig:Breadcrumbs :items="[
                {label: 'Nástěnka', path: path('portal_dashboard')},
                {label: match_source.name, path: path('portal_match_source_detail', {id: match_source.id.toRfc4122})},
                {label: 'Nový zápas'},
            ]" />
        {% else %}
            <twig:Breadcrumbs :items="[
                {label: 'Nástěnka', path: path('portal_dashboard')},
                {label: match_source.name, path: path('portal_match_source_detail', {id: match_source.id.toRfc4122})},
                {label: sport_match.homeTeam ~ ' vs ' ~ sport_match.awayTeam, path: path('portal_sport_match_detail', {id: sport_match.id.toRfc4122})},
                {label: 'Upravit zápas'},
            ]" />
        {% endif %}

        <header class="mb-8">
            <p class="eyebrow mb-3">{{ match_source.name }}</p>
            <h1 class="grad-headline text-3xl font-extrabold tracking-tight sm:text-4xl">
                {{ mode == 'create' ? 'Nový zápas' : 'Upravit zápas' }}
            </h1>
        </header>

        <div class="card-glass p-6 sm:p-8">
            {% set action = mode == 'create'
                ? path('portal_sport_match_create', {matchSourceId: match_source.id.toRfc4122})
                : path('portal_sport_match_edit', {id: sport_match.id.toRfc4122}) %}

            {{ form_start(form, {action: action, attr: {class: 'space-y-5', novalidate: 'novalidate'}}) }}

                <div class="field">
                    {{ form_label(form.homeTeam, null, {label_attr: {class: 'field-label'}}) }}
                    {{ form_widget(form.homeTeam, {attr: {class: 'input'}}) }}
                    {{ form_errors(form.homeTeam) }}
                </div>

                <div class="field">
                    {{ form_label(form.awayTeam, null, {label_attr: {class: 'field-label'}}) }}
                    {{ form_widget(form.awayTeam, {attr: {class: 'input'}}) }}
                    {{ form_errors(form.awayTeam) }}
                </div>

                <div class="field">
                    {{ form_label(form.kickoffAt, null, {label_attr: {class: 'field-label'}}) }}
                    {{ form_widget(form.kickoffAt, {attr: {class: 'input'}}) }}
                    {{ form_errors(form.kickoffAt) }}
                </div>

                <div class="field">
                    {{ form_label(form.venue, null, {label_attr: {class: 'field-label'}}) }}
                    {{ form_widget(form.venue, {attr: {class: 'input'}}) }}
                    {{ form_errors(form.venue) }}
                </div>

                <div class="field">
                    {{ form_label(form.round, null, {label_attr: {class: 'field-label'}}) }}
                    {{ form_widget(form.round, {attr: {class: 'input'}}) }}
                    {% if form.round.vars.help %}<p class="text-xs text-white/50">{{ form.round.vars.help }}</p>{% endif %}
                    {{ form_errors(form.round) }}
                </div>

                <div>
                    <label class="flex cursor-pointer items-start gap-3">
                        {{ form_widget(form.isPlayoff, {attr: {class: 'mt-0.5 h-5 w-5 shrink-0 rounded border-white/20 bg-inset text-accent-500 focus:ring-accent-500'}}) }}
                        <span class="text-sm">
                            <span class="block font-medium text-white">{{ form.isPlayoff.vars.label }}</span>
                            {% if form.isPlayoff.vars.help %}
                                <span class="mt-1 block text-xs leading-relaxed text-white/50">{{ form.isPlayoff.vars.help }}</span>
                            {% endif %}
                        </span>
                    </label>
                    {{ form_errors(form.isPlayoff) }}
                </div>

                <div class="flex flex-wrap gap-3 pt-2">
                    <button type="submit" class="btn btn-primary">
                        <twig:ux:icon name="lucide:{{ mode == 'create' ? 'plus' : 'save' }}" class="h-4 w-4" />
                        {{ mode == 'create' ? 'Vytvořit zápas' : 'Uložit změny' }}
                    </button>
                    <a href="{{ path('portal_match_source_detail', {id: match_source.id.toRfc4122}) }}" class="btn btn-ghost">
                        Zrušit
                    </a>
                </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
