{% extends 'base.html.twig' %}

{% block title %}{{ mode == 'create' ? 'Nový zápas' : 'Upravit zápas' }} — Tipovačka{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-[#081e44]">
            {{ mode == 'create' ? 'Nový zápas' : 'Upravit zápas' }}
        </h1>
        <p class="text-gray-500 mt-1">Turnaj: {{ tournament.name }}</p>
    </div>

    <div class="bg-white rounded-2xl shadow-lg p-8">
        {% set action = mode == 'create'
            ? path('portal_sport_match_create', {tournamentId: tournament.id.toRfc4122})
            : path('portal_sport_match_edit', {id: sport_match.id.toRfc4122}) %}

        {{ form_start(form, {action: action, attr: {class: 'space-y-5', novalidate: 'novalidate'}}) }}

            <div>
                {{ form_label(form.homeTeam) }}
                {{ form_widget(form.homeTeam, {attr: {class: 'w-full px-4 py-2.5 border border-gray-300 rounded-lg'}}) }}
                {{ form_errors(form.homeTeam) }}
            </div>

            <div>
                {{ form_label(form.awayTeam) }}
                {{ form_widget(form.awayTeam, {attr: {class: 'w-full px-4 py-2.5 border border-gray-300 rounded-lg'}}) }}
                {{ form_errors(form.awayTeam) }}
            </div>

            <div>
                {{ form_label(form.kickoffAt) }}
                {{ form_widget(form.kickoffAt, {attr: {class: 'w-full px-4 py-2.5 border border-gray-300 rounded-lg'}}) }}
                {{ form_errors(form.kickoffAt) }}
            </div>

            <div>
                {{ form_label(form.venue) }}
                {{ form_widget(form.venue, {attr: {class: 'w-full px-4 py-2.5 border border-gray-300 rounded-lg'}}) }}
                {{ form_errors(form.venue) }}
            </div>

            <div class="flex gap-3">
                <button type="submit" class="bg-[#081e44] hover:bg-[#0f2d5f] text-white py-3 px-6 rounded-lg font-medium">
                    {{ mode == 'create' ? 'Vytvořit zápas' : 'Uložit změny' }}
                </button>
                <a href="{{ path('portal_tournament_detail', {id: tournament.id.toRfc4122}) }}"
                   class="bg-gray-100 hover:bg-gray-200 text-gray-700 py-3 px-6 rounded-lg font-medium">
                    Zrušit
                </a>
            </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
