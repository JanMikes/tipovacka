{% extends 'base.html.twig' %}

{% block title %}Zapsat výsledek — {{ brand_name }}{% endblock %}

{% macro event_row(row) %}
    <div class="flex flex-wrap items-center gap-2 rounded-xl border border-white/[0.06] bg-white/[0.03] p-2" data-score-entry-target="eventRow">
        {{ form_widget(row.type, {attr: {class: 'input w-auto shrink-0', 'data-role': 'type', 'data-action': 'score-entry#rowChanged'}}) }}
        {{ form_widget(row.side, {attr: {class: 'input w-auto shrink-0', 'data-role': 'side', 'data-action': 'score-entry#sideChanged'}}) }}
        {{ form_widget(row.minute, {attr: {class: 'input w-20 shrink-0 text-center', 'data-role': 'minute', placeholder: 'min', min: 0, max: 150}}) }}
        <span class="min-w-[12rem] flex-1">
            {{ form_widget(row.playerName, {attr: {class: 'input w-full', 'data-role': 'player', placeholder: 'Jméno hráče…', autocomplete: 'off'}}) }}
        </span>
        <button type="button" class="btn btn-ghost btn-sm shrink-0 px-2" data-action="score-entry#removeRow" title="Odebrat řádek" aria-label="Odebrat řádek">
            <twig:ux:icon name="lucide:x" class="h-4 w-4" />
        </button>
        {{ form_errors(row.minute) }}
        {{ form_errors(row.playerName) }}
    </div>
{% endmacro %}

{% import _self as ui %}

{% block body %}
<div class="bg-radial">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <twig:Breadcrumbs :items="[
            {label: 'Nástěnka', path: path('portal_dashboard')},
            {label: sport_match.matchSource.name, path: path('portal_match_source_detail', {id: sport_match.matchSource.id.toRfc4122})},
            {label: sport_match.homeTeam ~ ' vs ' ~ sport_match.awayTeam, path: path('portal_sport_match_detail', {id: sport_match.id.toRfc4122})},
            {label: 'Výsledek'},
        ]" />

        <header class="mb-8">
            <p class="eyebrow mb-3">{{ sport_match.matchSource.name }}</p>
            <h1 class="grad-headline text-3xl font-extrabold tracking-tight sm:text-4xl">Zapsat výsledek</h1>
            <p class="mt-2 text-sm text-white/60">{{ sport_match.homeTeam }} vs. {{ sport_match.awayTeam }}</p>
        </header>

        {% set prototype_html %}{{ ui.event_row(form.events.vars.prototype) }}{% endset %}

        <div
            data-controller="score-entry"
            data-score-entry-players-url-value="{{ path('portal_match_source_players', {id: sport_match.matchSource.id.toRfc4122}) }}"
            data-score-entry-home-team-value="{{ sport_match.homeTeam }}"
            data-score-entry-away-team-value="{{ sport_match.awayTeam }}"
            data-score-entry-prototype-value="{{ prototype_html|e('html_attr') }}"
        >
            <div class="card-glass p-6 sm:p-8">
                {{ form_start(form, {attr: {class: 'space-y-8', novalidate: 'novalidate'}}) }}

                    {{ form_errors(form) }}

                    {# ── State: Probíhá / Ukončený toggle, or a static pill when
                          the match can no longer run live (finished correction) ── #}
                    {% if allow_live %}
                        <div class="field">
                            <span class="field-label">Stav zápasu</span>
                            <div class="grid grid-cols-2 gap-2">
                                {% for child in form.state %}
                                    <label class="cursor-pointer">
                                        {{ form_widget(child, {attr: {class: 'peer sr-only', 'data-action': 'score-entry#stateChanged'}}) }}
                                        <span class="flex items-center justify-center gap-2 rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-sm font-semibold text-white/60 transition-colors peer-checked:border-accent-400 peer-checked:bg-accent-500/15 peer-checked:text-white">
                                            {{ child.vars.label }}
                                        </span>
                                    </label>
                                {% endfor %}
                            </div>
                            {% do form.state.setRendered %}
                            {{ form_errors(form.state) }}
                        </div>
                    {% else %}
                        <div class="field">
                            <span class="field-label">Stav zápasu</span>
                            <div>
                                <twig:Pill label="Ukončený" variant="done" icon="check" />
                            </div>
                            {% do form.state.setRendered %}
                            {{ form_errors(form.state) }}
                        </div>
                    {% endif %}

                    {# ── Score steppers ─────────────────────────────────────── #}
                    <div class="grid grid-cols-[1fr_auto_1fr] items-start gap-4 text-center">
                        <div class="field items-center">
                            <twig:TeamFlag :name="sport_match.homeTeam" size="48" />
                            <span class="field-label normal-case tracking-normal text-sm font-semibold text-white/80">{{ sport_match.homeTeam }}</span>
                            <div class="flex items-center justify-center gap-1.5">
                                <button type="button" class="btn btn-ghost btn-sm px-2" data-action="score-entry#step" data-score-entry-side-param="home" data-score-entry-delta-param="-1" aria-label="Ubrat gól domácím">
                                    <twig:ux:icon name="lucide:minus" class="h-4 w-4" />
                                </button>
                                {{ form_widget(form.homeScore, {attr: {class: 'score-input', style: 'width:72px;height:56px;font-size:26px', 'data-score-entry-target': 'homeScore', 'data-action': 'input->score-entry#scoreChanged'}}) }}
                                <button type="button" class="btn btn-ghost btn-sm px-2" data-action="score-entry#step" data-score-entry-side-param="home" data-score-entry-delta-param="1" aria-label="Přidat gól domácím">
                                    <twig:ux:icon name="lucide:plus" class="h-4 w-4" />
                                </button>
                            </div>
                            {{ form_errors(form.homeScore) }}
                        </div>

                        <div class="flex h-full items-center pt-14 text-3xl font-black text-white/30">:</div>

                        <div class="field items-center">
                            <twig:TeamFlag :name="sport_match.awayTeam" size="48" />
                            <span class="field-label normal-case tracking-normal text-sm font-semibold text-white/80">{{ sport_match.awayTeam }}</span>
                            <div class="flex items-center justify-center gap-1.5">
                                <button type="button" class="btn btn-ghost btn-sm px-2" data-action="score-entry#step" data-score-entry-side-param="away" data-score-entry-delta-param="-1" aria-label="Ubrat gól hostům">
                                    <twig:ux:icon name="lucide:minus" class="h-4 w-4" />
                                </button>
                                {{ form_widget(form.awayScore, {attr: {class: 'score-input', style: 'width:72px;height:56px;font-size:26px', 'data-score-entry-target': 'awayScore', 'data-action': 'input->score-entry#scoreChanged'}}) }}
                                <button type="button" class="btn btn-ghost btn-sm px-2" data-action="score-entry#step" data-score-entry-side-param="away" data-score-entry-delta-param="1" aria-label="Přidat gól hostům">
                                    <twig:ux:icon name="lucide:plus" class="h-4 w-4" />
                                </button>
                            </div>
                            {{ form_errors(form.awayScore) }}
                        </div>
                    </div>

                    {# ── Period scores (labels per sport) ───────────────────── #}
                    <fieldset class="field">
                        <legend class="field-label">{{ sport.periodLabelPlural|capitalize }} <span class="font-normal normal-case text-white/40">(nepovinné)</span></legend>
                        <div class="space-y-2">
                            {% for periodForm in form.periods %}
                                <div class="flex items-center gap-3">
                                    <span class="w-28 shrink-0 text-sm text-white/70">{{ loop.index }}. {{ sport.periodLabelSingular }}</span>
                                    {{ form_widget(periodForm.homeScore, {attr: {class: 'input w-16 text-center'}}) }}
                                    <span class="text-white/40">:</span>
                                    {{ form_widget(periodForm.awayScore, {attr: {class: 'input w-16 text-center'}}) }}
                                    {{ form_errors(periodForm.homeScore) }}
                                    {{ form_errors(periodForm.awayScore) }}
                                </div>
                            {% endfor %}
                        </div>
                        {% do form.periods.setRendered %}
                        {{ form_errors(form.periods) }}
                    </fieldset>

                    {# ── Overtime (revealed only on a regular-time draw) ────── #}
                    <fieldset class="field hidden" data-score-entry-target="overtime">
                        <legend class="field-label">Po prodloužení / nájezdech</legend>
                        <p class="mb-2 text-xs text-white/50">Konečný výsledek včetně prodloužení — remíza v základní hrací době zůstává hlavním výsledkem pro tipy.</p>
                        <div class="flex items-center gap-3">
                            <span class="w-28 shrink-0 text-sm text-white/70">Konečný stav</span>
                            {{ form_widget(form.overtimeHomeScore, {attr: {class: 'input w-16 text-center', 'data-score-entry-target': 'overtimeHome'}}) }}
                            <span class="text-white/40">:</span>
                            {{ form_widget(form.overtimeAwayScore, {attr: {class: 'input w-16 text-center', 'data-score-entry-target': 'overtimeAway'}}) }}
                        </div>
                        {{ form_errors(form.overtimeHomeScore) }}
                        {{ form_errors(form.overtimeAwayScore) }}
                    </fieldset>

                    {# ── Scorers & cards ────────────────────────────────────── #}
                    <fieldset class="field">
                        <legend class="field-label">Střelci</legend>
                        <div class="space-y-2" data-score-entry-target="eventsList">
                            {% for row in form.events %}
                                {{ ui.event_row(row) }}
                            {% endfor %}
                        </div>
                        {% do form.events.setRendered %}
                        {{ form_errors(form.events) }}

                        <div class="mt-3 flex flex-wrap gap-2">
                            <button type="button" class="btn btn-ghost btn-sm" data-action="score-entry#addGoal" data-score-entry-side-param="home">
                                <twig:ux:icon name="lucide:plus" class="h-4 w-4" />Gól {{ sport_match.homeTeam }}
                            </button>
                            <button type="button" class="btn btn-ghost btn-sm" data-action="score-entry#addGoal" data-score-entry-side-param="away">
                                <twig:ux:icon name="lucide:plus" class="h-4 w-4" />Gól {{ sport_match.awayTeam }}
                            </button>
                            <button type="button" class="btn btn-ghost btn-sm" data-action="score-entry#addCard">
                                <twig:ux:icon name="lucide:plus" class="h-4 w-4" />Karta
                            </button>
                        </div>

                        <p class="mt-3 hidden text-xs text-draw" data-score-entry-target="warning">
                            <twig:ux:icon name="lucide:triangle-alert" class="-mt-px mr-1 inline h-3.5 w-3.5" />Počet gólů v seznamu střelců neodpovídá zadanému skóre. Uložit můžete i tak.
                        </p>
                    </fieldset>

                    {# ── Last match of the source ───────────────────────────── #}
                    {% if not sport_match.matchSource.isCompleted %}
                        <div class="hidden" data-score-entry-target="finishOnly">
                            <label class="flex cursor-pointer items-start gap-3 rounded-xl border border-white/[0.08] bg-white/[0.03] p-4">
                                {{ form_widget(form.isLastMatch, {attr: {class: 'mt-0.5'}}) }}
                                <span>
                                    <span class="block text-sm font-semibold text-white">Toto byl poslední zápas zdroje</span>
                                    <span class="mt-0.5 block text-xs text-white/50">Zdroj zápasů se označí jako ukončený a soutěže nad ním mohou být vyhodnoceny jako dohrané.</span>
                                </span>
                            </label>
                        </div>
                    {% else %}
                        {% do form.isLastMatch.setRendered %}
                    {% endif %}

                    <div class="flex flex-wrap gap-3 pt-2">
                        <button type="submit" class="btn btn-success">
                            <twig:ux:icon name="lucide:check" class="h-4 w-4" />
                            Uložit
                        </button>
                        <a href="{{ path('portal_sport_match_detail', {id: sport_match.id.toRfc4122}) }}" class="btn btn-ghost">
                            Zrušit
                        </a>
                    </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
