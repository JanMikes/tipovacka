{% extends 'base.html.twig' %}

{% block title %}Skóre zápasu — Tipovačka{% endblock %}

{% block body %}
<div class="max-w-lg mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-navy-900">Výsledek zápasu</h1>
        <p class="text-navy-900/60 mt-1">{{ sport_match.homeTeam }} vs. {{ sport_match.awayTeam }}</p>
    </div>

    <div class="bg-white rounded-2xl shadow-card ring-1 ring-navy-900/5 p-8">
        {{ form_start(form, {attr: {class: 'space-y-5', novalidate: 'novalidate'}}) }}

            <div class="grid grid-cols-2 gap-4">
                <div>
                    {{ form_label(form.homeScore) }}
                    {{ form_widget(form.homeScore, {attr: {class: 'w-full px-4 py-2.5 border border-navy-100 rounded-lg'}}) }}
                    {{ form_errors(form.homeScore) }}
                </div>

                <div>
                    {{ form_label(form.awayScore) }}
                    {{ form_widget(form.awayScore, {attr: {class: 'w-full px-4 py-2.5 border border-navy-100 rounded-lg'}}) }}
                    {{ form_errors(form.awayScore) }}
                </div>
            </div>

            <div class="flex gap-3">
                <button type="submit" class="bg-navy-900 hover:bg-navy-700 text-white py-3 px-6 rounded-lg font-medium">
                    Uložit skóre
                </button>
                <a href="{{ path('portal_sport_match_detail', {id: sport_match.id.toRfc4122}) }}"
                   class="bg-navy-50 hover:bg-navy-100 text-navy-900 py-3 px-6 rounded-lg font-medium">
                    Zrušit
                </a>
            </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
