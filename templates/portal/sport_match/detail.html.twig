{% extends 'base.html.twig' %}

{% block title %}{{ sport_match.homeTeam }} vs {{ sport_match.awayTeam }} — Tipovačka{% endblock %}

{% block body %}
<div class="mx-auto w-full max-w-5xl px-4 py-8 sm:px-6 sm:py-12 lg:px-8">

    {# Breadcrumb #}
    <nav class="mb-4 flex items-center gap-1.5 text-sm text-navy-900/60" aria-label="Breadcrumb">
        <a href="{{ path('portal_dashboard') }}" class="hover:text-cyan-600">Nástěnka</a>
        <twig:ux:icon name="lucide:chevron-right" class="h-4 w-4" />
        <a href="{{ path('portal_tournament_detail', {id: sport_match.tournament.id.toRfc4122}) }}" class="truncate hover:text-cyan-600">{{ sport_match.tournament.name }}</a>
        <twig:ux:icon name="lucide:chevron-right" class="h-4 w-4" />
        <span class="truncate text-navy-900/80">{{ sport_match.homeTeam }} vs {{ sport_match.awayTeam }}</span>
    </nav>

    {# Hero card #}
    <section class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-navy-900 via-navy-800 to-navy-700 p-6 text-white shadow-card sm:p-8">
        <div aria-hidden="true" class="pointer-events-none absolute -right-16 -top-16 h-60 w-60 rounded-full bg-cyan-500/15 blur-3xl"></div>

        <div class="relative flex flex-wrap items-start justify-between gap-3">
            <span class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-semibold
                {% if sport_match.isScheduled %}bg-blue-500/20 text-blue-300
                {% elseif sport_match.isLive %}bg-orange-500/20 text-orange-300 animate-pulse
                {% elseif sport_match.isFinished %}bg-green-500/20 text-green-300
                {% elseif sport_match.isPostponed %}bg-yellow-500/20 text-yellow-300
                {% else %}bg-white/10 text-white{% endif %}">
                {% if sport_match.isScheduled %}Naplánován
                {% elseif sport_match.isLive %}Živě
                {% elseif sport_match.isFinished %}Odehrán
                {% elseif sport_match.isPostponed %}Odložen
                {% else %}Zrušen{% endif %}
            </span>
            <span class="inline-flex items-center gap-1.5 text-sm text-white/75">
                <twig:ux:icon name="lucide:clock" class="h-4 w-4" />
                {{ sport_match.kickoffAt|date('d. m. Y H:i') }}
            </span>
        </div>

        <div class="relative mt-6 grid grid-cols-[1fr_auto_1fr] items-center gap-4 text-center">
            <div>
                <p class="text-xs font-semibold uppercase tracking-wider text-white/50">Domácí</p>
                <p class="mt-1 text-xl font-bold sm:text-2xl">{{ sport_match.homeTeam }}</p>
            </div>
            {% if sport_match.isFinished %}
                <p class="rounded-xl bg-white/10 px-4 py-2 text-3xl font-bold tabular-nums backdrop-blur sm:text-4xl">
                    {{ sport_match.homeScore }} : {{ sport_match.awayScore }}
                </p>
            {% else %}
                <p class="text-sm font-semibold text-white/50">vs</p>
            {% endif %}
            <div>
                <p class="text-xs font-semibold uppercase tracking-wider text-white/50">Hosté</p>
                <p class="mt-1 text-xl font-bold sm:text-2xl">{{ sport_match.awayTeam }}</p>
            </div>
        </div>

        {% if sport_match.venue %}
            <p class="relative mt-6 flex items-center justify-center gap-1.5 text-sm text-white/70">
                <twig:ux:icon name="lucide:info" class="h-4 w-4" />
                {{ sport_match.venue }}
            </p>
        {% endif %}
    </section>

    {# Inline per-group guess cards #}
    {% set my_groups = my_groups_for_tournament|default([]) %}
    {% if my_groups|length > 0 %}
        <section class="mt-8">
            <header class="mb-4 flex flex-wrap items-center justify-between gap-3">
                <h2 class="flex items-center gap-2 text-xl font-semibold text-navy-900">
                    <twig:ux:icon name="lucide:target" class="h-5 w-5 text-cyan-500" />
                    Tvoje tipy
                    <span class="rounded-full bg-navy-50 px-2.5 py-0.5 text-xs font-semibold text-navy-700">{{ my_groups|length }}</span>
                </h2>
                <p class="text-xs text-navy-900/60">Tipuj zvlášť za každou skupinu, ve které jsi.</p>
            </header>

            <ul class="grid grid-cols-1 gap-4 {% if my_groups|length > 1 %}md:grid-cols-2{% endif %}">
                {% for g in my_groups %}
                    <li>
                        <article class="flex h-full flex-col overflow-hidden rounded-2xl bg-white shadow-card ring-1 ring-navy-900/5">
                            <header class="flex items-center justify-between gap-3 border-b border-navy-100/70 px-5 py-3">
                                <div class="flex min-w-0 items-center gap-2">
                                    <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-cyan-100 text-cyan-600">
                                        <twig:ux:icon name="lucide:users" class="h-4 w-4" />
                                    </span>
                                    <a href="{{ path('portal_group_detail', {id: g.id.toRfc4122}) }}" class="truncate font-semibold text-navy-900 transition-colors hover:text-cyan-600">
                                        {{ g.name }}
                                    </a>
                                </div>
                                <a href="{{ path('portal_group_sport_match_guesses', {groupId: g.id.toRfc4122, sportMatchId: sport_match.id.toRfc4122}) }}" class="inline-flex shrink-0 items-center gap-1 text-xs font-medium text-cyan-600 hover:text-cyan-700" title="Zobrazit tipy členů skupiny">
                                    Tipy členů
                                    <twig:ux:icon name="lucide:chevron-right" class="h-3.5 w-3.5" />
                                </a>
                            </header>

                            <div class="flex-1 p-5">
                                <twig:Guess:GuessSubmitForm
                                    sportMatch="{{ sport_match }}"
                                    groupId="{{ g.id.toRfc4122 }}"
                                    class="!rounded-none !bg-transparent !p-0 !shadow-none !ring-0"
                                />
                            </div>
                        </article>
                    </li>
                {% endfor %}
            </ul>
        </section>
    {% endif %}

    {# Match management (admins only) #}
    {% set can_edit   = is_granted('sport_match_edit', sport_match) %}
    {% set can_score  = is_granted('sport_match_set_score', sport_match) %}
    {% set can_cancel = is_granted('sport_match_cancel', sport_match) %}
    {% set can_delete = is_granted('sport_match_delete', sport_match) %}

    {% if can_edit or can_score or can_cancel or can_delete %}
        <section class="mt-8 rounded-2xl bg-white shadow-card ring-1 ring-navy-900/5">
            <header class="flex items-center gap-2.5 border-b border-navy-100/70 px-6 py-4">
                <twig:ux:icon name="lucide:settings" class="h-5 w-5 text-cyan-500" />
                <h2 class="text-lg font-semibold text-navy-900">Správa zápasu</h2>
            </header>
            <div class="flex flex-wrap gap-3 px-6 py-5">
                {% if can_edit %}
                    <a href="{{ path('portal_sport_match_edit', {id: sport_match.id.toRfc4122}) }}" class="inline-flex items-center gap-1.5 rounded-lg bg-navy-50 px-4 py-2 text-sm font-semibold text-navy-900 transition-colors hover:bg-navy-100">
                        <twig:ux:icon name="lucide:pencil" class="h-4 w-4" />Upravit
                    </a>
                {% endif %}

                {% if can_score %}
                    <a href="{{ path('portal_sport_match_set_score', {id: sport_match.id.toRfc4122}) }}" class="inline-flex items-center gap-1.5 rounded-lg bg-green-600 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-green-700">
                        <twig:ux:icon name="lucide:check" class="h-4 w-4" />
                        {{ sport_match.isFinished ? 'Upravit skóre' : 'Zadat skóre' }}
                    </a>
                {% endif %}

                {% if can_edit and (sport_match.isScheduled or sport_match.isPostponed) %}
                    <form method="post" action="{{ path('portal_sport_match_postpone', {id: sport_match.id.toRfc4122}) }}" class="inline-flex items-center gap-2">
                        <input type="hidden" name="_token" value="{{ csrf_token('sport_match_postpone_' ~ sport_match.id.toRfc4122) }}">
                        <input type="datetime-local" name="new_kickoff_at" required class="rounded-lg border border-navy-100 px-2 py-1.5 text-sm outline-none focus:border-transparent focus:ring-2 focus:ring-cyan-500">
                        <button type="submit" class="inline-flex items-center gap-1.5 rounded-lg bg-yellow-500 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-yellow-600">
                            <twig:ux:icon name="lucide:clock" class="h-4 w-4" />Odložit
                        </button>
                    </form>
                {% endif %}

                {% if can_edit and sport_match.isPostponed %}
                    <form method="post" action="{{ path('portal_sport_match_reschedule', {id: sport_match.id.toRfc4122}) }}" class="inline-flex items-center gap-2">
                        <input type="hidden" name="_token" value="{{ csrf_token('sport_match_reschedule_' ~ sport_match.id.toRfc4122) }}">
                        <input type="datetime-local" name="new_kickoff_at" required class="rounded-lg border border-navy-100 px-2 py-1.5 text-sm outline-none focus:border-transparent focus:ring-2 focus:ring-cyan-500">
                        <button type="submit" class="inline-flex items-center gap-1.5 rounded-lg bg-blue-500 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-blue-600">
                            <twig:ux:icon name="lucide:calendar" class="h-4 w-4" />Přesunout zpět
                        </button>
                    </form>
                {% endif %}

                {% if can_cancel and not sport_match.isFinished and not sport_match.isCancelled %}
                    <form method="post" action="{{ path('portal_sport_match_cancel', {id: sport_match.id.toRfc4122}) }}" class="inline"
                        data-controller="confirm"
                        data-confirm-variant-value="warning"
                        data-confirm-title-value="Zrušit zápas"
                        data-confirm-message-value="Opravdu chceš zápas {{ sport_match.homeTeam }} – {{ sport_match.awayTeam }} zrušit? Tipy na něj nebudou bodovány."
                        data-confirm-confirm-label-value="Ano, zrušit">
                        <input type="hidden" name="_token" value="{{ csrf_token('sport_match_cancel_' ~ sport_match.id.toRfc4122) }}">
                        <button type="submit" class="inline-flex items-center gap-1.5 rounded-lg bg-orange-500 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-orange-600">
                            <twig:ux:icon name="lucide:circle-x" class="h-4 w-4" />Zrušit zápas
                        </button>
                    </form>
                {% endif %}

                {% if can_delete %}
                    <form method="post" action="{{ path('portal_sport_match_delete', {id: sport_match.id.toRfc4122}) }}" class="inline"
                        data-controller="confirm"
                        data-confirm-title-value="Smazat zápas"
                        data-confirm-message-value="Opravdu chceš zápas {{ sport_match.homeTeam }} – {{ sport_match.awayTeam }} smazat? Všechny tipy na něj zmizí."
                        data-confirm-confirm-label-value="Ano, smazat">
                        <input type="hidden" name="_token" value="{{ csrf_token('sport_match_delete_' ~ sport_match.id.toRfc4122) }}">
                        <button type="submit" class="inline-flex items-center gap-1.5 rounded-lg bg-red-50 px-4 py-2 text-sm font-semibold text-red-700 transition-colors hover:bg-red-100">
                            <twig:ux:icon name="lucide:trash-2" class="h-4 w-4" />Smazat
                        </button>
                    </form>
                {% endif %}
            </div>
        </section>
    {% endif %}
</div>
{% endblock %}
