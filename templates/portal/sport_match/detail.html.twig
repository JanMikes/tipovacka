{% extends 'base.html.twig' %}

{% block title %}{{ sport_match.homeTeam }} vs {{ sport_match.awayTeam }} — {{ brand_name }}{% endblock %}

{% block body %}
<div class="bg-radial">
    <div class="mx-auto w-full max-w-5xl px-4 py-8 sm:px-6 sm:py-12 lg:px-8">

        <twig:Breadcrumbs :items="[
            {label: 'Nástěnka', path: path('portal_dashboard')},
            {label: sport_match.matchSource.name, path: path('portal_match_source_detail', {id: sport_match.matchSource.id.toRfc4122})},
            {label: sport_match.homeTeam ~ ' vs ' ~ sport_match.awayTeam},
        ]" />

        {# Hero card #}
        <section class="card-glass relative overflow-hidden p-6 text-white sm:p-8">
            <div class="tip-head">
                <div class="tip-stage">
                    <span class="round">{{ sport_match.matchSource.name }}</span>
                    <span class="when">{{ sport_match.kickoffAt|date('j. n. Y') }} · {{ sport_match.kickoffAt|date('H:i') }}</span>
                </div>

                {% if sport_match.isFinished %}
                    <twig:Pill label="Odehrán" variant="done" icon="check" />
                {% elseif sport_match.isCancelled %}
                    <twig:Pill label="Zrušen" variant="locked" icon="circle-x" />
                {% elseif sport_match.isPostponed %}
                    <twig:Pill label="Odložen" variant="warn" icon="triangle-alert" />
                {% elseif sport_match.isLive %}
                    {# No live state is surfaced (cut) — an in-progress match is simply locked. #}
                    <twig:Pill label="Uzamčeno" variant="locked" icon="lock" />
                {% else %}
                    <twig:Pill label="Naplánován" variant="soon" dot="true" />
                {% endif %}
            </div>

            <div class="tip-teams mt-6">
                <div class="tip-team">
                    <twig:TeamFlag :name="sport_match.homeTeam" size="56" />
                    <span class="name">{{ sport_match.homeTeam }}</span>
                </div>

                {% if sport_match.isFinished or (sport_match.isLive and sport_match.homeScore is not null) %}
                    <div class="final-score text-white">
                        <span class="sc">{{ sport_match.homeScore }}</span>
                        <span class="sep">:</span>
                        <span class="sc">{{ sport_match.awayScore }}</span>
                    </div>
                {% else %}
                    <div class="tip-vs">vs</div>
                {% endif %}

                <div class="tip-team">
                    <twig:TeamFlag :name="sport_match.awayTeam" size="56" />
                    <span class="name">{{ sport_match.awayTeam }}</span>
                </div>
            </div>

            {% if not sport_match.isCancelled and (sport_match.periodScores is not null or sport_match.hasOvertimeScore) %}
                <p class="mt-3 text-center text-xs text-white/50">
                    {%- if sport_match.periodScores is not null -%}
                        ({% for p in sport_match.periodScores.toArray %}{{ p[0] }}:{{ p[1] }}{% if not loop.last %}, {% endif %}{% endfor %})
                    {%- endif -%}
                    {%- if sport_match.hasOvertimeScore %} po prodl. {{ sport_match.overtimeHomeScore }}:{{ sport_match.overtimeAwayScore }}{% endif -%}
                </p>
            {% endif %}

            {% if sport_match.venue %}
                <p class="mt-6 inline-flex items-center gap-1.5 text-xs text-white/50">
                    <twig:ux:icon name="lucide:building-2" class="h-3.5 w-3.5" />
                    {{ sport_match.venue }}
                </p>
            {% endif %}
        </section>

        {# Match timeline (visible to everyone once events exist; cancelled matches show no live data) #}
        {% if not sport_match.isCancelled %}
            {% include 'portal/sport_match/_timeline.html.twig' with {sport_match: sport_match, match_events: match_events|default([])} only %}
        {% endif %}

        {# Inline per-competition guess cards #}
        {% set my_competitions = my_competitions_for_match_source|default([]) %}
        {% if my_competitions|length > 0 %}
            <section class="mt-8">
                <header class="mb-4 flex flex-wrap items-center justify-between gap-3">
                    <h2 class="flex items-center gap-2 text-xl font-semibold text-white">
                        <twig:ux:icon name="lucide:target" class="h-5 w-5 text-accent-300" />
                        Vaše tipy
                        <span class="rounded-full bg-white/5 px-2.5 py-0.5 text-xs font-semibold text-white/70">{{ my_competitions|length }}</span>
                    </h2>
                    <p class="text-xs text-white/50">Tipujte zvlášť za každou soutěž, ve které jste.</p>
                </header>

                <ul class="grid grid-cols-1 gap-4 {% if my_competitions|length > 1 %}md:grid-cols-2{% endif %}">
                    {% for g in my_competitions %}
                        <li class="relative">
                            {% if not g.hasGuess %}
                                <span
                                    class="absolute -top-3 left-1/2 z-10 inline-flex -translate-x-1/2 items-center gap-1.5 rounded-full bg-accent-500 px-3 py-1 text-xs font-semibold text-white shadow-lg ring-2 ring-navy-900"
                                    title="Pro tuto soutěž chybí váš tip"
                                    aria-label="Chybí tip pro tuto soutěž"
                                >
                                    <twig:ux:icon name="lucide:circle-alert" class="h-4 w-4" />
                                    Nevyplněno
                                </span>
                            {% endif %}
                            <article class="card-glass flex h-full flex-col overflow-hidden p-0 {% if not g.hasGuess %}ring-1 ring-accent-400/60{% endif %}">
                                <header class="flex items-center justify-between gap-3 border-b border-white/[0.06] px-5 py-3">
                                    <div class="flex min-w-0 items-center gap-2">
                                        <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-accent-500/15 text-accent-300">
                                            <twig:ux:icon name="lucide:users" class="h-4 w-4" />
                                        </span>
                                        <a href="{{ path('portal_competition_detail', {id: g.id.toRfc4122}) }}" class="truncate font-semibold text-white transition-colors hover:text-accent-300">
                                            {{ g.name }}
                                        </a>
                                    </div>
                                    <a href="{{ path('portal_competition_sport_match_guesses', {competitionId: g.id.toRfc4122, sportMatchId: sport_match.id.toRfc4122}) }}" class="inline-flex shrink-0 items-center gap-1 text-xs font-medium text-accent-300 transition-colors hover:text-accent-200" title="Zobrazit tipy členů soutěže">
                                        Tipy členů
                                        <twig:ux:icon name="lucide:chevron-right" class="h-3.5 w-3.5" />
                                    </a>
                                </header>

                                <div class="flex-1 p-5">
                                    <twig:Guess:GuessSubmitForm
                                        id="guess-form-{{ g.id.toRfc4122 }}"
                                        sportMatch="{{ sport_match }}"
                                        competitionId="{{ g.id.toRfc4122 }}"
                                        class="!rounded-none !bg-transparent !p-0 !shadow-none !ring-0"
                                    />
                                    {% if g.stats %}
                                        <twig:Match:TipStats
                                            :stats="g.stats"
                                            :homeTeam="sport_match.homeTeam"
                                            :awayTeam="sport_match.awayTeam"
                                        />
                                    {% endif %}
                                </div>
                            </article>
                        </li>
                    {% endfor %}
                </ul>
            </section>
        {% endif %}

        {# Match management (admins only) #}
        {% set can_edit   = is_granted('sport_match_edit', sport_match) %}
        {% set can_score  = is_granted('sport_match_set_score', sport_match) %}
        {% set can_cancel = is_granted('sport_match_cancel', sport_match) %}
        {% set can_delete = is_granted('sport_match_delete', sport_match) %}

        {% if can_edit or can_score or can_cancel or can_delete %}
            <section class="card-glass mt-8 overflow-hidden p-0">
                <header class="flex items-center gap-2.5 border-b border-white/[0.06] px-6 py-4">
                    <twig:ux:icon name="lucide:settings" class="h-5 w-5 text-accent-300" />
                    <h2 class="text-lg font-semibold text-white">Správa zápasu</h2>
                </header>
                <div class="flex flex-wrap items-end gap-3 px-6 py-5">
                    {% if can_edit %}
                        <a href="{{ path('portal_sport_match_edit', {id: sport_match.id.toRfc4122}) }}" class="btn btn-ghost btn-sm">
                            <twig:ux:icon name="lucide:pencil" class="h-4 w-4" />Upravit
                        </a>
                    {% endif %}

                    {% if can_score %}
                        <a href="{{ path('portal_sport_match_set_score', {id: sport_match.id.toRfc4122}) }}" class="btn btn-success btn-sm">
                            <twig:ux:icon name="lucide:check" class="h-4 w-4" />
                            {{ sport_match.isFinished ? 'Upravit skóre' : 'Zadat skóre' }}
                        </a>
                    {% endif %}

                    {% if can_edit and (sport_match.isScheduled or sport_match.isPostponed) %}
                        <form method="post" action="{{ path('portal_sport_match_postpone', {id: sport_match.id.toRfc4122}) }}" class="flex flex-wrap items-end gap-2">
                            <input type="hidden" name="_token" value="{{ csrf_token('sport_match_postpone_' ~ sport_match.id.toRfc4122) }}">
                            <div class="field">
                                <label class="field-label" for="postpone-kickoff-{{ sport_match.id.toRfc4122 }}">Nový termín</label>
                                <input type="text" name="new_kickoff_at" id="postpone-kickoff-{{ sport_match.id.toRfc4122 }}" required
                                       data-controller="datepicker" data-datepicker-mode-value="datetime"
                                       class="input w-auto">
                            </div>
                            <button type="submit" class="btn btn-ghost btn-sm">
                                <twig:ux:icon name="lucide:clock" class="h-4 w-4" />Odložit
                            </button>
                        </form>
                    {% endif %}

                    {% if can_edit and sport_match.isPostponed %}
                        <form method="post" action="{{ path('portal_sport_match_reschedule', {id: sport_match.id.toRfc4122}) }}" class="flex flex-wrap items-end gap-2">
                            <input type="hidden" name="_token" value="{{ csrf_token('sport_match_reschedule_' ~ sport_match.id.toRfc4122) }}">
                            <div class="field">
                                <label class="field-label" for="reschedule-kickoff-{{ sport_match.id.toRfc4122 }}">Nový termín</label>
                                <input type="text" name="new_kickoff_at" id="reschedule-kickoff-{{ sport_match.id.toRfc4122 }}" required
                                       data-controller="datepicker" data-datepicker-mode-value="datetime"
                                       class="input w-auto">
                            </div>
                            <button type="submit" class="btn btn-primary btn-sm">
                                <twig:ux:icon name="lucide:calendar" class="h-4 w-4" />Přesunout zpět
                            </button>
                        </form>
                    {% endif %}

                    {% if can_cancel and not sport_match.isFinished and not sport_match.isCancelled %}
                        <form method="post" action="{{ path('portal_sport_match_cancel', {id: sport_match.id.toRfc4122}) }}" class="inline"
                            data-controller="confirm"
                            data-confirm-variant-value="warning"
                            data-confirm-title-value="Zrušit zápas"
                            data-confirm-message-value="Opravdu chcete zápas {{ sport_match.homeTeam }} – {{ sport_match.awayTeam }} zrušit? Tipy na něj nebudou bodovány."
                            data-confirm-confirm-label-value="Ano, zrušit">
                            <input type="hidden" name="_token" value="{{ csrf_token('sport_match_cancel_' ~ sport_match.id.toRfc4122) }}">
                            <button type="submit" class="btn btn-ghost btn-sm">
                                <twig:ux:icon name="lucide:circle-x" class="h-4 w-4" />Zrušit zápas
                            </button>
                        </form>
                    {% endif %}

                    {% if can_delete %}
                        <form method="post" action="{{ path('portal_sport_match_delete', {id: sport_match.id.toRfc4122}) }}" class="inline"
                            data-controller="confirm"
                            data-confirm-title-value="Smazat zápas"
                            data-confirm-message-value="Opravdu chcete zápas {{ sport_match.homeTeam }} – {{ sport_match.awayTeam }} smazat? Všechny tipy na něj zmizí."
                            data-confirm-confirm-label-value="Ano, smazat">
                            <input type="hidden" name="_token" value="{{ csrf_token('sport_match_delete_' ~ sport_match.id.toRfc4122) }}">
                            <button type="submit" class="btn btn-danger btn-sm">
                                <twig:ux:icon name="lucide:trash-2" class="h-4 w-4" />Smazat
                            </button>
                        </form>
                    {% endif %}
                </div>
            </section>
        {% endif %}
    </div>
</div>
{% endblock %}
