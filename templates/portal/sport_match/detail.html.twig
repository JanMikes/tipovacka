{% extends 'base.html.twig' %}

{% block title %}{{ sport_match.homeTeam }} vs {{ sport_match.awayTeam }} — Tipovačka{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-6">
        <a href="{{ path('portal_tournament_detail', {id: sport_match.tournament.id.toRfc4122}) }}"
           class="text-sm text-cyan-500 hover:underline">
            &larr; {{ sport_match.tournament.name }}
        </a>
    </div>

    <div class="bg-white rounded-2xl shadow-lg p-8 mb-6">
        <div class="flex items-center justify-between mb-6">
            <h1 class="text-3xl font-bold text-navy-900">
                {{ sport_match.homeTeam }} <span class="text-gray-400">vs.</span> {{ sport_match.awayTeam }}
            </h1>
            <span class="px-3 py-1 rounded-full text-xs font-medium
                {% if sport_match.isScheduled %}bg-blue-100 text-blue-800
                {% elseif sport_match.isLive %}bg-orange-100 text-orange-800
                {% elseif sport_match.isFinished %}bg-green-100 text-green-800
                {% elseif sport_match.isPostponed %}bg-yellow-100 text-yellow-800
                {% else %}bg-gray-200 text-gray-800{% endif %}">
                {% if sport_match.isScheduled %}Naplánován
                {% elseif sport_match.isLive %}Probíhá
                {% elseif sport_match.isFinished %}Ukončen
                {% elseif sport_match.isPostponed %}Odložen
                {% else %}Zrušen{% endif %}
            </span>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
            <div>
                <p class="text-sm font-medium text-gray-500 mb-1">Začátek</p>
                <p class="text-navy-900">{{ sport_match.kickoffAt|date('d. m. Y H:i') }}</p>
            </div>
            {% if sport_match.venue %}
                <div>
                    <p class="text-sm font-medium text-gray-500 mb-1">Místo</p>
                    <p class="text-navy-900">{{ sport_match.venue }}</p>
                </div>
            {% endif %}
        </div>

        {% if sport_match.isFinished %}
            <div class="mt-4 p-4 bg-gray-50 rounded-lg text-center">
                <p class="text-sm font-medium text-gray-500 mb-1">Konečné skóre</p>
                <p class="text-4xl font-bold text-navy-900">
                    {{ sport_match.homeScore }} : {{ sport_match.awayScore }}
                </p>
            </div>
        {% endif %}
    </div>

    {% if my_groups_for_tournament|default([])|length > 0 %}
        <div class="bg-white rounded-2xl shadow-lg p-6 mb-6">
            <h2 class="text-lg font-semibold text-navy-900 mb-4">Tipy podle skupiny</h2>
            <ul class="space-y-2">
                {% for g in my_groups_for_tournament %}
                    <li>
                        <a href="{{ path('portal_group_sport_match_guesses', {groupId: g.id.toRfc4122, sportMatchId: sport_match.id.toRfc4122}) }}"
                           class="text-cyan-500 hover:underline text-sm">
                            {{ g.name }} – otevřít tipování
                        </a>
                    </li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    {% if is_granted('sport_match_edit', sport_match) or is_granted('sport_match_set_score', sport_match) or is_granted('sport_match_cancel', sport_match) or is_granted('sport_match_delete', sport_match) %}
        <div class="bg-white rounded-2xl shadow-lg p-6">
            <h2 class="text-lg font-semibold text-navy-900 mb-4">Správa zápasu</h2>
            <div class="flex flex-wrap gap-3">
                {% if is_granted('sport_match_edit', sport_match) %}
                    <a href="{{ path('portal_sport_match_edit', {id: sport_match.id.toRfc4122}) }}"
                       class="bg-navy-900 hover:bg-navy-700 text-white py-2 px-4 rounded-lg text-sm font-medium">
                        Upravit
                    </a>
                {% endif %}

                {% if is_granted('sport_match_set_score', sport_match) %}
                    <a href="{{ path('portal_sport_match_set_score', {id: sport_match.id.toRfc4122}) }}"
                       class="bg-green-600 hover:bg-green-700 text-white py-2 px-4 rounded-lg text-sm font-medium">
                        {{ sport_match.isFinished ? 'Upravit skóre' : 'Zadat skóre' }}
                    </a>
                {% endif %}

                {% if is_granted('sport_match_edit', sport_match) and (sport_match.isScheduled or sport_match.isPostponed) %}
                    <form method="post" action="{{ path('portal_sport_match_postpone', {id: sport_match.id.toRfc4122}) }}"
                          class="inline-flex items-center gap-2">
                        <input type="hidden" name="_token" value="{{ csrf_token('sport_match_postpone_' ~ sport_match.id.toRfc4122) }}">
                        <input type="datetime-local" name="new_kickoff_at" required
                               class="px-2 py-1 border border-gray-300 rounded text-sm">
                        <button type="submit"
                                class="bg-yellow-500 hover:bg-yellow-600 text-white py-2 px-4 rounded-lg text-sm font-medium">
                            Odložit
                        </button>
                    </form>
                {% endif %}

                {% if is_granted('sport_match_edit', sport_match) and sport_match.isPostponed %}
                    <form method="post" action="{{ path('portal_sport_match_reschedule', {id: sport_match.id.toRfc4122}) }}"
                          class="inline-flex items-center gap-2">
                        <input type="hidden" name="_token" value="{{ csrf_token('sport_match_reschedule_' ~ sport_match.id.toRfc4122) }}">
                        <input type="datetime-local" name="new_kickoff_at" required
                               class="px-2 py-1 border border-gray-300 rounded text-sm">
                        <button type="submit"
                                class="bg-blue-500 hover:bg-blue-600 text-white py-2 px-4 rounded-lg text-sm font-medium">
                            Přesunout zpět
                        </button>
                    </form>
                {% endif %}

                {% if is_granted('sport_match_cancel', sport_match) and not sport_match.isFinished and not sport_match.isCancelled %}
                    <form method="post" action="{{ path('portal_sport_match_cancel', {id: sport_match.id.toRfc4122}) }}" class="inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('sport_match_cancel_' ~ sport_match.id.toRfc4122) }}">
                        <button type="submit"
                                class="bg-orange-500 hover:bg-orange-600 text-white py-2 px-4 rounded-lg text-sm font-medium"
                                onclick="return confirm('Opravdu chcete zápas zrušit?')">
                            Zrušit zápas
                        </button>
                    </form>
                {% endif %}

                {% if is_granted('sport_match_delete', sport_match) %}
                    <form method="post" action="{{ path('portal_sport_match_delete', {id: sport_match.id.toRfc4122}) }}" class="inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('sport_match_delete_' ~ sport_match.id.toRfc4122) }}">
                        <button type="submit"
                                class="bg-red-600 hover:bg-red-700 text-white py-2 px-4 rounded-lg text-sm font-medium"
                                onclick="return confirm('Opravdu chcete zápas smazat?')">
                            Smazat
                        </button>
                    </form>
                {% endif %}
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}
