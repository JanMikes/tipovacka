{% extends 'base.html.twig' %}

{% block title %}Zápasy — {{ brand_name }}{% endblock %}

{% block body %}
<div class="bg-radial">
<div class="mx-auto w-full max-w-5xl px-4 py-10 sm:px-6 sm:py-14 lg:px-8">

    {# ───── Hero ───── #}
    <header class="mb-8">
        <p class="eyebrow mb-3">Zápasy</p>
        <h1 class="grad-headline text-3xl font-extrabold tracking-tight sm:text-4xl">Vaše zápasy</h1>
        <p class="mt-3 max-w-2xl text-white/60">Všechny zápasy napříč vašimi soutěžemi na jednom místě — tipnutelné i už odehrané.</p>
    </header>

    {# ───── Filtry ───── #}
    <div class="mb-8 flex flex-wrap gap-2">
        {% for key, label in filters %}
            {% set is_active = key == active_filter %}
            <a
                href="{{ path('portal_matches') }}{{ key == 'vse' ? '' : '?filtr=' ~ key }}"
                class="inline-flex items-center gap-2 rounded-full border px-4 py-1.5 text-sm font-semibold transition-colors {{ is_active ? 'border-accent-500/50 bg-accent-500/15 text-accent-200' : 'border-white/10 bg-white/[0.04] text-white/60 hover:border-white/20 hover:text-white' }}"
            >
                {{ label }}
                <span class="rounded-full px-1.5 py-0.5 text-xs font-bold tabular-nums {{ is_active ? 'bg-accent-500/25 text-accent-100' : 'bg-white/10 text-white/50' }}">{{ counts[key] }}</span>
            </a>
        {% endfor %}
    </div>

    {# ───── Seznam zápasů ───── #}
    {% if matches|length == 0 %}
        <div class="card-glass p-10 text-center">
            <span class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-2xl border border-accent-500/30 bg-accent-500/15 text-accent-300">
                <twig:ux:icon name="lucide:calendar" class="h-7 w-7" />
            </span>
            <h3 class="text-lg font-semibold text-white">
                {% if active_filter == 'vse' %}Žádné zápasy{% else %}V tomto filtru nejsou žádné zápasy{% endif %}
            </h3>
            <p class="mx-auto mt-2 max-w-md text-sm text-white/60">
                {% if active_filter == 'vse' %}
                    Jakmile se ve vašich soutěžích objeví zápasy, uvidíte je tady.
                {% else %}
                    Zkuste jiný filtr — třeba <a href="{{ path('portal_matches') }}" class="font-semibold text-accent-300 hover:text-accent-200">Vše</a>.
                {% endif %}
            </p>
        </div>
    {% else %}
        <ul class="flex flex-col gap-3">
            {% for m in matches %}
                {# Per-competition locking: tippable = open in at least one of the user's competitions (resolver-driven). #}
                {% set is_tippable = m.isTippable %}
                {# Zlomky počítají jen soutěže s otevřenou uzávěrkou (open-including). #}
                {% set guessed_among_open = m.openCompetitionsCount - m.pendingCompetitionsCount %}
                {% set is_locked = not m.isFinished and not m.isPostponed and m.openCompetitionsCount == 0 and m.guessedCompetitionsCount == 0 %}
                {% set is_tipped = m.guessedCompetitionsCount > 0 and m.pendingCompetitionsCount == 0 %}
                {% set has_pending = m.pendingCompetitionsCount > 0 %}
                {#
                    Stav → clean enum (live je CUT, probíhající zápas čteme jako „Uzamčeno"):
                      finished | odloženo | locked (bez tipu a bez otevřené soutěže) |
                      pending (chybí tip v otevřené soutěži) | tipped (vše natipováno) | open (brzy)
                    Jeden pilulkový slot; zlomky (x/y) = natipováno / soutěže s otevřenou uzávěrkou.
                #}
                {% if m.isFinished %}
                    {% set row_state = 'finished' %}{% set pill_variant = 'done' %}{% set pill_icon = 'check' %}{% set pill_label = 'Ukončeno' %}{% set pill_dot = false %}
                {% elseif m.isPostponed %}
                    {% set row_state = 'locked' %}{% set pill_variant = 'warn' %}{% set pill_icon = 'triangle-alert' %}{% set pill_label = 'Odloženo' %}{% set pill_dot = false %}
                {% elseif is_locked %}
                    {% set row_state = 'locked' %}{% set pill_variant = 'locked' %}{% set pill_icon = 'lock' %}{% set pill_label = 'Uzamčeno' %}{% set pill_dot = false %}
                {% elseif has_pending %}
                    {% set row_state = 'open' %}{% set pill_variant = 'soon' %}{% set pill_icon = 'circle-alert' %}{% set pill_dot = false %}
                    {% set pill_label = m.openCompetitionsCount > 1 ? 'Chybí tip (' ~ guessed_among_open ~ '/' ~ m.openCompetitionsCount ~ ')' : 'Chybí tip' %}
                {% elseif is_tipped %}
                    {% set row_state = 'tipped' %}{% set pill_variant = 'tipped' %}{% set pill_icon = 'check' %}{% set pill_dot = false %}
                    {% set pill_label = m.openCompetitionsCount > 1 ? 'Tip odeslán (' ~ guessed_among_open ~ '/' ~ m.openCompetitionsCount ~ ')' : 'Tip odeslán' %}
                {% else %}
                    {% set row_state = 'open' %}{% set pill_variant = 'soon' %}{% set pill_icon = null %}{% set pill_label = 'Brzy' %}{% set pill_dot = true %}
                {% endif %}
                <li>
                    <twig:Match:MatchRow
                        :homeTeam="m.homeTeam"
                        :awayTeam="m.awayTeam"
                        :kickoffAt="m.kickoffAt"
                        :round="m.round"
                        :isPlayoff="m.isPlayoff"
                        :state="row_state"
                        :pillVariant="pill_variant"
                        :pillIcon="pill_icon"
                        :pillLabel="pill_label"
                        :pillDot="pill_dot"
                        :resultHome="m.isFinished ? m.homeScore : null"
                        :resultAway="m.isFinished ? m.awayScore : null"
                        :detailUrl="path('portal_sport_match_detail', {id: m.id.toRfc4122})"
                        :detailLabel="is_tippable ? 'Tipovat' : 'Detail zápasu'"
                    />

                    {% if m.matchSourceName or m.venue %}
                        <p class="mt-1.5 px-4 text-xs text-white/40 sm:px-5">
                            {{ m.matchSourceName }}{% if m.venue %} · {{ m.venue }}{% endif %}
                        </p>
                    {% endif %}
                </li>
            {% endfor %}
        </ul>
    {% endif %}
</div>
</div>
{% endblock %}
