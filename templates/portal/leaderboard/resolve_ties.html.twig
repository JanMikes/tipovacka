{% extends 'base.html.twig' %}

{% block title %}Rozřazení shod — {{ group.name }} — Tipovačka{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-6">
        <a href="{{ path('portal_group_leaderboard', {groupId: group.id.toRfc4122}) }}" class="text-sm text-[#149AD5] hover:underline">
            ← Zpět na žebříček
        </a>
        <h1 class="text-3xl font-bold text-[#081e44] mt-2">Rozřazení shod</h1>
        <p class="text-gray-500">Seřaďte hráče se stejnými body do požadovaného pořadí.</p>
    </div>

    {% if tiedGroups|length == 0 %}
        <div class="bg-white rounded-2xl shadow-lg p-6">
            <p class="text-sm text-gray-500">Aktuálně neexistují žádné shody k rozřazení.</p>
        </div>
    {% else %}
        {{ form_start(form, {attr: {'data-controller': 'orderable-list'}}) }}
            {% for bucket in tiedGroups %}
                <div class="bg-white rounded-2xl shadow-lg p-6 mb-4">
                    <h2 class="text-lg font-semibold text-[#081e44] mb-3">
                        Shoda: {{ bucket[0].totalPoints }} bodů
                    </h2>
                    <ul class="divide-y divide-gray-100" data-orderable-list-target="list">
                        {% for row in bucket %}
                            <li
                                class="py-3 flex items-center justify-between cursor-move bg-gray-50 hover:bg-gray-100 px-3 rounded"
                                draggable="true"
                                data-orderable-list-target="item"
                                data-user-id="{{ row.userId.toRfc4122 }}"
                            >
                                <span class="font-medium text-[#081e44]">{{ row.nickname }}</span>
                                <span class="text-xs text-gray-500">{{ row.totalPoints }} b.</span>
                            </li>
                        {% endfor %}
                    </ul>
                </div>
            {% endfor %}

            <div class="bg-white rounded-2xl shadow-lg p-6">
                <div data-orderable-list-target="hiddenContainer" class="hidden">
                    {{ form_widget(form.orderedUserIds) }}
                </div>

                <div class="flex gap-3">
                    <button
                        type="submit"
                        class="bg-[#081e44] hover:bg-[#0f2d5f] text-white py-2 px-4 rounded-lg text-sm font-medium transition-colors"
                    >
                        Uložit pořadí
                    </button>
                </div>
            </div>
        {{ form_end(form) }}
    {% endif %}
</div>
{% endblock %}
