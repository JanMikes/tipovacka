{% extends 'base.html.twig' %}

{% block title %}Rozřazení shod — {{ group.name }} — {{ brand_name }}{% endblock %}

{% block body %}
<div class="mx-auto max-w-3xl px-4 py-12 pb-32 sm:px-6 lg:px-8">
    <twig:Breadcrumbs :items="[
        {label: 'Nástěnka', path: path('portal_dashboard')},
        {label: group.name, path: path('portal_group_detail', {id: group.id.toRfc4122})},
        {label: 'Žebříček', path: path('portal_group_leaderboard', {groupId: group.id.toRfc4122})},
        {label: 'Rozřazení shod'},
    ]" />

    <header class="mb-8">
        <span class="eyebrow">{{ group.name }}</span>
        <h1 class="mt-2 text-3xl font-black leading-tight tracking-tight text-white sm:text-4xl">Rozřazení shod</h1>
        <p class="mt-3 text-sm leading-relaxed text-white/70">
            Seřaďte hráče se stejnými body do požadovaného pořadí. Přetáhněte řádky pomocí úchytu.
        </p>
    </header>

    {% if tiedGroups|length == 0 %}
        <div class="card-glass flex flex-col items-center gap-3 p-10 text-center">
            <twig:ux:icon name="lucide:check-check" class="h-8 w-8 text-white/40" />
            <p class="text-sm text-white/70">Aktuálně neexistují žádné shody k rozřazení.</p>
        </div>
    {% else %}
        {{ form_start(form, {attr: {'data-controller': 'orderable-list'}}) }}
            {% for bucket in tiedGroups %}
                <section class="card mb-4 p-6">
                    <div class="mb-4 flex items-center gap-2">
                        <twig:Badge label="{{ bucket[0].totalPoints }} b" variant="points" />
                        <h2 class="text-sm font-semibold uppercase tracking-wider text-white/50">Shoda na bodech</h2>
                    </div>
                    <ul class="flex flex-col gap-2" data-orderable-list-target="list">
                        {% for row in bucket %}
                            <li
                                class="group flex cursor-move items-center gap-3 rounded-xl border border-white/10 bg-surface-2 px-3 py-3 transition-colors hover:bg-white/[0.06]"
                                draggable="true"
                                data-orderable-list-target="item"
                                data-user-id="{{ row.userId.toRfc4122 }}"
                            >
                                <twig:ux:icon name="lucide:grip-vertical" class="h-5 w-5 shrink-0 text-white/30 transition-colors group-hover:text-white/60" />
                                <twig:Avatar name="{{ row.fullName ?: row.nickname }}" size="36" />
                                <div class="min-w-0 flex-1">
                                    <span class="block truncate text-sm font-bold text-white">{{ row.nickname }}</span>
                                    {% if row.fullName %}<small class="block truncate text-[11px] font-light text-white/50">{{ row.fullName }}</small>{% endif %}
                                </div>
                                <span class="shrink-0 text-[11px] font-light text-white/50">{{ row.totalPoints }} b</span>
                            </li>
                        {% endfor %}
                    </ul>
                </section>
            {% endfor %}

            <div data-orderable-list-target="hiddenContainer" class="hidden">
                {{ form_widget(form.orderedUserIds) }}
            </div>

            <div class="fixed inset-x-0 bottom-0 z-30 border-t border-white/10 bg-navy-900/90 backdrop-blur-xl">
                <div class="mx-auto flex max-w-3xl items-center justify-end gap-3 px-4 py-3 sm:px-6 lg:px-8">
                    <button type="submit" class="btn btn-primary w-full justify-center sm:w-auto">
                        <twig:ux:icon name="lucide:save" class="h-4 w-4" />
                        Uložit pořadí
                    </button>
                </div>
            </div>
        {{ form_end(form) }}
    {% endif %}
</div>
{% endblock %}
