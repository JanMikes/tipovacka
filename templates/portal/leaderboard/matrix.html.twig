{% extends 'base.html.twig' %}

{% block title %}Tabulka — {{ competition.name }} — {{ brand_name }}{% endblock %}

{% block body %}
<div class="mx-auto w-full max-w-[min(100vw-2rem,120rem)] px-4 py-8 sm:px-6 sm:py-12 lg:px-8">

    <twig:Breadcrumbs :items="[
        {label: 'Nástěnka', path: path('portal_dashboard')},
        {label: competition.name, path: path('portal_competition_detail', {id: competition.id.toRfc4122})},
        {label: 'Žebříček', path: path('portal_competition_leaderboard', {competitionId: competition.id.toRfc4122})},
        {label: 'Tabulka'},
    ]" />

    <header class="mb-6 flex flex-wrap items-end justify-between gap-4">
        <div>
            <p class="eyebrow">Tipy a body</p>
            <h1 class="mt-1 flex items-center gap-2.5 text-3xl font-black tracking-tight sm:text-4xl">
                <twig:ux:icon name="lucide:table-2" class="h-7 w-7 text-accent-400" />
                <span class="grad-headline">Tabulka</span>
            </h1>
            <p class="mt-2 text-white/70">
                Soutěž
                <a href="{{ path('portal_competition_detail', {id: competition.id.toRfc4122}) }}" class="font-bold text-accent-300 transition-colors hover:text-accent-200">{{ competition.name }}</a>
                — tipy a body za každý zápas, řádek na hráče, sloupec na zápas.
            </p>
        </div>

        <div class="flex items-center gap-3 text-xs text-white/50">
            <span class="font-bold uppercase tracking-[0.1em]">Legenda</span>
            <span class="inline-flex items-center gap-1.5"><span class="inline-block h-3 w-5 rounded bg-accent-500/30 ring-1 ring-accent-400/50"></span>1. místo</span>
            <span class="inline-flex items-center gap-1.5"><span class="inline-block h-3 w-5 rounded bg-accent-500/[0.18] ring-1 ring-accent-400/30"></span>2. místo</span>
            <span class="inline-flex items-center gap-1.5"><span class="inline-block h-3 w-5 rounded bg-accent-500/10 ring-1 ring-accent-400/20"></span>3. místo</span>
        </div>
    </header>

    {% if matrix.matches|length == 0 or matrix.members|length == 0 %}
        <section class="card-glass p-10 text-center">
            <p class="text-sm text-white/50">
                {% if matrix.matches|length == 0 %}
                    V soutěži zatím nejsou žádné zápasy.
                {% else %}
                    Soutěž zatím nemá žádné hráče.
                {% endif %}
            </p>
        </section>
    {% else %}
        <div class="relative -mx-4 overflow-auto bg-surface ring-1 ring-white/10 sm:mx-0 sm:rounded-2xl" style="max-height: calc(100vh - 12rem);">
            <table class="min-w-full border-separate border-spacing-0 text-sm">
                <thead>
                    <tr>
                        <th scope="col" class="sticky left-0 top-0 z-30 border-b border-r border-white/10 bg-surface-2 px-2 py-3 text-left text-[10px] font-bold uppercase tracking-[0.1em] text-white/50 sm:px-4">
                            <div class="flex min-w-[132px] items-center gap-2 sm:min-w-[200px] sm:gap-3">
                                <span class="w-4 text-right sm:w-6">#</span>
                                <span class="flex-1">Hráč</span>
                                <span class="tabular-nums">Body</span>
                            </div>
                        </th>
                        {% for m in matrix.matches %}
                            {% set stateLabel = '' %}
                            {% if m.state.value == 'finished' %}{% set stateLabel = ' — odehráno ' ~ m.actualHomeScore ~ ':' ~ m.actualAwayScore %}
                            {% elseif m.state.value == 'live' %}{% set stateLabel = ' — uzamčeno' %}
                            {% elseif m.state.value == 'postponed' %}{% set stateLabel = ' — odloženo' %}
                            {% elseif m.state.value == 'cancelled' %}{% set stateLabel = ' — zrušeno' %}
                            {% endif %}
                            <th scope="col" class="sticky top-0 z-20 whitespace-nowrap border-b border-white/10 bg-surface-2 px-2 py-2 text-center"
                                title="{{ m.homeTeam }} – {{ m.awayTeam }} ({{ m.kickoffAt|date('d. m. Y H:i') }}){{ stateLabel }}">
                                <div class="text-[11px] font-bold tracking-wider text-white">
                                    {{ m.homeTeam|slice(0, 3)|upper }}<span class="mx-0.5 text-white/40">–</span>{{ m.awayTeam|slice(0, 3)|upper }}
                                </div>
                                <div class="mt-0.5 text-[10px] font-normal">
                                    {% if m.state.value == 'finished' %}
                                        <span class="inline-block rounded bg-white/5 px-1.5 py-0.5 tabular-nums text-white ring-1 ring-white/10">{{ m.actualHomeScore }}:{{ m.actualAwayScore }}</span>
                                    {% elseif m.state.value == 'live' %}
                                        <span class="inline-flex items-center gap-1 rounded bg-white/5 px-1.5 py-0.5 text-white/50 ring-1 ring-white/10">
                                            <twig:ux:icon name="lucide:lock" class="h-2.5 w-2.5" />uzamčeno
                                        </span>
                                    {% elseif m.state.value == 'postponed' %}
                                        <span class="text-draw">odloženo</span>
                                    {% elseif m.state.value == 'cancelled' %}
                                        <span class="text-loss">zrušeno</span>
                                    {% else %}
                                        <span class="tabular-nums text-white/40">{{ m.kickoffAt|date('d.m.') }}</span>
                                    {% endif %}
                                </div>
                            </th>
                        {% endfor %}
                    </tr>
                </thead>
                <tbody>
                    {% for member in matrix.members %}
                        <tr>
                            <th scope="row" class="sticky left-0 z-10 border-b border-r border-white/10 bg-surface-2 px-2 py-3 text-left sm:px-4">
                                <div class="flex min-w-[132px] items-center gap-2 sm:min-w-[200px] sm:gap-3">
                                    <span class="w-4 text-right text-xs font-bold tabular-nums {{ member.rank == 1 ? 'text-gold' : (member.rank == 2 ? 'text-silver' : (member.rank == 3 ? 'text-bronze' : 'text-white/50')) }} sm:w-6">{{ member.rank }}.</span>
                                    <a href="{{ path('portal_competition_leaderboard_member', {competitionId: competition.id.toRfc4122, userId: member.userId.toRfc4122}) }}"
                                       class="min-w-0 flex-1 font-bold text-white transition-colors hover:text-accent-300">
                                        <span class="block truncate">{{ member.nickname }}</span>
                                        {% if member.fullName %}<small class="block truncate text-xs font-light text-white/50">{{ member.fullName }}</small>{% endif %}
                                    </a>
                                    <span class="tabular-nums font-black text-white">{{ member.totalPoints }}</span>
                                </div>
                            </th>
                            {% for m in matrix.matches %}
                                {% set matchKey = m.sportMatchId.toRfc4122 %}
                                {% set cell = member.cells[matchKey] ?? null %}
                                {% set highlight = '' %}
                                {% if cell is not null and cell.points is not null and cell.points > 0 %}
                                    {% if m.topScores[0] is defined and cell.points == m.topScores[0] %}
                                        {% set highlight = 'bg-accent-500/30' %}
                                    {% elseif m.topScores[1] is defined and cell.points == m.topScores[1] %}
                                        {% set highlight = 'bg-accent-500/[0.18]' %}
                                    {% elseif m.topScores[2] is defined and cell.points == m.topScores[2] %}
                                        {% set highlight = 'bg-accent-500/10' %}
                                    {% endif %}
                                {% endif %}
                                <td class="whitespace-nowrap border-b border-white/[0.06] px-2 py-2 text-center {{ highlight }}">
                                    {% if cell is not null %}
                                        {% if cell.hidden %}
                                            <span class="inline-flex items-center justify-center text-white/40" title="Tip skrytý do uzávěrky">
                                                <twig:ux:icon name="lucide:lock" class="h-4 w-4" />
                                            </span>
                                        {% else %}
                                            {% set extra_tip_parts = [] %}
                                            {% if cell.periodScores is not null %}
                                                {% set periods_text = [] %}
                                                {% for p in cell.periodScores %}{% set periods_text = periods_text|merge([p[0] ~ ':' ~ p[1]]) %}{% endfor %}
                                                {% set extra_tip_parts = extra_tip_parts|merge(['Části: ' ~ periods_text|join(', ')]) %}
                                            {% endif %}
                                            {% if cell.overtimeHomeScore is not null %}
                                                {% set extra_tip_parts = extra_tip_parts|merge(['Po prodloužení: ' ~ cell.overtimeHomeScore ~ ':' ~ cell.overtimeAwayScore]) %}
                                            {% endif %}
                                            {% if cell.scorerNames|length > 0 %}
                                                {% set extra_tip_parts = extra_tip_parts|merge(['Střelci: ' ~ cell.scorerNames|join(', ')]) %}
                                            {% endif %}
                                            <div class="text-[11px] tabular-nums text-white/50"{% if extra_tip_parts|length > 0 %} title="{{ extra_tip_parts|join(' · ') }}"{% endif %}>
                                                {{ cell.homeScore }}:{{ cell.awayScore }}{% if extra_tip_parts|length > 0 %}<span class="text-accent-300">*</span>{% endif %}
                                            </div>
                                            <div class="mt-0.5 text-sm font-black tabular-nums text-white">
                                                {% if cell.points is null %}
                                                    <span class="text-white/30">—</span>
                                                {% else %}
                                                    {{ cell.points }}
                                                {% endif %}
                                            </div>
                                        {% endif %}
                                    {% else %}
                                        <span class="text-white/25">—</span>
                                    {% endif %}
                                </td>
                            {% endfor %}
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>
{% endblock %}
