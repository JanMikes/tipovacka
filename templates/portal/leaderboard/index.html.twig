{% extends 'base.html.twig' %}

{% block title %}Žebříček — {{ group.name }} — Tipovačka{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    {% if group.tournament.isFinished and winner is defined and winner is not null %}
        <section class="mb-10 rounded-2xl bg-white p-6 shadow-sm sm:p-10">
            <picture>
                <source media="(max-width: 767px)" srcset="{{ asset('images/winner/winner-square.png') }}">
                <source media="(min-width: 768px)" srcset="{{ asset('images/winner/winner-wide.png') }}">
                <img
                    src="{{ asset('images/winner/winner-wide.png') }}"
                    alt="Oslavná ilustrace vítěze turnaje"
                    class="mx-auto w-full max-w-2xl"
                    loading="lazy"
                    decoding="async"
                >
            </picture>

            <div class="mt-6 text-center">
                <h2 class="text-3xl font-bold text-[#081e44] sm:text-4xl">
                    Gratulujeme, <span class="text-[#149AD5]">{{ winner.nickname }}</span>!
                </h2>
                <p class="mt-3 text-base text-[#081e44]/70 sm:text-lg">
                    {{ winner.nickname }} vyhrává turnaj <strong>{{ group.tournament.name }}</strong> s {{ winner.totalPoints }} body.
                </p>
            </div>
        </section>
    {% endif %}

    <div class="mb-6 flex items-center justify-between flex-wrap gap-3">
        <div>
            <h1 class="text-3xl font-bold text-[#081e44]">Žebříček</h1>
            <p class="text-gray-500">
                Skupina:
                <a href="{{ path('portal_group_detail', {id: group.id.toRfc4122}) }}" class="text-[#149AD5] hover:underline">
                    {{ group.name }}
                </a>
            </p>
        </div>

        {% if is_granted('leaderboard_resolve_ties', group) %}
            <a
                href="{{ path('portal_group_leaderboard_resolve_ties', {groupId: group.id.toRfc4122}) }}"
                class="bg-[#081e44] hover:bg-[#0f2d5f] text-white py-2 px-4 rounded-lg text-sm font-medium transition-colors"
            >
                Rozřadit shody
            </a>
        {% endif %}
    </div>

    {{ component('Leaderboard:GroupLeaderboard', {group: group}) }}
</div>
{% endblock %}
