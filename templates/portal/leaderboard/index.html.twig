{% extends 'base.html.twig' %}

{% block title %}Žebříček — {{ competition.name }} — {{ brand_name }}{% endblock %}

{% block body %}
<div class="bg-radial mx-auto w-full max-w-5xl px-4 py-8 sm:px-6 sm:py-12 lg:px-8">

    <twig:Breadcrumbs :items="[
        {label: 'Nástěnka', path: path('portal_dashboard')},
        {label: competition.name, path: path('portal_competition_detail', {id: competition.id.toRfc4122})},
        {label: 'Žebříček'},
    ]" />

    {% if competition.matchSource.isCompleted and winner is defined and winner is not null %}
        <section class="surface-accent mb-8 p-6 sm:p-10">
            <picture>
                <source media="(max-width: 767px)" srcset="{{ asset('images/winner/winner-square.png') }}">
                <source media="(min-width: 768px)" srcset="{{ asset('images/winner/winner-wide.png') }}">
                <img
                    src="{{ asset('images/winner/winner-wide.png') }}"
                    alt="Oslavná ilustrace vítěze soutěže"
                    class="mx-auto w-full max-w-2xl"
                    loading="lazy"
                    decoding="async"
                >
            </picture>
            <div class="mt-6 text-center">
                <span class="inline-flex items-center gap-1.5 rounded-full bg-white/15 px-3 py-1 text-xs font-bold uppercase tracking-wider text-white ring-1 ring-white/25">
                    <twig:ux:icon name="lucide:crown" class="h-3.5 w-3.5" />
                    Vítěz
                </span>
                <h2 class="mt-3 text-3xl font-black tracking-tight text-white sm:text-4xl">
                    Gratulujeme, {{ winner.nickname }}!
                </h2>
                <p class="mt-3 text-base text-white/80 sm:text-lg">
                    {{ winner.nickname }} vyhrává soutěž <strong class="font-bold text-white">{{ competition.name }}</strong>
                    s {{ winner.totalPoints }} {{ winner.totalPoints == 1 ? 'bodem' : 'body' }}.
                </p>
            </div>
        </section>
    {% endif %}

    <header class="mb-6 flex flex-wrap items-end justify-between gap-4">
        <div>
            <p class="eyebrow">Soutěžní žebříček</p>
            <h1 class="mt-1 flex items-center gap-2.5 text-3xl font-black tracking-tight sm:text-4xl">
                <twig:ux:icon name="lucide:trophy" class="h-7 w-7 text-accent-400" />
                <span class="grad-headline">Žebříček</span>
            </h1>
            <p class="mt-2 text-white/70">
                Soutěž
                <a href="{{ path('portal_competition_detail', {id: competition.id.toRfc4122}) }}" class="font-bold text-accent-300 transition-colors hover:text-accent-200">{{ competition.name }}</a>
            </p>
        </div>

        <div class="flex flex-wrap items-end gap-3">
            {% if my_competitions|length > 1 %}
                <twig:SoutezSwitcher
                    :competitions="my_competitions"
                    currentId="{{ competition.id.toRfc4122 }}"
                    route="portal_competition_leaderboard"
                    param="competitionId"
                    label="Žebříček soutěže"
                />
            {% endif %}
            <a href="{{ path('portal_competition_leaderboard_matrix', {competitionId: competition.id.toRfc4122}) }}" class="btn btn-ghost btn-sm">
                <twig:ux:icon name="lucide:table-2" class="h-4 w-4 text-accent-400" />
                Tabulka
            </a>
            {% if is_granted('leaderboard_resolve_ties', competition) %}
                <a href="{{ path('portal_competition_leaderboard_resolve_ties', {competitionId: competition.id.toRfc4122}) }}" class="btn btn-primary btn-sm">
                    <twig:ux:icon name="lucide:list-ordered" class="h-4 w-4" />
                    Rozřadit shody
                </a>
            {% endif %}
        </div>
    </header>

    {% if me_row is not null %}
        <div class="you-strip mb-8">
            <div class="ys-hero">
                <span class="lbl">Tvoje pozice</span>
                <span class="pos">{{ me_row.rank }}.<small>/ {{ player_count }}</small></span>
            </div>
            <div class="ys-divider"></div>
            <div class="col">
                <span class="k">Body</span>
                <span class="v">{{ me_row.totalPoints }}</span>
            </div>
            {% if gap_to_top5 is not null or gap_to_top3 is not null %}
                <div class="ys-divider"></div>
                {% if gap_to_top5 is not null %}
                    <div class="col">
                        <span class="k">Do top 5</span>
                        <span class="v text-accent-300">+{{ gap_to_top5 }} b</span>
                    </div>
                {% endif %}
                {% if gap_to_top3 is not null %}
                    <div class="col">
                        <span class="k">Do top 3</span>
                        <span class="v text-accent-300">+{{ gap_to_top3 }} b</span>
                    </div>
                {% endif %}
            {% elseif me_row.rank <= 3 %}
                <div class="ys-divider"></div>
                <div class="col">
                    <span class="k">Stav</span>
                    <span class="v text-win">{{ me_row.rank == 1 ? 'Vedeš' : 'Top 3' }}</span>
                </div>
            {% endif %}
            <a href="{{ path('portal_matches') }}" class="btn btn-ghost btn-sm ml-auto">
                Tipnout další zápas
                <twig:ux:icon name="lucide:arrow-right" class="h-4 w-4" />
            </a>
        </div>
    {% endif %}

    {% if podium_rows|length >= 3 %}
        <twig:Leaderboard:Podium :rows="podium_rows" />
    {% endif %}

    {{ component('Leaderboard:CompetitionLeaderboard', {competition: competition}) }}
</div>
{% endblock %}
