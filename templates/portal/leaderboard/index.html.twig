{% extends 'base.html.twig' %}

{% block title %}Žebříček — {{ group.name }} — Tipovačka{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-6 flex items-center justify-between flex-wrap gap-3">
        <div>
            <h1 class="text-3xl font-bold text-[#081e44]">Žebříček</h1>
            <p class="text-gray-500">
                Skupina:
                <a href="{{ path('portal_group_detail', {id: group.id.toRfc4122}) }}" class="text-[#149AD5] hover:underline">
                    {{ group.name }}
                </a>
            </p>
        </div>

        {% if is_granted('leaderboard_resolve_ties', group) %}
            <a
                href="{{ path('portal_group_leaderboard_resolve_ties', {groupId: group.id.toRfc4122}) }}"
                class="bg-[#081e44] hover:bg-[#0f2d5f] text-white py-2 px-4 rounded-lg text-sm font-medium transition-colors"
            >
                Rozřadit shody
            </a>
        {% endif %}
    </div>

    {{ component('Leaderboard:GroupLeaderboard', {group: group}) }}
</div>
{% endblock %}
