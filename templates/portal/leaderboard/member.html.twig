{% extends 'base.html.twig' %}

{% block title %}{{ breakdown.nickname }} — Žebříček — {{ brand_name }}{% endblock %}

{% block body %}
<div class="bg-radial mx-auto w-full max-w-5xl px-4 py-8 sm:px-6 sm:py-12 lg:px-8">

    <twig:Breadcrumbs :items="[
        {label: 'Nástěnka', path: path('portal_dashboard')},
        {label: competition.name, path: path('portal_competition_detail', {id: competition.id.toRfc4122})},
        {label: 'Žebříček', path: path('portal_competition_leaderboard', {competitionId: competition.id.toRfc4122})},
        {label: breakdown.nickname},
    ]" />

    <header class="mb-6 flex flex-wrap items-center justify-between gap-4">
        <div>
            <p class="eyebrow">Přehled hráče</p>
            <h1 class="mt-1 flex items-center gap-3 text-3xl font-black tracking-tight text-white sm:text-4xl">
                <twig:Avatar name="{{ breakdown.nickname }}" size="48" />
                {{ breakdown.nickname }}
            </h1>
        </div>
        <div class="surface-accent px-5 py-3 text-center">
            <p class="text-[10px] font-bold uppercase tracking-[0.14em] text-white/70">Celkem bodů</p>
            <p class="text-3xl font-black tabular-nums">{{ breakdown.totalPoints }}</p>
        </div>
    </header>

    <section class="card-glass">
        <header class="flex items-center gap-2.5 border-b border-white/10 px-6 py-4">
            <twig:ux:icon name="lucide:calendar" class="h-5 w-5 text-accent-400" />
            <h2 class="text-lg font-bold text-white">Přehled zápasů</h2>
        </header>

        {% if breakdown.rows|length == 0 %}
            <p class="px-6 py-10 text-center text-sm text-white/50">Zatím žádné odehrané zápasy.</p>
        {% else %}
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-white/10 text-left text-[10px] font-bold uppercase tracking-[0.1em] text-white/40">
                            <th class="px-6 py-3">Zápas</th>
                            <th class="px-3 py-3 text-center">Výsledek</th>
                            <th class="px-3 py-3 text-center">Váš tip</th>
                            <th class="px-3 py-3">Detail</th>
                            <th class="px-6 py-3 text-right">Body</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for row in breakdown.rows %}
                            <tr class="border-b border-white/[0.06] last:border-0">
                                <td class="px-6 py-3">
                                    <div class="font-bold text-white">{{ row.homeTeam }} <span class="font-normal text-white/40">—</span> {{ row.awayTeam }}</div>
                                    <div class="text-xs font-light text-white/50">{{ row.kickoffAt|date('d. m. Y H:i') }}</div>
                                </td>
                                <td class="px-3 py-3 text-center">
                                    <span class="inline-block rounded-md bg-white/5 px-2 py-0.5 font-bold tabular-nums text-white ring-1 ring-white/10">
                                        {{ row.actualHomeScore }} : {{ row.actualAwayScore }}
                                    </span>
                                </td>
                                <td class="px-3 py-3 text-center">
                                    {% if row.myHomeScore is not null %}
                                        <span class="font-bold tabular-nums text-white">{{ row.myHomeScore }} : {{ row.myAwayScore }}</span>
                                    {% else %}
                                        <span class="text-xs text-white/40">netipováno</span>
                                    {% endif %}
                                </td>
                                <td class="px-3 py-3 text-xs text-white/60">
                                    {% if row.breakdown|length > 0 %}
                                        <ul class="space-y-0.5">
                                            {% for item in row.breakdown %}
                                                <li>{% if item.multiplier > 1 %}{{ item.multiplier }}× {% endif %}{{ item.label }} <span class="font-bold text-white">({{ item.points }} b.)</span></li>
                                            {% endfor %}
                                        </ul>
                                    {% else %}
                                        <span class="text-white/30">—</span>
                                    {% endif %}
                                </td>
                                <td class="px-6 py-3 text-right">
                                    <span class="font-black tabular-nums {{ row.totalPoints > 0 ? 'text-win' : 'text-white/40' }}">
                                        {{ row.totalPoints > 0 ? '+' }}{{ row.totalPoints }}
                                    </span>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </section>
</div>
{% endblock %}
