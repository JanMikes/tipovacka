{% extends 'base.html.twig' %}

{% block title %}Přidat e-mail tipujícímu — {{ brand_name }}{% endblock %}

{% block body %}
<div class="mx-auto w-full max-w-2xl px-4 py-8 sm:px-6 sm:py-12 lg:px-8">
    <twig:Breadcrumbs :items="[
        {label: 'Nástěnka', path: path('portal_dashboard')},
        {label: group.name, path: path('portal_group_detail', {id: group.id.toRfc4122})},
        {label: 'Přidat e-mail tipujícímu'},
    ]" />

    <header class="mb-8 mt-2">
        <span class="eyebrow">{{ target.displayName }}</span>
        <h1 class="mt-2 text-3xl font-black tracking-tight text-white sm:text-4xl">Přidat e-mail tipujícímu</h1>
        <p class="mt-2 text-sm leading-relaxed text-white/70">
            Po přidání e-mailu odešleme tipujícímu pozvánku na nastavení hesla. Odkaz platí 7 dní.
            Jakmile si heslo nastaví, bude se moct přihlásit a své tipy si dál spravovat sám.
        </p>
    </header>

    <div class="card-glass p-6 sm:p-8">
        {{ form_start(form, {attr: {class: 'space-y-6', novalidate: 'novalidate'}}) }}

            <div class="field">
                {{ form_label(form.email) }}
                {{ form_widget(form.email, {attr: {class: 'input'}}) }}
                {{ form_errors(form.email) }}
            </div>

            <div class="flex flex-wrap gap-3 pt-2">
                <button type="submit" class="btn btn-primary">
                    <twig:ux:icon name="lucide:mail" class="h-4 w-4" />
                    Odeslat pozvánku
                </button>
                <a href="{{ path('portal_group_detail', {id: group.id.toRfc4122}) }}" class="btn btn-ghost">
                    Zrušit
                </a>
            </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
