{% extends 'base.html.twig' %}

{% block title %}Správa tipů členů — {{ group.name }}{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 pb-32">
    <twig:Breadcrumbs :items="[
        {label: 'Nástěnka', path: path('portal_dashboard')},
        {label: group.name, path: path('portal_group_detail', {id: group.id.toRfc4122})},
        {label: 'Správa tipů členů'},
    ]" />

    <div class="mb-6">
        <h1 class="text-3xl font-bold text-navy-900">Správa tipů členů</h1>
        <p class="text-navy-900/60 mt-2">
            Vyber člena a zadej nebo uprav jeho tipy na všechny nadcházející zápasy.
            Užitečné pro členy, kteří sami do aplikace nechodí.
        </p>
    </div>

    <form method="get" action="{{ path('portal_group_manage_member_tips', {id: group.id.toRfc4122}) }}"
          class="bg-white rounded-2xl shadow-card ring-1 ring-navy-900/5 p-5 mb-6">
        <label for="member-select" class="block text-sm font-medium text-navy-900 mb-1.5">Tipující</label>
        <select id="member-select"
                name="member"
                data-controller="tom-select"
                data-tom-select-placeholder-value="Vyhledej tipujícího…"
                data-tom-select-submit-on-change-value="true"
                data-tom-select-no-results-text-value="Žádný tipující nenalezen">
            <option value=""></option>
            {% for member in members %}
                {% set hasNickname = member.nickname is not null and member.nickname != '' %}
                {% set hasFullName = member.fullName != '' %}
                <option value="{{ member.id.toRfc4122 }}"
                        data-data="{{ {
                            nickname: hasNickname ? member.nickname : '',
                            fullName: hasFullName ? member.fullName : '',
                            unverified: not member.isVerified,
                        }|json_encode }}"
                        {% if selectedMember and selectedMember.id.equals(member.id) %}selected{% endif %}>
                    {{ member.displayName }}{% if hasNickname and hasFullName %} {{ member.fullName }}{% endif %}{% if not member.isVerified %} (neověřený){% endif %}
                </option>
            {% endfor %}
        </select>
        <noscript>
            <button type="submit" class="mt-3 bg-navy-900 hover:bg-navy-700 text-white py-2 px-4 rounded-lg text-sm font-medium">
                Vybrat
            </button>
        </noscript>
    </form>

    {% if selectedMember is null %}
        <div class="bg-white rounded-2xl shadow-card ring-1 ring-navy-900/5 p-6 text-center text-navy-900/60">
            Vyber tipujícího v selectboxu výše.
        </div>
    {% elseif rows|length == 0 %}
        <div class="bg-white rounded-2xl shadow-card ring-1 ring-navy-900/5 p-6 text-center text-navy-900/60">
            Žádné nadcházející zápasy k tipování.
        </div>
    {% else %}
        <form method="post"
              action="{{ path('portal_group_guess_on_behalf_batch', {
                  groupId: group.id.toRfc4122,
                  memberId: selectedMember.id.toRfc4122,
              }) }}">
            <input type="hidden" name="_token"
                   value="{{ csrf_token('guess_on_behalf_batch_' ~ group.id.toRfc4122 ~ '_' ~ selectedMember.id.toRfc4122) }}">

            <div class="bg-white rounded-2xl shadow-card ring-1 ring-navy-900/5 overflow-hidden">
                <header class="border-b border-navy-100/70 px-6 py-4">
                    <h2 class="text-lg font-semibold text-navy-900">
                        Tipy pro {{ selectedMember.displayName }}
                    </h2>
                    <p class="text-xs text-navy-900/60 mt-1">
                        Vyplň skóre u zápasů, které chceš uložit. Nevyplněné zápasy se přeskočí.
                    </p>
                </header>

                <ul class="divide-y divide-navy-100/70">
                    {% for row in rows %}
                        <li class="flex flex-wrap items-center justify-between gap-3 px-6 py-4">
                            <div class="min-w-0 flex-1">
                                <div class="font-medium text-navy-900">
                                    {{ row.match.homeTeam }} <span class="text-gray-400">vs.</span> {{ row.match.awayTeam }}
                                </div>
                                <p class="text-xs text-navy-900/60 mt-0.5">
                                    {{ row.match.kickoffAt|date('d. m. Y H:i') }}
                                </p>
                            </div>

                            <div class="flex items-center gap-2">
                                <input type="number"
                                       name="guesses[{{ row.match.id.toRfc4122 }}][homeScore]"
                                       min="0" max="99"
                                       value="{{ row.guess ? row.guess.homeScore : '' }}"
                                       class="w-16 rounded-lg border border-navy-100 px-2 py-1 text-center font-semibold outline-none focus:border-transparent focus:ring-2 focus:ring-cyan-500"
                                       aria-label="Domácí – {{ row.match.homeTeam }}">
                                <span class="text-navy-900/40">:</span>
                                <input type="number"
                                       name="guesses[{{ row.match.id.toRfc4122 }}][awayScore]"
                                       min="0" max="99"
                                       value="{{ row.guess ? row.guess.awayScore : '' }}"
                                       class="w-16 rounded-lg border border-navy-100 px-2 py-1 text-center font-semibold outline-none focus:border-transparent focus:ring-2 focus:ring-cyan-500"
                                       aria-label="Hosté – {{ row.match.awayTeam }}">
                            </div>
                        </li>
                    {% endfor %}
                </ul>
            </div>

            <div class="fixed inset-x-0 bottom-0 z-30 border-t border-navy-100 bg-white/95 backdrop-blur shadow-[0_-4px_12px_rgba(0,0,0,0.05)]">
                <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-3 flex items-center justify-between gap-3">
                    <p class="text-xs text-navy-900/60 hidden sm:block">
                        {{ rows|length }} {{ rows|length == 1 ? 'zápas' : (rows|length < 5 ? 'zápasy' : 'zápasů') }}
                    </p>
                    <button type="submit"
                            class="inline-flex items-center gap-1.5 rounded-lg bg-navy-900 hover:bg-navy-700 px-5 py-2.5 text-sm font-semibold text-white transition-colors w-full sm:w-auto justify-center">
                        <twig:ux:icon name="lucide:save" class="h-4 w-4" />
                        Uložit vše
                    </button>
                </div>
            </div>
        </form>
    {% endif %}
</div>
{% endblock %}
