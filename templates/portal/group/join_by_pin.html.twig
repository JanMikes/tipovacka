{% extends 'base.html.twig' %}

{% block title %}Připojit se ke skupině — Tipovačka{% endblock %}

{% block body %}
<div class="max-w-md mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-navy-900">Připojit se ke skupině</h1>
        <p class="text-navy-900/60 mt-1">Zadej 8místný PIN, který ti někdo dal.</p>
    </div>

    <div class="bg-white rounded-2xl shadow-card ring-1 ring-navy-900/5 p-8">
        {{ form_start(form, {attr: {class: 'space-y-5', novalidate: 'novalidate'}}) }}

            <div>
                {{ form_label(form.pin, null, {label_attr: {class: 'block text-sm font-medium text-navy-900 mb-1.5'}}) }}
                {{ form_widget(form.pin, {attr: {class: 'w-full px-4 py-2.5 border border-navy-100 rounded-lg focus:ring-2 focus:ring-cyan-500 focus:border-transparent outline-none transition font-mono tracking-widest text-center text-lg'}}) }}
                {{ form_errors(form.pin) }}
            </div>

            <button
                type="submit"
                class="w-full bg-navy-900 hover:bg-navy-700 text-white py-3 px-6 rounded-lg font-medium transition-colors"
            >
                Připojit se
            </button>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
