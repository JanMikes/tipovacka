{% extends 'base.html.twig' %}

{% block title %}Připojit se ke skupině — Tipovačka{% endblock %}

{% block body %}
<div class="max-w-md mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-[#081e44]">Připojit se ke skupině</h1>
        <p class="text-gray-500 mt-1">Zadej 8místný PIN, který ti někdo dal.</p>
    </div>

    <div class="bg-white rounded-2xl shadow-lg p-8">
        {{ form_start(form, {attr: {class: 'space-y-5', novalidate: 'novalidate'}}) }}

            <div>
                {{ form_label(form.pin, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.pin, {attr: {class: 'w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#149AD5] focus:border-transparent outline-none transition font-mono tracking-widest text-center text-lg'}}) }}
                {{ form_errors(form.pin) }}
            </div>

            <button
                type="submit"
                class="w-full bg-[#081e44] hover:bg-[#0f2d5f] text-white py-3 px-6 rounded-lg font-medium transition-colors"
            >
                Připojit se
            </button>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
