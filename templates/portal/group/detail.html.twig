{% extends 'base.html.twig' %}

{% block title %}{{ detail.name }} — Tipovačka{% endblock %}

{% block body %}
<div class="mx-auto w-full max-w-6xl px-4 py-8 sm:px-6 sm:py-12 lg:px-8">

    <twig:Breadcrumbs :items="[
        {label: 'Nástěnka', path: path('portal_dashboard')},
        {label: detail.tournamentName, path: path('portal_tournament_detail', {id: detail.tournamentId.toRfc4122})},
        {label: detail.name},
    ]" />

    {# Hero #}
    <header class="mb-6">
        <div class="flex flex-wrap items-center gap-3">
            <h1 class="text-3xl font-bold tracking-tight text-navy-900 sm:text-4xl">{{ detail.name }}</h1>
            {% if detail.tournamentIsFinished %}
                <span class="inline-flex items-center rounded-full bg-gray-200 px-2.5 py-0.5 text-xs font-semibold text-gray-800">Turnaj ukončen</span>
            {% endif %}
        </div>
        <p class="mt-2 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-navy-900/60">
            <span class="inline-flex items-center gap-1.5">
                <twig:ux:icon name="lucide:trophy" class="h-4 w-4" />
                <a href="{{ path('portal_tournament_detail', {id: detail.tournamentId.toRfc4122}) }}" class="hover:text-cyan-600">{{ detail.tournamentName }}</a>
            </span>
            <span class="inline-flex items-center gap-1.5">
                <twig:ux:icon name="lucide:user" class="h-4 w-4" />{{ detail.ownerNickname }}
            </span>
        </p>
    </header>

    {% if detail.description %}
        <section class="mb-6 rounded-2xl bg-white p-6 shadow-card ring-1 ring-navy-900/5">
            <p class="whitespace-pre-line text-navy-900/80">{{ detail.description }}</p>
        </section>
    {% endif %}

    <div class="grid gap-6 lg:grid-cols-12">

        {# ───── Main column ───── #}
        <div class="space-y-6 lg:col-span-8">

            {# Quick-tip CTA: batch-fill all my guesses for this group at once.
               Only shown to members while the tournament is still running. #}
            {% if isMember and not detail.tournamentIsFinished %}
                <a href="{{ path('portal_group_my_tips_batch', {id: group.id.toRfc4122}) }}"
                   class="group flex items-center gap-4 rounded-2xl bg-gradient-to-br from-cyan-500 to-cyan-600 p-5 text-white shadow-card transition-shadow hover:shadow-card-hover">
                    <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-white/15 ring-1 ring-white/20">
                        <twig:ux:icon name="lucide:zap" class="h-6 w-6" />
                    </span>
                    <div class="min-w-0 flex-1">
                        <p class="text-base font-semibold">Tipnout všechny zápasy najednou</p>
                        <p class="mt-0.5 text-sm text-white/80">Vyplň nebo uprav své tipy v jedné tabulce. Prázdná pole se přeskočí.</p>
                    </div>
                    <twig:ux:icon name="lucide:arrow-right" class="h-5 w-5 shrink-0 transition-transform group-hover:translate-x-1" />
                </a>
            {% endif %}

            {# Members #}
            <section class="rounded-2xl bg-white shadow-card ring-1 ring-navy-900/5">
                <details class="group">
                    <summary class="flex cursor-pointer list-none items-center justify-between gap-3 px-6 py-4 hover:bg-navy-50/40 [&::-webkit-details-marker]:hidden">
                        <div class="flex items-center gap-2.5">
                            <twig:ux:icon name="lucide:users" class="h-5 w-5 text-cyan-500" />
                            <h2 class="text-lg font-semibold text-navy-900">Členové</h2>
                            <span class="rounded-full bg-navy-50 px-2.5 py-0.5 text-xs font-semibold text-navy-700">{{ detail.members|length }}</span>
                        </div>
                        <twig:ux:icon name="lucide:chevron-down" class="h-5 w-5 text-navy-900/60 transition-transform group-open:rotate-180" />
                    </summary>

                    <ul class="divide-y divide-navy-100/70 border-t border-navy-100/70">
                    {% for member in detail.members %}
                        {% set score = score_by_user_id[member.userId.toRfc4122] ?? null %}
                        <li class="flex flex-wrap items-center justify-between gap-3 px-6 py-4">
                            <div class="min-w-0 flex-1">
                                <div class="flex items-center gap-2 flex-wrap">
                                    <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-navy-100 text-xs font-semibold text-navy-700">
                                        {{ member.displayName|slice(0, 1)|upper }}
                                    </span>
                                    <a href="{{ path('portal_group_leaderboard_member', {groupId: group.id.toRfc4122, userId: member.userId.toRfc4122}) }}" class="min-w-0 font-medium text-navy-900 transition-colors hover:text-cyan-600 hover:underline">
                                        <span class="block truncate">{{ member.displayName }}</span>
                                        {% if member.fullName %}<small class="block truncate text-xs font-normal text-navy-900/60">{{ member.fullName }}</small>{% endif %}
                                    </a>
                                    {% if member.isOwner %}
                                        <span class="inline-flex items-center gap-1 rounded-full bg-purple-100 px-2.5 py-0.5 text-xs font-semibold text-purple-800">
                                            <twig:ux:icon name="lucide:crown" class="h-3 w-3" />Vlastník
                                        </span>
                                    {% endif %}
                                    {% if member.isAnonymous %}
                                        <span class="inline-flex items-center gap-1 rounded-full bg-amber-100 px-2.5 py-0.5 text-xs font-semibold text-amber-800">
                                            <twig:ux:icon name="lucide:user" class="h-3 w-3" />Anonymní
                                        </span>
                                    {% endif %}
                                </div>
                                <p class="mt-1 pl-10 text-xs text-navy-900/60">Přidán {{ member.joinedAt|date('d. m. Y') }}</p>
                            </div>

                            <div class="flex shrink-0 items-center gap-3">
                                {% if score %}
                                    <div class="text-right">
                                        <p class="text-xs font-medium uppercase tracking-wider text-navy-900/50">
                                            {{ score.rank }}. místo
                                        </p>
                                        <p class="text-lg font-bold tabular-nums text-navy-900">
                                            {{ score.totalPoints }}<span class="ml-0.5 text-xs font-medium text-navy-900/60">b</span>
                                        </p>
                                    </div>
                                {% endif %}
                                {% if is_granted('group_manage_members', group) and member.isAnonymous %}
                                    <a href="{{ path('portal_group_promote_anonymous_member', {id: group.id.toRfc4122, userId: member.userId.toRfc4122}) }}" class="text-sm font-medium text-cyan-600 hover:text-cyan-700 hover:underline">
                                        Přidat e-mail
                                    </a>
                                {% endif %}
                                {% if is_granted('group_manage_members', group) and not member.isOwner %}
                                    <form method="post" action="{{ path('portal_group_remove_member', {id: group.id.toRfc4122, userId: member.userId.toRfc4122}) }}" class="inline"
                                        data-controller="confirm"
                                        data-confirm-title-value="Odebrat člena"
                                        data-confirm-message-value="Opravdu chceš člena {{ member.displayName }} odebrat ze skupiny? Ztratí všechny své tipy v této skupině."
                                        data-confirm-confirm-label-value="Ano, odebrat">
                                        <input type="hidden" name="_token" value="{{ csrf_token('group_remove_member_' ~ group.id.toRfc4122 ~ '_' ~ member.userId.toRfc4122) }}">
                                        <button type="submit" class="text-sm font-medium text-red-600 hover:text-red-700 hover:underline">
                                            Odebrat
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        </li>
                    {% else %}
                        <li class="px-6 py-10 text-center text-sm text-navy-900/60">Zatím žádní členové.</li>
                    {% endfor %}
                    </ul>
                </details>
            </section>

            {# My guesses #}
            {% if my_guesses|length > 0 %}
                <section class="rounded-2xl bg-white shadow-card ring-1 ring-navy-900/5">
                    <details class="group">
                        <summary class="flex cursor-pointer list-none items-center justify-between gap-3 px-6 py-4 hover:bg-navy-50/40 [&::-webkit-details-marker]:hidden">
                            <div class="flex items-center gap-2.5">
                                <twig:ux:icon name="lucide:target" class="h-5 w-5 text-cyan-500" />
                                <h2 class="text-lg font-semibold text-navy-900">Moje tipy</h2>
                                <span class="rounded-full bg-navy-50 px-2.5 py-0.5 text-xs font-semibold text-navy-700">{{ my_guesses|length }}</span>
                            </div>
                            <twig:ux:icon name="lucide:chevron-down" class="h-5 w-5 text-navy-900/60 transition-transform group-open:rotate-180" />
                        </summary>
                    <ul class="divide-y divide-navy-100/70 border-t border-navy-100/70">
                        {% for row in my_guesses %}
                            {%- set state = row.state.value -%}
                            <li>
                                <a href="{{ path('portal_sport_match_detail', {id: row.sportMatchId.toRfc4122}) }}" class="grid grid-cols-[auto_1fr_auto_auto] items-center gap-3 px-6 py-4 transition-colors hover:bg-navy-50/40 sm:gap-5">
                                    <div class="flex w-16 flex-col text-xs text-navy-900/60">
                                        <span class="font-medium">{{ row.kickoffAt|date('d. m.') }}</span>
                                        <span>{{ row.kickoffAt|date('H:i') }}</span>
                                    </div>

                                    <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-2 text-sm">
                                        <span class="truncate text-right font-medium text-navy-900">{{ row.homeTeam }}</span>
                                        {% if state == 'finished' and row.actualHomeScore is not null %}
                                            <span class="rounded-md bg-navy-50 px-2 py-0.5 text-sm font-bold tabular-nums text-navy-900">
                                                {{ row.actualHomeScore }} : {{ row.actualAwayScore }}
                                            </span>
                                        {% else %}
                                            <span class="text-xs font-semibold text-navy-900/40">vs</span>
                                        {% endif %}
                                        <span class="truncate font-medium text-navy-900">{{ row.awayTeam }}</span>
                                    </div>

                                    <div class="text-right">
                                        <p class="text-[10px] font-semibold uppercase tracking-wider text-navy-900/50">Můj tip</p>
                                        <p class="rounded-md bg-cyan-100 px-2 py-0.5 text-sm font-bold tabular-nums text-cyan-700">
                                            {{ row.myHomeScore }} : {{ row.myAwayScore }}
                                        </p>
                                    </div>

                                    <span class="shrink-0 rounded-full px-2 py-0.5 text-[10px] font-semibold
                                        {%- if state == 'scheduled' %} bg-blue-100 text-blue-800
                                        {%- elseif state == 'live' %} bg-orange-100 text-orange-800 animate-pulse
                                        {%- elseif state == 'finished' %} bg-green-100 text-green-800
                                        {%- elseif state == 'postponed' %} bg-yellow-100 text-yellow-800
                                        {%- else %} bg-gray-200 text-gray-800{% endif %}">
                                        {% if state == 'scheduled' %}Plán
                                        {% elseif state == 'live' %}Živě
                                        {% elseif state == 'finished' %}Odehrán
                                        {% elseif state == 'postponed' %}Odložen
                                        {% else %}Zrušen{% endif %}
                                    </span>
                                </a>
                            </li>
                        {% endfor %}
                    </ul>
                    </details>
                </section>
            {% endif %}

            {# Pending join requests (public tournaments only) #}
            {% if is_granted('group_manage_members', group) and group.tournament.isPublic %}
                <section class="rounded-2xl bg-white shadow-card ring-1 ring-navy-900/5">
                    <header class="flex items-center gap-2.5 border-b border-navy-100/70 px-6 py-4">
                        <twig:ux:icon name="lucide:log-in" class="h-5 w-5 text-cyan-500" />
                        <h2 class="text-lg font-semibold text-navy-900">Žádosti o připojení</h2>
                        {% if pendingJoinRequests|length > 0 %}
                            <span class="rounded-full bg-cyan-100 px-2.5 py-0.5 text-xs font-semibold text-cyan-700">{{ pendingJoinRequests|length }}</span>
                        {% endif %}
                    </header>

                    {% if pendingJoinRequests|length > 0 %}
                        <ul class="divide-y divide-navy-100/70">
                            {% for req in pendingJoinRequests %}
                                <li class="flex flex-wrap items-center justify-between gap-3 px-6 py-4">
                                    <div>
                                        <span class="font-medium text-navy-900">{{ req.nickname }}</span>
                                        <p class="text-xs text-navy-900/60">Žádost {{ req.requestedAt|date('d. m. Y H:i') }}</p>
                                    </div>
                                    <div class="flex gap-2">
                                        <form method="post" action="{{ path('portal_join_request_approve', {requestId: req.requestId.toRfc4122}) }}" class="inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('join_request_approve_' ~ req.requestId.toRfc4122) }}">
                                            <button type="submit" class="inline-flex items-center gap-1 rounded-lg bg-green-600 px-3 py-1.5 text-sm font-semibold text-white transition-colors hover:bg-green-700">
                                                <twig:ux:icon name="lucide:check" class="h-3.5 w-3.5" />Schválit
                                            </button>
                                        </form>
                                        <form method="post" action="{{ path('portal_join_request_reject', {requestId: req.requestId.toRfc4122}) }}" class="inline"
                                            data-controller="confirm"
                                            data-confirm-title-value="Zamítnout žádost"
                                            data-confirm-message-value="Opravdu chceš zamítnout žádost od {{ req.nickname }}?"
                                            data-confirm-confirm-label-value="Ano, zamítnout">
                                            <input type="hidden" name="_token" value="{{ csrf_token('join_request_reject_' ~ req.requestId.toRfc4122) }}">
                                            <button type="submit" class="inline-flex items-center gap-1 rounded-lg bg-red-600 px-3 py-1.5 text-sm font-semibold text-white transition-colors hover:bg-red-700">
                                                <twig:ux:icon name="lucide:x" class="h-3.5 w-3.5" />Zamítnout
                                            </button>
                                        </form>
                                    </div>
                                </li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        <p class="px-6 py-10 text-center text-sm text-navy-900/60">Žádné čekající žádosti.</p>
                    {% endif %}
                </section>
            {% endif %}

            {# Email invitations — admin / owner only #}
            {% if is_granted('group_manage_members', group) %}
                <section class="rounded-2xl bg-white shadow-card ring-1 ring-navy-900/5">
                    <header class="flex items-center gap-2.5 border-b border-navy-100/70 px-6 py-4">
                        <twig:ux:icon name="lucide:mail" class="h-5 w-5 text-cyan-500" />
                        <h2 class="text-lg font-semibold text-navy-900">Pozvánky e-mailem</h2>
                    </header>

                    <div class="px-6 py-5">
                        {{ form_start(invitationForm) }}
                            <div class="flex flex-wrap items-end gap-3">
                                <div class="min-w-[220px] flex-1">
                                    {{ form_row(invitationForm.email) }}
                                </div>
                                <button type="submit" class="inline-flex items-center gap-1.5 rounded-lg bg-navy-900 px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-navy-700">
                                    <twig:ux:icon name="lucide:mail" class="h-4 w-4" />
                                    Odeslat pozvánku
                                </button>
                            </div>
                        {{ form_end(invitationForm) }}

                        {% if bulkInvitationForm %}
                            <details class="mt-5 border-t border-navy-100/70 pt-5">
                                <summary class="cursor-pointer text-sm font-semibold text-navy-900 hover:text-cyan-600">
                                    Pozvat více lidí najednou
                                </summary>
                                <div class="mt-3">
                                    <p class="mb-3 text-xs text-navy-900/60">
                                        Pro neznámé e-maily založíme prázdný účet a odešleme odkaz na dokončení registrace — pozvaný si jen zvolí heslo a rovnou se připojí.
                                    </p>
                                    {{ form_start(bulkInvitationForm) }}
                                        <div class="space-y-3">
                                            {{ form_row(bulkInvitationForm.emails) }}
                                            <button type="submit" class="inline-flex items-center gap-1.5 rounded-lg bg-navy-900 px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-navy-700">
                                                <twig:ux:icon name="lucide:users" class="h-4 w-4" />
                                                Odeslat hromadně
                                            </button>
                                        </div>
                                    {{ form_end(bulkInvitationForm) }}
                                </div>
                            </details>
                        {% endif %}

                        <div class="mt-5 border-t border-navy-100/70 pt-5">
                            <p class="mb-3 text-xs text-navy-900/60">
                                Někdo nechce e-mail? Přidej ho ručně a zadávej jeho tipy za něj. Později mu stačí přidat e-mail a pozveme ho k nastavení hesla.
                            </p>
                            <a href="{{ path('portal_group_add_anonymous_member', {id: group.id.toRfc4122}) }}" class="inline-flex items-center gap-1.5 rounded-lg bg-navy-50 px-4 py-2.5 text-sm font-semibold text-navy-900 transition-colors hover:bg-navy-100">
                                <twig:ux:icon name="lucide:user" class="h-4 w-4" />
                                Přidat tipujícího bez e-mailu
                            </a>
                        </div>


                        {% if pendingInvitations|length > 0 %}
                            <div class="mt-6 border-t border-navy-100/70 pt-5">
                                <p class="mb-3 text-xs font-semibold uppercase tracking-wider text-navy-900/50">Čekající pozvánky</p>
                                <ul class="divide-y divide-navy-100/70">
                                    {% for inv in pendingInvitations %}
                                        <li class="flex flex-wrap items-center justify-between gap-3 py-3">
                                            <div>
                                                <span class="font-medium text-navy-900">{{ inv.email }}</span>
                                                <p class="text-xs text-navy-900/60">Pozval {{ inv.inviterNickname }} · odesláno {{ inv.sentAt|date('d. m. Y H:i') }} · vyprší {{ inv.expiresAt|date('d. m. Y') }}</p>
                                            </div>
                                            <form method="post" action="{{ path('portal_invitation_revoke', {invitationId: inv.invitationId.toRfc4122}) }}" class="inline"
                                                data-controller="confirm"
                                                data-confirm-title-value="Zrušit pozvánku"
                                                data-confirm-message-value="Opravdu chceš zrušit pozvánku pro {{ inv.email }}? Odkaz z e-mailu přestane fungovat."
                                                data-confirm-confirm-label-value="Ano, zrušit">
                                                <input type="hidden" name="_token" value="{{ csrf_token('invitation_revoke_' ~ inv.invitationId.toRfc4122) }}">
                                                <button type="submit" class="text-sm font-medium text-red-600 hover:text-red-700 hover:underline">
                                                    Zrušit
                                                </button>
                                            </form>
                                        </li>
                                    {% endfor %}
                                </ul>
                            </div>
                        {% endif %}
                    </div>
                </section>
            {% endif %}
        </div>

        {# ───── Sidebar ───── #}
        <aside class="space-y-6 lg:col-span-4">

            {# Leaderboard CTA #}
            {% if is_granted('leaderboard_view', group) %}
                <section class="rounded-2xl bg-gradient-to-br from-navy-900 via-navy-800 to-navy-700 p-6 text-white shadow-card">
                    <div class="flex items-center gap-2.5">
                        <twig:ux:icon name="lucide:trophy" class="h-5 w-5 text-cyan-400" />
                        <h2 class="text-sm font-semibold uppercase tracking-wider">Žebříček</h2>
                    </div>
                    <p class="mt-2 text-sm text-white/70">Podívej se, kdo vede a kolik má bodů.</p>
                    <a href="{{ path('portal_group_leaderboard', {groupId: group.id.toRfc4122}) }}" class="mt-4 inline-flex w-full items-center justify-center gap-1.5 rounded-lg bg-cyan-500 px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-cyan-600">
                        Zobrazit žebříček
                        <twig:ux:icon name="lucide:arrow-right" class="h-4 w-4" />
                    </a>
                </section>
            {% endif %}

            {# Invites (PIN + shareable link) #}
            {% if is_granted('group_manage_members', group) %}
                <section class="rounded-2xl bg-white shadow-card ring-1 ring-navy-900/5">
                    <header class="flex items-center gap-2.5 border-b border-navy-100/70 px-6 py-4">
                        <twig:ux:icon name="lucide:key-round" class="h-5 w-5 text-cyan-500" />
                        <h2 class="text-lg font-semibold text-navy-900">Rychlé pozvánky</h2>
                    </header>
                    <div class="space-y-5 px-6 py-5">
                        <div>
                            <p class="mb-2 text-xs font-semibold uppercase tracking-wider text-navy-900/50">PIN</p>
                            {% if detail.pin %}
                                <div class="space-y-2">
                                    <code class="block rounded-lg bg-navy-50 px-3 py-2 text-center font-mono text-lg tracking-[0.3em] text-navy-900">{{ detail.pin }}</code>
                                    <div class="flex flex-wrap gap-3 text-xs">
                                        <form method="post" action="{{ path('portal_group_pin_regenerate', {id: group.id.toRfc4122}) }}" class="inline"
                                            data-controller="confirm"
                                            data-confirm-variant-value="warning"
                                            data-confirm-title-value="Obnovit PIN"
                                            data-confirm-message-value="Vygenerujeme nový PIN a stávající přestane platit. Pokud jsi starý PIN někomu poslal, přestane se s ním dát připojit."
                                            data-confirm-confirm-label-value="Ano, obnovit">
                                            <input type="hidden" name="_token" value="{{ csrf_token('group_pin_regenerate_' ~ group.id.toRfc4122) }}">
                                            <button type="submit" class="font-medium text-cyan-600 hover:underline">Obnovit</button>
                                        </form>
                                        <form method="post" action="{{ path('portal_group_pin_revoke', {id: group.id.toRfc4122}) }}" class="inline"
                                            data-controller="confirm"
                                            data-confirm-title-value="Zrušit PIN"
                                            data-confirm-message-value="PIN bude zneplatněn a nikdo se podle něj nebude moct připojit. Nový PIN můžeš kdykoli vygenerovat znovu."
                                            data-confirm-confirm-label-value="Ano, zrušit">
                                            <input type="hidden" name="_token" value="{{ csrf_token('group_pin_revoke_' ~ group.id.toRfc4122) }}">
                                            <button type="submit" class="font-medium text-red-600 hover:underline">Zrušit</button>
                                        </form>
                                    </div>
                                </div>
                            {% else %}
                                <p class="text-sm text-navy-900/60">PIN není aktivní.</p>
                                <form method="post" action="{{ path('portal_group_pin_regenerate', {id: group.id.toRfc4122}) }}" class="mt-2 inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('group_pin_regenerate_' ~ group.id.toRfc4122) }}">
                                    <button type="submit" class="text-sm font-medium text-cyan-600 hover:underline">Vygenerovat PIN</button>
                                </form>
                            {% endif %}
                        </div>

                        <div class="border-t border-navy-100/70 pt-4">
                            <p class="mb-2 flex items-center gap-1.5 text-xs font-semibold uppercase tracking-wider text-navy-900/50">
                                <twig:ux:icon name="lucide:share-2" class="h-3.5 w-3.5" />
                                Odkaz
                            </p>
                            {% if detail.shareableLinkToken %}
                                <div class="space-y-2">
                                    <code class="block break-all rounded-lg bg-navy-50 px-3 py-2 text-xs text-navy-900">{{ url('group_join_by_link', {token: detail.shareableLinkToken}) }}</code>
                                    <div class="flex flex-wrap gap-3 text-xs">
                                        <form method="post" action="{{ path('portal_group_link_regenerate', {id: group.id.toRfc4122}) }}" class="inline"
                                            data-controller="confirm"
                                            data-confirm-variant-value="warning"
                                            data-confirm-title-value="Obnovit odkaz"
                                            data-confirm-message-value="Vygenerujeme nový odkaz a ten stávající přestane fungovat. Pokud jsi ho někomu poslal, nebude se přes něj dát připojit."
                                            data-confirm-confirm-label-value="Ano, obnovit">
                                            <input type="hidden" name="_token" value="{{ csrf_token('group_link_regenerate_' ~ group.id.toRfc4122) }}">
                                            <button type="submit" class="font-medium text-cyan-600 hover:underline">Obnovit</button>
                                        </form>
                                        <form method="post" action="{{ path('portal_group_link_revoke', {id: group.id.toRfc4122}) }}" class="inline"
                                            data-controller="confirm"
                                            data-confirm-title-value="Zrušit odkaz"
                                            data-confirm-message-value="Odkaz bude zneplatněn a nikdo se podle něj nebude moct připojit. Nový odkaz můžeš kdykoli vygenerovat znovu."
                                            data-confirm-confirm-label-value="Ano, zrušit">
                                            <input type="hidden" name="_token" value="{{ csrf_token('group_link_revoke_' ~ group.id.toRfc4122) }}">
                                            <button type="submit" class="font-medium text-red-600 hover:underline">Zrušit</button>
                                        </form>
                                    </div>
                                </div>
                            {% else %}
                                <p class="text-sm text-navy-900/60">Odkaz není aktivní.</p>
                                <form method="post" action="{{ path('portal_group_link_regenerate', {id: group.id.toRfc4122}) }}" class="mt-2 inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('group_link_regenerate_' ~ group.id.toRfc4122) }}">
                                    <button type="submit" class="text-sm font-medium text-cyan-600 hover:underline">Vygenerovat odkaz</button>
                                </form>
                            {% endif %}
                        </div>
                    </div>
                </section>
            {% endif %}

            {# Actions #}
            <section class="rounded-2xl bg-white shadow-card ring-1 ring-navy-900/5">
                <header class="flex items-center gap-2.5 border-b border-navy-100/70 px-6 py-4">
                    <twig:ux:icon name="lucide:settings" class="h-5 w-5 text-cyan-500" />
                    <h2 class="text-lg font-semibold text-navy-900">Správa</h2>
                </header>
                <div class="space-y-2 px-6 py-5">
                    {% if is_granted('group_edit', group) %}
                        <a href="{{ path('portal_group_edit', {id: group.id.toRfc4122}) }}" class="flex w-full items-center gap-2 rounded-lg bg-navy-50 px-4 py-2.5 text-sm font-semibold text-navy-900 transition-colors hover:bg-navy-100">
                            <twig:ux:icon name="lucide:pencil" class="h-4 w-4" />Upravit skupinu
                        </a>
                    {% endif %}

                    {% if isMember and not detail.tournamentIsFinished %}
                        <a href="{{ path('portal_group_my_tips_batch', {id: group.id.toRfc4122}) }}" class="flex w-full items-center gap-2 rounded-lg bg-navy-50 px-4 py-2.5 text-sm font-semibold text-navy-900 transition-colors hover:bg-navy-100">
                            <twig:ux:icon name="lucide:zap" class="h-4 w-4" />Tipnout vše najednou
                        </a>
                    {% endif %}

                    {% if is_granted('group_manage_members', group) %}
                        <a href="{{ path('portal_group_manage_member_tips', {id: group.id.toRfc4122}) }}" class="flex w-full items-center gap-2 rounded-lg bg-navy-50 px-4 py-2.5 text-sm font-semibold text-navy-900 transition-colors hover:bg-navy-100">
                            <twig:ux:icon name="lucide:target" class="h-4 w-4" />Tipovat za členy
                        </a>
                    {% endif %}

                    {% if is_granted('group_leave', group) %}
                        <form method="post" action="{{ path('portal_group_leave', {id: group.id.toRfc4122}) }}"
                            data-controller="confirm"
                            data-confirm-variant-value="warning"
                            data-confirm-title-value="Opustit skupinu"
                            data-confirm-message-value="Opravdu chceš skupinu opustit? Přijdeš o všechny tipy, které jsi v ní zadal."
                            data-confirm-confirm-label-value="Ano, opustit">
                            <input type="hidden" name="_token" value="{{ csrf_token('group_leave_' ~ group.id.toRfc4122) }}">
                            <button type="submit" class="flex w-full items-center gap-2 rounded-lg bg-yellow-50 px-4 py-2.5 text-sm font-semibold text-yellow-800 transition-colors hover:bg-yellow-100">
                                <twig:ux:icon name="lucide:log-out" class="h-4 w-4" />Opustit skupinu
                            </button>
                        </form>
                    {% endif %}

                    {% if is_granted('group_delete', group) %}
                        <form method="post" action="{{ path('portal_group_delete', {id: group.id.toRfc4122}) }}"
                            data-controller="confirm"
                            data-confirm-title-value="Smazat skupinu"
                            data-confirm-message-value="Opravdu chceš skupinu „{{ detail.name }}“ smazat? Všichni členové přijdou o své tipy a skupina zmizí ze žebříčku."
                            data-confirm-confirm-label-value="Ano, smazat">
                            <input type="hidden" name="_token" value="{{ csrf_token('group_delete_' ~ group.id.toRfc4122) }}">
                            <button type="submit" class="flex w-full items-center gap-2 rounded-lg bg-red-50 px-4 py-2.5 text-sm font-semibold text-red-700 transition-colors hover:bg-red-100">
                                <twig:ux:icon name="lucide:trash-2" class="h-4 w-4" />Smazat skupinu
                            </button>
                        </form>
                    {% endif %}
                </div>
            </section>
        </aside>
    </div>
</div>
{% endblock %}
