{% extends 'base.html.twig' %}

{% block title %}{{ detail.name }} — Tipovačka{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8">
        <div class="flex items-center gap-3 mb-2 flex-wrap">
            <h1 class="text-3xl font-bold text-[#081e44]">{{ detail.name }}</h1>
            {% if detail.tournamentIsFinished %}
                <span class="px-3 py-1 rounded-full text-xs font-medium bg-gray-200 text-gray-800">Turnaj ukončen</span>
            {% endif %}
        </div>
        <p class="text-gray-500">
            Turnaj:
            <a href="{{ path('portal_tournament_detail', {id: detail.tournamentId.toRfc4122}) }}" class="text-[#149AD5] hover:underline">
                {{ detail.tournamentName }}
            </a>
            · Vlastník: {{ detail.ownerNickname }}
        </p>
    </div>

    {% if detail.description %}
        <div class="bg-white rounded-2xl shadow-lg p-6 mb-6">
            <p class="text-sm font-medium text-gray-500 mb-1">Popis</p>
            <p class="text-[#081e44] whitespace-pre-line">{{ detail.description }}</p>
        </div>
    {% endif %}

    {% if is_granted('group_manage_members', group) %}
        <div class="bg-white rounded-2xl shadow-lg p-6 mb-6">
            <h2 class="text-lg font-semibold text-[#081e44] mb-4">Pozvánky</h2>

            <div class="mb-5">
                <p class="text-sm font-medium text-gray-500 mb-1">PIN pro připojení</p>
                {% if detail.pin %}
                    <div class="flex items-center gap-3 flex-wrap">
                        <code class="bg-gray-100 text-[#081e44] font-mono text-lg px-3 py-1.5 rounded">{{ detail.pin }}</code>
                        <form method="post" action="{{ path('portal_group_pin_regenerate', {id: group.id.toRfc4122}) }}" class="inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('group_pin_regenerate_' ~ group.id.toRfc4122) }}">
                            <button type="submit" class="text-sm text-[#149AD5] hover:underline">Obnovit</button>
                        </form>
                        <form method="post" action="{{ path('portal_group_pin_revoke', {id: group.id.toRfc4122}) }}" class="inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('group_pin_revoke_' ~ group.id.toRfc4122) }}">
                            <button type="submit" class="text-sm text-red-600 hover:underline">Zrušit</button>
                        </form>
                    </div>
                {% else %}
                    <div class="flex items-center gap-3 flex-wrap">
                        <span class="text-gray-500 text-sm">PIN není aktivní.</span>
                        <form method="post" action="{{ path('portal_group_pin_regenerate', {id: group.id.toRfc4122}) }}" class="inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('group_pin_regenerate_' ~ group.id.toRfc4122) }}">
                            <button type="submit" class="text-sm text-[#149AD5] hover:underline">Vygenerovat PIN</button>
                        </form>
                    </div>
                {% endif %}
            </div>

            <div>
                <p class="text-sm font-medium text-gray-500 mb-1">Pozvánkový odkaz</p>
                {% if detail.shareableLinkToken %}
                    <div class="flex items-center gap-3 flex-wrap">
                        <code class="bg-gray-100 text-[#081e44] text-xs px-3 py-1.5 rounded break-all">{{ url('group_join_by_link', {token: detail.shareableLinkToken}) }}</code>
                        <form method="post" action="{{ path('portal_group_link_regenerate', {id: group.id.toRfc4122}) }}" class="inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('group_link_regenerate_' ~ group.id.toRfc4122) }}">
                            <button type="submit" class="text-sm text-[#149AD5] hover:underline">Obnovit</button>
                        </form>
                        <form method="post" action="{{ path('portal_group_link_revoke', {id: group.id.toRfc4122}) }}" class="inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('group_link_revoke_' ~ group.id.toRfc4122) }}">
                            <button type="submit" class="text-sm text-red-600 hover:underline">Zrušit</button>
                        </form>
                    </div>
                {% else %}
                    <div class="flex items-center gap-3 flex-wrap">
                        <span class="text-gray-500 text-sm">Odkaz není aktivní.</span>
                        <form method="post" action="{{ path('portal_group_link_regenerate', {id: group.id.toRfc4122}) }}" class="inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('group_link_regenerate_' ~ group.id.toRfc4122) }}">
                            <button type="submit" class="text-sm text-[#149AD5] hover:underline">Vygenerovat odkaz</button>
                        </form>
                    </div>
                {% endif %}
            </div>
        </div>
    {% endif %}

    <div class="bg-white rounded-2xl shadow-lg p-6 mb-6">
        <h2 class="text-lg font-semibold text-[#081e44] mb-4">Členové ({{ detail.members|length }})</h2>
        <ul class="divide-y divide-gray-100">
            {% for member in detail.members %}
                <li class="py-3 flex items-center justify-between flex-wrap gap-3">
                    <div>
                        <span class="font-medium text-[#081e44]">{{ member.nickname }}</span>
                        {% if member.isOwner %}
                            <span class="ml-2 px-2 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">Vlastník</span>
                        {% endif %}
                        <p class="text-xs text-gray-500">Přidán {{ member.joinedAt|date('d. m. Y') }}</p>
                    </div>
                    {% if is_granted('group_manage_members', group) and not member.isOwner %}
                        <form method="post" action="{{ path('portal_group_remove_member', {id: group.id.toRfc4122, userId: member.userId.toRfc4122}) }}" class="inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('group_remove_member_' ~ group.id.toRfc4122 ~ '_' ~ member.userId.toRfc4122) }}">
                            <button
                                type="submit"
                                class="text-sm text-red-600 hover:underline"
                                onclick="return confirm('Opravdu chceš tohoto člena odebrat?')"
                            >
                                Odebrat
                            </button>
                        </form>
                    {% endif %}
                </li>
            {% else %}
                <li class="py-3 text-sm text-gray-500">Zatím žádní členové.</li>
            {% endfor %}
        </ul>
    </div>

    <div class="bg-white rounded-2xl shadow-lg p-6 mb-6">
        <h2 class="text-lg font-semibold text-[#081e44] mb-4">Správa</h2>
        <div class="flex flex-wrap gap-3">
            {% if is_granted('group_edit', group) %}
                <a
                    href="{{ path('portal_group_edit', {id: group.id.toRfc4122}) }}"
                    class="bg-[#081e44] hover:bg-[#0f2d5f] text-white py-2 px-4 rounded-lg text-sm font-medium transition-colors"
                >
                    Upravit
                </a>
            {% endif %}

            {% if is_granted('group_leave', group) %}
                <form method="post" action="{{ path('portal_group_leave', {id: group.id.toRfc4122}) }}" class="inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('group_leave_' ~ group.id.toRfc4122) }}">
                    <button
                        type="submit"
                        class="bg-yellow-500 hover:bg-yellow-600 text-white py-2 px-4 rounded-lg text-sm font-medium transition-colors"
                        onclick="return confirm('Opravdu chceš skupinu opustit?')"
                    >
                        Opustit skupinu
                    </button>
                </form>
            {% endif %}

            {% if is_granted('group_delete', group) %}
                <form method="post" action="{{ path('portal_group_delete', {id: group.id.toRfc4122}) }}" class="inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('group_delete_' ~ group.id.toRfc4122) }}">
                    <button
                        type="submit"
                        class="bg-red-600 hover:bg-red-700 text-white py-2 px-4 rounded-lg text-sm font-medium transition-colors"
                        onclick="return confirm('Opravdu chceš skupinu smazat?')"
                    >
                        Smazat skupinu
                    </button>
                </form>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
