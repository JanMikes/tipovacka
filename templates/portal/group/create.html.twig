{% extends 'base.html.twig' %}

{% block title %}Nová skupina — Tipovačka{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <twig:Breadcrumbs :items="[
        {label: 'Nástěnka', path: path('portal_dashboard')},
        {label: tournament.name, path: path('portal_tournament_detail', {id: tournament.id.toRfc4122})},
        {label: 'Nová skupina'},
    ]" />
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-navy-900">Nová skupina</h1>
        <p class="text-navy-900/60 mt-1">Turnaj: <strong>{{ tournament.name }}</strong></p>
    </div>

    <div class="bg-white rounded-2xl shadow-card ring-1 ring-navy-900/5 p-8">
        {{ form_start(form, {attr: {class: 'space-y-5', novalidate: 'novalidate'}}) }}

            {% if pinGate ?? false %}
                <div class="rounded-lg border border-purple-200 bg-purple-50 p-4">
                    <p class="text-sm text-purple-900 mb-3">
                        Tento turnaj je soukromý. Pro založení skupiny je potřeba zadat PIN, který ti poskytne vlastník turnaje.
                    </p>
                    {{ form_label(form.tournamentCreationPin, null, {label_attr: {class: 'block text-sm font-medium text-navy-900 mb-1.5'}}) }}
                    {{ form_widget(form.tournamentCreationPin, {attr: {class: 'w-full px-4 py-2.5 border border-navy-100 rounded-lg focus:ring-2 focus:ring-cyan-500 focus:border-transparent outline-none transition font-mono tracking-wider uppercase'}}) }}
                    {{ form_errors(form.tournamentCreationPin) }}
                </div>
            {% endif %}

            <div>
                {{ form_label(form.name, null, {label_attr: {class: 'block text-sm font-medium text-navy-900 mb-1.5'}}) }}
                {{ form_widget(form.name, {attr: {class: 'w-full px-4 py-2.5 border border-navy-100 rounded-lg focus:ring-2 focus:ring-cyan-500 focus:border-transparent outline-none transition'}}) }}
                {{ form_errors(form.name) }}
            </div>

            <div>
                {{ form_label(form.description, null, {label_attr: {class: 'block text-sm font-medium text-navy-900 mb-1.5'}}) }}
                {{ form_widget(form.description, {attr: {class: 'w-full px-4 py-2.5 border border-navy-100 rounded-lg focus:ring-2 focus:ring-cyan-500 focus:border-transparent outline-none transition'}}) }}
                {{ form_errors(form.description) }}
            </div>

            <div class="flex items-start gap-3">
                {{ form_widget(form.withPin, {attr: {class: 'mt-1 h-4 w-4 rounded border-navy-100 text-cyan-500 focus:ring-cyan-500'}}) }}
                <div>
                    {{ form_label(form.withPin, null, {label_attr: {class: 'block text-sm font-medium text-navy-900'}}) }}
                    <p class="text-xs text-navy-900/60">8místný kód, který můžeš sdílet se svými kamarády.</p>
                </div>
            </div>
            {{ form_errors(form.withPin) }}

            <div class="flex gap-3">
                <button
                    type="submit"
                    class="bg-navy-900 hover:bg-navy-700 text-white py-3 px-6 rounded-lg font-medium transition-colors"
                >
                    Vytvořit skupinu
                </button>

                <a
                    href="{{ path('portal_tournament_detail', {id: tournament.id.toRfc4122}) }}"
                    class="bg-navy-50 hover:bg-navy-100 text-navy-900 py-3 px-6 rounded-lg font-medium transition-colors"
                >
                    Zrušit
                </a>
            </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
