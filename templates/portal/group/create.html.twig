{% extends 'base.html.twig' %}

{% block title %}Nová skupina — Tipovačka{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-[#081e44]">Nová skupina</h1>
        <p class="text-gray-500 mt-1">Turnaj: <strong>{{ tournament.name }}</strong></p>
    </div>

    <div class="bg-white rounded-2xl shadow-lg p-8">
        {{ form_start(form, {attr: {class: 'space-y-5', novalidate: 'novalidate'}}) }}

            {% if pinGate ?? false %}
                <div class="rounded-lg border border-purple-200 bg-purple-50 p-4">
                    <p class="text-sm text-purple-900 mb-3">
                        Tento turnaj je soukromý. Pro založení skupiny je potřeba zadat PIN, který ti poskytne vlastník turnaje.
                    </p>
                    {{ form_label(form.tournamentCreationPin, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.tournamentCreationPin, {attr: {class: 'w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#149AD5] focus:border-transparent outline-none transition font-mono tracking-wider uppercase'}}) }}
                    {{ form_errors(form.tournamentCreationPin) }}
                </div>
            {% endif %}

            <div>
                {{ form_label(form.name, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.name, {attr: {class: 'w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#149AD5] focus:border-transparent outline-none transition'}}) }}
                {{ form_errors(form.name) }}
            </div>

            <div>
                {{ form_label(form.description, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.description, {attr: {class: 'w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#149AD5] focus:border-transparent outline-none transition'}}) }}
                {{ form_errors(form.description) }}
            </div>

            <div class="flex items-start gap-3">
                {{ form_widget(form.withPin, {attr: {class: 'mt-1 h-4 w-4 rounded border-gray-300 text-[#149AD5] focus:ring-[#149AD5]'}}) }}
                <div>
                    {{ form_label(form.withPin, null, {label_attr: {class: 'block text-sm font-medium text-gray-700'}}) }}
                    <p class="text-xs text-gray-500">8místný kód, který můžeš sdílet se svými kamarády.</p>
                </div>
            </div>
            {{ form_errors(form.withPin) }}

            <div class="flex gap-3">
                <button
                    type="submit"
                    class="bg-[#081e44] hover:bg-[#0f2d5f] text-white py-3 px-6 rounded-lg font-medium transition-colors"
                >
                    Vytvořit skupinu
                </button>

                <a
                    href="{{ path('portal_tournament_detail', {id: tournament.id.toRfc4122}) }}"
                    class="bg-gray-100 hover:bg-gray-200 text-gray-700 py-3 px-6 rounded-lg font-medium transition-colors"
                >
                    Zrušit
                </a>
            </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
