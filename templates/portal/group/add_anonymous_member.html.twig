{% extends 'base.html.twig' %}

{% block title %}Přidat tipujícího bez e-mailu — Tipovačka{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <twig:Breadcrumbs :items="[
        {label: 'Nástěnka', path: path('portal_dashboard')},
        {label: group.name, path: path('portal_group_detail', {id: group.id.toRfc4122})},
        {label: 'Přidat tipujícího bez e-mailu'},
    ]" />
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-navy-900">Přidat tipujícího bez e-mailu</h1>
        <p class="text-navy-900/60 mt-1">Skupina: <strong>{{ group.name }}</strong></p>
        <p class="text-sm text-navy-900/60 mt-2">
            Tipujícího můžeš přidat ručně — bez e-mailu se nemůže přihlásit, ale jeho tipy za něj můžeš zadávat ty.
            Později mu stačí přidat e-mail a dostane pozvánku k nastavení hesla.
        </p>
    </div>

    <div class="bg-white rounded-2xl shadow-card ring-1 ring-navy-900/5 p-8">
        {{ form_start(form, {attr: {class: 'space-y-5', novalidate: 'novalidate'}}) }}

            <div>
                {{ form_label(form.firstName, null, {label_attr: {class: 'block text-sm font-medium text-navy-900 mb-1.5'}}) }}
                {{ form_widget(form.firstName, {attr: {class: 'w-full px-4 py-2.5 border border-navy-100 rounded-lg focus:ring-2 focus:ring-cyan-500 focus:border-transparent outline-none transition'}}) }}
                {{ form_errors(form.firstName) }}
            </div>

            <div>
                {{ form_label(form.lastName, null, {label_attr: {class: 'block text-sm font-medium text-navy-900 mb-1.5'}}) }}
                {{ form_widget(form.lastName, {attr: {class: 'w-full px-4 py-2.5 border border-navy-100 rounded-lg focus:ring-2 focus:ring-cyan-500 focus:border-transparent outline-none transition'}}) }}
                {{ form_errors(form.lastName) }}
            </div>

            <div>
                {{ form_label(form.nickname, null, {label_attr: {class: 'block text-sm font-medium text-navy-900 mb-1.5'}}) }}
                {{ form_widget(form.nickname, {attr: {class: 'w-full px-4 py-2.5 border border-navy-100 rounded-lg focus:ring-2 focus:ring-cyan-500 focus:border-transparent outline-none transition'}}) }}
                {% if form.nickname.vars.help %}
                    <p class="text-xs text-navy-900/60 mt-1">{{ form.nickname.vars.help }}</p>
                {% endif %}
                {{ form_errors(form.nickname) }}
            </div>

            <div class="flex gap-3 pt-2">
                <button type="submit" class="bg-navy-900 hover:bg-navy-700 text-white py-3 px-6 rounded-lg font-medium transition-colors">
                    Přidat tipujícího
                </button>
                <a href="{{ path('portal_group_detail', {id: group.id.toRfc4122}) }}" class="bg-navy-50 hover:bg-navy-100 text-navy-900 py-3 px-6 rounded-lg font-medium transition-colors">
                    Zrušit
                </a>
            </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
