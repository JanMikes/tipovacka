{% extends 'base.html.twig' %}

{% block title %}Tipy – {{ sport_match.homeTeam }} vs {{ sport_match.awayTeam }}{% endblock %}

{% block body %}
<div class="mx-auto w-full max-w-4xl px-4 py-8 sm:px-6 sm:py-12 lg:px-8">

    <twig:Breadcrumbs :items="[
        {label: 'Nástěnka', path: path('portal_dashboard')},
        {label: competition.name, path: path('portal_competition_detail', {id: competition.id.toRfc4122})},
        {label: sport_match.homeTeam ~ ' vs ' ~ sport_match.awayTeam},
    ]" />

    {#
        Hero state model:
        - scheduled + before deadline → BRZY (.pill-soon)
        - live nebo po uzávěrce (a není dohráno) → UZAMČENO (.pill-locked);
          a known live score is shown in the hero (the timeline reveals the
          goals anyway — hiding the score would be incoherent)
        - finished → UKONČENO (.pill-done) + final score
        - postponed → ODLOŽEN (.pill-warn)
        - cancelled → ZRUŠEN (.pill-locked)
    #}
    {% set is_past_deadline = effective_deadline <= date() %}
    {% set is_locked_state = sport_match.isLive or (not sport_match.isFinished and not sport_match.isPostponed and not sport_match.isCancelled and is_past_deadline) %}

    {# Match hero card #}
    <section class="card-glass relative mb-6 overflow-hidden p-6 text-white sm:p-8">
        <div class="tip-head">
            <div class="tip-stage">
                <span class="round">{{ sport_match.round ?: sport_match.matchSource.name }}</span>
                <span class="when">
                    {% if sport_match.round %}{{ sport_match.matchSource.name }} · {% endif %}{{ sport_match.kickoffAt|date('j. n. Y') }} · {{ sport_match.kickoffAt|date('H:i') }}
                </span>
            </div>

            {% if sport_match.isFinished %}
                <span class="pill pill-done">
                    <twig:ux:icon name="lucide:check" class="h-3 w-3" />UKONČENO
                </span>
            {% elseif sport_match.isCancelled %}
                <span class="pill pill-locked">
                    <twig:ux:icon name="lucide:circle-x" class="h-3 w-3" />ZRUŠEN
                </span>
            {% elseif sport_match.isPostponed %}
                <span class="pill pill-warn">
                    <twig:ux:icon name="lucide:triangle-alert" class="h-3 w-3" />ODLOŽEN
                </span>
            {% elseif is_locked_state %}
                <span class="pill pill-locked">
                    <twig:ux:icon name="lucide:lock" class="h-3 w-3" />UZAMČENO
                </span>
            {% else %}
                <span class="pill pill-soon">
                    <span class="dot"></span>BRZY
                </span>
            {% endif %}
        </div>

        {% if not sport_match.isFinished and not sport_match.isCancelled and effective_deadline != sport_match.kickoffAt %}
            <p class="mt-3 inline-flex items-center gap-1.5 text-xs text-white/60">
                <twig:ux:icon name="lucide:hourglass" class="h-3.5 w-3.5" />
                Uzávěrka tipů: {{ effective_deadline|date('j. n. Y H:i') }}
            </p>
        {% endif %}

        <div class="tip-teams mt-6">
            <div class="tip-team">
                <twig:TeamFlag :name="sport_match.homeTeam" size="56" />
                <span class="name">{{ sport_match.homeTeam }}</span>
            </div>

            {% if sport_match.isFinished or (sport_match.isLive and sport_match.homeScore is not null) %}
                <div class="final-score text-white">
                    <span class="sc">{{ sport_match.homeScore }}</span>
                    <span class="sep">:</span>
                    <span class="sc">{{ sport_match.awayScore }}</span>
                </div>
            {% else %}
                <div class="tip-vs">vs</div>
            {% endif %}

            <div class="tip-team">
                <twig:TeamFlag :name="sport_match.awayTeam" size="56" />
                <span class="name">{{ sport_match.awayTeam }}</span>
            </div>
        </div>

        {% if sport_match.isFinished %}
            <div class="result-banner mt-6">
                <twig:ux:icon name="lucide:flag" class="h-4 w-4 shrink-0" />
                Konečný výsledek <b>{{ sport_match.homeScore }} : {{ sport_match.awayScore }}</b>
                {%- if sport_match.periodScores is not null %}
                    <span class="text-white/60">({% for p in sport_match.periodScores.toArray %}{{ p[0] }}:{{ p[1] }}{% if not loop.last %}, {% endif %}{% endfor %})</span>
                {%- endif %}
                {%- if sport_match.hasOvertimeScore %}
                    <span class="text-white/60">po prodl. {{ sport_match.overtimeHomeScore }}:{{ sport_match.overtimeAwayScore }}</span>
                {%- endif %}
            </div>
        {% endif %}

        {% if sport_match.venue %}
            <p class="mt-4 inline-flex items-center gap-1.5 text-xs text-white/50">
                <twig:ux:icon name="lucide:building-2" class="h-3.5 w-3.5" />
                {{ sport_match.venue }}
            </p>
        {% endif %}
    </section>

    {# Match timeline (visible to everyone once events exist; cancelled matches show no live data) #}
    {% if not sport_match.isCancelled %}
        {% include 'portal/sport_match/_timeline.html.twig' with {sport_match: sport_match, match_events: match_events|default([])} only %}
    {% endif %}

    <div class="space-y-4">
        {# Tip entry (live score-input block). The component owns its own state (open / tipped / locked / read-only). #}
        <section class="card-glass p-5 sm:p-6">
            <h2 class="eyebrow mb-3 flex items-center gap-1.5">
                <twig:ux:icon name="lucide:target" class="h-3.5 w-3.5" />
                Váš tip
            </h2>
            <twig:Guess:GuessSubmitForm :sportMatch="sport_match" competitionId="{{ competition.id.toRfc4122 }}" />
        </section>

        {% if pick_distribution %}
            <twig:Match:PickDistribution
                :distribution="pick_distribution"
                :homeTeam="sport_match.homeTeam"
                :awayTeam="sport_match.awayTeam"
            />
        {% endif %}

        {% if match_ranking is defined and match_ranking is not null and match_ranking.rows|length > 0 %}
            <section class="card-glass p-5 sm:p-6">
                <h2 class="eyebrow mb-4 flex items-center gap-1.5">
                    <twig:ux:icon name="lucide:list-ordered" class="h-3.5 w-3.5" />
                    Pořadí za zápas
                </h2>
                {% set me_id = app.user ? app.user.id.toRfc4122 : null %}
                <div class="overflow-x-auto">
                    <table class="lb-table">
                        <thead class="lb-thead">
                            <tr>
                                <th class="w-12">Pozice</th>
                                <th>Hráč</th>
                                <th class="text-center">Tip</th>
                                <th class="text-right">Body</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for row in match_ranking.rows %}
                                {% set is_me = me_id and row.userId.toRfc4122 == me_id %}
                                {% set is_exact = sport_match.isFinished and row.guessHome == sport_match.homeScore and row.guessAway == sport_match.awayScore %}
                                <tr class="lb-tr{{ is_me ? ' me' }}">
                                    <td><span class="lb-pos{{ row.rank <= 3 ? ' rank-' ~ row.rank }}">{{ row.rank }}.</span></td>
                                    <td>
                                        <div class="flex items-center gap-3">
                                            <twig:Avatar name="{{ row.fullName ?: row.nickname }}" size="32" rank="{{ row.rank <= 3 ? row.rank : null }}" />
                                            <span class="min-w-0">
                                                <span class="block truncate text-sm font-bold text-white">{{ row.nickname }}{% if is_me %} <span class="text-accent-300">· Ty</span>{% endif %}</span>
                                                {% if row.fullName %}<small class="block truncate text-[11px] font-light text-white/50">{{ row.fullName }}</small>{% endif %}
                                            </span>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <span class="inline-flex items-center gap-1.5">
                                            <span class="font-semibold text-white tabular-nums">{{ row.guessHome }}:{{ row.guessAway }}</span>
                                            {% if is_exact %}<span class="pill pill-success"><twig:ux:icon name="lucide:check" class="h-3 w-3" />Přesně</span>{% endif %}
                                        </span>
                                    </td>
                                    <td class="text-right"><span class="lb-pts">{{ row.totalPoints }}</span> <span class="text-[11px] font-light text-white/50">b</span></td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </section>
        {% endif %}

        <twig:Guess:MatchGuessesList
            :sportMatch="sport_match"
            competitionId="{{ competition.id.toRfc4122 }}"
            :applyHiding="not can_see_all_tips"
        />

        {% if premium_enabled %}
            <twig:PremiumTeaser />
        {% endif %}

        {% if deadline_form is not null %}
            <section class="card-glass p-5 sm:p-6">
                <header class="mb-4 flex items-center gap-2.5">
                    <twig:ux:icon name="lucide:hourglass" class="h-5 w-5 text-accent-300" />
                    <h2 class="text-lg font-semibold text-white">Uzávěrka tipů pro tento zápas</h2>
                </header>
                {{ form_start(deadline_form, {attr: {class: 'flex flex-wrap items-end gap-3'}}) }}
                    <div class="field flex-1 min-w-[220px]">
                        {{ form_label(deadline_form.deadline, null, {label_attr: {class: 'field-label mb-1.5'}}) }}
                        {{ form_widget(deadline_form.deadline, {attr: {class: 'input'}}) }}
                        {% if deadline_form.deadline.vars.help %}
                            <p class="mt-1 text-xs text-white/50">{{ deadline_form.deadline.vars.help }}</p>
                        {% endif %}
                        {{ form_errors(deadline_form.deadline) }}
                    </div>
                    <button type="submit" class="btn btn-primary">
                        <twig:ux:icon name="lucide:save" class="h-4 w-4" />
                        Uložit
                    </button>
                {{ form_end(deadline_form) }}
            </section>
        {% endif %}

        {% if is_granted('competition_manage_members', competition) and member_rows|length > 0 %}
            <section class="card-glass overflow-hidden p-0">
                <header class="border-b border-white/[0.06] px-5 py-4 sm:px-6">
                    <div class="flex items-center gap-2.5">
                        <twig:ux:icon name="lucide:users" class="h-5 w-5 text-accent-300" />
                        <h2 class="text-lg font-semibold text-white">Tipy členů</h2>
                    </div>
                    <p class="mt-1 text-xs text-white/50">Jako vlastník můžete zadat tip za člena, který sám nemá přístup.</p>
                </header>

                {% set can_edit = sport_match.isOpenForGuesses and (effective_deadline > date()) %}

                <ul class="divide-y divide-white/[0.06]">
                    {% for row in member_rows %}
                        <li class="flex flex-wrap items-center justify-between gap-3 px-5 py-4 sm:px-6">
                            <div class="flex min-w-[140px] items-center gap-2.5">
                                <twig:Avatar :name="row.user.nickname" size="32" />
                                <span class="font-medium text-white">{{ row.user.nickname }}</span>
                                {% if not row.user.isVerified %}
                                    <twig:Pill label="NEOVĚŘENÝ" variant="warn" />
                                {% endif %}
                            </div>

                            <form method="post"
                                  action="{{ path('portal_competition_guess_on_behalf', {
                                      competitionId: competition.id.toRfc4122,
                                      sportMatchId: sport_match.id.toRfc4122,
                                      memberId: row.user.id.toRfc4122,
                                  }) }}"
                                  class="flex items-center gap-2">
                                <input type="hidden" name="_token"
                                       value="{{ csrf_token('guess_on_behalf_' ~ competition.id.toRfc4122 ~ '_' ~ sport_match.id.toRfc4122 ~ '_' ~ row.user.id.toRfc4122) }}">
                                <input type="number" name="homeScore" min="0" max="99" required
                                       value="{{ row.guess ? row.guess.homeScore : '' }}"
                                       {% if not can_edit %}disabled{% endif %}
                                       class="score-input w-14 disabled:cursor-not-allowed disabled:opacity-60"
                                       aria-label="Domácí">
                                <span class="text-white/30">:</span>
                                <input type="number" name="awayScore" min="0" max="99" required
                                       value="{{ row.guess ? row.guess.awayScore : '' }}"
                                       {% if not can_edit %}disabled{% endif %}
                                       class="score-input w-14 disabled:cursor-not-allowed disabled:opacity-60"
                                       aria-label="Hosté">
                                <button type="submit"
                                        {% if not can_edit %}disabled{% endif %}
                                        class="btn btn-primary btn-sm disabled:cursor-not-allowed disabled:opacity-40">
                                    {{ row.guess ? 'Upravit' : 'Uložit' }}
                                </button>
                            </form>
                        </li>
                    {% endfor %}
                </ul>
            </section>
        {% endif %}
    </div>
</div>
{% endblock %}
