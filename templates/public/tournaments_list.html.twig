{% extends 'base.html.twig' %}

{% block title %}Veřejné turnaje — Tipovačka{% endblock %}

{% block body %}
<div class="mx-auto w-full max-w-6xl px-4 py-10 sm:px-6 sm:py-14 lg:px-8">

    {# Page header #}
    <div class="mb-10 flex flex-wrap items-end justify-between gap-4">
        <div>
            <nav class="flex items-center gap-1.5 text-sm text-navy-900/60" aria-label="Breadcrumb">
                <a href="{{ path('app_home') }}" class="hover:text-cyan-600">Domů</a>
                <twig:ux:icon name="lucide:chevron-right" class="h-4 w-4" />
                <span class="text-navy-900/80">Turnaje</span>
            </nav>
            <h1 class="mt-2 text-3xl font-bold tracking-tight text-navy-900 sm:text-4xl">Veřejné turnaje</h1>
            <p class="mt-2 max-w-xl text-navy-900/70">Připoj se do jedné ze skupin a začni tipovat. Žádné poplatky, žádná registrace k turnaji — stačí pár kliků.</p>
        </div>

        {% if tournaments|length > 0 %}
            <span class="inline-flex items-center gap-2 rounded-full bg-white px-4 py-2 text-sm font-semibold text-navy-900 shadow-card ring-1 ring-navy-900/5">
                <twig:ux:icon name="lucide:trophy" class="h-4 w-4 text-cyan-500" />
                {{ tournaments|length }} {% if tournaments|length == 1 %}turnaj{% elseif tournaments|length < 5 %}turnaje{% else %}turnajů{% endif %}
            </span>
        {% endif %}
    </div>

    {% if app.user and app.user.isVerified %}
        <div class="mb-10">
            {{ include('_partials/join_by_pin_form.html.twig', { size: 'large' }) }}
        </div>
    {% endif %}

    {% if tournaments|length == 0 %}
        <div class="rounded-2xl bg-white shadow-card ring-1 ring-navy-900/5">
            {% if app.user %}
                <twig:EmptyState
                    illustration="search"
                    title="Žádné veřejné turnaje"
                    body="Aktuálně nejsou k dispozici žádné veřejné turnaje. Založ si vlastní soukromý turnaj."
                    ctaLabel="Vytvořit turnaj"
                    ctaPath="{{ path('portal_tournament_create') }}"
                />
            {% else %}
                <twig:EmptyState
                    illustration="search"
                    title="Žádné veřejné turnaje"
                    body="Aktuálně nejsou k dispozici žádné veřejné turnaje. Zaregistruj se a založ si vlastní."
                    ctaLabel="Zaregistruj se"
                    ctaPath="{{ path('app_register') }}"
                />
            {% endif %}
        </div>
    {% else %}
        <ul class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
            {% for t in tournaments %}
                {% set is_finished = t.finishedAt is not null %}
                <li>
                    <a
                        href="{{ path('public_tournament_detail', {id: t.id.toRfc4122}) }}"
                        class="group flex h-full flex-col justify-between rounded-2xl bg-white p-6 shadow-card ring-1 ring-navy-900/5 transition-shadow hover:shadow-card-hover hover:ring-cyan-500/30"
                    >
                        <div>
                            <div class="mb-3 flex items-start justify-between gap-3">
                                <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-cyan-100 text-cyan-600">
                                    <twig:ux:icon name="lucide:trophy" class="h-5 w-5" />
                                </span>
                                <div class="flex flex-wrap items-center gap-1.5">
                                    <span class="inline-flex items-center rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-semibold text-blue-800">Veřejný</span>
                                    {% if is_finished %}
                                        <span class="inline-flex items-center rounded-full bg-gray-200 px-2.5 py-0.5 text-xs font-semibold text-gray-800">Ukončen</span>
                                    {% endif %}
                                </div>
                            </div>

                            <h2 class="text-lg font-semibold leading-tight text-navy-900 transition-colors group-hover:text-cyan-600">
                                {{ t.name }}
                            </h2>

                            <div class="mt-3 flex items-center gap-1.5 text-sm text-navy-900/60">
                                <twig:ux:icon name="lucide:user" class="h-4 w-4" />
                                <span>{{ t.ownerNickname }}</span>
                            </div>

                            {% if t.startAt or t.endAt %}
                                <div class="mt-1.5 flex items-center gap-1.5 text-sm text-navy-900/60">
                                    <twig:ux:icon name="lucide:calendar" class="h-4 w-4" />
                                    <span>
                                        {% if t.startAt %}{{ t.startAt|date('d. m. Y') }}{% endif %}
                                        {% if t.startAt and t.endAt %} – {% endif %}
                                        {% if t.endAt %}{{ t.endAt|date('d. m. Y') }}{% endif %}
                                    </span>
                                </div>
                            {% endif %}
                        </div>

                        <div class="mt-5 flex items-center justify-end text-sm font-semibold text-cyan-600">
                            Zobrazit detail
                            <twig:ux:icon name="lucide:arrow-right" class="ml-1 h-4 w-4" />
                        </div>
                    </a>
                </li>
            {% endfor %}
        </ul>
    {% endif %}
</div>
{% endblock %}
