{% extends 'base.html.twig' %}

{% block title %}Turnaje — Tipovačka{% endblock %}

{% block body %}
<div class="mx-auto w-full max-w-6xl px-4 py-10 sm:px-6 sm:py-14 lg:px-8">

    {# Breadcrumb #}
    <nav class="mb-6 flex items-center gap-1.5 text-sm text-navy-900/60" aria-label="Breadcrumb">
        <a href="{{ path('app_home') }}" class="hover:text-cyan-600">Domů</a>
        <twig:ux:icon name="lucide:chevron-right" class="h-4 w-4" />
        <span class="text-navy-900/80">Turnaje</span>
    </nav>

    {# Page header #}
    <header class="mb-8">
        <h1 class="text-3xl font-bold tracking-tight text-navy-900 sm:text-4xl">Turnaje</h1>
        <p class="mt-2 max-w-2xl text-navy-900/70">Vytvoř si vlastní soukromou ligu pro kamarády, nebo se přidej do některého z veřejných turnajů.</p>
    </header>

    {# PIN-join — compact for authenticated users #}
    {% if app.user and app.user.isVerified %}
        <div class="mb-12">
            {{ include('_partials/join_by_pin_form.html.twig', { size: 'large', collapsible: user_has_groups|default(false) }) }}
        </div>
    {% endif %}

    {# ───── Soukromé turnaje — user's private (owned or member) ───── #}
    {% if private_tournaments|length > 0 %}
        <section class="mb-12">
            <div class="mb-4 flex flex-wrap items-end justify-between gap-3">
                <div>
                    <h2 class="flex items-center gap-2 text-xl font-semibold text-navy-900">
                        <twig:ux:icon name="lucide:lock" class="h-5 w-5 text-amber-500" />
                        Soukromé turnaje
                        <span class="rounded-full bg-navy-50 px-2.5 py-0.5 text-xs font-semibold text-navy-700">{{ private_tournaments|length }}</span>
                    </h2>
                    <p class="mt-1 text-sm text-navy-900/60">Turnaje, které jsi založil nebo ve kterých hraješ se svojí skupinou.</p>
                </div>
            </div>

            <ul class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
                {% for t in private_tournaments %}
                    {% set is_finished = t.finishedAt is not null %}
                    <li>
                        <a
                            href="{{ path('public_tournament_detail', {id: t.id.toRfc4122}) }}"
                            class="group flex h-full flex-col justify-between rounded-2xl bg-white p-6 shadow-card ring-1 ring-amber-500/20 transition-shadow hover:shadow-card-hover hover:ring-amber-500/40"
                        >
                            <div>
                                <div class="mb-3 flex items-start justify-between gap-3">
                                    <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-amber-100 text-amber-600">
                                        <twig:ux:icon name="lucide:lock" class="h-5 w-5" />
                                    </span>
                                    <div class="flex flex-wrap items-center gap-1.5">
                                        <span class="inline-flex items-center gap-1 rounded-full bg-amber-100 px-2.5 py-0.5 text-xs font-semibold text-amber-800">
                                            <twig:ux:icon name="lucide:lock" class="h-3 w-3" />Soukromý
                                        </span>
                                        {% if is_finished %}
                                            <span class="inline-flex items-center rounded-full bg-gray-200 px-2.5 py-0.5 text-xs font-semibold text-gray-800">Ukončen</span>
                                        {% endif %}
                                    </div>
                                </div>

                                <h3 class="text-lg font-semibold leading-tight text-navy-900 transition-colors group-hover:text-amber-700">
                                    {{ t.name }}
                                </h3>

                                <div class="mt-3 flex items-center gap-1.5 text-sm text-navy-900/60">
                                    <twig:ux:icon name="lucide:user" class="h-4 w-4" />
                                    <span>{{ t.ownerNickname }}</span>
                                </div>

                                {% if t.startAt or t.endAt %}
                                    <div class="mt-1.5 flex items-center gap-1.5 text-sm text-navy-900/60">
                                        <twig:ux:icon name="lucide:calendar" class="h-4 w-4" />
                                        <span>
                                            {% if t.startAt %}{{ t.startAt|date('d. m. Y') }}{% endif %}
                                            {% if t.startAt and t.endAt %} – {% endif %}
                                            {% if t.endAt %}{{ t.endAt|date('d. m. Y') }}{% endif %}
                                        </span>
                                    </div>
                                {% endif %}
                            </div>

                            <div class="mt-5 flex items-center justify-end text-sm font-semibold text-amber-700">
                                Otevřít turnaj
                                <twig:ux:icon name="lucide:arrow-right" class="ml-1 h-4 w-4" />
                            </div>
                        </a>
                    </li>
                {% endfor %}
            </ul>
        </section>
    {% endif %}

    {# ───── Veřejné turnaje ───── #}
    <section>
        <div class="mb-4 flex flex-wrap items-end justify-between gap-3">
            <div>
                <h2 class="flex items-center gap-2 text-xl font-semibold text-navy-900">
                    <twig:ux:icon name="lucide:globe" class="h-5 w-5 text-cyan-500" />
                    Veřejné turnaje
                    {% if public_tournaments|length > 0 %}
                        <span class="rounded-full bg-navy-50 px-2.5 py-0.5 text-xs font-semibold text-navy-700">{{ public_tournaments|length }}</span>
                    {% endif %}
                </h2>
                <p class="mt-1 text-sm text-navy-900/60">Otevřené turnaje, do kterých se může kdokoli přidat.</p>
            </div>
        </div>

        {% if public_tournaments|length == 0 %}
            <div class="rounded-2xl bg-white shadow-card ring-1 ring-navy-900/5">
                {% if app.user %}
                    <twig:EmptyState
                        illustration="search"
                        title="Žádné veřejné turnaje"
                        body="Aktuálně nejsou k dispozici žádné veřejné turnaje. Založ si vlastní soukromý turnaj."
                        ctaLabel="Vytvořit turnaj"
                        ctaPath="{{ path('portal_tournament_create') }}"
                    />
                {% else %}
                    <twig:EmptyState
                        illustration="search"
                        title="Žádné veřejné turnaje"
                        body="Aktuálně nejsou k dispozici žádné veřejné turnaje. Zaregistruj se a založ si vlastní."
                        ctaLabel="Zaregistruj se"
                        ctaPath="{{ path('app_register') }}"
                    />
                {% endif %}
            </div>
        {% else %}
            <ul class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
                {% for t in public_tournaments %}
                    {% set is_finished = t.finishedAt is not null %}
                    <li>
                        <a
                            href="{{ path('public_tournament_detail', {id: t.id.toRfc4122}) }}"
                            class="group flex h-full flex-col justify-between rounded-2xl bg-white p-6 shadow-card ring-1 ring-navy-900/5 transition-shadow hover:shadow-card-hover hover:ring-cyan-500/30"
                        >
                            <div>
                                <div class="mb-3 flex items-start justify-between gap-3">
                                    <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-cyan-100 text-cyan-600">
                                        <twig:ux:icon name="lucide:trophy" class="h-5 w-5" />
                                    </span>
                                    <div class="flex flex-wrap items-center gap-1.5">
                                        <span class="inline-flex items-center rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-semibold text-blue-800">Veřejný</span>
                                        {% if is_finished %}
                                            <span class="inline-flex items-center rounded-full bg-gray-200 px-2.5 py-0.5 text-xs font-semibold text-gray-800">Ukončen</span>
                                        {% endif %}
                                    </div>
                                </div>

                                <h3 class="text-lg font-semibold leading-tight text-navy-900 transition-colors group-hover:text-cyan-600">
                                    {{ t.name }}
                                </h3>

                                <div class="mt-3 flex items-center gap-1.5 text-sm text-navy-900/60">
                                    <twig:ux:icon name="lucide:user" class="h-4 w-4" />
                                    <span>{{ t.ownerNickname }}</span>
                                </div>

                                {% if t.startAt or t.endAt %}
                                    <div class="mt-1.5 flex items-center gap-1.5 text-sm text-navy-900/60">
                                        <twig:ux:icon name="lucide:calendar" class="h-4 w-4" />
                                        <span>
                                            {% if t.startAt %}{{ t.startAt|date('d. m. Y') }}{% endif %}
                                            {% if t.startAt and t.endAt %} – {% endif %}
                                            {% if t.endAt %}{{ t.endAt|date('d. m. Y') }}{% endif %}
                                        </span>
                                    </div>
                                {% endif %}
                            </div>

                            <div class="mt-5 flex items-center justify-end text-sm font-semibold text-cyan-600">
                                Zobrazit detail
                                <twig:ux:icon name="lucide:arrow-right" class="ml-1 h-4 w-4" />
                            </div>
                        </a>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    </section>

    {# ───── Hero CTA: create your own private tournament ───── #}
    {% set createHref = app.user ? path('portal_tournament_create') : path('app_register') %}
    <section class="relative mt-12 overflow-hidden rounded-2xl bg-gradient-to-br from-navy-900 via-navy-800 to-navy-700 p-6 text-white shadow-card sm:p-8">
        <div aria-hidden="true" class="pointer-events-none absolute -right-20 -top-20 h-72 w-72 rounded-full bg-cyan-500/20 blur-3xl"></div>
        <div aria-hidden="true" class="pointer-events-none absolute -left-10 -bottom-20 h-56 w-56 rounded-full bg-purple-500/15 blur-3xl"></div>

        <div class="relative grid gap-6 md:grid-cols-[1fr_auto] md:items-center">
            <div class="flex items-start gap-4">
                <span class="hidden h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-white/10 backdrop-blur sm:flex">
                    <twig:ux:icon name="lucide:trophy" class="h-7 w-7 text-cyan-400" />
                </span>
                <div class="min-w-0">
                    <span class="inline-flex items-center gap-1 rounded-full bg-cyan-500/20 px-2.5 py-0.5 text-xs font-semibold text-cyan-300">
                        <twig:ux:icon name="lucide:sparkles" class="h-3 w-3" />
                        Nové
                    </span>
                    <h2 class="mt-2 text-2xl font-bold tracking-tight sm:text-3xl">Vytvoř si vlastní soukromý turnaj</h2>
                    <p class="mt-2 max-w-xl text-sm text-white/75 sm:text-base">Nastav si vlastní pravidla a bodování, založ skupiny pro různé party a tipujte jen s lidmi, které chceš.</p>

                    <ul class="mt-4 flex flex-wrap gap-x-4 gap-y-2 text-xs text-white/70 sm:text-sm">
                        <li class="inline-flex items-center gap-1.5">
                            <twig:ux:icon name="lucide:lock" class="h-4 w-4 text-cyan-400" />
                            Přístup přes pozvánku nebo PIN
                        </li>
                        <li class="inline-flex items-center gap-1.5">
                            <twig:ux:icon name="lucide:users" class="h-4 w-4 text-cyan-400" />
                            Více skupin v jednom turnaji
                        </li>
                        <li class="inline-flex items-center gap-1.5">
                            <twig:ux:icon name="lucide:shield-check" class="h-4 w-4 text-cyan-400" />
                            Zdarma, bez závazků
                        </li>
                    </ul>
                </div>
            </div>

            <div class="flex md:flex-col md:items-stretch md:justify-center">
                <a href="{{ createHref }}" class="inline-flex w-full items-center justify-center gap-1.5 rounded-lg bg-cyan-500 px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-cyan-600 sm:w-auto">
                    <twig:ux:icon name="lucide:circle-plus" class="h-4 w-4" />
                    {% if app.user %}Vytvořit turnaj{% else %}Začít zdarma{% endif %}
                </a>
                {% if app.user is null %}
                    <p class="mt-2 text-center text-xs text-white/60 md:mt-3">Stačí krátká registrace.</p>
                {% endif %}
            </div>
        </div>
    </section>
</div>
{% endblock %}
