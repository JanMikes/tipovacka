{% extends 'base.html.twig' %}

{% block title %}{{ tournament.name }} — {{ brand_name }}{% endblock %}

{% block body %}
<div class="bg-radial">
<div class="mx-auto w-full max-w-6xl px-4 py-10 sm:px-6 sm:py-12 lg:px-8">

    {# Breadcrumb #}
    <nav class="mb-6 flex items-center gap-1.5 text-sm text-white/50" aria-label="Breadcrumb">
        <a href="{{ path('app_home') }}" class="transition-colors hover:text-accent-300">Domů</a>
        <twig:ux:icon name="lucide:chevron-right" class="h-4 w-4 text-white/30" />
        <a href="{{ path('public_tournaments_list') }}" class="transition-colors hover:text-accent-300">Turnaje</a>
        <twig:ux:icon name="lucide:chevron-right" class="h-4 w-4 text-white/30" />
        <span class="truncate text-white/80">{{ tournament.name }}</span>
    </nav>

    {# Hero #}
    <section class="surface-accent relative overflow-hidden p-6 sm:p-8">
        <div class="relative flex flex-wrap items-start gap-4">
            <span class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl border border-white/10 bg-white/10 backdrop-blur">
                <twig:ux:icon name="lucide:trophy" class="h-7 w-7 text-accent-300" />
            </span>
            <div class="min-w-0 flex-1">
                <div class="mb-3 flex flex-wrap items-center gap-2">
                    {% if tournament.isPublic %}
                        <twig:Pill label="Veřejný" variant="accent" icon="globe" />
                    {% else %}
                        <twig:Badge label="Soukromý" variant="group" icon="lock" />
                    {% endif %}
                    {% if tournament.isFinished %}
                        <twig:Pill label="Ukončen" variant="done" />
                    {% endif %}
                </div>
                <h1 class="grad-headline text-3xl font-extrabold tracking-tight sm:text-4xl">
                    <span>{{ tournament.name }}</span>
                </h1>
                <div class="mt-3 flex flex-wrap items-center gap-x-5 gap-y-1.5 text-sm text-white/70">
                    <span class="inline-flex items-center gap-1.5">
                        <twig:ux:icon name="lucide:user" class="h-4 w-4 text-white/50" />
                        {{ tournament.owner.nickname }}
                    </span>
                    {% if tournament.startAt or tournament.endAt %}
                        <span class="inline-flex items-center gap-1.5">
                            <twig:ux:icon name="lucide:calendar" class="h-4 w-4 text-white/50" />
                            {% if tournament.startAt %}{{ tournament.startAt|date('d. m. Y') }}{% endif %}
                            {% if tournament.startAt and tournament.endAt %} – {% endif %}
                            {% if tournament.endAt %}{{ tournament.endAt|date('d. m. Y') }}{% endif %}
                        </span>
                    {% endif %}
                </div>
            </div>
        </div>

        {% if tournament.description %}
            <p class="relative mt-6 max-w-3xl whitespace-pre-line text-white/75">{{ tournament.description }}</p>
        {% endif %}
    </section>

    {% set canCreateGroup = is_granted('tournament_create_group', tournament) %}
    {% set canUsePinGate = not canCreateGroup and app.user and app.user.isVerified and tournament.isActive and tournament.hasCreationPin %}
    {% set createGroupPath = path('portal_group_create', {tournamentId: tournament.id.toRfc4122}) %}

    {# Two-column layout #}
    <div class="mt-8 grid grid-cols-1 gap-6 lg:grid-cols-12">

        {# ───── Left: main content ───── #}
        <div class="space-y-6 lg:col-span-8">

            {# Groups #}
            <section id="groups" class="card-glass overflow-hidden p-0">
                <header class="flex flex-wrap items-center justify-between gap-3 border-b border-white/[0.06] px-6 py-4">
                    <div class="flex items-center gap-2.5">
                        <twig:ux:icon name="lucide:users" class="h-5 w-5 text-accent-300" />
                        <h2 class="text-lg font-semibold text-white">Skupiny</h2>
                        {% if groups|length > 0 %}
                            <span class="rounded-full border border-white/10 bg-white/5 px-2.5 py-0.5 text-xs font-semibold text-white/70">{{ groups|length }}</span>
                        {% endif %}
                    </div>
                    {% if canCreateGroup or canUsePinGate %}
                        <a href="{{ createGroupPath }}" class="btn btn-primary btn-sm">
                            <twig:ux:icon name="lucide:user-round-plus" class="h-4 w-4" />
                            {% if canUsePinGate %}Založit s PINem{% else %}Založit vlastní skupinu{% endif %}
                        </a>
                    {% endif %}
                </header>

                {% if groups|length == 0 %}
                    {% if canCreateGroup or canUsePinGate %}
                        <div class="px-6 py-10 text-center">
                            <span class="mx-auto flex h-12 w-12 items-center justify-center rounded-2xl border border-accent-500/30 bg-accent-500/15 text-accent-300">
                                <twig:ux:icon name="lucide:sparkles" class="h-6 w-6" />
                            </span>
                            <h3 class="mt-4 text-base font-semibold text-white">Buďte první se svou skupinou</h3>
                            <p class="mx-auto mt-1.5 max-w-sm text-sm text-white/60">V tomto turnaji ještě žádná skupina není. Založte si vlastní a pozvěte kamarády.</p>
                            <a href="{{ createGroupPath }}" class="btn btn-primary btn-sm mt-5">
                                <twig:ux:icon name="lucide:user-round-plus" class="h-4 w-4" />
                                {% if canUsePinGate %}Založit s PINem{% else %}Založit vlastní skupinu{% endif %}
                            </a>
                        </div>
                    {% else %}
                        <p class="px-6 py-10 text-center text-sm text-white/50">V tomto turnaji zatím nejsou žádné skupiny.</p>
                    {% endif %}
                {% else %}
                    <ul class="divide-y divide-white/[0.06]">
                        {% for g in groups %}
                            {% set is_member = app.user and g.groupId.toRfc4122 in member_group_ids %}
                            {% set has_pending_request = app.user and g.groupId.toRfc4122 in pending_request_group_ids %}
                            <li>
                                {% if is_member %}
                                    <a href="{{ path('portal_group_detail', {id: g.groupId.toRfc4122}) }}" class="group flex flex-wrap items-center justify-between gap-4 px-6 py-4 transition-colors hover:bg-white/[0.04]">
                                        <div class="min-w-0 flex-1">
                                            <p class="flex flex-wrap items-center gap-2 font-medium text-white transition-colors group-hover:text-accent-300">
                                                {{ g.groupName }}
                                                <twig:Pill label="Jste členem" variant="success" icon="check" />
                                            </p>
                                            <p class="mt-1 flex items-center gap-1.5 text-xs text-white/50">
                                                <twig:ux:icon name="lucide:user" class="h-3.5 w-3.5 text-white/40" />
                                                {{ g.ownerNickname }}
                                            </p>
                                        </div>
                                        <span class="inline-flex shrink-0 items-center gap-1 text-sm font-semibold text-accent-300">
                                            Přejít do skupiny
                                            <twig:ux:icon name="lucide:arrow-right" class="h-4 w-4 transition-transform group-hover:translate-x-0.5" />
                                        </span>
                                    </a>
                                {% else %}
                                    <div class="flex flex-wrap items-center justify-between gap-4 px-6 py-4">
                                        <div class="min-w-0 flex-1">
                                            <p class="font-medium text-white">{{ g.groupName }}</p>
                                            <p class="mt-1 flex items-center gap-1.5 text-xs text-white/50">
                                                <twig:ux:icon name="lucide:user" class="h-3.5 w-3.5 text-white/40" />
                                                {{ g.ownerNickname }}
                                            </p>
                                        </div>
                                        <div class="shrink-0">
                                            {% if app.user is null %}
                                                <a href="{{ path('app_login') }}" class="btn btn-primary btn-sm">
                                                    <twig:ux:icon name="lucide:log-in" class="h-4 w-4" />
                                                    Přihlásit se
                                                </a>
                                            {% elseif has_pending_request %}
                                                <twig:Pill label="Žádost čeká na schválení" variant="warn" icon="clock" />
                                            {% elseif not tournament.isFinished and app.user.isVerified %}
                                                <form method="post" action="{{ path('portal_group_request_join', {id: g.groupId.toRfc4122}) }}" class="inline">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('group_request_join_' ~ g.groupId.toRfc4122) }}">
                                                    <button type="submit" class="btn btn-ghost btn-sm">
                                                        Požádat o připojení
                                                        <twig:ux:icon name="lucide:arrow-right" class="h-4 w-4" />
                                                    </button>
                                                </form>
                                            {% elseif not app.user.isVerified %}
                                                <span class="text-xs text-white/50">Ověřte e-mail pro připojení</span>
                                            {% endif %}
                                        </div>
                                    </div>
                                {% endif %}
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </section>

            {# Matches #}
            <section class="card-glass overflow-hidden p-0">
                <header class="flex items-center justify-between gap-3 border-b border-white/[0.06] px-6 py-4">
                    <div class="flex items-center gap-2.5">
                        <twig:ux:icon name="lucide:calendar" class="h-5 w-5 text-accent-300" />
                        <h2 class="text-lg font-semibold text-white">Zápasy</h2>
                    </div>
                    {% set matches = sport_matches ?? [] %}
                    {% if matches|length > 0 %}
                        <span class="rounded-full border border-white/10 bg-white/5 px-2.5 py-0.5 text-xs font-semibold text-white/70">{{ matches|length }}</span>
                    {% endif %}
                </header>

                {% if matches|length == 0 %}
                    <p class="px-6 py-10 text-center text-sm text-white/50">V tomto turnaji zatím nejsou žádné zápasy.</p>
                {% else %}
                    <ul class="divide-y divide-white/[0.06]">
                        {% for m in matches %}
                            {%- set state = m.state.value -%}
                            <li class="grid grid-cols-[auto_1fr_auto] items-center gap-3 px-6 py-4 sm:gap-6">
                                <div class="flex flex-col text-xs text-white/50 sm:w-24">
                                    <span class="font-medium text-white/70">{{ m.kickoffAt|date('d. m.') }}</span>
                                    <span>{{ m.kickoffAt|date('H:i') }}</span>
                                </div>

                                <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-3 text-sm">
                                    <span class="truncate text-right font-medium text-white">{{ m.homeTeam }}</span>
                                    {% if state == 'finished' %}
                                        <span class="rounded-md border border-white/10 bg-white/5 px-2 py-0.5 text-sm font-bold tabular-nums text-white">
                                            {{ m.homeScore }} : {{ m.awayScore }}
                                        </span>
                                    {% else %}
                                        <span class="text-xs font-semibold text-white/40">vs</span>
                                    {% endif %}
                                    <span class="truncate font-medium text-white">{{ m.awayTeam }}</span>
                                </div>

                                {% if state == 'scheduled' %}
                                    <twig:Pill label="Naplánován" variant="accent" />
                                {% elseif state == 'live' %}
                                    <twig:Pill label="Živě" variant="live" dot />
                                {% elseif state == 'finished' %}
                                    <twig:Pill label="Odehrán" variant="success" />
                                {% elseif state == 'postponed' %}
                                    <twig:Pill label="Odložen" variant="warn" />
                                {% else %}
                                    <twig:Pill label="Zrušen" variant="neutral" />
                                {% endif %}
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </section>
        </div>

        {# ───── Right: sidebar ───── #}
        <aside class="lg:col-span-4">
            <div class="sticky top-24 space-y-4">
                <div class="card-glass p-6">
                    <h3 class="flex items-center gap-2 text-xs font-semibold uppercase tracking-wider text-white/50">
                        <twig:ux:icon name="lucide:info" class="h-4 w-4" />
                        O turnaji
                    </h3>
                    <dl class="mt-4 space-y-4 text-sm">
                        <div>
                            <dt class="text-[10px] font-bold uppercase tracking-wider text-white/40">Vlastník</dt>
                            <dd class="mt-1 flex items-center gap-1.5 text-white">
                                <twig:ux:icon name="lucide:user" class="h-4 w-4 text-white/40" />
                                {{ tournament.owner.nickname }}
                            </dd>
                        </div>
                        {% if tournament.startAt %}
                            <div>
                                <dt class="text-[10px] font-bold uppercase tracking-wider text-white/40">Začátek</dt>
                                <dd class="mt-1 flex items-center gap-1.5 text-white">
                                    <twig:ux:icon name="lucide:clock" class="h-4 w-4 text-white/40" />
                                    {{ tournament.startAt|date('d. m. Y H:i') }}
                                </dd>
                            </div>
                        {% endif %}
                        {% if tournament.endAt %}
                            <div>
                                <dt class="text-[10px] font-bold uppercase tracking-wider text-white/40">Konec</dt>
                                <dd class="mt-1 flex items-center gap-1.5 text-white">
                                    <twig:ux:icon name="lucide:clock" class="h-4 w-4 text-white/40" />
                                    {{ tournament.endAt|date('d. m. Y H:i') }}
                                </dd>
                            </div>
                        {% endif %}
                    </dl>
                </div>

                {{ include('_partials/tournament_rules.html.twig', { items: rule_items }) }}

                {% if app.user and app.user.isVerified and not tournament.isFinished %}
                    {{ include('_partials/join_by_pin_form.html.twig', { size: 'compact' }) }}
                {% endif %}

                {% if canCreateGroup or canUsePinGate %}
                    <div class="surface-accent relative overflow-hidden p-6">
                        <div class="relative">
                            <h3 class="flex items-center gap-2 text-xs font-semibold uppercase tracking-wider text-white/60">
                                <twig:ux:icon name="lucide:user-round-plus" class="h-4 w-4 text-accent-300" />
                                Založte si vlastní skupinu
                            </h3>
                            <p class="mt-3 text-sm text-white/75">
                                {% if canUsePinGate %}
                                    Máte PIN turnaje? Vytvořte si vlastní skupinu a tipujte s kamarády.
                                {% else %}
                                    Tipujte s vlastní partou — založte skupinu a pozvěte kamarády odkazem nebo PINem.
                                {% endif %}
                            </p>
                            <a href="{{ createGroupPath }}" class="btn btn-primary btn-sm mt-4 w-full">
                                {% if canUsePinGate %}Založit s PINem{% else %}Vytvořit skupinu{% endif %}
                                <twig:ux:icon name="lucide:arrow-right" class="h-4 w-4" />
                            </a>
                        </div>
                    </div>
                {% endif %}

                {% if app.user is null %}
                    <div class="card-glass border-dashed p-5 text-sm">
                        <p class="font-semibold text-white">Ještě nemáte účet?</p>
                        <p class="mt-1 text-white/60">Zaregistrujte se zdarma a připojte se do skupiny.</p>
                        <a href="{{ path('app_register') }}" class="btn-link mt-3 inline-flex items-center gap-1 text-sm font-semibold text-accent-300 hover:text-accent-400">
                            Registrovat
                            <twig:ux:icon name="lucide:arrow-right" class="h-4 w-4" />
                        </a>
                    </div>
                {% endif %}
            </div>
        </aside>
    </div>
</div>
</div>
{% endblock %}
