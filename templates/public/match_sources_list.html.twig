{% extends 'base.html.twig' %}

{% block title %}Zdroje zápasů — {{ brand_name }}{% endblock %}

{% block body %}
<div class="bg-radial">
<div class="mx-auto w-full max-w-6xl px-4 py-10 sm:px-6 sm:py-14 lg:px-8">

    {# Breadcrumb #}
    <nav class="mb-6 flex items-center gap-1.5 text-sm text-white/50" aria-label="Breadcrumb">
        <a href="{{ path('app_home') }}" class="transition-colors hover:text-accent-300">Domů</a>
        <twig:ux:icon name="lucide:chevron-right" class="h-4 w-4 text-white/30" />
        <span class="text-white/80">Zdroje zápasů</span>
    </nav>

    {# Page header #}
    <header class="mb-8">
        <p class="eyebrow mb-3">Přehled soutěží</p>
        <h1 class="grad-headline text-3xl font-extrabold tracking-tight sm:text-4xl">
            <span>Zdroje zápasů</span>
        </h1>
        <p class="mt-3 max-w-2xl text-white/60">Založte si vlastní soukromou ligu pro kamarády, nebo se přidejte k soutěži nad některým veřejným zdrojem zápasů.</p>
    </header>

    {# PIN-join — compact for authenticated users #}
    {% if app.user and app.user.isVerified %}
        <div class="mb-12">
            {{ include('_partials/join_by_pin_form.html.twig', { size: 'large', collapsible: user_has_competitions|default(false) }) }}
        </div>
    {% endif %}

    {# ───── Soukromé zdroje zápasů — user's private (owned or member) ───── #}
    {% if private_match_sources|length > 0 %}
        <section class="mb-12">
            <div class="mb-5 flex flex-wrap items-end justify-between gap-3">
                <div>
                    <h2 class="flex items-center gap-2 text-xl font-semibold text-white">
                        <twig:ux:icon name="lucide:lock" class="h-5 w-5 text-accent-300" />
                        Soukromé zdroje zápasů
                        <span class="rounded-full border border-white/10 bg-white/5 px-2.5 py-0.5 text-xs font-semibold text-white/70">{{ private_match_sources|length }}</span>
                    </h2>
                    <p class="mt-1.5 text-sm text-white/50">Zdroje zápasů, které jste založili nebo ve kterých soutěžíte.</p>
                </div>
            </div>

            <ul class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
                {% for t in private_match_sources %}
                    {% set is_finished = t.completedAt is not null %}
                    <li>
                        <a
                            href="{{ path('public_match_source_detail', {id: t.id.toRfc4122}) }}"
                            class="card-glass group flex h-full flex-col justify-between p-6 transition-transform duration-200 hover:-translate-y-1"
                        >
                            <div>
                                <div class="mb-4 flex items-start justify-between gap-3">
                                    <span class="flex h-11 w-11 items-center justify-center rounded-xl border border-accent-500/30 bg-accent-500/15 text-accent-300">
                                        <twig:ux:icon name="lucide:lock" class="h-5 w-5" />
                                    </span>
                                    <div class="flex flex-wrap items-center gap-1.5">
                                        <twig:Badge label="Soukromý" variant="competition" icon="lock" />
                                        {% if is_finished %}
                                            <twig:Pill label="Ukončen" variant="done" />
                                        {% endif %}
                                    </div>
                                </div>

                                <h3 class="text-lg font-semibold leading-tight text-white transition-colors group-hover:text-accent-300">
                                    {{ t.name }}
                                </h3>

                                <div class="mt-3 flex items-center gap-1.5 text-sm text-white/50">
                                    <twig:ux:icon name="lucide:user" class="h-4 w-4 text-white/40" />
                                    <span>{{ t.ownerNickname }}</span>
                                </div>

                                {% if t.startAt or t.endAt %}
                                    <div class="mt-1.5 flex items-center gap-1.5 text-sm text-white/50">
                                        <twig:ux:icon name="lucide:calendar" class="h-4 w-4 text-white/40" />
                                        <span>
                                            {% if t.startAt %}{{ t.startAt|date('d. m. Y') }}{% endif %}
                                            {% if t.startAt and t.endAt %} – {% endif %}
                                            {% if t.endAt %}{{ t.endAt|date('d. m. Y') }}{% endif %}
                                        </span>
                                    </div>
                                {% endif %}
                            </div>

                            <div class="mt-5 flex items-center justify-end text-sm font-semibold text-accent-300">
                                Otevřít zdroj zápasů
                                <twig:ux:icon name="lucide:arrow-right" class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-0.5" />
                            </div>
                        </a>
                    </li>
                {% endfor %}
            </ul>
        </section>
    {% endif %}

    {# ───── Veřejné zdroje zápasů ───── #}
    <section>
        <div class="mb-5 flex flex-wrap items-end justify-between gap-3">
            <div>
                <h2 class="flex items-center gap-2 text-xl font-semibold text-white">
                    <twig:ux:icon name="lucide:globe" class="h-5 w-5 text-accent-300" />
                    Veřejné zdroje zápasů
                    {% if public_match_sources|length > 0 %}
                        <span class="rounded-full border border-white/10 bg-white/5 px-2.5 py-0.5 text-xs font-semibold text-white/70">{{ public_match_sources|length }}</span>
                    {% endif %}
                </h2>
                <p class="mt-1.5 text-sm text-white/50">Otevřené zdroje zápasů, do jejichž soutěží se může kdokoli přidat.</p>
            </div>
        </div>

        {% if public_match_sources|length == 0 %}
            <div class="card-glass p-10 text-center">
                <span class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-2xl border border-accent-500/30 bg-accent-500/15 text-accent-300">
                    <twig:ux:icon name="lucide:search" class="h-7 w-7" />
                </span>
                <h3 class="text-lg font-semibold text-white">Žádné veřejné zdroje zápasů</h3>
                {% if app.user %}
                    <p class="mx-auto mt-2 max-w-md text-sm text-white/60">Aktuálně nejsou k dispozici žádné veřejné zdroje zápasů. Založte si vlastní.</p>
                    <a href="{{ path('portal_match_source_create') }}" class="btn btn-primary btn-sm mt-6">
                        <twig:ux:icon name="lucide:circle-plus" class="h-4 w-4" />
                        Nový zdroj zápasů
                    </a>
                {% else %}
                    <p class="mx-auto mt-2 max-w-md text-sm text-white/60">Aktuálně nejsou k dispozici žádné veřejné zdroje zápasů. Zaregistrujte se a založte si vlastní.</p>
                    <a href="{{ path('app_register') }}" class="btn btn-primary btn-sm mt-6">
                        Zaregistrovat se
                        <twig:ux:icon name="lucide:arrow-right" class="h-4 w-4" />
                    </a>
                {% endif %}
            </div>
        {% else %}
            <ul class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
                {% for t in public_match_sources %}
                    {% set is_finished = t.completedAt is not null %}
                    <li>
                        <a
                            href="{{ path('public_match_source_detail', {id: t.id.toRfc4122}) }}"
                            class="card-glass group flex h-full flex-col justify-between p-6 transition-transform duration-200 hover:-translate-y-1"
                        >
                            <div>
                                <div class="mb-4 flex items-start justify-between gap-3">
                                    <span class="flex h-11 w-11 items-center justify-center rounded-xl border border-accent-500/30 bg-accent-500/15 text-accent-300">
                                        <twig:ux:icon name="lucide:trophy" class="h-5 w-5" />
                                    </span>
                                    <div class="flex flex-wrap items-center gap-1.5">
                                        <twig:Pill label="Veřejný" variant="accent" icon="globe" />
                                        {% if is_finished %}
                                            <twig:Pill label="Ukončen" variant="done" />
                                        {% endif %}
                                    </div>
                                </div>

                                <h3 class="text-lg font-semibold leading-tight text-white transition-colors group-hover:text-accent-300">
                                    {{ t.name }}
                                </h3>

                                <div class="mt-3 flex items-center gap-1.5 text-sm text-white/50">
                                    <twig:ux:icon name="lucide:user" class="h-4 w-4 text-white/40" />
                                    <span>{{ t.ownerNickname }}</span>
                                </div>

                                {% if t.startAt or t.endAt %}
                                    <div class="mt-1.5 flex items-center gap-1.5 text-sm text-white/50">
                                        <twig:ux:icon name="lucide:calendar" class="h-4 w-4 text-white/40" />
                                        <span>
                                            {% if t.startAt %}{{ t.startAt|date('d. m. Y') }}{% endif %}
                                            {% if t.startAt and t.endAt %} – {% endif %}
                                            {% if t.endAt %}{{ t.endAt|date('d. m. Y') }}{% endif %}
                                        </span>
                                    </div>
                                {% endif %}
                            </div>

                            <div class="mt-5 flex items-center justify-end text-sm font-semibold text-accent-300">
                                Zobrazit detail
                                <twig:ux:icon name="lucide:arrow-right" class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-0.5" />
                            </div>
                        </a>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    </section>

    {# ───── Hero CTA: create your own private match_source ───── #}
    {% set createHref = app.user ? path('portal_match_source_create') : path('app_register') %}
    <section class="surface-accent relative mt-12 overflow-hidden p-6 sm:p-8">
        <div class="relative grid gap-6 md:grid-cols-[1fr_auto] md:items-center">
            <div class="flex items-start gap-4">
                <span class="hidden h-14 w-14 shrink-0 items-center justify-center rounded-2xl border border-white/10 bg-white/10 backdrop-blur sm:flex">
                    <twig:ux:icon name="lucide:trophy" class="h-7 w-7 text-accent-300" />
                </span>
                <div class="min-w-0">
                    <p class="eyebrow mb-2 inline-flex items-center gap-1.5">
                        <twig:ux:icon name="lucide:sparkles" class="h-3.5 w-3.5" />
                        Nové
                    </p>
                    <h2 class="text-2xl font-bold tracking-tight text-white sm:text-3xl">Vytvořte si vlastní zdroj zápasů</h2>
                    <p class="mt-2 max-w-xl text-sm text-white/70 sm:text-base">Nastavte si vlastní pravidla a bodování, založte soutěže pro různé party a tipujte jen s lidmi, které chcete.</p>

                    <ul class="mt-4 flex flex-wrap gap-x-4 gap-y-2 text-xs text-white/70 sm:text-sm">
                        <li class="inline-flex items-center gap-1.5">
                            <twig:ux:icon name="lucide:lock" class="h-4 w-4 text-accent-300" />
                            Přístup přes pozvánku nebo PIN
                        </li>
                        <li class="inline-flex items-center gap-1.5">
                            <twig:ux:icon name="lucide:users" class="h-4 w-4 text-accent-300" />
                            Více soutěží nad jedním zdrojem zápasů
                        </li>
                        <li class="inline-flex items-center gap-1.5">
                            <twig:ux:icon name="lucide:shield-check" class="h-4 w-4 text-accent-300" />
                            Zdarma, bez závazků
                        </li>
                    </ul>
                </div>
            </div>

            <div class="flex md:flex-col md:items-stretch md:justify-center">
                <a href="{{ createHref }}" class="btn btn-primary w-full sm:w-auto">
                    <twig:ux:icon name="lucide:circle-plus" class="h-4 w-4" />
                    {% if app.user %}Nový zdroj zápasů{% else %}Začít zdarma{% endif %}
                </a>
                {% if app.user is null %}
                    <p class="mt-2 text-center text-xs text-white/50 md:mt-3">Stačí krátká registrace.</p>
                {% endif %}
            </div>
        </div>
    </section>
</div>
</div>
{% endblock %}
