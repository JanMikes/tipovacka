{% extends 'base.html.twig' %}

{% block title %}Soutěže — {{ brand_name }}{% endblock %}
{% block meta_description %}Připojte se do veřejných tipovacích soutěží {{ brand_name }}. Zaplaťte vstupné v kreditech a tipujte s ostatními. Bez sázek, jen pro radost.{% endblock %}

{% block body %}
<div class="bg-radial">
<div class="mx-auto w-full max-w-6xl px-4 py-10 sm:px-6 sm:py-14 lg:px-8">

    {# Breadcrumb #}
    <nav class="mb-6 flex items-center gap-1.5 text-sm text-white/50" aria-label="Breadcrumb">
        <a href="{{ path('app_home') }}" class="transition-colors hover:text-accent-300">Domů</a>
        <twig:ux:icon name="lucide:chevron-right" class="h-4 w-4 text-white/30" />
        <span class="text-white/80">Soutěže</span>
    </nav>

    {# Page header #}
    <header class="mb-8">
        <p class="eyebrow mb-3">Veřejné soutěže</p>
        <h1 class="grad-headline text-3xl font-extrabold tracking-tight sm:text-4xl">
            <span>Připojte se do soutěže</span>
        </h1>
        <p class="mt-3 max-w-2xl text-white/60">Veřejné tipovací soutěže, do kterých se může přidat kdokoli. Zaplatíte vstupné v kreditech (nebo je zdarma) a tipujete s ostatními o nejlepší skóre.</p>
    </header>

    {# PIN-join — compact for authenticated users #}
    {% if app.user and app.user.isVerified %}
        <div class="mb-12">
            {{ include('_partials/join_by_pin_form.html.twig', { size: 'large', collapsible: user_has_competitions|default(false) }) }}
        </div>
    {% endif %}

    {# ───── Global competitions ───── #}
    <section>
        <div class="mb-5 flex flex-wrap items-end justify-between gap-3">
            <div>
                <h2 class="flex items-center gap-2 text-xl font-semibold text-white">
                    <twig:ux:icon name="lucide:globe" class="h-5 w-5 text-accent-300" />
                    Veřejné soutěže
                    {% if competitions|length > 0 %}
                        <span class="rounded-full border border-white/10 bg-white/5 px-2.5 py-0.5 text-xs font-semibold text-white/70">{{ competitions|length }}</span>
                    {% endif %}
                </h2>
                <p class="mt-1.5 text-sm text-white/50">Otevřené soutěže, do kterých se může přidat kdokoli.</p>
            </div>
        </div>

        {% if competitions|length == 0 %}
            <div class="card-glass p-10 text-center">
                <span class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-2xl border border-accent-500/30 bg-accent-500/15 text-accent-300">
                    <twig:ux:icon name="lucide:search" class="h-7 w-7" />
                </span>
                <h3 class="text-lg font-semibold text-white">Žádné veřejné soutěže</h3>
                {% if app.user %}
                    <p class="mx-auto mt-2 max-w-md text-sm text-white/60">Aktuálně tu nejsou žádné veřejné soutěže. Vytvořte si vlastní soutěž od začátku.</p>
                    <a href="{{ path('portal_competition_create') }}" class="btn btn-primary btn-sm mt-6">
                        <twig:ux:icon name="lucide:circle-plus" class="h-4 w-4" />
                        Vytvořit soutěž
                    </a>
                {% else %}
                    <p class="mx-auto mt-2 max-w-md text-sm text-white/60">Aktuálně tu nejsou žádné veřejné soutěže. Zaregistrujte se a založte si vlastní.</p>
                    <a href="{{ path('app_register') }}" class="btn btn-primary btn-sm mt-6">
                        Zaregistrovat se
                        <twig:ux:icon name="lucide:arrow-right" class="h-4 w-4" />
                    </a>
                {% endif %}
            </div>
        {% else %}
            <ul class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
                {% for c in competitions %}
                    <li id="soutez-{{ c.competitionId.toRfc4122 }}">
                        <div class="card-glass flex h-full flex-col justify-between p-6">
                            <div>
                                <div class="mb-4 flex items-start justify-between gap-3">
                                    <span class="flex h-11 w-11 items-center justify-center rounded-xl border border-accent-500/30 bg-accent-500/15 text-accent-300">
                                        <twig:ux:icon name="lucide:trophy" class="h-5 w-5" />
                                    </span>
                                    {% if c.entryFeeCredits > 0 %}
                                        <span class="inline-flex items-center gap-1.5 rounded-full border border-accent-500/40 bg-accent-500/15 px-3 py-1 text-sm font-semibold text-accent-300">
                                            <twig:ux:icon name="lucide:wallet" class="h-4 w-4" />
                                            Vstup: {{ c.entryFeeCredits|credits }}
                                        </span>
                                    {% else %}
                                        <twig:Pill label="Zdarma" variant="success" />
                                    {% endif %}
                                </div>

                                <h3 class="text-lg font-semibold leading-tight text-white">{{ c.name }}</h3>

                                <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1.5 text-sm text-white/50">
                                    <span class="flex items-center gap-1.5">
                                        <twig:ux:icon name="lucide:globe" class="h-4 w-4 text-white/40" />
                                        {{ c.sportName }}
                                    </span>
                                    <span class="flex items-center gap-1.5">
                                        <twig:ux:icon name="lucide:users" class="h-4 w-4 text-white/40" />
                                        {{ c.playerCount }} {% if c.playerCount == 1 %}hráč{% elseif c.playerCount >= 2 and c.playerCount <= 4 %}hráči{% else %}hráčů{% endif %}
                                    </span>
                                </div>

                                {% if c.sourceStartAt or c.sourceEndAt %}
                                    <div class="mt-1.5 flex items-center gap-1.5 text-sm text-white/50">
                                        <twig:ux:icon name="lucide:calendar" class="h-4 w-4 text-white/40" />
                                        <span>
                                            {% if c.sourceStartAt %}{{ c.sourceStartAt|date('d. m. Y') }}{% endif %}
                                            {% if c.sourceStartAt and c.sourceEndAt %} – {% endif %}
                                            {% if c.sourceEndAt %}{{ c.sourceEndAt|date('d. m. Y') }}{% endif %}
                                        </span>
                                    </div>
                                {% endif %}
                            </div>

                            <div class="mt-5">
                                {% if c.viewerIsMember %}
                                    <a href="{{ path('portal_competition_detail', {id: c.competitionId.toRfc4122}) }}" class="btn btn-ghost btn-sm w-full">
                                        Otevřít soutěž
                                        <twig:ux:icon name="lucide:arrow-right" class="h-4 w-4" />
                                    </a>
                                {% elseif app.user and app.user.isVerified %}
                                    {% if c.entryFeeCredits > 0 and wallet_balance < c.entryFeeCredits %}
                                        <p class="mb-2 text-center text-xs text-white/50">Máte {{ wallet_balance }}/{{ c.entryFeeCredits|credits }}</p>
                                        <a href="{{ path('portal_credits') }}" class="btn btn-ghost btn-sm w-full">
                                            <twig:ux:icon name="lucide:wallet" class="h-4 w-4" />
                                            Dokoupit kredity
                                        </a>
                                    {% else %}
                                        <form method="post" action="{{ path('portal_competition_join_global', {id: c.competitionId.toRfc4122}) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('competition_join_global_' ~ c.competitionId.toRfc4122) }}">
                                            <button type="submit" class="btn btn-primary btn-sm w-full">
                                                <twig:ux:icon name="lucide:user-round-plus" class="h-4 w-4" />
                                                {% if c.entryFeeCredits > 0 %}Připojit se za {{ c.entryFeeCredits|credits }}{% else %}Připojit se zdarma{% endif %}
                                            </button>
                                        </form>
                                    {% endif %}
                                {% else %}
                                    <a href="{{ path('app_login') }}" class="btn btn-primary btn-sm w-full">
                                        <twig:ux:icon name="lucide:log-in" class="h-4 w-4" />
                                        Přihlásit se a připojit
                                    </a>
                                {% endif %}
                            </div>
                        </div>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    </section>

    {# ───── Hero CTA: create your own competition (from scratch) ───── #}
    {% set createHref = app.user ? path('portal_competition_create') : path('app_register') %}
    <section class="surface-accent relative mt-12 overflow-hidden p-6 sm:p-8">
        <div class="relative grid gap-6 md:grid-cols-[1fr_auto] md:items-center">
            <div class="flex items-start gap-4">
                <span class="hidden h-14 w-14 shrink-0 items-center justify-center rounded-2xl border border-white/10 bg-white/10 backdrop-blur sm:flex">
                    <twig:ux:icon name="lucide:trophy" class="h-7 w-7 text-accent-300" />
                </span>
                <div class="min-w-0">
                    <p class="eyebrow mb-2 inline-flex items-center gap-1.5">
                        <twig:ux:icon name="lucide:sparkles" class="h-3.5 w-3.5" />
                        Vlastní soutěž
                    </p>
                    <h2 class="text-2xl font-bold tracking-tight text-white sm:text-3xl">Chcete tipovat jen se svými lidmi?</h2>
                    <p class="mt-2 max-w-xl text-sm text-white/70 sm:text-base">Založte si vlastní soukromou soutěž, nastavte pravidla a bodování a pozvěte jen ty, které chcete. Zdarma, bez závazků.</p>
                </div>
            </div>

            <div class="flex md:flex-col md:items-stretch md:justify-center">
                <a href="{{ createHref }}" class="btn btn-primary w-full sm:w-auto">
                    <twig:ux:icon name="lucide:circle-plus" class="h-4 w-4" />
                    {% if app.user %}Vytvořit soutěž{% else %}Začít zdarma{% endif %}
                </a>
                {% if app.user is null %}
                    <p class="mt-2 text-center text-xs text-white/50 md:mt-3">Stačí krátká registrace.</p>
                {% endif %}
            </div>
        </div>
    </section>
</div>
</div>
{% endblock %}
